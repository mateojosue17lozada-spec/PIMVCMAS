		</ReportParameter>
		<ReportParameter Name="FiltroTipo">
			<DataType>String</DataType>
			<DefaultValue>
				<Values>
					<Value>todos</Value>
				</Values>
			</DefaultValue>
			<Prompt>FiltroTipo</Prompt>
		</ReportParameter>
		<ReportParameter Name="FechaDesde">
			<DataType>String</DataType>
			<DefaultValue>
				<Values>
					<Value>Todas</Value>
				</Values>
			</DefaultValue>
			<Prompt>FechaDesde</Prompt>
		</ReportParameter>
		<ReportParameter Name="FechaHasta">
