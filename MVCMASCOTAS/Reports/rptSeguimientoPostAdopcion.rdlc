<?xml version="1.0" encoding="utf-8" ?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2008/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner">
    <Body>
        <ReportItems>

            <!-- ENCABEZADO -->
            <Rectangle Name="RectanguloEncabezado">
                <Style>
                    <Border><Style>Solid</Style></Border>
                    <BackgroundColor>#E67E22</BackgroundColor>
                </Style>
                <Height>1.5cm</Height>
                <Width>19cm</Width>
                <Top>0cm</Top>
                <Left>0cm</Left>
                <ReportItems>
                    <Textbox Name="TextboxTitulo">
                        <Style>
                            <FontSize>20pt</FontSize>
                            <FontWeight>Bold</FontWeight>
                            <Color>White</Color>
                            <PaddingLeft>5pt</PaddingLeft>
                            <PaddingTop>5pt</PaddingTop>
                        </Style>
                        <Top>0cm</Top>
                        <Left>0cm</Left>
                        <Height>1.2cm</Height>
                        <Width>12cm</Width>
                        <CanGrow>true</CanGrow>
                        <Paragraphs>
                            <Paragraph>
                                <TextRuns>
                                    <TextRun>
                                        <Value>POST-SEGUIMIENTO DE ADOPCIONES</Value>
                                        <Style><FontSize>20pt</FontSize><FontWeight>Bold</FontWeight><Color>White</Color></Style>
                                    </TextRun>
                                </TextRuns>
                            </Paragraph>
                        </Paragraphs>
                    </Textbox>
                </ReportItems>
            </Rectangle>

            <!-- FILTROS -->
            <Rectangle Name="RectanguloFiltros">
                <Style>
                    <Border><Style>Solid</Style><Color>#BDC3C7</Color></Border>
                    <BackgroundColor>#ECF0F1</BackgroundColor>
                </Style>
                <Height>1.5cm</Height>
                <Width>19cm</Width>
                <Top>1.6cm</Top>
                <Left>0cm</Left>
                <ReportItems>
                    <Textbox Name="TextboxFechaGeneracion">
                        <Style><FontSize>10pt</FontSize><Color>#2C3E50</Color><PaddingLeft>5pt</PaddingLeft><PaddingTop>5pt</PaddingTop></Style>
                        <Top>0cm</Top>
                        <Left>0cm</Left>
                        <Height>0.6cm</Height>
                        <Width>10cm</Width>
                        <CanGrow>true</CanGrow>
                        <Paragraphs>
                            <Paragraph>
                                <TextRuns>
                                    <TextRun>
                                        <Value>=("Fecha: " &amp; Parameters!FechaGeneracion.Value)</Value>
                                    </TextRun>
                                </TextRuns>
                            </Paragraph>
                        </Paragraphs>
                    </Textbox>
                    <Textbox Name="TextboxUsuario">
                        <Style><FontSize>10pt</FontSize><Color>#2C3E50</Color><PaddingLeft>5pt</PaddingLeft></Style>
                        <Top>0.7cm</Top>
                        <Left>0cm</Left>
                        <Height>0.6cm</Height>
                        <Width>10cm</Width>
                        <CanGrow>true</CanGrow>
                        <Paragraphs>
                            <Paragraph>
                                <TextRuns>
                                    <TextRun>
                                        <Value>=("Generado por: " &amp; Parameters!Usuario.Value)</Value>
                                    </TextRun>
                                </TextRuns>
                            </Paragraph>
                        </Paragraphs>
                    </Textbox>
                    <Textbox Name="TextboxFiltros">
                        <Style><FontSize>10pt</FontSize><Color>#2C3E50</Color><TextAlign>Right</TextAlign><PaddingRight>5pt</PaddingRight><PaddingTop>5pt</PaddingTop></Style>
                        <Top>0cm</Top>
                        <Left>12cm</Left>
                        <Height>1.2cm</Height>
                        <Width>7cm</Width>
                        <CanGrow>true</CanGrow>
                        <Paragraphs>
                            <Paragraph>
                                <TextRuns>
                                    <TextRun>
                                        <Value>=("Tipo: " &amp; Parameters!FiltroTipo.Value &amp; " | Desde: " &amp; Parameters!FechaDesde.Value &amp; " | Hasta: " &amp; Parameters!FechaHasta.Value)</Value>
                                    </TextRun>
                                </TextRuns>
                            </Paragraph>
                        </Paragraphs>
                    </Textbox>
                </ReportItems>
            </Rectangle>

            <!-- TABLA DE SEGUIMIENTOS -->
            <Tablix Name="TablixSeguimientos">
                <Style><Border><Style>Solid</Style><Color>#34495E</Color></Border></Style>
                <TablixBody>
                    <TablixColumns>
                        <TablixColumn><Width>1.8cm</Width></TablixColumn>
                        <TablixColumn><Width>2.2cm</Width></TablixColumn>
                        <TablixColumn><Width>2.5cm</Width></TablixColumn>
                        <TablixColumn><Width>2.2cm</Width></TablixColumn>
                        <TablixColumn><Width>2.5cm</Width></TablixColumn>
                        <TablixColumn><Width>2.2cm</Width></TablixColumn>
                        <TablixColumn><Width>2.2cm</Width></TablixColumn>
                        <TablixColumn><Width>2.5cm</Width></TablixColumn>
                        <TablixColumn><Width>1.8cm</Width></TablixColumn>
                    </TablixColumns>
                    <TablixRows>
                        <!-- Encabezados -->
                        <TablixRow>
                            <Height>0.8cm</Height>
                            <TablixCells>
                                <TablixCell>
                                    <CellContents>
                                        <Textbox Name="HeaderContrato">
                                            <Style><BackgroundColor>#E67E22</BackgroundColor><Color>White</Color><FontWeight>Bold</FontWeight><TextAlign>Center</TextAlign><Border><Style>Solid</Style><Color>White</Color></Border></Style>
                                            <CanGrow>true</CanGrow>
                                            <Paragraphs><Paragraph><TextRuns><TextRun><Value>Contrato</Value></TextRun></TextRuns></Paragraph></Paragraphs>
                                        </Textbox>
                                    </CellContents>
                                </TablixCell>
                                <TablixCell>
                                    <CellContents>
                                        <Textbox Name="HeaderMascota">
                                            <Style><BackgroundColor>#E67E22</BackgroundColor><Color>White</Color><FontWeight>Bold</FontWeight><TextAlign>Center</TextAlign><Border><Style>Solid</Style><Color>White</Color></Border></Style>
                                            <CanGrow>true</CanGrow>
                                            <Paragraphs><Paragraph><TextRuns><TextRun><Value>Mascota</Value></TextRun></TextRuns></Paragraph></Paragraphs>
                                        </Textbox>
                                    </CellContents>
                                </TablixCell>
                                <TablixCell>
                                    <CellContents>
                                        <Textbox Name="HeaderAdoptante">
                                            <Style><BackgroundColor>#E67E22</BackgroundColor><Color>White</Color><FontWeight>Bold</FontWeight><TextAlign>Center</TextAlign><Border><Style>Solid</Style><Color>White</Color></Border></Style>
                                            <CanGrow>true</CanGrow>
                                            <Paragraphs><Paragraph><TextRuns><TextRun><Value>Adoptante</Value></TextRun></TextRuns></Paragraph></Paragraphs>
                                        </Textbox>
                                    </CellContents>
                                </TablixCell>
                                <TablixCell>
                                    <CellContents>
                                        <Textbox Name="HeaderTipo">
                                            <Style><BackgroundColor>#E67E22</BackgroundColor><Color>White</Color><FontWeight>Bold</FontWeight><TextAlign>Center</TextAlign><Border><Style>Solid</Style><Color>White</Color></Border></Style>
                                            <CanGrow>true</CanGrow>
                                            <Paragraphs><Paragraph><TextRuns><TextRun><Value>Tipo</Value></TextRun></TextRuns></Paragraph></Paragraphs>
                                        </Textbox>
                                    </CellContents>
                                </TablixCell>
                                <TablixCell>
                                    <CellContents>
                                        <Textbox Name="HeaderFechaSeguim">
                                            <Style><BackgroundColor>#E67E22</BackgroundColor><Color>White</Color><FontWeight>Bold</FontWeight><TextAlign>Center</TextAlign><Border><Style>Solid</Style><Color>White</Color></Border></Style>
                                            <CanGrow>true</CanGrow>
                                            <Paragraphs><Paragraph><TextRuns><TextRun><Value>Fecha Seguim.</Value></TextRun></TextRuns></Paragraph></Paragraphs>
                                        </Textbox>
                                    </CellContents>
                                </TablixCell>
                                <TablixCell>
                                    <CellContents>
                                        <Textbox Name="HeaderProximo">
                                            <Style><BackgroundColor>#E67E22</BackgroundColor><Color>White</Color><FontWeight>Bold</FontWeight><TextAlign>Center</TextAlign><Border><Style>Solid</Style><Color>White</Color></Border></Style>
                                            <CanGrow>true</CanGrow>
                                            <Paragraphs><Paragraph><TextRuns><TextRun><Value>Próximo</Value></TextRun></TextRuns></Paragraph></Paragraphs>
                                        </Textbox>
                                    </CellContents>
                                </TablixCell>
                                <TablixCell>
                                    <CellContents>
                                        <Textbox Name="HeaderEstadoMascota">
                                            <Style><BackgroundColor>#E67E22</BackgroundColor><Color>White</Color><FontWeight>Bold</FontWeight><TextAlign>Center</TextAlign><Border><Style>Solid</Style><Color>White</Color></Border></Style>
                                            <CanGrow>true</CanGrow>
                                            <Paragraphs><Paragraph><TextRuns><TextRun><Value>Estado Mascota</Value></TextRun></TextRuns></Paragraph></Paragraphs>
                                        </Textbox>
                                    </CellContents>
                                </TablixCell>
                                <TablixCell>
                                    <CellContents>
                                        <Textbox Name="HeaderResponsable">
                                            <Style><BackgroundColor>#E67E22</BackgroundColor><Color>White</Color><FontWeight>Bold</FontWeight><TextAlign>Center</TextAlign><Border><Style>Solid</Style><Color>White</Color></Border></Style>
                                            <CanGrow>true</CanGrow>
                                            <Paragraphs><Paragraph><TextRuns><TextRun><Value>Responsable</Value></TextRun></TextRuns></Paragraph></Paragraphs>
                                        </Textbox>
                                    </CellContents>
                                </TablixCell>
                                <TablixCell>
                                    <CellContents>
                                        <Textbox Name="HeaderIntervenc">
                                            <Style><BackgroundColor>#E67E22</BackgroundColor><Color>White</Color><FontWeight>Bold</FontWeight><TextAlign>Center</TextAlign><Border><Style>Solid</Style><Color>White</Color></Border></Style>
                                            <CanGrow>true</CanGrow>
                                            <Paragraphs><Paragraph><TextRuns><TextRun><Value>Intervenc.</Value></TextRun></TextRuns></Paragraph></Paragraphs>
                                        </Textbox>
                                    </CellContents>
                                </TablixCell>
                            </TablixCells>
                        </TablixRow>

                        <!-- Datos -->
                        <TablixRow>
                            <Height>0.7cm</Height>
                            <TablixCells>
                                <TablixCell>
                                    <CellContents>
                                        <Textbox Name="DataNumeroContrato">
                                            <Style><Border><Style>Solid</Style><Color>#BDC3C7</Color></Border><TextAlign>Center</TextAlign></Style>
                                            <CanGrow>true</CanGrow>
                                            <Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!NumeroContrato.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs>
                                        </Textbox>
                                    </CellContents>
                                </TablixCell>
                                <TablixCell>
                                    <CellContents>
                                        <Textbox Name="DataNombreMascota">
                                            <Style><Border><Style>Solid</Style><Color>#BDC3C7</Color></Border></Style>
                                            <CanGrow>true</CanGrow>
                                            <Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!NombreMascota.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs>
                                        </Textbox>
                                    </CellContents>
                                </TablixCell>
                                <TablixCell>
                                    <CellContents>
                                        <Textbox Name="DataNombreAdoptante">
                                            <Style><Border><Style>Solid</Style><Color>#BDC3C7</Color></Border></Style>
                                            <CanGrow>true</CanGrow>
                                            <Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!NombreAdoptante.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs>
                                        </Textbox>
                                    </CellContents>
                                </TablixCell>
                                <TablixCell>
                                    <CellContents>
                                        <Textbox Name="DataTipoSeguimiento">
                                            <Style><Border><Style>Solid</Style><Color>#BDC3C7</Color></Border><TextAlign>Center</TextAlign></Style>
                                            <CanGrow>true</CanGrow>
                                            <Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!TipoSeguimiento.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs>
                                        </Textbox>
                                    </CellContents>
                                </TablixCell>
                                <TablixCell>
                                    <CellContents>
                                        <Textbox Name="DataFechaSeguimiento">
                                            <Style>
                                                <Border><Style>Solid</Style><Color>#BDC3C7</Color></Border>
                                                <TextAlign>Center</TextAlign>
                                                <Color>=IIF(IsNothing(Fields!FechaSeguimiento.Value), "Red", "Black")</Color>
                                                <FontWeight>=IIF(IsNothing(Fields!FechaSeguimiento.Value), "Bold", "Normal")</FontWeight>
                                            </Style>
                                            <CanGrow>true</CanGrow>
                                            <Paragraphs><Paragraph><TextRuns><TextRun><Value>=IIF(IsNothing(Fields!FechaSeguimiento.Value), "PENDIENTE", Format(Fields!FechaSeguimiento.Value, "dd/MM/yyyy"))</Value></TextRun></TextRuns></Paragraph></Paragraphs>
                                        </Textbox>
                                    </CellContents>
                                </TablixCell>
                                <TablixCell>
                                    <CellContents>
                                        <Textbox Name="DataProximoSeguimiento">
                                            <Style>
                                                <Border><Style>Solid</Style><Color>#BDC3C7</Color></Border>
                                                <TextAlign>Center</TextAlign>
                                                <Color>=IIF(IsNothing(Fields!ProximoSeguimiento.Value), "Gray", IIF(Fields!ProximoSeguimiento.Value &lt; Today(), "Red", "Green"))</Color>
                                            </Style>
                                            <CanGrow>true</CanGrow>
                                            <Paragraphs><Paragraph><TextRuns><TextRun><Value>=IIF(IsNothing(Fields!ProximoSeguimiento.Value), "No programado", Format(Fields!ProximoSeguimiento.Value, "dd/MM/yyyy"))</Value></TextRun></TextRuns></Paragraph></Paragraphs>
                                        </Textbox>
                                    </CellContents>
                                </TablixCell>
                                <TablixCell>
                                    <CellContents>
                                        <Textbox Name="DataEstadoMascota">
                                            <Style><Border><Style>Solid</Style><Color>#BDC3C7</Color></Border><TextAlign>Center</TextAlign></Style>
                                            <CanGrow>true</CanGrow>
                                            <Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!EstadoMascota.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs>
                                        </Textbox>
                                    </CellContents>
                                </TablixCell>
                                <TablixCell>
                                    <CellContents>
                                        <Textbox Name="DataResponsable">
                                            <Style><Border><Style>Solid</Style><Color>#BDC3C7</Color></Border></Style>
                                            <CanGrow>true</CanGrow>
                                            <Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!ResponsableNombre.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs>
                                        </Textbox>
                                    </CellContents>
                                </TablixCell>
                                <TablixCell>
                                    <CellContents>
                                        <Textbox Name="DataRequiereIntervencion">
                                            <Style>
                                                <Border><Style>Solid</Style><Color>#BDC3C7</Color></Border>
                                                <TextAlign>Center</TextAlign>
                                                <FontWeight>Bold</FontWeight>
                                                <Color>=IIF(Fields!RequiereIntervencion.Value = True, "Red", "Green")</Color>
                                            </Style>
                                            <CanGrow>true</CanGrow>
                                            <Paragraphs><Paragraph><TextRuns><TextRun><Value>=IIF(Fields!RequiereIntervencion.Value = True, "Si", "No")</Value></TextRun></TextRuns></Paragraph></Paragraphs>
                                        </Textbox>
                                    </CellContents>
                                </TablixCell>
                            </TablixCells>
                        </TablixRow>
                    </TablixRows>
                </TablixBody>
                <TablixColumnHierarchy>
                    <TablixMembers>
                        <TablixMember /><TablixMember /><TablixMember /><TablixMember /><TablixMember />
                        <TablixMember /><TablixMember /><TablixMember /><TablixMember />
                    </TablixMembers>
                </TablixColumnHierarchy>
                <TablixRowHierarchy>
                    <TablixMembers>
                        <TablixMember><KeepWithGroup>After</KeepWithGroup></TablixMember>
                        <TablixMember><Group Name="Detalle" /></TablixMember>
                    </TablixMembers>
                </TablixRowHierarchy>
                <DataSetName>DataSetSeguimientos</DataSetName>
                <Top>3.3cm</Top>
                <Left>0cm</Left>
                <Width>19cm</Width>
            </Tablix>

            <!-- PIE DE PÁGINA -->
            <Rectangle Name="RectanguloPie">
                <Style><Border><Style>Solid</Style><Color>#E67E22</Color></Border><BackgroundColor>#ECF0F1</BackgroundColor></Style>
                <Height>1.5cm</Height>
                <Width>19cm</Width>
                <Top>25cm</Top>
                <Left>0cm</Left>
                <ReportItems>
                    <Textbox Name="TextboxResumen">
                        <Style><FontSize>11pt</FontSize><FontWeight>Bold</FontWeight><Color>#E67E22</Color><PaddingLeft>5pt</PaddingLeft><PaddingTop>5pt</PaddingTop></Style>
                        <Top>0cm</Top>
                        <Left>0cm</Left>
                        <Height>1cm</Height>
                        <Width>15cm</Width>
                        <CanGrow>true</CanGrow>
                        <Paragraphs>
                            <Paragraph>
                                <TextRuns>
                                    <TextRun>
                                        <Value>=("Total: " &amp; Parameters!TotalRegistros.Value &amp; " | Realizados: " &amp; Parameters!Realizados.Value &amp; " | Pendientes: " &amp; Parameters!Pendientes.Value &amp; " | Vencidos: " &amp; Parameters!Vencidos.Value &amp; " | Intervención: " &amp; Parameters!RequierenIntervencion.Value)</Value>
                                    </TextRun>
                                </TextRuns>
                            </Paragraph>
                        </Paragraphs>
                    </Textbox>
                    <Textbox Name="TextboxPagina">
                        <Style><FontSize>10pt</FontSize><Color>#7F8C8D</Color><TextAlign>Right</TextAlign><PaddingRight>5pt</PaddingRight><PaddingTop>5pt</PaddingTop></Style>
                        <Top>0cm</Top>
                        <Left>15cm</Left>
                        <Height>1cm</Height>
                        <Width>4cm</Width>
                        <CanGrow>true</CanGrow>
                        <Paragraphs>
                            <Paragraph>
                                <TextRuns>
                                    <TextRun>
                                        <Value>=("Página " &amp; Globals!PageNumber &amp; " de " &amp; Globals!TotalPages)</Value>
                                    </TextRun>
                                </TextRuns>
                            </Paragraph>
                        </Paragraphs>
                    </Textbox>
                </ReportItems>
            </Rectangle>

        </ReportItems>
        <Height>27cm</Height>
        <Style />
    </Body>
    <Width>21cm</Width>
    <Page>
        <PageHeight>29.7cm</PageHeight>
        <PageWidth>21cm</PageWidth>
        <LeftMargin>1cm</LeftMargin>
        <RightMargin>1cm</RightMargin>
        <TopMargin>1cm</TopMargin>
        <BottomMargin>1cm</BottomMargin>
        <Style />
    </Page>
    <DataSources>
        <DataSource Name="DataSourceSeguimientos">
            <ConnectionProperties>
                <DataProvider>SQL</DataProvider>
                <ConnectString>Data Source=localhost;Initial Catalog=RefugioMascotasDB</ConnectString>
            </ConnectionProperties>
        </DataSource>
    </DataSources>
    <DataSets>
        <DataSet Name="DataSetSeguimientos">
            <Query>
                <DataSourceName>DataSourceSeguimientos</DataSourceName>
                <CommandText>SELECT * FROM SeguimientoAdopcion</CommandText>
            </Query>
            <Fields>
                <Field Name="SeguimientoId"><DataField>SeguimientoId</DataField><rd:TypeName>System.Int32</rd:TypeName></Field>
                <Field Name="FechaSeguimiento"><DataField>FechaSeguimiento</DataField><rd:TypeName>System.DateTime</rd:TypeName></Field>
                <Field Name="TipoSeguimiento"><DataField>TipoSeguimiento</DataField><rd:TypeName>System.String</rd:TypeName></Field>
                <Field Name="EstadoMascota"><DataField>EstadoMascota</DataField><rd:TypeName>System.String</rd:TypeName></Field>
                <Field Name="CondicionesVivienda"><DataField>CondicionesVivienda</DataField><rd:TypeName>System.String</rd:TypeName></Field>
                <Field Name="RelacionConAdoptante"><DataField>RelacionConAdoptante</DataField><rd:TypeName>System.String</rd:TypeName></Field>
                <Field Name="Observaciones"><DataField>Observaciones</DataField><rd:TypeName>System.String</rd:TypeName></Field>
                <Field Name="Recomendaciones"><DataField>Recomendaciones</DataField><rd:TypeName>System.String</rd:TypeName></Field>
                <Field Name="RequiereIntervencion"><DataField>RequiereIntervencion</DataField><rd:TypeName>System.Boolean</rd:TypeName></Field>
                <Field Name="ProximoSeguimiento"><DataField>ProximoSeguimiento</DataField><rd:TypeName>System.DateTime</rd:TypeName></Field>
                <Field Name="ContratoId"><DataField>ContratoId</DataField><rd:TypeName>System.Int32</rd:TypeName></Field>
                <Field Name="NumeroContrato"><DataField>NumeroContrato</DataField><rd:TypeName>System.String</rd:TypeName></Field>
                <Field Name="FechaContrato"><DataField>FechaContrato</DataField><rd:TypeName>System.DateTime</rd:TypeName></Field>
                <Field Name="MascotaId"><DataField>MascotaId</DataField><rd:TypeName>System.Int32</rd:TypeName></Field>
                <Field Name="NombreMascota"><DataField>NombreMascota</DataField><rd:TypeName>System.String</rd:TypeName></Field>
                <Field Name="EspecieMascota"><DataField>EspecieMascota</DataField><rd:TypeName>System.String</rd:TypeName></Field>
                <Field Name="RazaMascota"><DataField>RazaMascota</DataField><rd:TypeName>System.String</rd:TypeName></Field>
                <Field Name="NombreAdoptante"><DataField>NombreAdoptante</DataField><rd:TypeName>System.String</rd:TypeName></Field>
                <Field Name="TelefonoAdoptante"><DataField>TelefonoAdoptante</DataField><rd:TypeName>System.String</rd:TypeName></Field>
                <Field Name="EmailAdoptante"><DataField>EmailAdoptante</DataField><rd:TypeName>System.String</rd:TypeName></Field>
                <Field Name="DireccionAdoptante"><DataField>DireccionAdoptante</DataField><rd:TypeName>System.String</rd:TypeName></Field>
                <Field Name="ResponsableNombre"><DataField>ResponsableNombre</DataField><rd:TypeName>System.String</rd:TypeName></Field>
                <Field Name="FechaGeneracion"><DataField>FechaGeneracion</DataField><rd:TypeName>System.DateTime</rd:TypeName></Field>
            </Fields>
        </DataSet>
    </DataSets>
    <ReportParameters>
        <ReportParameter Name="FechaGeneracion"><DataType>String</DataType><Prompt>FechaGeneracion</Prompt></ReportParameter>
        <ReportParameter Name="Usuario"><DataType>String</DataType><Prompt>Usuario</Prompt></ReportParameter>
        <ReportParameter Name="FiltroTipo"><DataType>String</DataType><Prompt>FiltroTipo</Prompt></ReportParameter>
        <ReportParameter Name="FechaDesde"><DataType>String</DataType><Prompt>FechaDesde</Prompt></ReportParameter>
        <ReportParameter Name="FechaHasta"><DataType>String</DataType><Prompt>FechaHasta</Prompt></ReportParameter>
        <ReportParameter Name="TotalRegistros"><DataType>String</DataType><Prompt>TotalRegistros</Prompt></ReportParameter>
        <ReportParameter Name="Realizados"><DataType>String</DataType><Prompt>Realizados</Prompt></ReportParameter>
        <ReportParameter Name="Pendientes"><DataType>String</DataType><Prompt>Pendientes</Prompt></ReportParameter>
        <ReportParameter Name="Vencidos"><DataType>String</DataType><Prompt>Vencidos</Prompt></ReportParameter>
        <ReportParameter Name="RequierenIntervencion"><DataType>String</DataType><Prompt>RequierenIntervencion</Prompt></ReportParameter>
    </ReportParameters>
    <Language>es-ES</Language>
    <rd:ReportUnitType>Cm</rd:ReportUnitType>
</Report>