	<DataSources>
		<DataSource Name="DataSetSeguimientos">
			<ConnectionProperties>
				<DataProvider>System.Data.DataSet</DataProvider>
				<ConnectString>/* Local Connection */</ConnectString>
			</ConnectionProperties>
			<rd:DataSourceID>00000000-0000-0000-0000-000000000004</rd:DataSourceID>
		</DataSource>
	</DataSources>
	<DataSets>
		<DataSet Name="DataSetSeguimientos">
			<Query>
				<DataSourceName>DataSetSeguimientos</DataSourceName>
				<CommandText>/* Local Query */</CommandText>
			</Query>
			<Fields>
				<Field Name="SeguimientoId">
					<DataField>SeguimientoId</DataField>
					<rd:TypeName>System.Int32</rd:TypeName>
				</Field>
				<Field Name="NumeroContrato">
					<DataField>NumeroContrato</DataField>
					<rd:TypeName>System.String</rd:TypeName>
				</Field>
				<Field Name="NombreMascota">
					<DataField>NombreMascota</DataField>
					<rd:TypeName>System.String</rd:TypeName>
				</Field>
				<Field Name="EspecieMascota">
