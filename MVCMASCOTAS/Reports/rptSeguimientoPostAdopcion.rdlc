					</Border>
				</Style>
				<Paragraphs>
					<Paragraph>
						<TextRuns>
							<TextRun>
								<Value>=("Tipo: " &amp; Parameters!FiltroTipo.Value &amp; "  |  Desde: " &amp; Parameters!FechaDesde.Value &amp; "  Hasta: " &amp; Parameters!FechaHasta.Value &amp; "  |  Total: " &amp; Parameters!TotalRegistros.Value &amp; "  Realizados: " &amp; Parameters!Realizados.Value &amp; "  Pendientes: " &amp; Parameters!Pendientes.Value &amp; "  Vencidos: " &amp; Parameters!Vencidos.Value &amp; "  Intervención: " &amp; Parameters!RequierenIntervencion.Value)</Value>
							</TextRun>
						</TextRuns>
					</Paragraph>
				</Paragraphs>
			</Textbox>

