					<rd:TypeName>System.String</rd:TypeName>
				</Field>
				<Field Name="FechaSeguimiento">
					<DataField>FechaSeguimiento</DataField>
					<rd:TypeName>System.Nullable`1[System.DateTime]</rd:TypeName>
				</Field>
				<Field Name="ProximoSeguimiento">
					<DataField>ProximoSeguimiento</DataField>
					<rd:TypeName>System.Nullable`1[System.DateTime]</rd:TypeName>
				</Field>
				<Field Name="EstadoMascota">
					<DataField>EstadoMascota</DataField>
					<rd:TypeName>System.String</rd:TypeName>
				</Field>
				<Field Name="CondicionesVivienda">
					<DataField>CondicionesVivienda</DataField>
					<rd:TypeName>System.String</rd:TypeName>
				</Field>
				<Field Name="RelacionConAdoptante">
					<DataField>RelacionConAdoptante</DataField>
					<rd:TypeName>System.String</rd:TypeName>
				</Field>
				<Field Name="RequiereIntervencion">
					<DataField>RequiereIntervencion</DataField>
					<rd:TypeName>System.Boolean</rd:TypeName>
				</Field>
				<Field Name="ResponsableNombre">
					<DataField>ResponsableNombre</DataField>
					<rd:TypeName>System.String</rd:TypeName>
				</Field>
				<Field Name="Observaciones">
					<DataField>Observaciones</DataField>
					<rd:TypeName>System.String</rd:TypeName>
				</Field>
			</Fields>
		</DataSet>
