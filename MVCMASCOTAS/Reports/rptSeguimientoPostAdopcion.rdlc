			<DefaultValue>
				<Values>
					<Value>Todas</Value>
				</Values>
			</DefaultValue>
			<Prompt>FechaHasta</Prompt>
		</ReportParameter>
		<ReportParameter Name="TotalRegistros">
			<DataType>String</DataType>
			<DefaultValue>
				<Values>
