											</Style>
										</Textbox>
									</CellContents>
								</TablixCell>
								<TablixCell>
									<CellContents>
										<Textbox Name="DEsp2b">
											<CanGrow>true</CanGrow>
											<Paragraphs>
												<Paragraph>
													<TextRuns>
														<TextRun>
															<Value>=Fields!TotalGatos.Value</Value>
														</TextRun>
													</TextRuns>
												</Paragraph>
											</Paragraphs>
											<Style>
												<BackgroundColor>#FDFEFE</BackgroundColor>
												<Border>
													<Style>Solid</Style>
													<Color>#D7DBDD</Color>
												</Border>
												<TextAlign>Center</TextAlign>
												<FontWeight>Bold</FontWeight>
											</Style>
										</Textbox>
									</CellContents>
								</TablixCell>
								<TablixCell>
									<CellContents>
										<Textbox Name="DEsp2c">
											<CanGrow>true</CanGrow>
											<Paragraphs>
												<Paragraph>
													<TextRuns>
														<TextRun>
															<Value>=IIF(Fields!TotalMascotas.Value &gt; 0, Format(CDbl(Fields!TotalGatos.Value) / CDbl(Fields!TotalMascotas.Value) * 100, "0.0") &amp; "%", "0%")</Value>
														</TextRun>
													</TextRuns>
												</Paragraph>
											</Paragraphs>
											<Style>
												<BackgroundColor>#FDFEFE</BackgroundColor>
