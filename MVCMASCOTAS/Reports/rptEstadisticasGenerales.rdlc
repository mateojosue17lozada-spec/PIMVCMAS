<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2008/01/reportdefinition"
        xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner">
	<ReportParameters>
		<ReportParameter Name="FechaGeneracion">
			<DataType>String</DataType>
			<DefaultValue>
				<Values>
					<Value></Value>
				</Values>
			</DefaultValue>
			<Prompt>FechaGeneracion</Prompt>
		</ReportParameter>
		<ReportParameter Name="Usuario">
			<DataType>String</DataType>
			<DefaultValue>
				<Values>
					<Value></Value>
				</Values>
			</DefaultValue>
			<Prompt>Usuario</Prompt>
		</ReportParameter>
	</ReportParameters>
	<DataSources>
		<DataSource Name="DataSetEstadisticas">
			<ConnectionProperties>
				<DataProvider>System.Data.DataSet</DataProvider>
				<ConnectString>/* Local Connection */</ConnectString>
			</ConnectionProperties>
			<rd:DataSourceID>00000000-0000-0000-0000-000000000005</rd:DataSourceID>
		</DataSource>
	</DataSources>
	<DataSets>
		<DataSet Name="DataSetEstadisticas">
			<Query>
				<DataSourceName>DataSetEstadisticas</DataSourceName>
				<CommandText>/* Local Query */</CommandText>
			</Query>
			<Fields>
				<Field Name="TotalMascotas">
					<DataField>TotalMascotas</DataField>
					<rd:TypeName>System.Int32</rd:TypeName>
				</Field>
				<Field Name="TotalAdopciones">
					<DataField>TotalAdopciones</DataField>
					<rd:TypeName>System.Int32</rd:TypeName>
				</Field>
				<Field Name="SolicitudesPendientes">
					<DataField>SolicitudesPendientes</DataField>
					<rd:TypeName>System.Int32</rd:TypeName>
				</Field>
				<Field Name="SeguimientosPendientes">
					<DataField>SeguimientosPendientes</DataField>
					<rd:TypeName>System.Int32</rd:TypeName>
				</Field>
				<Field Name="TotalPerros">
					<DataField>TotalPerros</DataField>
					<rd:TypeName>System.Int32</rd:TypeName>
				</Field>
				<Field Name="TotalGatos">
					<DataField>TotalGatos</DataField>
					<rd:TypeName>System.Int32</rd:TypeName>
				</Field>
				<Field Name="TotalOtros">
					<DataField>TotalOtros</DataField>
					<rd:TypeName>System.Int32</rd:TypeName>
				</Field>
				<Field Name="Disponibles">
					<DataField>Disponibles</DataField>
					<rd:TypeName>System.Int32</rd:TypeName>
				</Field>
				<Field Name="EnTratamiento">
					<DataField>EnTratamiento</DataField>
					<rd:TypeName>System.Int32</rd:TypeName>
				</Field>
				<Field Name="Adoptadas">
					<DataField>Adoptadas</DataField>
					<rd:TypeName>System.Int32</rd:TypeName>
				</Field>
				<Field Name="Rescatadas">
					<DataField>Rescatadas</DataField>
					<rd:TypeName>System.Int32</rd:TypeName>
				</Field>
				<Field Name="PromedioDiasAdopcion">
					<DataField>PromedioDiasAdopcion</DataField>
					<rd:TypeName>System.Double</rd:TypeName>
				</Field>
				<Field Name="MascotasSinAdoptarLargoPlazo">
					<DataField>MascotasSinAdoptarLargoPlazo</DataField>
					<rd:TypeName>System.Int32</rd:TypeName>
				</Field>
				<Field Name="AdopcionesEsteMes">
					<DataField>AdopcionesEsteMes</DataField>
					<rd:TypeName>System.Int32</rd:TypeName>
				</Field>
				<Field Name="SolicitudesEsteMes">
					<DataField>SolicitudesEsteMes</DataField>
					<rd:TypeName>System.Int32</rd:TypeName>
				</Field>
				<Field Name="IngresosEsteMes">
					<DataField>IngresosEsteMes</DataField>
					<rd:TypeName>System.Int32</rd:TypeName>
				</Field>
			</Fields>
		</DataSet>
	</DataSets>
	<Body>
		<Height>22cm</Height>
		<Style />
		<ReportItems>

			<!-- TITULO -->
			<Textbox Name="Titulo">
				<CanGrow>true</CanGrow>
				<Top>0cm</Top>
				<Left>0cm</Left>
				<Width>19cm</Width>
				<Height>1.2cm</Height>
				<Style>
					<BackgroundColor>#9B59B6</BackgroundColor>
					<Color>#FFFFFF</Color>
					<FontSize>18pt</FontSize>
					<FontWeight>Bold</FontWeight>
					<PaddingLeft>8pt</PaddingLeft>
					<PaddingTop>6pt</PaddingTop>
					<Border>
						<Style>None</Style>
					</Border>
				</Style>
				<Paragraphs>
					<Paragraph>
						<TextRuns>
							<TextRun>
								<Value>ESTADISTICAS GENERALES DEL REFUGIO</Value>
							</TextRun>
						</TextRuns>
					</Paragraph>
				</Paragraphs>
			</Textbox>

			<!-- INFO GENERACION -->
			<Textbox Name="InfoGen">
				<CanGrow>true</CanGrow>
				<Top>1.3cm</Top>
				<Left>0cm</Left>
				<Width>19cm</Width>
				<Height>0.7cm</Height>
				<Style>
					<BackgroundColor>#ECF0F1</BackgroundColor>
					<Color>#555555</Color>
					<FontSize>9pt</FontSize>
					<PaddingLeft>8pt</PaddingLeft>
					<PaddingTop>4pt</PaddingTop>
					<Border>
						<Style>None</Style>
					</Border>
				</Style>
				<Paragraphs>
					<Paragraph>
						<TextRuns>
							<TextRun>
								<Value>=("Generado el: " &amp; Parameters!FechaGeneracion.Value &amp; "   Por: " &amp; Parameters!Usuario.Value)</Value>
							</TextRun>
						</TextRuns>
					</Paragraph>
				</Paragraphs>
			</Textbox>

			<!-- KPIs: 4 columnas -->
			<Tablix Name="TablixKPI">
				<DataSetName>DataSetEstadisticas</DataSetName>
				<Top>2.3cm</Top>
				<Left>0cm</Left>
				<Width>19cm</Width>
				<Height>1.8cm</Height>
				<TablixBody>
					<TablixColumns>
						<TablixColumn>
							<Width>4.75cm</Width>
						</TablixColumn>
						<TablixColumn>
							<Width>4.75cm</Width>
						</TablixColumn>
						<TablixColumn>
							<Width>4.75cm</Width>
						</TablixColumn>
						<TablixColumn>
							<Width>4.75cm</Width>
						</TablixColumn>
					</TablixColumns>
					<TablixRows>
						<TablixRow>
							<Height>1.8cm</Height>
							<TablixCells>
								<TablixCell>
									<CellContents>
										<Textbox Name="KpiMascotas">
											<CanGrow>true</CanGrow>
											<Style>
												<Border>
													<Style>Solid</Style>
													<Color>#9B59B6</Color>
												</Border>
												<BackgroundColor>#F5EEF8</BackgroundColor>
												<TextAlign>Center</TextAlign>
												<PaddingTop>4pt</PaddingTop>
											</Style>
											<Paragraphs>
												<Paragraph>
													<TextRuns>
														<TextRun>
															<Value>=Fields!TotalMascotas.Value</Value>
															<Style>
																<FontSize>26pt</FontSize>
																<FontWeight>Bold</FontWeight>
																<Color>#9B59B6</Color>
															</Style>
														</TextRun>
													</TextRuns>
													<Style>
														<TextAlign>Center</TextAlign>
													</Style>
												</Paragraph>
												<Paragraph>
													<TextRuns>
														<TextRun>
															<Value>Mascotas activas</Value>
															<Style>
																<FontSize>9pt</FontSize>
																<Color>#555555</Color>
															</Style>
														</TextRun>
													</TextRuns>
													<Style>
														<TextAlign>Center</TextAlign>
													</Style>
												</Paragraph>
											</Paragraphs>
										</Textbox>
									</CellContents>
								</TablixCell>
								<TablixCell>
									<CellContents>
										<Textbox Name="KpiAdopciones">
											<CanGrow>true</CanGrow>
											<Style>
												<Border>
													<Style>Solid</Style>
													<Color>#2980B9</Color>
												</Border>
												<BackgroundColor>#EBF5FB</BackgroundColor>
												<TextAlign>Center</TextAlign>
												<PaddingTop>4pt</PaddingTop>
											</Style>
											<Paragraphs>
												<Paragraph>
													<TextRuns>
														<TextRun>
															<Value>=Fields!TotalAdopciones.Value</Value>
															<Style>
																<FontSize>26pt</FontSize>
																<FontWeight>Bold</FontWeight>
																<Color>#2980B9</Color>
															</Style>
														</TextRun>
													</TextRuns>
													<Style>
														<TextAlign>Center</TextAlign>
													</Style>
												</Paragraph>
												<Paragraph>
													<TextRuns>
														<TextRun>
															<Value>Adopciones totales</Value>
															<Style>
																<FontSize>9pt</FontSize>
																<Color>#555555</Color>
															</Style>
														</TextRun>
													</TextRuns>
													<Style>
														<TextAlign>Center</TextAlign>
													</Style>
												</Paragraph>
											</Paragraphs>
										</Textbox>
									</CellContents>
								</TablixCell>
								<TablixCell>
									<CellContents>
										<Textbox Name="KpiSolicitudes">
											<CanGrow>true</CanGrow>
											<Style>
												<Border>
													<Style>Solid</Style>
													<Color>#E67E22</Color>
												</Border>
												<BackgroundColor>#FEF9E7</BackgroundColor>
												<TextAlign>Center</TextAlign>
												<PaddingTop>4pt</PaddingTop>
											</Style>
											<Paragraphs>
												<Paragraph>
													<TextRuns>
														<TextRun>
															<Value>=Fields!SolicitudesPendientes.Value</Value>
															<Style>
																<FontSize>26pt</FontSize>
																<FontWeight>Bold</FontWeight>
																<Color>#E67E22</Color>
															</Style>
														</TextRun>
													</TextRuns>
													<Style>
														<TextAlign>Center</TextAlign>
													</Style>
												</Paragraph>
												<Paragraph>
													<TextRuns>
														<TextRun>
															<Value>Solicitudes pend.</Value>
															<Style>
																<FontSize>9pt</FontSize>
																<Color>#555555</Color>
															</Style>
														</TextRun>
													</TextRuns>
													<Style>
														<TextAlign>Center</TextAlign>
													</Style>
												</Paragraph>
											</Paragraphs>
										</Textbox>
									</CellContents>
								</TablixCell>
								<TablixCell>
									<CellContents>
										<Textbox Name="KpiSeguimientos">
											<CanGrow>true</CanGrow>
											<Style>
												<Border>
													<Style>Solid</Style>
													<Color>#E74C3C</Color>
												</Border>
												<BackgroundColor>#FDEDEC</BackgroundColor>
												<TextAlign>Center</TextAlign>
												<PaddingTop>4pt</PaddingTop>
											</Style>
											<Paragraphs>
												<Paragraph>
													<TextRuns>
														<TextRun>
															<Value>=Fields!SeguimientosPendientes.Value</Value>
															<Style>
																<FontSize>26pt</FontSize>
																<FontWeight>Bold</FontWeight>
																<Color>#E74C3C</Color>
															</Style>
														</TextRun>
													</TextRuns>
													<Style>
														<TextAlign>Center</TextAlign>
													</Style>
												</Paragraph>
												<Paragraph>
													<TextRuns>
														<TextRun>
															<Value>Seguimientos pend.</Value>
															<Style>
																<FontSize>9pt</FontSize>
																<Color>#555555</Color>
															</Style>
														</TextRun>
													</TextRuns>
													<Style>
														<TextAlign>Center</TextAlign>
													</Style>
												</Paragraph>
											</Paragraphs>
										</Textbox>
									</CellContents>
								</TablixCell>
							</TablixCells>
						</TablixRow>
					</TablixRows>
				</TablixBody>
				<TablixColumnHierarchy>
					<TablixMembers>
						<TablixMember />
						<TablixMember />
						<TablixMember />
						<TablixMember />
					</TablixMembers>
				</TablixColumnHierarchy>
				<TablixRowHierarchy>
					<TablixMembers>
						<TablixMember>
							<Group Name="GrupoKPI">
								<GroupExpressions>
									<GroupExpression>=1</GroupExpression>
								</GroupExpressions>
							</Group>
						</TablixMember>
					</TablixMembers>
				</TablixRowHierarchy>
			</Tablix>

			<!-- TITULO ESPECIE -->
			<Textbox Name="TitEspecie">
				<CanGrow>true</CanGrow>
				<Top>4.4cm</Top>
				<Left>0cm</Left>
				<Width>9cm</Width>
				<Height>0.6cm</Height>
				<Style>
					<BackgroundColor>#34495E</BackgroundColor>
					<Color>#FFFFFF</Color>
					<FontSize>10pt</FontSize>
					<FontWeight>Bold</FontWeight>
					<PaddingLeft>5pt</PaddingLeft>
					<PaddingTop>3pt</PaddingTop>
					<Border>
						<Style>None</Style>
					</Border>
				</Style>
				<Paragraphs>
					<Paragraph>
						<TextRuns>
							<TextRun>
								<Value>DISTRIBUCION POR ESPECIE</Value>
							</TextRun>
						</TextRuns>
					</Paragraph>
				</Paragraphs>
			</Textbox>

			<!-- TABLA ESPECIE -->
			<Tablix Name="TablixEspecie">
				<DataSetName>DataSetEstadisticas</DataSetName>
				<Top>5.1cm</Top>
				<Left>0cm</Left>
				<Width>9cm</Width>
				<TablixBody>
					<TablixColumns>
						<TablixColumn>
							<Width>4.5cm</Width>
						</TablixColumn>
						<TablixColumn>
							<Width>2.25cm</Width>
						</TablixColumn>
						<TablixColumn>
							<Width>2.25cm</Width>
						</TablixColumn>
					</TablixColumns>
					<TablixRows>
						<TablixRow>
							<Height>0.65cm</Height>
							<TablixCells>
								<TablixCell>
									<CellContents>
										<Textbox Name="HEsp1">
											<CanGrow>true</CanGrow>
											<Paragraphs>
												<Paragraph>
													<TextRuns>
														<TextRun>
															<Value>Especie</Value>
														</TextRun>
													</TextRuns>
												</Paragraph>
											</Paragraphs>
											<Style>
												<BackgroundColor>#7D3C98</BackgroundColor>
												<Color>#FFFFFF</Color>
												<FontWeight>Bold</FontWeight>
												<TextAlign>Center</TextAlign>
												<Border>
													<Style>Solid</Style>
													<Color>#FFFFFF</Color>
												</Border>
											</Style>
										</Textbox>
									</CellContents>
								</TablixCell>
								<TablixCell>
									<CellContents>
										<Textbox Name="HEsp2">
											<CanGrow>true</CanGrow>
											<Paragraphs>
												<Paragraph>
													<TextRuns>
														<TextRun>
															<Value>Cantidad</Value>
														</TextRun>
													</TextRuns>
												</Paragraph>
											</Paragraphs>
											<Style>
												<BackgroundColor>#7D3C98</BackgroundColor>
												<Color>#FFFFFF</Color>
												<FontWeight>Bold</FontWeight>
												<TextAlign>Center</TextAlign>
												<Border>
													<Style>Solid</Style>
													<Color>#FFFFFF</Color>
												</Border>
											</Style>
										</Textbox>
									</CellContents>
								</TablixCell>
								<TablixCell>
									<CellContents>
										<Textbox Name="HEsp3">
											<CanGrow>true</CanGrow>
											<Paragraphs>
												<Paragraph>
													<TextRuns>
														<TextRun>
															<Value>%</Value>
														</TextRun>
													</TextRuns>
												</Paragraph>
											</Paragraphs>
											<Style>
												<BackgroundColor>#7D3C98</BackgroundColor>
												<Color>#FFFFFF</Color>
												<FontWeight>Bold</FontWeight>
												<TextAlign>Center</TextAlign>
												<Border>
													<Style>Solid</Style>
													<Color>#FFFFFF</Color>
												</Border>
											</Style>
										</Textbox>
									</CellContents>
								</TablixCell>
							</TablixCells>
						</TablixRow>
						<TablixRow>
							<Height>0.6cm</Height>
							<TablixCells>
								<TablixCell>
									<CellContents>
										<Textbox Name="DEsp1a">
											<CanGrow>true</CanGrow>
											<Paragraphs>
												<Paragraph>
													<TextRuns>
														<TextRun>
															<Value>Perros</Value>
														</TextRun>
													</TextRuns>
												</Paragraph>
											</Paragraphs>
											<Style>
												<Border>
													<Style>Solid</Style>
													<Color>#D7DBDD</Color>
												</Border>
												<PaddingLeft>4pt</PaddingLeft>
											</Style>
										</Textbox>
									</CellContents>
								</TablixCell>
								<TablixCell>
									<CellContents>
										<Textbox Name="DEsp1b">
											<CanGrow>true</CanGrow>
											<Paragraphs>
												<Paragraph>
													<TextRuns>
														<TextRun>
															<Value>=Fields!TotalPerros.Value</Value>
														</TextRun>
													</TextRuns>
												</Paragraph>
											</Paragraphs>
											<Style>
												<Border>
													<Style>Solid</Style>
													<Color>#D7DBDD</Color>
												</Border>
												<TextAlign>Center</TextAlign>
												<FontWeight>Bold</FontWeight>
											</Style>
										</Textbox>
									</CellContents>
								</TablixCell>
								<TablixCell>
									<CellContents>
										<Textbox Name="DEsp1c">
											<CanGrow>true</CanGrow>
											<Paragraphs>
												<Paragraph>
													<TextRuns>
														<TextRun>
															<Value>=IIF(Fields!TotalMascotas.Value &gt; 0, Format(CDbl(Fields!TotalPerros.Value) / CDbl(Fields!TotalMascotas.Value) * 100, "0.0") &amp; "%", "0%")</Value>
														</TextRun>
													</TextRuns>
												</Paragraph>
											</Paragraphs>
											<Style>
												<Border>
													<Style>Solid</Style>
													<Color>#D7DBDD</Color>
												</Border>
												<TextAlign>Center</TextAlign>
											</Style>
										</Textbox>
									</CellContents>
								</TablixCell>
							</TablixCells>
						</TablixRow>
						<TablixRow>
							<Height>0.6cm</Height>
