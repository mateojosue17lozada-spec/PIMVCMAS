<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2008/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner">
	<Body>
		<ReportItems>

			<!-- Encabezado -->
			<Rectangle Name="RectanguloEncabezado">
				<Style>
					<BackgroundColor>#9B59B6</BackgroundColor>
				</Style>
				<Height>1.5cm</Height>
				<Width>19cm</Width>
				<Top>0cm</Top>
				<Left>0cm</Left>
				<ReportItems>
					<Textbox Name="TextboxTitulo">
						<Style>
							<FontSize>20pt</FontSize>
							<FontWeight>Bold</FontWeight>
							<Color>White</Color>
							<PaddingLeft>5pt</PaddingLeft>
						</Style>
						<Top>0cm</Top>
						<Left>0cm</Left>
						<Height>1.2cm</Height>
						<Width>19cm</Width>
						<CanGrow>true</CanGrow>
						<Paragraphs>
							<Paragraph>
								<TextRuns>
									<TextRun>
										<Value>ESTADISTICAS GENERALES DEL REFUGIO</Value>
										<Style>
											<FontSize>20pt</FontSize>
											<FontWeight>Bold</FontWeight>
											<Color>White</Color>
										</Style>
									</TextRun>
								</TextRuns>
							</Paragraph>
						</Paragraphs>
					</Textbox>
				</ReportItems>
			</Rectangle>

			<!-- Fecha y usuario -->
			<Rectangle Name="RectanguloFiltros">
				<Style>
					<BackgroundColor>#ECF0F1</BackgroundColor>
					<Border>
						<Style>Solid</Style>
						<Color>#BDC3C7</Color>
					</Border>
				</Style>
				<Height>1cm</Height>
				<Width>19cm</Width>
				<Top>1.6cm</Top>
				<Left>0cm</Left>
				<ReportItems>
					<Textbox Name="TextboxFecha">
						<Style>
							<FontSize>10pt</FontSize>
							<PaddingLeft>5pt</PaddingLeft>
							<PaddingTop>5pt</PaddingTop>
						</Style>
						<Top>0cm</Top>
						<Left>0cm</Left>
						<Height>0.8cm</Height>
						<Width>10cm</Width>
						<CanGrow>true</CanGrow>
						<Paragraphs>
							<Paragraph>
								<TextRuns>
									<TextRun>
										<Value>=("Fecha: " &amp; Parameters!FechaGeneracion.Value)</Value>
									</TextRun>
								</TextRuns>
							</Paragraph>
						</Paragraphs>
					</Textbox>
					<Textbox Name="TextboxUsuario">
						<Style>
							<FontSize>10pt</FontSize>
							<TextAlign>Right</TextAlign>
							<PaddingRight>5pt</PaddingRight>
							<PaddingTop>5pt</PaddingTop>
						</Style>
						<Top>0cm</Top>
						<Left>12cm</Left>
						<Height>0.8cm</Height>
						<Width>7cm</Width>
						<CanGrow>true</CanGrow>
						<Paragraphs>
							<Paragraph>
								<TextRuns>
									<TextRun>
										<Value>=("Generado por: " &amp; Parameters!Usuario.Value)</Value>
									</TextRun>
								</TextRuns>
							</Paragraph>
						</Paragraphs>
					</Textbox>
				</ReportItems>
			</Rectangle>

			<!-- Totales principales en tarjetas -->
			<Rectangle Name="RectanguloTotales">
				<Style>
					<Border>
						<Style>Solid</Style>
						<Color>#34495E</Color>
					</Border>
					<BackgroundColor>#F8F9F9</BackgroundColor>
				</Style>
				<Height>3.5cm</Height>
				<Width>19cm</Width>
				<Top>2.8cm</Top>
				<Left>0cm</Left>
				<ReportItems>
					<Textbox Name="TotalMascotas">
						<Style>
							<FontSize>24pt</FontSize>
							<FontWeight>Bold</FontWeight>
							<TextAlign>Center</TextAlign>
							<Color>#9B59B6</Color>
						</Style>
						<Top>0.5cm</Top>
						<Left>1cm</Left>
						<Height>1.5cm</Height>
						<Width>4cm</Width>
						<CanGrow>true</CanGrow>
						<Paragraphs>
							<Paragraph>
								<TextRuns>
									<TextRun>
										<Value>=Fields!TotalMascotas.Value</Value>
									</TextRun>
								</TextRuns>
							</Paragraph>
						</Paragraphs>
					</Textbox>
					<Textbox Name="LabelMascotas">
						<Style>
							<FontSize>12pt</FontSize>
							<TextAlign>Center</TextAlign>
						</Style>
						<Top>2cm</Top>
						<Left>1cm</Left>
						<Height>0.8cm</Height>
						<Width>4cm</Width>
						<CanGrow>true</CanGrow>
						<Paragraphs>
							<Paragraph>
								<TextRuns>
									<TextRun>
										<Value>Mascotas activas</Value>
									</TextRun>
								</TextRuns>
							</Paragraph>
						</Paragraphs>
					</Textbox>

					<Textbox Name="TotalAdopciones">
						<Style>
							<FontSize>24pt</FontSize>
							<FontWeight>Bold</FontWeight>
							<TextAlign>Center</TextAlign>
							<Color>#3498DB</Color>
						</Style>
						<Top>0.5cm</Top>
						<Left>6cm</Left>
						<Height>1.5cm</Height>
						<Width>4cm</Width>
						<CanGrow>true</CanGrow>
						<Paragraphs>
							<Paragraph>
								<TextRuns>
									<TextRun>
										<Value>=Fields!TotalAdopciones.Value</Value>
									</TextRun>
								</TextRuns>
							</Paragraph>
						</Paragraphs>
					</Textbox>
					<Textbox Name="LabelAdopciones">
						<Style>
							<FontSize>12pt</FontSize>
							<TextAlign>Center</TextAlign>
						</Style>
						<Top>2cm</Top>
						<Left>6cm</Left>
						<Height>0.8cm</Height>
						<Width>4cm</Width>
						<CanGrow>true</CanGrow>
						<Paragraphs>
							<Paragraph>
								<TextRuns>
									<TextRun>
										<Value>Adopciones totales</Value>
									</TextRun>
								</TextRuns>
							</Paragraph>
						</Paragraphs>
					</Textbox>

					<Textbox Name="SolicitudesPendientes">
						<Style>
							<FontSize>24pt</FontSize>
							<FontWeight>Bold</FontWeight>
							<TextAlign>Center</TextAlign>
							<Color>#E67E22</Color>
						</Style>
						<Top>0.5cm</Top>
						<Left>11cm</Left>
						<Height>1.5cm</Height>
						<Width>4cm</Width>
						<CanGrow>true</CanGrow>
						<Paragraphs>
							<Paragraph>
								<TextRuns>
									<TextRun>
										<Value>=Fields!SolicitudesPendientes.Value</Value>
									</TextRun>
								</TextRuns>
							</Paragraph>
						</Paragraphs>
					</Textbox>
					<Textbox Name="LabelSolicitudes">
						<Style>
							<FontSize>12pt</FontSize>
							<TextAlign>Center</TextAlign>
						</Style>
						<Top>2cm</Top>
						<Left>11cm</Left>
						<Height>0.8cm</Height>
						<Width>4cm</Width>
						<CanGrow>true</CanGrow>
						<Paragraphs>
							<Paragraph>
								<TextRuns>
									<TextRun>
										<Value>Solicitudes pendientes</Value>
									</TextRun>
								</TextRuns>
							</Paragraph>
						</Paragraphs>
					</Textbox>

					<Textbox Name="SeguimientosPendientes">
						<Style>
							<FontSize>24pt</FontSize>
							<FontWeight>Bold</FontWeight>
							<TextAlign>Center</TextAlign>
							<Color>#E74C3C</Color>
						</Style>
						<Top>0.5cm</Top>
						<Left>15cm</Left>
						<Height>1.5cm</Height>
						<Width>4cm</Width>
						<CanGrow>true</CanGrow>
						<Paragraphs>
							<Paragraph>
								<TextRuns>
									<TextRun>
										<Value>=Fields!SeguimientosPendientes.Value</Value>
									</TextRun>
								</TextRuns>
							</Paragraph>
						</Paragraphs>
					</Textbox>
					<Textbox Name="LabelSeguimientos">
						<Style>
							<FontSize>12pt</FontSize>
							<TextAlign>Center</TextAlign>
						</Style>
						<Top>2cm</Top>
						<Left>15cm</Left>
						<Height>0.8cm</Height>
						<Width>4cm</Width>
						<CanGrow>true</CanGrow>
						<Paragraphs>
							<Paragraph>
								<TextRuns>
									<TextRun>
										<Value>Seguimientos pend.</Value>
									</TextRun>
								</TextRuns>
							</Paragraph>
						</Paragraphs>
					</Textbox>
				</ReportItems>
			</Rectangle>

			<!-- Tabla de distribución por especie y estado -->
			<Rectangle Name="RectanguloDistribucion">
				<Style>
					<Border>
						<Style>Solid</Style>
						<Color>#34495E</Color>
					</Border>
					<BackgroundColor>#F8F9F9</BackgroundColor>
				</Style>
				<Height>5cm</Height>
				<Width>19cm</Width>
				<Top>6.5cm</Top>
				<Left>0cm</Left>
				<ReportItems>
					<Textbox Name="TextboxTituloDistribucion">
						<Style>
							<FontSize>14pt</FontSize>
							<FontWeight>Bold</FontWeight>
							<PaddingLeft>5pt</PaddingLeft>
						</Style>
						<Top>0.2cm</Top>
						<Left>0.2cm</Left>
						<Height>0.8cm</Height>
						<Width>10cm</Width>
						<CanGrow>true</CanGrow>
						<Paragraphs>
							<Paragraph>
								<TextRuns>
									<TextRun>
										<Value>Distribucion de mascotas</Value>
									</TextRun>
								</TextRuns>
							</Paragraph>
						</Paragraphs>
					</Textbox>

					<!-- Tabla distribución por especie -->
					<Tablix Name="TablixDistribucion">
						<Style>
							<Border>
								<Style>Solid</Style>
							</Border>
						</Style>
						<TablixBody>
							<TablixColumns>
								<TablixColumn>
									<Width>4cm</Width>
								</TablixColumn>
								<TablixColumn>
									<Width>4cm</Width>
								</TablixColumn>
								<TablixColumn>
									<Width>4cm</Width>
								</TablixColumn>
							</TablixColumns>
							<TablixRows>
								<TablixRow>
									<Height>0.7cm</Height>
									<TablixCells>
										<TablixCell>
											<CellContents>
												<Textbox Name="HeaderEspecie">
													<Style>
														<BackgroundColor>#34495E</BackgroundColor>
														<Color>White</Color>
														<FontWeight>Bold</FontWeight>
														<TextAlign>Center</TextAlign>
														<Border>
															<Style>Solid</Style>
															<Color>White</Color>
														</Border>
													</Style>
													<CanGrow>true</CanGrow>
													<Paragraphs>
														<Paragraph>
															<TextRuns>
																<TextRun>
																	<Value>Especie</Value>
																</TextRun>
															</TextRuns>
														</Paragraph>
													</Paragraphs>
												</Textbox>
											</CellContents>
										</TablixCell>
										<TablixCell>
											<CellContents>
												<Textbox Name="HeaderCantidad">
													<Style>
														<BackgroundColor>#34495E</BackgroundColor>
														<Color>White</Color>
														<FontWeight>Bold</FontWeight>
														<TextAlign>Center</TextAlign>
														<Border>
															<Style>Solid</Style>
															<Color>White</Color>
														</Border>
													</Style>
													<CanGrow>true</CanGrow>
													<Paragraphs>
														<Paragraph>
															<TextRuns>
																<TextRun>
																	<Value>Cantidad</Value>
																</TextRun>
															</TextRuns>
														</Paragraph>
													</Paragraphs>
												</Textbox>
											</CellContents>
										</TablixCell>
										<TablixCell>
											<CellContents>
												<Textbox Name="HeaderPorcentaje">
													<Style>
														<BackgroundColor>#34495E</BackgroundColor>
														<Color>White</Color>
														<FontWeight>Bold</FontWeight>
														<TextAlign>Center</TextAlign>
														<Border>
															<Style>Solid</Style>
															<Color>White</Color>
														</Border>
													</Style>
													<CanGrow>true</CanGrow>
													<Paragraphs>
														<Paragraph>
															<TextRuns>
																<TextRun>
																	<Value>%</Value>
																</TextRun>
															</TextRuns>
														</Paragraph>
													</Paragraphs>
												</Textbox>
											</CellContents>
										</TablixCell>
									</TablixCells>
								</TablixRow>
								<TablixRow>
									<Height>0.7cm</Height>
									<TablixCells>
										<TablixCell>
											<CellContents>
												<Textbox Name="DataPerrosLabel">
													<Style>
														<Border>
															<Style>Solid</Style>
															<Color>#BDC3C7</Color>
														</Border>
													</Style>
													<CanGrow>true</CanGrow>
													<Paragraphs>
														<Paragraph>
															<TextRuns>
																<TextRun>
																	<Value>Perros</Value>
																</TextRun>
															</TextRuns>
														</Paragraph>
													</Paragraphs>
												</Textbox>
											</CellContents>
										</TablixCell>
										<TablixCell>
											<CellContents>
												<Textbox Name="DataPerrosCantidad">
													<Style>
														<Border>
															<Style>Solid</Style>
															<Color>#BDC3C7</Color>
														</Border>
														<TextAlign>Center</TextAlign>
													</Style>
													<CanGrow>true</CanGrow>
													<Paragraphs>
														<Paragraph>
															<TextRuns>
																<TextRun>
																	<Value>=Fields!TotalPerros.Value</Value>
																</TextRun>
															</TextRuns>
														</Paragraph>
													</Paragraphs>
												</Textbox>
											</CellContents>
										</TablixCell>
										<TablixCell>
											<CellContents>
												<Textbox Name="DataPerrosPct">
													<Style>
														<Border>
															<Style>Solid</Style>
															<Color>#BDC3C7</Color>
														</Border>
														<TextAlign>Center</TextAlign>
													</Style>
													<CanGrow>true</CanGrow>
													<Paragraphs>
														<Paragraph>
															<TextRuns>
																<TextRun>
																	<Value>=IIF(Fields!TotalMascotas.Value &gt; 0, Format(Fields!TotalPerros.Value / Fields!TotalMascotas.Value * 100, "0.0") &amp; "%", "0%")</Value>
																</TextRun>
															</TextRuns>
														</Paragraph>
													</Paragraphs>
												</Textbox>
											</CellContents>
										</TablixCell>
									</TablixCells>
								</TablixRow>
								<TablixRow>
									<Height>0.7cm</Height>
									<TablixCells>
										<TablixCell>
											<CellContents>
												<Textbox Name="DataGatosLabel">
													<Style>
														<Border>
															<Style>Solid</Style>
															<Color>#BDC3C7</Color>
														</Border>
													</Style>
													<CanGrow>true</CanGrow>
													<Paragraphs>
														<Paragraph>
															<TextRuns>
																<TextRun>
																	<Value>Gatos</Value>
																</TextRun>
															</TextRuns>
														</Paragraph>
													</Paragraphs>
												</Textbox>
											</CellContents>
										</TablixCell>
										<TablixCell>
											<CellContents>
												<Textbox Name="DataGatosCantidad">
													<Style>
														<Border>
															<Style>Solid</Style>
															<Color>#BDC3C7</Color>
														</Border>
														<TextAlign>Center</TextAlign>
													</Style>
													<CanGrow>true</CanGrow>
													<Paragraphs>
														<Paragraph>
															<TextRuns>
																<TextRun>
																	<Value>=Fields!TotalGatos.Value</Value>
																</TextRun>
															</TextRuns>
														</Paragraph>
													</Paragraphs>
												</Textbox>
											</CellContents>
										</TablixCell>
										<TablixCell>
											<CellContents>
												<Textbox Name="DataGatosPct">
													<Style>
														<Border>
															<Style>Solid</Style>
															<Color>#BDC3C7</Color>
														</Border>
														<TextAlign>Center</TextAlign>
													</Style>
													<CanGrow>true</CanGrow>
													<Paragraphs>
														<Paragraph>
															<TextRuns>
																<TextRun>
																	<Value>=IIF(Fields!TotalMascotas.Value &gt; 0, Format(Fields!TotalGatos.Value / Fields!TotalMascotas.Value * 100, "0.0") &amp; "%", "0%")</Value>
																</TextRun>
															</TextRuns>
														</Paragraph>
													</Paragraphs>
												</Textbox>
											</CellContents>
										</TablixCell>
									</TablixCells>
								</TablixRow>
								<TablixRow>
									<Height>0.7cm</Height>
									<TablixCells>
										<TablixCell>
											<CellContents>
												<Textbox Name="DataOtrosLabel">
													<Style>
														<Border>
															<Style>Solid</Style>
															<Color>#BDC3C7</Color>
														</Border>
													</Style>
													<CanGrow>true</CanGrow>
													<Paragraphs>
														<Paragraph>
															<TextRuns>
																<TextRun>
																	<Value>Otros</Value>
																</TextRun>
															</TextRuns>
														</Paragraph>
													</Paragraphs>
												</Textbox>
											</CellContents>
										</TablixCell>
										<TablixCell>
											<CellContents>
												<Textbox Name="DataOtrosCantidad">
													<Style>
														<Border>
															<Style>Solid</Style>
															<Color>#BDC3C7</Color>
														</Border>
														<TextAlign>Center</TextAlign>
													</Style>
													<CanGrow>true</CanGrow>
													<Paragraphs>
														<Paragraph>
															<TextRuns>
																<TextRun>
																	<Value>=Fields!TotalOtros.Value</Value>
																</TextRun>
															</TextRuns>
														</Paragraph>
													</Paragraphs>
												</Textbox>
											</CellContents>
										</TablixCell>
										<TablixCell>
											<CellContents>
												<Textbox Name="DataOtrosPct">
													<Style>
														<Border>
															<Style>Solid</Style>
															<Color>#BDC3C7</Color>
														</Border>
														<TextAlign>Center</TextAlign>
													</Style>
													<CanGrow>true</CanGrow>
													<Paragraphs>
														<Paragraph>
															<TextRuns>
																<TextRun>
																	<Value>=IIF(Fields!TotalMascotas.Value &gt; 0, Format(Fields!TotalOtros.Value / Fields!TotalMascotas.Value * 100, "0.0") &amp; "%", "0%")</Value>
																</TextRun>
															</TextRuns>
														</Paragraph>
													</Paragraphs>
												</Textbox>
											</CellContents>
										</TablixCell>
									</TablixCells>
								</TablixRow>
							</TablixRows>
						</TablixBody>
						<TablixColumnHierarchy>
							<TablixMembers>
								<TablixMember/>
								<TablixMember/>
								<TablixMember/>
							</TablixMembers>
						</TablixColumnHierarchy>
						<TablixRowHierarchy>
							<TablixMembers>
								<TablixMember>
									<KeepWithGroup>After</KeepWithGroup>
								</TablixMember>
								<TablixMember>
									<Group Name="DetalleDistribucion1"/>
								</TablixMember>
								<TablixMember>
									<Group Name="DetalleDistribucion2"/>
								</TablixMember>
								<TablixMember>
									<Group Name="DetalleDistribucion3"/>
								</TablixMember>
							</TablixMembers>
						</TablixRowHierarchy>
						<DataSetName>DataSetEstadisticas</DataSetName>
						<Top>1cm</Top>
						<Left>0.5cm</Left>
						<Width>12cm</Width>
					</Tablix>

					<!-- Tabla de estados -->
					<Tablix Name="TablixEstados">
						<Style>
							<Border>
								<Style>Solid</Style>
							</Border>
						</Style>
						<TablixBody>
							<TablixColumns>
								<TablixColumn>
									<Width>4cm</Width>
								</TablixColumn>
								<TablixColumn>
									<Width>4cm</Width>
								</TablixColumn>
							</TablixColumns>
							<TablixRows>
								<TablixRow>
									<Height>0.7cm</Height>
									<TablixCells>
										<TablixCell>
											<CellContents>
												<Textbox Name="HeaderEstado">
													<Style>
														<BackgroundColor>#34495E</BackgroundColor>
														<Color>White</Color>
														<FontWeight>Bold</FontWeight>
														<TextAlign>Center</TextAlign>
														<Border>
															<Style>Solid</Style>
															<Color>White</Color>
														</Border>
													</Style>
													<CanGrow>true</CanGrow>
													<Paragraphs>
														<Paragraph>
															<TextRuns>
																<TextRun>
																	<Value>Estado</Value>
																</TextRun>
															</TextRuns>
														</Paragraph>
													</Paragraphs>
												</Textbox>
											</CellContents>
										</TablixCell>
										<TablixCell>
											<CellContents>
