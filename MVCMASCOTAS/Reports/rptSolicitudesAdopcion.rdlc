													<TextRuns>
														<TextRun>
															<Value>=Fields!DiasEnProceso.Value</Value>
														</TextRun>
													</TextRuns>
												</Paragraph>
											</Paragraphs>
										</Textbox>
									</CellContents>
								</TablixCell>
							</TablixCells>
						</TablixRow>
					</TablixRows>
				</TablixBody>
				<TablixColumnHierarchy>
					<TablixMembers>
						<TablixMember />
						<TablixMember />
						<TablixMember />
						<TablixMember />
						<TablixMember />
						<TablixMember />
						<TablixMember />
						<TablixMember />
						<TablixMember />
						<TablixMember />
					</TablixMembers>
				</TablixColumnHierarchy>
				<TablixRowHierarchy>
					<TablixMembers>
						<TablixMember>
							<KeepWithGroup>After</KeepWithGroup>
						</TablixMember>
						<TablixMember>
							<Group Name="Detalle" />
						</TablixMember>
					</TablixMembers>
				</TablixRowHierarchy>
				<DataSetName>DataSetSolicitudes</DataSetName>
				<Top>3.3cm</Top>
				<Left>0cm</Left>
				<Width>19cm</Width>
			</Tablix>

			<!-- PIE DE PÁGINA -->
			<Rectangle Name="RectanguloPie">
				<Style>
					<Border>
						<Style>Solid</Style>
						<Color>#F39C12</Color>
					</Border>
					<BackgroundColor>#ECF0F1</BackgroundColor>
				</Style>
				<Height>1.5cm</Height>
				<Width>19cm</Width>
				<Top>25cm</Top>
				<Left>0cm</Left>
				<ReportItems>
					<Textbox Name="TextboxResumen">
						<Style>
							<FontSize>11pt</FontSize>
							<FontWeight>Bold</FontWeight>
							<Color>#F39C12</Color>
							<PaddingLeft>5pt</PaddingLeft>
							<PaddingTop>5pt</PaddingTop>
						</Style>
						<Top>0cm</Top>
						<Left>0cm</Left>
						<Height>1cm</Height>
						<Width>14cm</Width>
						<CanGrow>true</CanGrow>
						<Paragraphs>
							<Paragraph>
								<TextRuns>
									<TextRun>
										<Value>=("Total: " &amp; Parameters!TotalRegistros.Value &amp; " | Pendientes: " &amp; Parameters!Pendientes.Value &amp; " | Aprobadas: " &amp; Parameters!Aprobadas.Value &amp; " | Rechazadas: " &amp; Parameters!Rechazadas.Value)</Value>
									</TextRun>
								</TextRuns>
							</Paragraph>
						</Paragraphs>
					</Textbox>
					<Textbox Name="TextboxPagina">
						<Style>
							<FontSize>10pt</FontSize>
							<Color>#7F8C8D</Color>
							<TextAlign>Right</TextAlign>
							<PaddingRight>5pt</PaddingRight>
							<PaddingTop>5pt</PaddingTop>
						</Style>
						<Top>0cm</Top>
						<Left>14cm</Left>
						<Height>1cm</Height>
						<Width>5cm</Width>
						<CanGrow>true</CanGrow>
						<Paragraphs>
							<Paragraph>
								<TextRuns>
									<TextRun>
										<Value>=("Página " &amp; Globals!PageNumber &amp; " de " &amp; Globals!TotalPages)</Value>
									</TextRun>
								</TextRuns>
							</Paragraph>
						</Paragraphs>
					</Textbox>
				</ReportItems>
			</Rectangle>

		</ReportItems>
		<Height>27cm</Height>
		<Style />
