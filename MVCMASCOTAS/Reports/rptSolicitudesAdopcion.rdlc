						<TablixRow>
							<Height>0.6cm</Height>
							<TablixCells>
								<TablixCell>
									<CellContents>
										<Textbox Name="DS1">
											<CanGrow>true</CanGrow>
											<Paragraphs>
												<Paragraph>
													<TextRuns>
														<TextRun>
															<Value>=Format(Fields!FechaSolicitud.Value, "dd/MM/yyyy")</Value>
