<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2008/01/reportdefinition"
        xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner">
	<ReportParameters>
		<ReportParameter Name="FechaGeneracion">
			<DataType>String</DataType>
			<DefaultValue>
				<Values>
					<Value></Value>
				</Values>
			</DefaultValue>
			<Prompt>FechaGeneracion</Prompt>
		</ReportParameter>
		<ReportParameter Name="Usuario">
			<DataType>String</DataType>
			<DefaultValue>
				<Values>
					<Value></Value>
				</Values>
			</DefaultValue>
			<Prompt>Usuario</Prompt>
		</ReportParameter>
		<ReportParameter Name="FiltroEstado">
			<DataType>String</DataType>
			<DefaultValue>
				<Values>
					<Value>Todos</Value>
				</Values>
			</DefaultValue>
			<Prompt>FiltroEstado</Prompt>
		</ReportParameter>
		<ReportParameter Name="FechaInicio">
			<DataType>String</DataType>
			<DefaultValue>
				<Values>
					<Value>Sin filtro</Value>
				</Values>
			</DefaultValue>
			<Prompt>FechaInicio</Prompt>
		</ReportParameter>
		<ReportParameter Name="FechaFin">
			<DataType>String</DataType>
			<DefaultValue>
				<Values>
					<Value>Sin filtro</Value>
				</Values>
			</DefaultValue>
			<Prompt>FechaFin</Prompt>
		</ReportParameter>
		<ReportParameter Name="TotalRegistros">
			<DataType>String</DataType>
			<DefaultValue>
				<Values>
					<Value>0</Value>
				</Values>
			</DefaultValue>
			<Prompt>TotalRegistros</Prompt>
		</ReportParameter>
		<ReportParameter Name="Pendientes">
			<DataType>String</DataType>
			<DefaultValue>
				<Values>
					<Value>0</Value>
				</Values>
			</DefaultValue>
			<Prompt>Pendientes</Prompt>
		</ReportParameter>
		<ReportParameter Name="Aprobadas">
			<DataType>String</DataType>
			<DefaultValue>
				<Values>
					<Value>0</Value>
				</Values>
			</DefaultValue>
			<Prompt>Aprobadas</Prompt>
		</ReportParameter>
		<ReportParameter Name="Rechazadas">
			<DataType>String</DataType>
			<DefaultValue>
				<Values>
					<Value>0</Value>
				</Values>
			</DefaultValue>
			<Prompt>Rechazadas</Prompt>
		</ReportParameter>
	</ReportParameters>
	<DataSources>
		<DataSource Name="DataSetSolicitudes">
			<ConnectionProperties>
				<DataProvider>System.Data.DataSet</DataProvider>
				<ConnectString>/* Local Connection */</ConnectString>
			</ConnectionProperties>
			<rd:DataSourceID>00000000-0000-0000-0000-000000000003</rd:DataSourceID>
		</DataSource>
	</DataSources>
	<DataSets>
		<DataSet Name="DataSetSolicitudes">
			<Query>
				<DataSourceName>DataSetSolicitudes</DataSourceName>
				<CommandText>/* Local Query */</CommandText>
			</Query>
			<Fields>
				<Field Name="SolicitudId">
					<DataField>SolicitudId</DataField>
					<rd:TypeName>System.Int32</rd:TypeName>
				</Field>
				<Field Name="FechaSolicitud">
					<DataField>FechaSolicitud</DataField>
					<rd:TypeName>System.DateTime</rd:TypeName>
				</Field>
				<Field Name="Estado">
					<DataField>Estado</DataField>
					<rd:TypeName>System.String</rd:TypeName>
				</Field>
				<Field Name="NombreSolicitante">
					<DataField>NombreSolicitante</DataField>
					<rd:TypeName>System.String</rd:TypeName>
				</Field>
				<Field Name="CedulaSolicitante">
					<DataField>CedulaSolicitante</DataField>
					<rd:TypeName>System.String</rd:TypeName>
				</Field>
				<Field Name="TelefonoSolicitante">
					<DataField>TelefonoSolicitante</DataField>
					<rd:TypeName>System.String</rd:TypeName>
				</Field>
				<Field Name="EmailSolicitante">
					<DataField>EmailSolicitante</DataField>
					<rd:TypeName>System.String</rd:TypeName>
				</Field>
				<Field Name="CiudadSolicitante">
					<DataField>CiudadSolicitante</DataField>
					<rd:TypeName>System.String</rd:TypeName>
				</Field>
				<Field Name="NombreMascota">
					<DataField>NombreMascota</DataField>
					<rd:TypeName>System.String</rd:TypeName>
				</Field>
				<Field Name="EspecieMascota">
					<DataField>EspecieMascota</DataField>
					<rd:TypeName>System.String</rd:TypeName>
				</Field>
				<Field Name="RazaMascota">
					<DataField>RazaMascota</DataField>
					<rd:TypeName>System.String</rd:TypeName>
				</Field>
				<Field Name="PuntajeEvaluacion">
					<DataField>PuntajeEvaluacion</DataField>
					<rd:TypeName>System.Nullable`1[System.Int32]</rd:TypeName>
				</Field>
				<Field Name="ResultadoEvaluacion">
					<DataField>ResultadoEvaluacion</DataField>
					<rd:TypeName>System.String</rd:TypeName>
				</Field>
				<Field Name="EvaluadorNombre">
					<DataField>EvaluadorNombre</DataField>
					<rd:TypeName>System.String</rd:TypeName>
				</Field>
				<Field Name="TipoVivienda">
					<DataField>TipoVivienda</DataField>
					<rd:TypeName>System.String</rd:TypeName>
				</Field>
				<Field Name="DiasEnProceso">
					<DataField>DiasEnProceso</DataField>
					<rd:TypeName>System.Int32</rd:TypeName>
				</Field>
				<Field Name="MotivoRechazo">
					<DataField>MotivoRechazo</DataField>
					<rd:TypeName>System.String</rd:TypeName>
				</Field>
			</Fields>
		</DataSet>
	</DataSets>
	<Body>
		<Height>20cm</Height>
		<Style />
		<ReportItems>

			<Textbox Name="Titulo">
				<CanGrow>true</CanGrow>
				<Top>0cm</Top>
				<Left>0cm</Left>
				<Width>19cm</Width>
				<Height>1.2cm</Height>
				<Style>
					<BackgroundColor>#E67E22</BackgroundColor>
					<Color>White</Color>
					<FontSize>16pt</FontSize>
					<FontWeight>Bold</FontWeight>
					<PaddingLeft>8pt</PaddingLeft>
					<PaddingTop>6pt</PaddingTop>
					<Border>
						<Style>None</Style>
					</Border>
				</Style>
				<Paragraphs>
					<Paragraph>
						<TextRuns>
							<TextRun>
								<Value>REPORTE DE SOLICITUDES DE ADOPCIÓN</Value>
							</TextRun>
						</TextRuns>
					</Paragraph>
				</Paragraphs>
			</Textbox>

			<Textbox Name="InfoFiltros">
				<CanGrow>true</CanGrow>
				<Top>1.3cm</Top>
				<Left>0cm</Left>
				<Width>19cm</Width>
				<Height>0.7cm</Height>
				<Style>
					<BackgroundColor>#ECF0F1</BackgroundColor>
					<FontSize>9pt</FontSize>
					<Color>#555555</Color>
					<PaddingLeft>8pt</PaddingLeft>
					<PaddingTop>4pt</PaddingTop>
					<Border>
						<Style>None</Style>
					</Border>
				</Style>
				<Paragraphs>
					<Paragraph>
						<TextRuns>
							<TextRun>
								<Value>=("Estado: " &amp; Parameters!FiltroEstado.Value &amp; "  |  Período: " &amp; Parameters!FechaInicio.Value &amp; " - " &amp; Parameters!FechaFin.Value &amp; "  |  Total: " &amp; Parameters!TotalRegistros.Value &amp; "  Pend: " &amp; Parameters!Pendientes.Value &amp; "  Aprobadas: " &amp; Parameters!Aprobadas.Value &amp; "  Rechazadas: " &amp; Parameters!Rechazadas.Value)</Value>
							</TextRun>
						</TextRuns>
					</Paragraph>
				</Paragraphs>
			</Textbox>

