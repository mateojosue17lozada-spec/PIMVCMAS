						</TablixRow>

						<!-- Datos -->
						<TablixRow>
							<Height>0.7cm</Height>
							<TablixCells>
								<TablixCell>
									<CellContents>
										<Textbox Name="DataSolicitudId">
											<Style>
												<Border>
													<Style>Solid</Style>
													<Color>#BDC3C7</Color>
												</Border>
												<TextAlign>Center</TextAlign>
											</Style>
											<CanGrow>true</CanGrow>
											<Paragraphs>
												<Paragraph>
													<TextRuns>
														<TextRun>
															<Value>=Fields!SolicitudId.Value</Value>
														</TextRun>
													</TextRuns>
												</Paragraph>
											</Paragraphs>
										</Textbox>
									</CellContents>
								</TablixCell>
								<TablixCell>
									<CellContents>
										<Textbox Name="DataFechaSolicitud">
											<Style>
												<Border>
													<Style>Solid</Style>
													<Color>#BDC3C7</Color>
												</Border>
												<TextAlign>Center</TextAlign>
											</Style>
											<CanGrow>true</CanGrow>
											<Paragraphs>
												<Paragraph>
													<TextRuns>
														<TextRun>
															<Value>=Format(Fields!FechaSolicitud.Value, "dd/MM/yyyy")</Value>
														</TextRun>
													</TextRuns>
												</Paragraph>
											</Paragraphs>
										</Textbox>
									</CellContents>
								</TablixCell>
								<TablixCell>
									<CellContents>
										<Textbox Name="DataNombreSolicitante">
											<Style>
												<Border>
													<Style>Solid</Style>
													<Color>#BDC3C7</Color>
												</Border>
											</Style>
											<CanGrow>true</CanGrow>
											<Paragraphs>
												<Paragraph>
													<TextRuns>
														<TextRun>
															<Value>=Fields!NombreSolicitante.Value</Value>
														</TextRun>
													</TextRuns>
												</Paragraph>
											</Paragraphs>
										</Textbox>
									</CellContents>
								</TablixCell>
								<TablixCell>
									<CellContents>
										<Textbox Name="DataNombreMascota">
											<Style>
												<Border>
													<Style>Solid</Style>
													<Color>#BDC3C7</Color>
												</Border>
											</Style>
											<CanGrow>true</CanGrow>
											<Paragraphs>
												<Paragraph>
													<TextRuns>
														<TextRun>
															<Value>=Fields!NombreMascota.Value</Value>
														</TextRun>
													</TextRuns>
												</Paragraph>
											</Paragraphs>
										</Textbox>
									</CellContents>
								</TablixCell>
								<TablixCell>
									<CellContents>
										<Textbox Name="DataEstado">
											<Style>
												<Border>
													<Style>Solid</Style>
													<Color>#BDC3C7</Color>
												</Border>
												<TextAlign>Center</TextAlign>
												<FontWeight>Bold</FontWeight>
												<Color>=IIF(Fields!Estado.Value = "Aprobada", "Green", IIF(Fields!Estado.Value = "Rechazada", "Red", IIF(Fields!Estado.Value = "Pendiente", "Orange", "Black")))</Color>
											</Style>
											<CanGrow>true</CanGrow>
											<Paragraphs>
												<Paragraph>
													<TextRuns>
														<TextRun>
															<Value>=Fields!Estado.Value</Value>
														</TextRun>
													</TextRuns>
												</Paragraph>
											</Paragraphs>
										</Textbox>
									</CellContents>
								</TablixCell>
								<TablixCell>
									<CellContents>
										<Textbox Name="DataPuntaje">
											<Style>
												<Border>
													<Style>Solid</Style>
													<Color>#BDC3C7</Color>
												</Border>
												<TextAlign>Center</TextAlign>
											</Style>
											<CanGrow>true</CanGrow>
											<Paragraphs>
												<Paragraph>
													<TextRuns>
														<TextRun>
															<Value>=Fields!PuntajeEvaluacion.Value</Value>
														</TextRun>
													</TextRuns>
												</Paragraph>
											</Paragraphs>
										</Textbox>
									</CellContents>
								</TablixCell>
								<TablixCell>
									<CellContents>
										<Textbox Name="DataResultado">
											<Style>
												<Border>
													<Style>Solid</Style>
													<Color>#BDC3C7</Color>
												</Border>
												<TextAlign>Center</TextAlign>
											</Style>
											<CanGrow>true</CanGrow>
											<Paragraphs>
												<Paragraph>
													<TextRuns>
														<TextRun>
															<Value>=Fields!ResultadoEvaluacion.Value</Value>
														</TextRun>
													</TextRuns>
												</Paragraph>
											</Paragraphs>
										</Textbox>
									</CellContents>
								</TablixCell>
								<TablixCell>
									<CellContents>
										<Textbox Name="DataEvaluador">
											<Style>
												<Border>
													<Style>Solid</Style>
													<Color>#BDC3C7</Color>
												</Border>
											</Style>
											<CanGrow>true</CanGrow>
											<Paragraphs>
												<Paragraph>
													<TextRuns>
														<TextRun>
															<Value>=Fields!EvaluadorNombre.Value</Value>
														</TextRun>
													</TextRuns>
												</Paragraph>
											</Paragraphs>
										</Textbox>
									</CellContents>
								</TablixCell>
								<TablixCell>
									<CellContents>
										<Textbox Name="DataVivienda">
											<Style>
												<Border>
													<Style>Solid</Style>
													<Color>#BDC3C7</Color>
												</Border>
												<TextAlign>Center</TextAlign>
											</Style>
											<CanGrow>true</CanGrow>
											<Paragraphs>
												<Paragraph>
													<TextRuns>
														<TextRun>
															<Value>=Fields!TipoVivienda.Value</Value>
														</TextRun>
													</TextRuns>
												</Paragraph>
											</Paragraphs>
										</Textbox>
									</CellContents>
								</TablixCell>
								<TablixCell>
									<CellContents>
										<Textbox Name="DataDias">
											<Style>
												<Border>
													<Style>Solid</Style>
													<Color>#BDC3C7</Color>
												</Border>
												<TextAlign>Center</TextAlign>
												<FontWeight>Bold</FontWeight>
											</Style>
											<CanGrow>true</CanGrow>
											<Paragraphs>
