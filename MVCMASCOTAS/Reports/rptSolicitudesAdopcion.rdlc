												</Border>
												<FontSize>8pt</FontSize>
												<TextAlign>Center</TextAlign>
												<FontWeight>Bold</FontWeight>
												<Color>=Switch(Fields!Estado.Value = "Aprobada", "Green", Fields!Estado.Value = "Rechazada", "Red", Fields!Estado.Value = "Pendiente", "#E67E22", True, "Black")</Color>
												<BackgroundColor>=IIF(RowNumber(Nothing) Mod 2 = 0, "#FEF9E7", "White")</BackgroundColor>
											</Style>
										</Textbox>
									</CellContents>
								</TablixCell>
								<TablixCell>
