<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2008/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner">
	<Body>
		<ReportItems>

			<!-- ENCABEZADO -->
			<Rectangle Name="RectanguloEncabezado">
				<Style>
					<Border>
						<Style>Solid</Style>
					</Border>
					<BackgroundColor>#F39C12</BackgroundColor>
				</Style>
				<Height>1.5cm</Height>
				<Width>19cm</Width>
				<Top>0cm</Top>
				<Left>0cm</Left>
				<ReportItems>
					<Textbox Name="TextboxTitulo">
						<Style>
							<FontSize>20pt</FontSize>
							<FontWeight>Bold</FontWeight>
							<Color>White</Color>
							<PaddingLeft>5pt</PaddingLeft>
							<PaddingTop>5pt</PaddingTop>
						</Style>
						<Top>0cm</Top>
						<Left>0cm</Left>
						<Height>1.2cm</Height>
						<Width>12cm</Width>
						<CanGrow>true</CanGrow>
						<Paragraphs>
							<Paragraph>
								<TextRuns>
									<TextRun>
										<Value>SOLICITUDES DE ADOPCION</Value>
										<Style>
											<FontSize>20pt</FontSize>
											<FontWeight>Bold</FontWeight>
											<Color>White</Color>
										</Style>
									</TextRun>
								</TextRuns>
							</Paragraph>
						</Paragraphs>
					</Textbox>
				</ReportItems>
			</Rectangle>

			<!-- FILTROS -->
			<Rectangle Name="RectanguloFiltros">
				<Style>
					<Border>
						<Style>Solid</Style>
						<Color>#BDC3C7</Color>
					</Border>
					<BackgroundColor>#ECF0F1</BackgroundColor>
				</Style>
				<Height>1.5cm</Height>
				<Width>19cm</Width>
				<Top>1.6cm</Top>
				<Left>0cm</Left>
				<ReportItems>
					<Textbox Name="TextboxFechaGeneracion">
						<Style>
							<FontSize>10pt</FontSize>
							<Color>#2C3E50</Color>
							<PaddingLeft>5pt</PaddingLeft>
							<PaddingTop>5pt</PaddingTop>
						</Style>
						<Top>0cm</Top>
						<Left>0cm</Left>
						<Height>0.6cm</Height>
						<Width>10cm</Width>
						<CanGrow>true</CanGrow>
						<Paragraphs>
							<Paragraph>
								<TextRuns>
									<TextRun>
										<Value>=("Fecha: " &amp; Parameters!FechaGeneracion.Value)</Value>
									</TextRun>
								</TextRuns>
							</Paragraph>
						</Paragraphs>
					</Textbox>
					<Textbox Name="TextboxUsuario">
						<Style>
							<FontSize>10pt</FontSize>
							<Color>#2C3E50</Color>
							<PaddingLeft>5pt</PaddingLeft>
						</Style>
						<Top>0.7cm</Top>
						<Left>0cm</Left>
						<Height>0.6cm</Height>
						<Width>10cm</Width>
						<CanGrow>true</CanGrow>
						<Paragraphs>
							<Paragraph>
								<TextRuns>
									<TextRun>
										<Value>=("Generado por: " &amp; Parameters!Usuario.Value)</Value>
									</TextRun>
								</TextRuns>
							</Paragraph>
						</Paragraphs>
					</Textbox>
					<Textbox Name="TextboxFiltros">
						<Style>
							<FontSize>10pt</FontSize>
							<Color>#2C3E50</Color>
							<TextAlign>Right</TextAlign>
							<PaddingRight>5pt</PaddingRight>
							<PaddingTop>5pt</PaddingTop>
						</Style>
						<Top>0cm</Top>
						<Left>12cm</Left>
						<Height>1.2cm</Height>
						<Width>7cm</Width>
						<CanGrow>true</CanGrow>
						<Paragraphs>
							<Paragraph>
								<TextRuns>
									<TextRun>
										<Value>=("Estado: " &amp; Parameters!FiltroEstado.Value &amp; " | Desde: " &amp; Parameters!FechaInicio.Value &amp; " | Hasta: " &amp; Parameters!FechaFin.Value)</Value>
									</TextRun>
								</TextRuns>
							</Paragraph>
						</Paragraphs>
					</Textbox>
				</ReportItems>
			</Rectangle>

			<!-- TABLA DE SOLICITUDES -->
			<Tablix Name="TablixSolicitudes">
				<Style>
					<Border>
						<Style>Solid</Style>
						<Color>#34495E</Color>
					</Border>
				</Style>
				<TablixBody>
					<TablixColumns>
						<TablixColumn>
							<Width>1.8cm</Width>
						</TablixColumn>
						<TablixColumn>
							<Width>2.5cm</Width>
						</TablixColumn>
						<TablixColumn>
							<Width>2.5cm</Width>
						</TablixColumn>
						<TablixColumn>
							<Width>2.5cm</Width>
						</TablixColumn>
						<TablixColumn>
							<Width>1.5cm</Width>
						</TablixColumn>
						<TablixColumn>
							<Width>1.5cm</Width>
						</TablixColumn>
						<TablixColumn>
							<Width>1.7cm</Width>
						</TablixColumn>
						<TablixColumn>
							<Width>1.7cm</Width>
						</TablixColumn>
						<TablixColumn>
							<Width>1.7cm</Width>
						</TablixColumn>
						<TablixColumn>
							<Width>1.6cm</Width>
						</TablixColumn>
					</TablixColumns>
					<TablixRows>
						<!-- Encabezados -->
						<TablixRow>
							<Height>0.8cm</Height>
							<TablixCells>
								<TablixCell>
									<CellContents>
										<Textbox Name="HeaderID">
											<Style>
												<BackgroundColor>#F39C12</BackgroundColor>
												<Color>White</Color>
												<FontWeight>Bold</FontWeight>
												<TextAlign>Center</TextAlign>
												<Border>
													<Style>Solid</Style>
													<Color>White</Color>
												</Border>
											</Style>
											<CanGrow>true</CanGrow>
											<Paragraphs>
												<Paragraph>
													<TextRuns>
														<TextRun>
															<Value>ID</Value>
														</TextRun>
													</TextRuns>
												</Paragraph>
											</Paragraphs>
										</Textbox>
									</CellContents>
								</TablixCell>
								<TablixCell>
									<CellContents>
										<Textbox Name="HeaderFecha">
											<Style>
												<BackgroundColor>#F39C12</BackgroundColor>
												<Color>White</Color>
												<FontWeight>Bold</FontWeight>
												<TextAlign>Center</TextAlign>
												<Border>
													<Style>Solid</Style>
													<Color>White</Color>
												</Border>
											</Style>
											<CanGrow>true</CanGrow>
											<Paragraphs>
												<Paragraph>
													<TextRuns>
														<TextRun>
															<Value>Fecha</Value>
														</TextRun>
													</TextRuns>
												</Paragraph>
											</Paragraphs>
										</Textbox>
									</CellContents>
								</TablixCell>
								<TablixCell>
									<CellContents>
										<Textbox Name="HeaderSolicitante">
											<Style>
												<BackgroundColor>#F39C12</BackgroundColor>
												<Color>White</Color>
												<FontWeight>Bold</FontWeight>
												<TextAlign>Center</TextAlign>
												<Border>
													<Style>Solid</Style>
													<Color>White</Color>
												</Border>
											</Style>
											<CanGrow>true</CanGrow>
											<Paragraphs>
												<Paragraph>
													<TextRuns>
														<TextRun>
															<Value>Solicitante</Value>
														</TextRun>
													</TextRuns>
												</Paragraph>
											</Paragraphs>
										</Textbox>
									</CellContents>
								</TablixCell>
								<TablixCell>
									<CellContents>
										<Textbox Name="HeaderMascota">
											<Style>
												<BackgroundColor>#F39C12</BackgroundColor>
												<Color>White</Color>
												<FontWeight>Bold</FontWeight>
												<TextAlign>Center</TextAlign>
												<Border>
													<Style>Solid</Style>
													<Color>White</Color>
												</Border>
											</Style>
											<CanGrow>true</CanGrow>
											<Paragraphs>
												<Paragraph>
													<TextRuns>
														<TextRun>
															<Value>Mascota</Value>
														</TextRun>
													</TextRuns>
												</Paragraph>
											</Paragraphs>
										</Textbox>
									</CellContents>
								</TablixCell>
								<TablixCell>
									<CellContents>
										<Textbox Name="HeaderEstado">
											<Style>
												<BackgroundColor>#F39C12</BackgroundColor>
												<Color>White</Color>
												<FontWeight>Bold</FontWeight>
												<TextAlign>Center</TextAlign>
												<Border>
													<Style>Solid</Style>
													<Color>White</Color>
												</Border>
											</Style>
											<CanGrow>true</CanGrow>
											<Paragraphs>
												<Paragraph>
													<TextRuns>
														<TextRun>
															<Value>Estado</Value>
														</TextRun>
													</TextRuns>
												</Paragraph>
											</Paragraphs>
										</Textbox>
									</CellContents>
								</TablixCell>
								<TablixCell>
									<CellContents>
										<Textbox Name="HeaderPuntaje">
											<Style>
												<BackgroundColor>#F39C12</BackgroundColor>
												<Color>White</Color>
												<FontWeight>Bold</FontWeight>
												<TextAlign>Center</TextAlign>
												<Border>
													<Style>Solid</Style>
													<Color>White</Color>
												</Border>
											</Style>
											<CanGrow>true</CanGrow>
											<Paragraphs>
												<Paragraph>
													<TextRuns>
														<TextRun>
															<Value>Puntaje</Value>
														</TextRun>
													</TextRuns>
												</Paragraph>
											</Paragraphs>
										</Textbox>
									</CellContents>
								</TablixCell>
								<TablixCell>
									<CellContents>
										<Textbox Name="HeaderResultado">
											<Style>
												<BackgroundColor>#F39C12</BackgroundColor>
												<Color>White</Color>
												<FontWeight>Bold</FontWeight>
												<TextAlign>Center</TextAlign>
												<Border>
													<Style>Solid</Style>
													<Color>White</Color>
												</Border>
											</Style>
											<CanGrow>true</CanGrow>
											<Paragraphs>
												<Paragraph>
													<TextRuns>
														<TextRun>
															<Value>Resultado</Value>
														</TextRun>
													</TextRuns>
												</Paragraph>
											</Paragraphs>
										</Textbox>
									</CellContents>
								</TablixCell>
								<TablixCell>
									<CellContents>
										<Textbox Name="HeaderEvaluador">
											<Style>
												<BackgroundColor>#F39C12</BackgroundColor>
												<Color>White</Color>
												<FontWeight>Bold</FontWeight>
												<TextAlign>Center</TextAlign>
												<Border>
													<Style>Solid</Style>
													<Color>White</Color>
												</Border>
											</Style>
											<CanGrow>true</CanGrow>
											<Paragraphs>
												<Paragraph>
													<TextRuns>
														<TextRun>
															<Value>Evaluador</Value>
														</TextRun>
													</TextRuns>
												</Paragraph>
											</Paragraphs>
										</Textbox>
									</CellContents>
								</TablixCell>
								<TablixCell>
									<CellContents>
										<Textbox Name="HeaderVivienda">
											<Style>
												<BackgroundColor>#F39C12</BackgroundColor>
												<Color>White</Color>
												<FontWeight>Bold</FontWeight>
												<TextAlign>Center</TextAlign>
												<Border>
													<Style>Solid</Style>
													<Color>White</Color>
												</Border>
											</Style>
											<CanGrow>true</CanGrow>
											<Paragraphs>
												<Paragraph>
													<TextRuns>
														<TextRun>
															<Value>Vivienda</Value>
														</TextRun>
													</TextRuns>
												</Paragraph>
											</Paragraphs>
										</Textbox>
									</CellContents>
								</TablixCell>
								<TablixCell>
									<CellContents>
										<Textbox Name="HeaderDias">
											<Style>
												<BackgroundColor>#F39C12</BackgroundColor>
												<Color>White</Color>
												<FontWeight>Bold</FontWeight>
												<TextAlign>Center</TextAlign>
												<Border>
													<Style>Solid</Style>
													<Color>White</Color>
												</Border>
