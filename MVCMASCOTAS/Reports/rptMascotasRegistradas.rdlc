	<ReportParameters>
		<ReportParameter Name="FechaGeneracion">
			<DataType>String</DataType>
			<DefaultValue>
				<Values>
					<Value></Value>
				</Values>
			</DefaultValue>
			<Prompt>FechaGeneracion</Prompt>
		</ReportParameter>
		<ReportParameter Name="Usuario">
			<DataType>String</DataType>
			<DefaultValue>
				<Values>
					<Value></Value>
				</Values>
			</DefaultValue>
