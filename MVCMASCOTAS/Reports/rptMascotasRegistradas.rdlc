				<Paragraphs>
					<Paragraph>
						<TextRuns>
							<TextRun>
								<Value>=("Especie: " &amp; Parameters!FiltroEspecie.Value &amp; "  |  Estado: " &amp; Parameters!FiltroEstado.Value &amp; "  |  Total: " &amp; Parameters!TotalRegistros.Value &amp; "  |  Perros: " &amp; Parameters!TotalPerros.Value &amp; "  |  Gatos: " &amp; Parameters!TotalGatos.Value &amp; "  |  Disponibles: " &amp; Parameters!TotalDisponibles.Value)</Value>
							</TextRun>
						</TextRuns>
					</Paragraph>
				</Paragraphs>
			</Textbox>

