		</ReportParameter>
		<ReportParameter Name="FiltroEspecie">
			<DataType>String</DataType>
			<DefaultValue>
				<Values>
					<Value>Todas</Value>
				</Values>
			</DefaultValue>
			<Prompt>FiltroEspecie</Prompt>
		</ReportParameter>
		<ReportParameter Name="FiltroEstado">
			<DataType>String</DataType>
			<DefaultValue>
				<Values>
