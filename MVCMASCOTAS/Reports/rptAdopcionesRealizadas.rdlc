                      <CellContents>
                        <Textbox Name="EspecieRaza">
                          <CanGrow>true</CanGrow>
                          <Paragraphs>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Value>=(Fields!EspecieMascota.Value &amp; " - " &amp; Fields!RazaMascota.Value)</Value>
                                  <Style />
                                </TextRun>
                              </TextRuns>
                              <Style />
                            </Paragraph>
                          </Paragraphs>
