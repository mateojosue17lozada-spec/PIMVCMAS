<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2008/01/reportdefinition"
        xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner">
	<ReportParameters>
		<ReportParameter Name="FechaGeneracion">
			<DataType>String</DataType>
			<DefaultValue>
				<Values>
					<Value></Value>
				</Values>
			</DefaultValue>
			<Prompt>FechaGeneracion</Prompt>
		</ReportParameter>
		<ReportParameter Name="Usuario">
			<DataType>String</DataType>
			<DefaultValue>
				<Values>
					<Value></Value>
				</Values>
			</DefaultValue>
			<Prompt>Usuario</Prompt>
		</ReportParameter>
		<ReportParameter Name="FechaInicio">
			<DataType>String</DataType>
			<DefaultValue>
				<Values>
					<Value>Todos</Value>
				</Values>
			</DefaultValue>
			<Prompt>FechaInicio</Prompt>
		</ReportParameter>
		<ReportParameter Name="FechaFin">
			<DataType>String</DataType>
			<DefaultValue>
				<Values>
					<Value>Todos</Value>
				</Values>
			</DefaultValue>
			<Prompt>FechaFin</Prompt>
		</ReportParameter>
		<ReportParameter Name="TotalRegistros">
			<DataType>String</DataType>
			<DefaultValue>
				<Values>
					<Value>0</Value>
				</Values>
			</DefaultValue>
			<Prompt>TotalRegistros</Prompt>
		</ReportParameter>
		<ReportParameter Name="TotalAdopciones">
			<DataType>String</DataType>
			<DefaultValue>
				<Values>
					<Value>0</Value>
				</Values>
			</DefaultValue>
			<Prompt>TotalAdopciones</Prompt>
		</ReportParameter>
	</ReportParameters>
	<DataSources>
		<DataSource Name="DataSetAdopciones">
			<ConnectionProperties>
				<DataProvider>System.Data.DataSet</DataProvider>
				<ConnectString>/* Local Connection */</ConnectString>
			</ConnectionProperties>
			<rd:DataSourceID>00000000-0000-0000-0000-000000000001</rd:DataSourceID>
		</DataSource>
	</DataSources>
	<DataSets>
		<DataSet Name="DataSetAdopciones">
			<Query>
				<DataSourceName>DataSetAdopciones</DataSourceName>
				<CommandText>/* Local Query */</CommandText>
			</Query>
			<Fields>
				<Field Name="NumeroContrato">
					<DataField>NumeroContrato</DataField>
					<rd:TypeName>System.String</rd:TypeName>
				</Field>
				<Field Name="FechaAdopcion">
					<DataField>FechaAdopcion</DataField>
					<rd:TypeName>System.DateTime</rd:TypeName>
				</Field>
				<Field Name="FechaSolicitud">
					<DataField>FechaSolicitud</DataField>
					<rd:TypeName>System.DateTime</rd:TypeName>
				</Field>
				<Field Name="NombreMascota">
					<DataField>NombreMascota</DataField>
					<rd:TypeName>System.String</rd:TypeName>
				</Field>
				<Field Name="EspecieMascota">
					<DataField>EspecieMascota</DataField>
					<rd:TypeName>System.String</rd:TypeName>
				</Field>
				<Field Name="RazaMascota">
					<DataField>RazaMascota</DataField>
					<rd:TypeName>System.String</rd:TypeName>
				</Field>
				<Field Name="SexoMascota">
					<DataField>SexoMascota</DataField>
					<rd:TypeName>System.String</rd:TypeName>
				</Field>
				<Field Name="EdadMascota">
					<DataField>EdadMascota</DataField>
					<rd:TypeName>System.String</rd:TypeName>
				</Field>
				<Field Name="NombreAdoptante">
					<DataField>NombreAdoptante</DataField>
					<rd:TypeName>System.String</rd:TypeName>
				</Field>
				<Field Name="CedulaAdoptante">
					<DataField>CedulaAdoptante</DataField>
					<rd:TypeName>System.String</rd:TypeName>
				</Field>
				<Field Name="TelefonoAdoptante">
					<DataField>TelefonoAdoptante</DataField>
					<rd:TypeName>System.String</rd:TypeName>
				</Field>
				<Field Name="EmailAdoptante">
					<DataField>EmailAdoptante</DataField>
					<rd:TypeName>System.String</rd:TypeName>
				</Field>
				<Field Name="CiudadAdoptante">
					<DataField>CiudadAdoptante</DataField>
					<rd:TypeName>System.String</rd:TypeName>
				</Field>
				<Field Name="EstadoSolicitud">
					<DataField>EstadoSolicitud</DataField>
					<rd:TypeName>System.String</rd:TypeName>
				</Field>
				<Field Name="PuntajeEvaluacion">
					<DataField>PuntajeEvaluacion</DataField>
					<rd:TypeName>System.Nullable`1[System.Int32]</rd:TypeName>
				</Field>
				<Field Name="ResultadoEvaluacion">
					<DataField>ResultadoEvaluacion</DataField>
					<rd:TypeName>System.String</rd:TypeName>
				</Field>
				<Field Name="EvaluadoPor">
					<DataField>EvaluadoPor</DataField>
					<rd:TypeName>System.String</rd:TypeName>
				</Field>
				<Field Name="VeterinarioAsignado">
					<DataField>VeterinarioAsignado</DataField>
					<rd:TypeName>System.String</rd:TypeName>
				</Field>
			</Fields>
		</DataSet>
	</DataSets>
	<Body>
		<Height>20cm</Height>
		<Style />
		<ReportItems>

			<!-- ENCABEZADO -->
			<Textbox Name="Titulo">
				<CanGrow>true</CanGrow>
				<Top>0cm</Top>
				<Left>0cm</Left>
				<Width>19cm</Width>
				<Height>1.2cm</Height>
				<Style>
					<BackgroundColor>#3498DB</BackgroundColor>
					<Color>White</Color>
					<FontSize>16pt</FontSize>
					<FontWeight>Bold</FontWeight>
					<PaddingLeft>8pt</PaddingLeft>
					<PaddingTop>6pt</PaddingTop>
					<Border>
						<Style>None</Style>
					</Border>
				</Style>
				<Paragraphs>
					<Paragraph>
						<TextRuns>
							<TextRun>
								<Value>REPORTE DE ADOPCIONES REALIZADAS</Value>
							</TextRun>
						</TextRuns>
					</Paragraph>
				</Paragraphs>
			</Textbox>

			<Textbox Name="InfoFiltros">
				<CanGrow>true</CanGrow>
				<Top>1.3cm</Top>
				<Left>0cm</Left>
				<Width>19cm</Width>
				<Height>0.7cm</Height>
				<Style>
					<BackgroundColor>#ECF0F1</BackgroundColor>
					<FontSize>9pt</FontSize>
					<Color>#555555</Color>
					<PaddingLeft>8pt</PaddingLeft>
					<PaddingTop>4pt</PaddingTop>
					<Border>
						<Style>None</Style>
					</Border>
				</Style>
				<Paragraphs>
					<Paragraph>
						<TextRuns>
							<TextRun>
								<Value>=("Período: " &amp; Parameters!FechaInicio.Value &amp; " al " &amp; Parameters!FechaFin.Value &amp; "   |   Total: " &amp; Parameters!TotalAdopciones.Value &amp; "   |   Generado: " &amp; Parameters!FechaGeneracion.Value &amp; " por " &amp; Parameters!Usuario.Value)</Value>
							</TextRun>
						</TextRuns>
					</Paragraph>
				</Paragraphs>
			</Textbox>

			<!-- TABLA DE DATOS -->
			<Tablix Name="TablixAdopciones">
				<DataSetName>DataSetAdopciones</DataSetName>
				<Top>2.3cm</Top>
				<Left>0cm</Left>
				<Width>19cm</Width>
				<TablixBody>
					<TablixColumns>
						<TablixColumn>
							<Width>2.5cm</Width>
						</TablixColumn>
						<TablixColumn>
							<Width>2.2cm</Width>
						</TablixColumn>
						<TablixColumn>
							<Width>2.5cm</Width>
						</TablixColumn>
						<TablixColumn>
							<Width>2cm</Width>
						</TablixColumn>
						<TablixColumn>
							<Width>3.5cm</Width>
