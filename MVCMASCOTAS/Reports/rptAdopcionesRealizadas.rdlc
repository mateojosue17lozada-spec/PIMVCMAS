				</TablixColumnHierarchy>
				<TablixRowHierarchy>
					<TablixMembers>
						<TablixMember>
							<KeepWithGroup>After</KeepWithGroup>
						</TablixMember>
						<TablixMember>
							<Group Name="GrupoAdopciones">
								<GroupExpressions>
									<GroupExpression>=Fields!NumeroContrato.Value</GroupExpression>
								</GroupExpressions>
							</Group>
						</TablixMember>
					</TablixMembers>
				</TablixRowHierarchy>
			</Tablix>

			<!-- PIE -->
			<Textbox Name="Pie">
				<CanGrow>true</CanGrow>
				<Top>19cm</Top>
				<Left>0cm</Left>
				<Width>19cm</Width>
				<Height>0.7cm</Height>
				<Style>
					<BackgroundColor>#ECF0F1</BackgroundColor>
					<Color>#7F8C8D</Color>
					<FontSize>9pt</FontSize>
					<TextAlign>Center</TextAlign>
					<PaddingTop>4pt</PaddingTop>
					<Border>
						<Style>Solid</Style>
						<Color>#3498DB</Color>
					</Border>
				</Style>
				<Paragraphs>
					<Paragraph>
						<TextRuns>
							<TextRun>
								<Value>=("Página " &amp; Globals!PageNumber &amp; " de " &amp; Globals!TotalPages &amp; "   |   ADOPTAMANIA Refugio de Animales")</Value>
							</TextRun>
						</TextRuns>
					</Paragraph>
				</Paragraphs>
			</Textbox>

		</ReportItems>
	</Body>
	<Width>19cm</Width>
	<Page>
		<PageHeight>29.7cm</PageHeight>
		<PageWidth>21cm</PageWidth>
		<LeftMargin>1cm</LeftMargin>
		<RightMargin>1cm</RightMargin>
		<TopMargin>1cm</TopMargin>
		<BottomMargin>1cm</BottomMargin>
		<Style />
	</Page>
	<Language>es-EC</Language>
	<rd:ReportUnitType>Cm</rd:ReportUnitType>
</Report>