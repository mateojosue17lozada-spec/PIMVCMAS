						</TablixRow>
						<!-- Fila de datos -->
						<TablixRow>
							<Height>0.6cm</Height>
							<TablixCells>
								<TablixCell>
									<CellContents>
										<Textbox Name="D1">
											<CanGrow>true</CanGrow>
											<Paragraphs>
												<Paragraph>
													<TextRuns>
														<TextRun>
															<Value>=Fields!NumeroContrato.Value</Value>
														</TextRun>
													</TextRuns>
												</Paragraph>
											</Paragraphs>
											<Style>
												<Border>
													<Style>Solid</Style>
													<Color>#D5D8DC</Color>
												</Border>
												<FontSize>8pt</FontSize>
												<PaddingLeft>3pt</PaddingLeft>
												<BackgroundColor>=IIF(RowNumber(Nothing) Mod 2 = 0, "#EBF5FB", "White")</BackgroundColor>
											</Style>
										</Textbox>
									</CellContents>
								</TablixCell>
								<TablixCell>
									<CellContents>
										<Textbox Name="D2">
											<CanGrow>true</CanGrow>
