                              <Style>Solid</Style>
                            </Border>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="PuntajeEvaluacion">
                          <CanGrow>true</CanGrow>
                          <Paragraphs>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Value>=IIF(IsNothing(Fields!PuntajeEvaluacion.Value), "N/A", CStr(Fields!PuntajeEvaluacion.Value) &amp; "%")</Value>
                                  <Style />
                                </TextRun>
                              </TextRuns>
                              <Style />
                            </Paragraph>
                          </Paragraphs>
                          <Style>
                            <Border>
                              <Color>#bdc3c7</Color>
                              <Style>Solid</Style>
                            </Border>
                            <FontWeight>Bold</FontWeight>
                            <TextAlign>Center</TextAlign>
                            <Color>=IIF(Fields!PuntajeEvaluacion.Value &gt;= 80, "Green", IIF(Fields!PuntajeEvaluacion.Value &gt;= 60, "Orange", "Red"))</Color>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="Veterinario">
                          <CanGrow>true</CanGrow>
                          <Paragraphs>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
