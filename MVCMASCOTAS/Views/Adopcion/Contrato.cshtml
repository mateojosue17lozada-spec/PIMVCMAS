@model MVCMASCOTAS.Models.SolicitudAdopcion

@{
    ViewBag.Title = "Contrato de Adopción - ADOPTAMANÍA";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Hero Section (solo pantalla) -->
<section class="contract-hero py-4 no-print">
    <div class="container">
        <div class="d-flex flex-wrap justify-content-between align-items-center">
            <div>
                <h1 class="h2 text-brown mb-1">
                    <i class="fas fa-file-contract text-green me-2"></i>Contrato de Adopción
                </h1>
                <p class="text-secondary mb-0">Contrato de adopción #@Model.SolicitudId</p>
            </div>
            <div class="mt-2 mt-sm-0">
                <a href="@Url.Action("MisSolicitudes", "Adopcion")" class="btn btn-outline-green">
                    <i class="fas fa-arrow-left me-2"></i>Volver
                </a>
            </div>
        </div>
    </div>
</section>

<!-- Contrato (imprimible) -->
<section class="py-4">
    <div class="container">
        <div class="contract-card">
            <div class="contract-header text-center">
                <h2 class="text-brown">CONTRATO DE ADOPCIÓN DE MASCOTA</h2>
                <p class="text-green fw-medium">ADOPTAMANÍA</p>
                <p class="text-secondary">Fecha: @DateTime.Now.ToString("dd/MM/yyyy")</p>
            </div>

            <div class="contract-section">
                <h5><i class="fas fa-user me-2"></i>1. PARTES DEL CONTRATO</h5>
                <p><strong class="text-green">EL REFUGIO:</strong> ADOPTAMANÍA, con domicilio en @ViewBag.DireccionRefugio</p>
                <p><strong class="text-green">EL ADOPTANTE:</strong> @Model.Usuarios.NombreCompleto, con cédula @Model.Usuarios.Cedula, domiciliado en @Model.Usuarios.Direccion</p>
            </div>

            <div class="contract-section">
                <h5><i class="fas fa-paw me-2"></i>2. OBJETO DEL CONTRATO</h5>
                <p>El presente contrato tiene por objeto la adopción de la mascota identificada como:</p>
                <ul class="pet-data">
                    <li><span class="label">Nombre:</span> <span class="value">@Model.Mascotas.Nombre</span></li>
                    <li><span class="label">Especie:</span> <span class="value">@Model.Mascotas.Especie</span></li>
                    <li><span class="label">Raza:</span> <span class="value">@Model.Mascotas.Raza</span></li>
                    <li><span class="label">Sexo:</span> <span class="value">@Model.Mascotas.Sexo</span></li>
                    <li><span class="label">Edad Aproximada:</span> <span class="value">@Model.Mascotas.EdadAproximada</span></li>
                </ul>
            </div>

            <div class="contract-section">
                <h5><i class="fas fa-list-check me-2"></i>3. OBLIGACIONES DEL ADOPTANTE</h5>
                <ol>
                    <li>Proporcionar alimentación adecuada y agua fresca diariamente.</li>
                    <li>Brindar atención veterinaria cuando sea necesario.</li>
                    <li>Mantener al día las vacunas y desparasitaciones.</li>
                    <li>Proporcionar un ambiente seguro y adecuado para la mascota.</li>
                    <li>No abandonar, maltratar o ceder la mascota sin autorización del refugio.</li>
                    <li>Permitir visitas de seguimiento por parte del refugio.</li>
                    <li>Notificar al refugio en caso de pérdida, enfermedad grave o fallecimiento.</li>
                    <li>Esterilizar a la mascota si aún no lo está (dentro de 60 días).</li>
                </ol>
            </div>

            <div class="contract-section">
                <h5><i class="fas fa-scale-balanced me-2"></i>4. DERECHOS DEL REFUGIO</h5>
                <ol>
                    <li>Realizar visitas de seguimiento durante el primer año.</li>
                    <li>Recuperar la mascota en caso de incumplimiento del contrato.</li>
                    <li>Solicitar informes sobre el estado de la mascota.</li>
                </ol>
            </div>

            <div class="contract-section">
                <h5><i class="fas fa-file-signature me-2"></i>5. CLÁUSULAS ESPECIALES</h5>
                @if (!string.IsNullOrEmpty(Model.Observaciones))
                {
                    <div class="special-clause">
                        <i class="fas fa-exclamation-circle text-green me-2"></i>
                        <span>@Model.Observaciones</span>
                    </div>
                }
                else
                {
                    <p class="text-secondary">No se aplican cláusulas especiales adicionales a las ya mencionadas.</p>
                }
            </div>

            <div class="contract-section">
                <h5><i class="fas fa-check-circle me-2"></i>6. ACEPTACIÓN</h5>
                <p>El adoptante declara haber leído y comprendido todas las cláusulas del presente contrato y se compromete a cumplirlas fielmente.</p>
            </div>

            <!-- Firmas -->
            <div class="signatures">
                <div class="signature-box">
                    <div class="signature-line"></div>
                    <p class="fw-bold text-brown">@Model.Usuarios.NombreCompleto</p>
                    <p class="text-secondary">Firma del Adoptante</p>
                    <p class="text-secondary small">C.I.: @Model.Usuarios.Cedula</p>
                </div>
                <div class="signature-box">
                    <div class="signature-line"></div>
                    <p class="fw-bold text-brown">Representante Legal</p>
                    <p class="text-secondary">Firma del Refugio</p>
                    <p class="text-secondary small">ADOPTAMANÍA</p>
                </div>
            </div>
        </div>

        <!-- Botones de acción (solo pantalla) -->
        <div class="action-buttons no-print text-center mt-4">
            <button onclick="window.print()" class="btn btn-green btn-lg mx-2 my-2">
                <i class="fas fa-print me-2"></i>Imprimir Contrato
            </button>
            <a href="@Url.Action("DescargarContrato", "Adopcion", new { id = Model.SolicitudId })" class="btn btn-yellow btn-lg mx-2 my-2">
                <i class="fas fa-download me-2"></i>Descargar PDF
            </a>
            <a href="@Url.Action("MisSolicitudes", "Adopcion")" class="btn btn-outline-green btn-lg mx-2 my-2">
                <i class="fas fa-arrow-left me-2"></i>Volver a Solicitudes
            </a>
        </div>
    </div>
</section>

@section Styles {
    <style>
        :root {
            --green: #97C78B;
            --yellow: #F2C66D;
            --pink: #FBCDC0;
            --brown: #2F2F2F;
            --bg-light: #F2E9D8;
            --beige: #F5E6D3;
            --text-secondary: #555555;
        }

        body {
            background-color: var(--beige);
        }

        /* Hero */
        .contract-hero {
            background-color: var(--beige);
            border-radius: 0 0 30px 30px;
            margin-bottom: 1rem;
        }

        /* Tarjeta del contrato */
        .contract-card {
            background: white;
            border-radius: 24px;
            padding: 2.5rem;
            box-shadow: 0 15px 35px rgba(151,199,139,0.15);
            border: 1px solid var(--green);
            max-width: 900px;
            margin: 0 auto;
        }

        .contract-header {
            border-bottom: 2px solid var(--green);
            padding-bottom: 1.5rem;
            margin-bottom: 2rem;
        }

        .contract-section {
            margin-bottom: 2rem;
            padding-bottom: 1rem;
            border-bottom: 1px dashed var(--bg-light);
        }

            .contract-section:last-child {
                border-bottom: none;
                margin-bottom: 0;
            }

            .contract-section h5 {
                color: var(--brown);
                margin-bottom: 1.2rem;
                font-size: 1.2rem;
                background-color: rgba(151,199,139,0.05);
                padding: 0.6rem 1rem;
                border-radius: 12px;
                border-left: 4px solid var(--green);
            }

        .pet-data {
            list-style: none;
            padding: 0;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 0.8rem;
        }

            .pet-data li {
                background-color: var(--bg-light);
                padding: 0.5rem 1rem;
                border-radius: 12px;
                border: 1px solid var(--green);
            }

            .pet-data .label {
                font-weight: 600;
                color: var(--brown);
                margin-right: 0.5rem;
            }

            .pet-data .value {
                color: var(--text-secondary);
            }

        ol {
            padding-left: 1.5rem;
            color: var(--text-secondary);
        }

            ol li {
                margin-bottom: 0.5rem;
            }

        .special-clause {
            background-color: var(--bg-light);
            border-left: 4px solid var(--green);
            padding: 1rem;
            border-radius: 12px;
            color: var(--brown);
        }

        /* Firmas */
        .signatures {
            display: flex;
            justify-content: space-around;
            margin-top: 3rem;
            gap: 2rem;
            flex-wrap: wrap;
        }

        .signature-box {
            text-align: center;
            min-width: 250px;
        }

        .signature-line {
            border-top: 2px solid var(--brown);
            width: 250px;
            margin: 0 auto 1rem;
            padding-top: 0.5rem;
        }

        /* Botones */
        .btn-green {
            background-color: var(--green);
            border: none;
            border-radius: 50px;
            padding: 0.6rem 2rem;
            font-weight: 500;
            transition: all 0.3s;
            color: white;
        }

            .btn-green:hover {
                background-color: #86b57a;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(151,199,139,0.4);
            }

        .btn-yellow {
            background-color: var(--yellow);
            border: none;
            border-radius: 50px;
            padding: 0.6rem 2rem;
            font-weight: 500;
            transition: all 0.3s;
            color: var(--brown);
        }

            .btn-yellow:hover {
                background-color: #e6b85c;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(242,198,109,0.4);
            }

        .btn-outline-green {
            border: 2px solid var(--green);
            background: transparent;
            color: var(--green);
            border-radius: 50px;
            padding: 0.6rem 2rem;
            font-weight: 500;
            transition: all 0.3s;
        }

            .btn-outline-green:hover {
                background-color: var(--green);
                color: white;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(151,199,139,0.3);
            }

        /* Estilos para impresión */
        @@media print {
            body {
                background-color: white;
                padding: 0.5in;
            }

            .no-print {
                display: none !important;
            }

            .contract-card {
                box-shadow: none;
                border: 1px solid #ccc;
                padding: 1.5rem;
            }

            .contract-section h5 {
                background-color: transparent;
                border-left-color: #000;
            }

            .signature-line {
                border-top-color: #000;
            }

            .text-green, .text-brown {
                color: black !important;
            }
        }

        /* Responsive */
        @@media (max-width: 768px) {
            .contract-card {
                padding: 1.5rem;
            }

            .pet-data {
                grid-template-columns: 1fr;
            }

            .signatures {
                flex-direction: column;
                align-items: center;
            }
        }
    </style>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function () {
            console.log('Vista Contrato de Adopción cargada');

            // Confirmación antes de descargar PDF
            $('a[href*="DescargarContrato"]').click(function (e) {
                e.preventDefault();
                var href = $(this).attr('href');

                Swal.fire({
                    title: '¿Descargar contrato?',
                    text: 'Se generará un archivo PDF del contrato de adopción.',
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonColor: '#F2C66D',
                    cancelButtonColor: '#97C78B',
                    confirmButtonText: '<i class="fas fa-download"></i> Sí, descargar',
                    cancelButtonText: '<i class="fas fa-times"></i> Cancelar'
                }).then((result) => {
                    if (result.isConfirmed) {
                        window.location.href = href;
                    }
                });
            });

            // Confirmación antes de imprimir
            $('button[onclick*="print"]').click(function (e) {
                e.preventDefault();

                Swal.fire({
                    title: '¿Imprimir contrato?',
                    html: `<p class="text-brown">¿Está listo para imprimir el contrato de adopción?</p>
                          <div class="alert alert-green border-green mt-2">
                              <small><i class="fas fa-info-circle text-green"></i> Asegúrese de que la impresora esté configurada correctamente.</small>
                          </div>`,
                    icon: 'info',
                    showCancelButton: true,
                    confirmButtonColor: '#97C78B',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: '<i class="fas fa-print"></i> Imprimir',
                    cancelButtonText: '<i class="fas fa-times"></i> Cancelar'
                }).then((result) => {
                    if (result.isConfirmed) {
                        window.print();
                    }
                });
            });

            @if (TempData["SuccessMessage"] != null)
            {
                <text>
                Swal.fire({
                    icon: 'success',
                    title: '¡Éxito!',
                    text: '@Html.Raw(TempData["SuccessMessage"])',
                    confirmButtonColor: '#97C78B',
                    timer: 3000
                });
                </text>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <text>
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: '@Html.Raw(TempData["ErrorMessage"])',
                    confirmButtonColor: '#FBCDC0'
                });
                </text>
            }
        });
    </script>
}