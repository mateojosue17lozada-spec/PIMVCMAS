@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function () {
            console.log('Vista Detalles de Solicitud cargada');

            // Obtener token AntiForgery (por si se usa en algún AJAX futuro)
            function getAntiForgeryToken() {
                var tokenInput = $('#__AjaxAntiForgeryForm input[name="__RequestVerificationToken"]').first();
                if (tokenInput.length > 0) return tokenInput.val();
                tokenInput = $('input[name="__RequestVerificationToken"]').first();
                if (tokenInput.length > 0) return tokenInput.val();
                return null;
            }
            var antiForgeryToken = getAntiForgeryToken();

            // Confirmación para cancelar solicitud con SweetAlert2
            $('#cancelarModal').on('show.bs.modal', function (e) {
                var modal = $(this);
                modal.find('form').off('submit').on('submit', function (event) {
                    event.preventDefault();

                    var motivo = modal.find('textarea[name="motivoCancelacion"]').val();
                    if (!motivo.trim()) {
                        Swal.fire({
                            icon: 'warning',
                            title: 'Motivo requerido',
                            text: 'Por favor, ingrese el motivo de la cancelación.',
                            confirmButtonColor: '#F2C66D'
                        });
                        return;
                    }

                    Swal.fire({
                        title: '¿Cancelar solicitud?',
                        html: `<p class="text-brown">¿Está seguro de cancelar esta solicitud de adopción?</p>
                              <div class="alert alert-beige border-green mt-2">
                                  <small><i class="fas fa-exclamation-circle text-green"></i> Esta acción no se puede deshacer</small>
                              </div>`,
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonColor: '#FBCDC0',
                        cancelButtonColor: '#97C78B',
                        confirmButtonText: '<i class="fas fa-times"></i> Sí, cancelar',
                        cancelButtonText: '<i class="fas fa-times"></i> No cancelar'
                    }).then((result) => {
                        if (result.isConfirmed) {
                            modal.find('button[type="submit"]').prop('disabled', true)
                                .html('<i class="fas fa-spinner fa-spin me-2"></i> Cancelando...');
                            setTimeout(() => {
                                event.target.submit();
                            }, 500);
                        }
                    });
                });
            });

            // Notificaciones de TempData
            @if (TempData["SuccessMessage"] != null)
            {
                <text>
                Swal.fire({
                    icon: 'success',
                    title: '¡Éxito!',
                    text: '@Html.Raw(TempData["SuccessMessage"])',
                    confirmButtonColor: '#97C78B',
                    timer: 3000
                });
                </text>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <text>
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: '@Html.Raw(TempData["ErrorMessage"])',
                    confirmButtonColor: '#FBCDC0'
                });
                </text>
            }
        });
    </script>
}