@model MVCMASCOTAS.Models.SolicitudAdopcion

@{
    ViewBag.Title = "Detalles de Solicitud - ADOPTAMANÍA";
    Layout = "~/Views/Shared/_Layout.cshtml";

    // VALIDACIÓN CRÍTICA - Si el modelo es null, muestra error
    if (Model == null)
    {
        <div class="alert alert-beige border-green fade-in-up">
            <h4 class="text-brown"><i class="fas fa-exclamation-triangle text-green"></i> Solicitud no encontrada</h4>
            <p class="text-brown">La solicitud que intentas ver no existe o ha sido eliminada.</p>
            <a href="@Url.Action("MisSolicitudes", "Adopcion")" class="btn btn-green mt-2">
                <i class="fas fa-arrow-left me-2"></i> Volver a mis solicitudes
            </a>
        </div>
        return;
    }

    // Variables seguras con validaciones
    var mascota = Model.Mascotas;
    var formulario = Model.FormularioAdopcionDetalle?.FirstOrDefault();
    var tieneMascota = mascota != null;
    var tieneFormulario = formulario != null;
    var tieneImagenMascota = tieneMascota && mascota.ImagenPrincipal != null && mascota.ImagenPrincipal.Length > 0;

    // Manejo seguro de estados
    var estado = Model.Estado ?? "Desconocido";
    var resultadoEvaluacion = Model.ResultadoEvaluacion ?? "";
    var observaciones = Model.Observaciones ?? "";
    var motivoRechazo = Model.MotivoRechazo ?? "";
}

<!-- Hero Section (simple) -->
<section class="details-hero py-4">
    <div class="container">
        <div class="d-flex flex-wrap justify-content-between align-items-center">
            <div>
                <h1 class="h2 text-brown mb-1">
                    <i class="fas fa-file-alt text-green me-2"></i>Detalles de Solicitud de Adopción
                </h1>
                <p class="text-secondary mb-0">Solicitud #@Model.SolicitudId</p>
            </div>
            <div class="mt-2 mt-sm-0">
                <a href="@Url.Action("MisSolicitudes", "Adopcion")" class="btn btn-outline-green">
                    <i class="fas fa-arrow-left me-2"></i>Volver
                </a>
            </div>
        </div>
    </div>
</section>

<!-- Main Content -->
<section class="py-4 bg-beige">
    <div class="container">
        <div class="row g-4">
            <!-- Columna Principal -->
            <div class="col-md-8">
                <!-- Mascota Solicitada -->
                <div class="info-card mb-4">
                    <div class="info-card-header bg-green text-white">
                        <i class="fas fa-paw me-2"></i>Mascota Solicitada
                    </div>
                    <div class="info-card-body">
                        @if (tieneMascota)
                        {
                            <div class="row g-3">
                                <div class="col-md-4">
                                    @if (tieneImagenMascota)
                                    {
                                        <img src="data:image/jpeg;base64,@Convert.ToBase64String(mascota.ImagenPrincipal)"
                                             class="img-fluid rounded-3 border-green shadow-sm"
                                             alt="@mascota.Nombre"
                                             style="max-height: 250px; object-fit: cover; width: 100%;" />
                                    }
                                    else
                                    {
                                        <div class="bg-light-mint rounded-3 d-flex align-items-center justify-content-center border-green"
                                             style="height: 250px;">
                                            <i class="fas fa-paw fa-3x text-secondary"></i>
                                        </div>
                                    }
                                </div>
                                <div class="col-md-8">
                                    <h4 class="text-brown mb-3">@mascota.Nombre</h4>
                                    <div class="row">
                                        <div class="col-md-6">
                                            <p class="text-brown mb-2"><strong><i class="fas fa-paw text-green me-2"></i>Especie:</strong> @(mascota.Especie ?? "N/A")</p>
                                            <p class="text-brown mb-2"><strong><i class="fas fa-dog text-green me-2"></i>Raza:</strong> @(mascota.Raza ?? "Mestizo")</p>
                                            <p class="text-brown mb-2"><strong><i class="fas fa-venus-mars text-green me-2"></i>Sexo:</strong> @(mascota.Sexo == "M" ? "Macho" : (mascota.Sexo == "F" ? "Hembra" : "N/A"))</p>
                                        </div>
                                        <div class="col-md-6">
                                            <p class="text-brown mb-2"><strong><i class="fas fa-birthday-cake text-green me-2"></i>Edad:</strong> @(mascota.EdadAproximada ?? "N/A")</p>
                                            <p class="text-brown mb-2"><strong><i class="fas fa-ruler text-green me-2"></i>Tamaño:</strong> @(mascota.Tamanio ?? "N/A")</p>
                                            <p class="text-brown mb-2"><strong><i class="fas fa-palette text-green me-2"></i>Color:</strong> @(mascota.Color ?? "N/A")</p>
                                        </div>
                                    </div>

                                    @if (!string.IsNullOrEmpty(mascota.DescripcionGeneral))
                                    {
                                        <hr class="border-green" />
                                        <div class="alert alert-beige border-green">
                                            <i class="fas fa-info-circle text-green me-2"></i>
                                            <span class="text-brown">@mascota.DescripcionGeneral</span>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-beige border-green">
                                <i class="fas fa-exclamation-triangle text-green me-2"></i>
                                <span class="text-brown">La información de la mascota no está disponible.</span>
                            </div>
                        }
                    </div>
                </div>

                <!-- Formulario de Adopción -->
                @if (tieneFormulario)
                {
                    <div class="info-card mb-4">
                        <div class="info-card-header bg-green text-white">
                            <i class="fas fa-clipboard-check me-2"></i>Tu Formulario de Adopción
                        </div>
                        <div class="info-card-body">
                            <!-- Vivienda -->
                            <h6 class="border-bottom pb-2 mb-3 text-brown">
                                <i class="fas fa-home text-green me-2"></i>Información de Vivienda
                            </h6>
                            <div class="row mb-4">
                                <div class="col-md-6">
                                    <p class="text-brown"><strong>Tipo de vivienda:</strong> @(formulario.TipoVivienda ?? "No especificado")</p>
                                    <p class="text-brown"><strong>¿Vivienda propia?:</strong> @(formulario.ViviendaPropia == true ? "Sí" : (formulario.ViviendaPropia == false ? "No" : "No especificado"))</p>
                                    <p class="text-brown"><strong>¿Tiene jardín?:</strong> @(formulario.TieneJardin == true ? "Sí" : (formulario.TieneJardin == false ? "No" : "No especificado"))</p>
                                </div>
                                <div class="col-md-6">
                                    @if (formulario.TieneJardin == true)
                                    {
                                        <p class="text-brown"><strong>Tamaño del jardín:</strong> @(formulario.TamanioJardin ?? "No especificado")</p>
                                    }
                                    <p class="text-brown"><strong>Personas en casa:</strong> @(formulario.PersonasEnCasa?.ToString() ?? "No especificado")</p>
                                    <p class="text-brown"><strong>¿Hay niños?:</strong> @(formulario.HayNinios == true ? "Sí" : (formulario.HayNinios == false ? "No" : "No especificado"))</p>
                                </div>
                            </div>

                            <!-- Experiencia -->
                            <h6 class="border-bottom pb-2 mb-3 text-brown">
                                <i class="fas fa-paw text-green me-2"></i>Experiencia con Mascotas
                            </h6>
                            <div class="row mb-4">
                                <div class="col-md-12">
                                    <p class="text-brown"><strong>¿Experiencia previa?:</strong> @(formulario.ExperienciaPreviaConMascotas == true ? "Sí" : (formulario.ExperienciaPreviaConMascotas == false ? "No" : "No especificado"))</p>
                                    @if (formulario.ExperienciaPreviaConMascotas == true && !string.IsNullOrEmpty(formulario.DetalleExperiencia))
                                    {
                                        <div class="alert alert-beige border-green">
                                            <strong class="text-brown">Detalle:</strong> <span class="text-brown">@formulario.DetalleExperiencia</span>
                                        </div>
                                    }

                                    <p class="text-brown"><strong>¿Tiene mascotas actualmente?:</strong> @(formulario.TieneMascotasActualmente == true ? "Sí" : (formulario.TieneMascotasActualmente == false ? "No" : "No especificado"))</p>
                                    @if (formulario.TieneMascotasActualmente == true)
                                    {
                                        <ul class="list-unstyled">
                                            @if (formulario.CantidadPerros > 0)
                                            {
                                                <li class="text-brown mb-1"><i class="fas fa-dog text-green me-2"></i>Perros: @formulario.CantidadPerros</li>
                                            }
                                            @if (formulario.CantidadGatos > 0)
                                            {
                                                <li class="text-brown mb-1"><i class="fas fa-cat text-green me-2"></i>Gatos: @formulario.CantidadGatos</li>
                                            }
                                            @if (!string.IsNullOrEmpty(formulario.OtrasMascotas))
                                            {
                                                <li class="text-brown mb-1"><i class="fas fa-paw text-green me-2"></i>Otros: @formulario.OtrasMascotas</li>
                                            }
                                        </ul>
                                    }
                                </div>
                            </div>

                            <!-- Motivo -->
                            @if (!string.IsNullOrEmpty(formulario.MotivoAdopcion))
                            {
                                <h6 class="border-bottom pb-2 mb-3 text-brown">
                                    <i class="fas fa-heart text-green me-2"></i>Motivo de Adopción
                                </h6>
                                <div class="alert alert-beige border-green mb-4">
                                    <span class="text-brown">@formulario.MotivoAdopcion</span>
                                </div>
                            }

                            <!-- Compromisos -->
                            <h6 class="border-bottom pb-2 mb-3 text-brown">
                                <i class="fas fa-handshake text-green me-2"></i>Compromisos Aceptados
                            </h6>
                            <ul class="list-unstyled">
                                <li class="text-brown mb-2">
                                    <i class="fas @(formulario.AceptaEsterilizacion == true ? "fa-check-circle text-green" : "fa-times-circle text-pink") me-2"></i>
                                    Esterilización
                                </li>
                                <li class="text-brown mb-2">
                                    <i class="fas @(formulario.AceptaVisitasSeguimiento == true ? "fa-check-circle text-green" : "fa-times-circle text-pink") me-2"></i>
                                    Visitas de seguimiento
                                </li>
                                <li class="text-brown mb-2">
                                    <i class="fas @(formulario.AceptaCondicionesLOBA == true ? "fa-check-circle text-green" : "fa-times-circle text-pink") me-2"></i>
                                    Condiciones LOBA
                                </li>
                                <li class="text-brown">
                                    <i class="fas @(formulario.AceptaDevolucionSiNoPuedeAtender == true ? "fa-check-circle text-green" : "fa-times-circle text-pink") me-2"></i>
                                    Devolución si no puede atender
                                </li>
                            </ul>
                        </div>
                    </div>
                }
                else
                {
                    <div class="alert alert-beige border-green mb-4">
                        <i class="fas fa-info-circle text-green me-2"></i>
                        <span class="text-brown">No se encontró información del formulario de adopción.</span>
                    </div>
                }

                <!-- Observaciones o Mensajes -->
                @if (!string.IsNullOrEmpty(observaciones))
                {
                    <div class="info-card mb-4">
                        <div class="info-card-header @(estado == "Aprobada" ? "bg-green" : (estado == "Rechazada" ? "bg-pink" : "bg-green")) @(estado == "Rechazada" ? "text-brown" : "text-white")">
                            <i class="fas @(estado == "Aprobada" ? "fa-check-circle" : (estado == "Rechazada" ? "fa-times-circle" : "fa-info-circle")) me-2"></i>
                            @(estado == "Aprobada" ? "Mensaje de Aprobación" :
                              estado == "Rechazada" ? "Información sobre el Rechazo" :
                              "Observaciones")
                        </div>
                        <div class="info-card-body">
                            <p class="mb-0 text-brown">@observaciones</p>
                        </div>
                    </div>
                }

                @if (!string.IsNullOrEmpty(motivoRechazo))
                {
                    <div class="info-card mb-4">
                        <div class="info-card-header bg-yellow">
                            <i class="fas fa-exclamation-triangle me-2"></i>Motivo del Rechazo
                        </div>
                        <div class="info-card-body">
                            <p class="mb-0 text-brown">@motivoRechazo</p>
                        </div>
                    </div>
                }
            </div>

            <!-- Columna Lateral -->
            <div class="col-md-4">
                <!-- Estado de la Solicitud -->
                <div class="state-card mb-4">
                    <div class="state-card-header @(estado == "Aprobada" ? "bg-green" :
                                                   estado == "Rechazada" ? "bg-pink" :
                                                   estado == "En evaluación" ? "bg-yellow" :
                                                   estado == "Pendiente" ? "bg-green" :
                                                   "bg-secondary") @(estado == "Rechazada" ? "text-brown" : "text-white")">
                        <i class="fas fa-clipboard-check me-2"></i>Estado de la Solicitud
                    </div>
                    <div class="state-card-body text-center">
                        <div class="mb-3">
                            @{
                                string estadoBadgeClass = estado == "Aprobada" ? "bg-green" :
                                                          estado == "Rechazada" ? "bg-pink" :
                                                          estado == "En evaluación" ? "bg-yellow" :
                                                          estado == "Pendiente" ? "bg-green" : "bg-secondary";
                                string estadoTextColor = estado == "Rechazada" ? "text-brown" : "text-white";
                            }
                            <span class="badge @estadoBadgeClass px-4 py-3 @estadoTextColor" style="font-size: 1.2rem;">
                                @if (estado == "Aprobada")
                                {
                                    <i class="fas fa-check-circle me-2"></i>
                                }
                                else if (estado == "Rechazada")
                                {
                                    <i class="fas fa-times-circle me-2"></i>
                                }
                                else if (estado == "En evaluación")
                                {
                                    <i class="fas fa-clock me-2"></i>
                                }
                                else
                                {
                                    <i class="fas fa-hourglass-half me-2"></i>
                                }
                                @estado
                            </span>
                        </div>

                        @if (!string.IsNullOrEmpty(resultadoEvaluacion))
                        {
                            <p class="mb-2 text-brown">
                                <strong>Resultado:</strong>
                                <span class="badge bg-light-mint text-brown border-green px-3 py-2">@resultadoEvaluacion</span>
                            </p>
                        }

                        @if (Model.PuntajeEvaluacion.HasValue)
                        {
                            <div class="mb-3">
                                <strong class="text-brown">Puntaje de Evaluación:</strong>
                                <div class="display-4 @(Model.PuntajeEvaluacion >= 80 ? "text-green" :
                                                       Model.PuntajeEvaluacion >= 60 ? "text-yellow" :
                                                       "text-pink")">
                                    @Model.PuntajeEvaluacion.Value
                                </div>
                                <small class="text-secondary">de 100 puntos</small>
                            </div>
                        }

                        <hr class="border-green" />

                        <div class="text-start">
                            <p class="text-brown mb-3">
                                <strong><i class="fas fa-calendar-alt text-green me-2"></i>Fecha de solicitud:</strong><br />
                                @(Model.FechaSolicitud?.ToString("dd/MM/yyyy HH:mm") ?? "N/A")
                            </p>

                            @if (Model.FechaEvaluacion.HasValue)
                            {
                                <p class="text-brown mb-3">
                                    <strong><i class="fas fa-calendar-check text-green me-2"></i>Fecha de evaluación:</strong><br />
                                    @Model.FechaEvaluacion.Value.ToString("dd/MM/yyyy HH:mm")
                                </p>
                            }

                            @if (Model.FechaRespuesta.HasValue)
                            {
                                <p class="text-brown mb-3">
                                    <strong><i class="fas fa-calendar-alt text-green me-2"></i>Fecha de respuesta:</strong><br />
                                    @Model.FechaRespuesta.Value.ToString("dd/MM/yyyy HH:mm")
                                </p>
                            }
                        </div>

                        @if (estado == "Aprobada")
                        {
                            <div class="alert alert-beige border-green mt-3 text-start">
                                <i class="fas fa-heart text-green me-2"></i>
                                <strong class="text-brown">¡Felicidades!</strong>
                                <p class="mb-0 small text-brown">Pronto nos pondremos en contacto contigo para coordinar la entrega.</p>
                            </div>
                        }
                        else if (estado == "Rechazada")
                        {
                            <div class="alert alert-beige border-green mt-3 text-start">
                                <i class="fas fa-info-circle text-green me-2"></i>
                                <p class="mb-0 small text-brown">No te desanimes. Puedes solicitar la adopción de otra mascota.</p>
                            </div>
                        }
                        else if (estado == "Pendiente" || estado == "En evaluación")
                        {
                            <div class="alert alert-beige border-green mt-3 text-start">
                                <i class="fas fa-clock text-green me-2"></i>
                                <p class="mb-0 small text-brown">Estamos evaluando tu solicitud. Te contactaremos pronto.</p>
                            </div>
                        }
                    </div>
                </div>

                <!-- Información de Contacto -->
                <div class="info-card mb-4">
                    <div class="info-card-header bg-green text-white">
                        <i class="fas fa-phone-alt me-2"></i>Información de Contacto
                    </div>
                    <div class="info-card-body">
                        <p class="small text-secondary mb-3">Si tienes preguntas sobre tu solicitud, contáctanos:</p>
                        <p class="mb-3 text-brown">
                            <i class="fas fa-envelope text-green me-2"></i>
                            <strong>Email:</strong><br />
                            <a href="mailto:adopciones@adoptamania.ec" class="text-green">adopciones@adoptamania.ec</a>
                        </p>
                        <p class="mb-3 text-brown">
                            <i class="fas fa-phone text-green me-2"></i>
                            <strong>Teléfono:</strong><br />
                            <a href="tel:+593999999999" class="text-green">+593 99 999 9999</a>
                        </p>
                        <p class="mb-0 text-brown">
                            <i class="fas fa-clock text-green me-2"></i>
                            <strong>Horario:</strong><br />
                            Lun - Vie: 9:00 AM - 5:00 PM
                        </p>
                    </div>
                </div>

                <!-- Acciones Rápidas -->
                <div class="info-card">
                    <div class="info-card-header bg-green text-white">
                        <i class="fas fa-cog me-2"></i>Acciones
                    </div>
                    <div class="info-card-body d-flex flex-column gap-2">
                        <a href="@Url.Action("MisSolicitudes", "Adopcion")" class="btn btn-green">
                            <i class="fas fa-list me-2"></i>Ver Mis Solicitudes
                        </a>

                        @if (tieneMascota)
                        {
                            <a href="@Url.Action("Detalle", "Mascotas", new { id = Model.MascotaId })" class="btn btn-outline-green">
                                <i class="fas fa-paw me-2"></i>Ver Mascota
                            </a>
                        }

                        @if (estado == "Rechazada" || estado == "Cancelada")
                        {
                            <a href="@Url.Action("Index", "Mascotas")" class="btn btn-green">
                                <i class="fas fa-heart me-2"></i>Buscar Otra Mascota
                            </a>
                        }

                        @if (estado == "Pendiente" || estado == "En evaluación")
                        {
                            <button type="button" class="btn btn-pink" data-bs-toggle="modal" data-bs-target="#cancelarModal">
                                <i class="fas fa-times me-2"></i>Cancelar Solicitud
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Modal para Cancelar -->
<div class="modal fade" id="cancelarModal" tabindex="-1" aria-labelledby="cancelarModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            @using (Html.BeginForm("CancelarSolicitud", "Adopcion", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                <input type="hidden" name="solicitudId" value="@Model.SolicitudId" />
                <div class="modal-header bg-pink">
                    <h5 class="modal-title text-brown" id="cancelarModalLabel">
                        <i class="fas fa-exclamation-triangle me-2"></i>Cancelar Solicitud
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    @if (tieneMascota)
                    {
                        <p class="text-brown">¿Está seguro que desea cancelar la solicitud para adoptar a <strong>@mascota.Nombre</strong>?</p>
                    }
                    else
                    {
                        <p class="text-brown">¿Está seguro que desea cancelar esta solicitud de adopción?</p>
                    }
                    <div class="mb-3">
                        <label for="motivoCancelacion" class="form-label text-brown">Motivo de cancelación:</label>
                        <textarea class="form-control border-green" name="motivoCancelacion" rows="3" required
                                  placeholder="Por favor, indique el motivo de la cancelación"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-green" data-bs-dismiss="modal">
                        <i class="fas fa-times me-2"></i>No cancelar
                    </button>
                    <button type="submit" class="btn btn-pink">
                        <i class="fas fa-check me-2"></i>Sí, cancelar solicitud
                    </button>
                </div>
            }
        </div>
    </div>
</div>

<!-- Formulario oculto para AntiForgeryToken (usado por AJAX) -->
<form id="__AjaxAntiForgeryForm" method="post">@Html.AntiForgeryToken()</form>

@section Styles {
    <style>
        :root {
            --green: #97C78B;
            --yellow: #F2C66D;
            --pink: #FBCDC0;
            --brown: #2F2F2F;
            --bg-light: #F2E9D8;
            --beige: #F5E6D3;
            --text-secondary: #555555;
        }

        body {
            background-color: var(--beige);
        }

        /* Hero */
        .details-hero {
            background-color: var(--beige);
            border-radius: 0 0 30px 30px;
            margin-bottom: 1rem;
        }

        /* Tarjetas de información */
        .info-card {
            background: white;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 15px 35px rgba(151,199,139,0.15);
            border: none;
        }

        .info-card-header {
            padding: 1rem 1.5rem;
            font-weight: 600;
            font-size: 1.1rem;
        }

        .info-card-body {
            padding: 1.5rem;
        }

        /* Tarjeta de estado */
        .state-card {
            background: white;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 15px 35px rgba(151,199,139,0.15);
            border: none;
        }

        .state-card-header {
            padding: 1rem 1.5rem;
            font-weight: 600;
            font-size: 1.1rem;
        }

        .state-card-body {
            padding: 1.5rem;
        }

        /* Badges */
        .badge.bg-green {
            background-color: var(--green) !important;
            color: white !important;
        }

        .badge.bg-yellow {
            background-color: var(--yellow) !important;
            color: var(--brown) !important;
        }

        .badge.bg-pink {
            background-color: var(--pink) !important;
            color: var(--brown) !important;
        }

        .badge.bg-light-mint {
            background-color: var(--bg-light) !important;
            color: var(--brown) !important;
            border: 1px solid var(--green);
        }

        /* Alertas */
        .alert-beige {
            background-color: var(--bg-light);
            border: 1px solid var(--green);
            color: var(--brown);
            border-radius: 16px;
        }

        /* Botones */
        .btn-green {
            background-color: var(--green);
            border: none;
            border-radius: 50px;
            padding: 0.6rem 1.8rem;
            font-weight: 500;
