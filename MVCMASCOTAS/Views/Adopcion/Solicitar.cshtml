@model MVCMASCOTAS.Models.ViewModels.SolicitudAdopcionViewModel

@{
    ViewBag.Title = "Solicitar Adopción";
}

<div class="row justify-content-center">
    <div class="col-md-10">
        <div class="alert alert-info">
            <h4><i class="fas fa-info-circle"></i> Proceso de Adopción</h4>
            <p>Estás a punto de solicitar la adopción de <strong>@ViewBag.NombreMascota</strong>. Por favor completa el siguiente formulario con información veraz y detallada.</p>
            <p>Nuestro equipo revisará tu solicitud y te contactaremos en un plazo de 3 a 5 días hábiles.</p>
        </div>

        <div class="card shadow-custom">
            <div class="card-header">
                <h3><i class="fas fa-file-alt"></i> Formulario de Adopción</h3>
            </div>
            <div class="card-body">
                @using (Html.BeginForm("Solicitar", "Adopcion", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(m => m.MascotaId)
                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                    <h5 class="border-bottom pb-2 mb-3">
                        <i class="fas fa-home"></i> Información de Vivienda
                    </h5>

                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label>Tipo de Vivienda *</label>
                                @Html.DropDownList("TipoVivienda", new SelectList(new[] {
                                    "Casa", "Departamento", "Finca/Quinta", "Otro"
                                }), "Seleccionar...", new { @class = "form-control", required = "required" })
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="form-check mt-4">
                                @Html.CheckBox("ViviendaPropia", false, new { @class = "form-check-input" })
                                <label class="form-check-label">Vivienda Propia</label>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="form-check mt-4">
                                @Html.CheckBox("TieneJardin", false, new { @class = "form-check-input" })
                                <label class="form-check-label">Tiene Jardín/Patio</label>
                            </div>
                        </div>
                    </div>

                    <div id="tamanio-jardin" style="display: none;">
                        <div class="form-group">
                            <label>Tamaño del Jardín/Patio</label>
                            @Html.DropDownList("TamanioJardin", new SelectList(new[] {
                                "Pequeño (< 50m²)", "Mediano (50-100m²)", "Grande (> 100m²)"
                            }), "Seleccionar...", new { @class = "form-control" })
                        </div>
                    </div>

                    <div class="form-check mb-3">
                        @Html.CheckBox("PermisoMascotas", false, new { @class = "form-check-input", required = "required" })
                        <label class="form-check-label">
                            <strong>* Tengo permiso del propietario/condominio para tener mascotas</strong>
                        </label>
                    </div>

                    <h5 class="border-bottom pb-2 mb-3 mt-4">
                        <i class="fas fa-users"></i> Composición del Hogar
                    </h5>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>Número de Personas en el Hogar *</label>
                                @Html.TextBox("PersonasEnCasa", "", new { @class = "form-control", type = "number", min = "1", required = "required" })
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-check mt-4">
                                @Html.CheckBox("HayNinios", false, new { @class = "form-check-input" })
                                <label class="form-check-label">Hay niños en el hogar</label>
                            </div>
                        </div>
                    </div>

                    <div id="edades-ninios" style="display: none;">
                        <div class="form-group">
                            <label>Edades de los niños</label>
                            @Html.TextBox("EdadesNinios", "", new { @class = "form-control", placeholder = "Ej: 5, 8 y 12 años" })
                        </div>
                    </div>

                    <h5 class="border-bottom pb-2 mb-3 mt-4">
                        <i class="fas fa-paw"></i> Experiencia con Mascotas
                    </h5>

                    <div class="form-check mb-3">
                        @Html.CheckBox("ExperienciaPreviaConMascotas", false, new { @class = "form-check-input" })
                        <label class="form-check-label">Tengo experiencia previa con mascotas</label>
                    </div>

                    <div id="detalle-experiencia" style="display: none;">
                        <div class="form-group">
                            <label>Describe tu experiencia previa *</label>
                            @Html.TextArea("DetalleExperiencia", new { @class = "form-control", rows = "3", required = "required", placeholder = "Describe las mascotas que has tenido anteriormente..." })
                        </div>
                    </div>

                    <div class="form-check mb-3">
                        @Html.CheckBox("TieneMascotasActualmente", false, new { @class = "form-check-input" })
                        <label class="form-check-label">Actualmente tengo otras mascotas</label>
                    </div>

                    <div id="mascotas-actuales" style="display: none;">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label>Cantidad de Perros</label>
                                    @Html.TextBox("CantidadPerros", "0", new { @class = "form-control", type = "number", min = "0" })
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label>Cantidad de Gatos</label>
                                    @Html.TextBox("CantidadGatos", "0", new { @class = "form-control", type = "number", min = "0" })
                                </div>
                            </div>
                        </div>

                        <div class="form-group">
                            <label>Otras mascotas</label>
                            @Html.TextBox("OtrasMascotas", "", new { @class = "form-control", placeholder = "Ej: Conejos, pájaros, etc." })
                        </div>

                        <div class="form-check mb-3">
                            @Html.CheckBox("MascotasEsterilizadas", false, new { @class = "form-check-input" })
                            <label class="form-check-label">Mis mascotas están esterilizadas</label>
                        </div>
                    </div>

                    <h5 class="border-bottom pb-2 mb-3 mt-4">
                        <i class="fas fa-clock"></i> Disponibilidad y Compromiso
                    </h5>

                    <div class="form-group">
                        <label>Tiempo disponible para la mascota diariamente *</label>
                        @Html.DropDownList("TiempoDisponibleDiario", new SelectList(new[] {
                            "Menos de 1 hora", "1-2 horas", "2-4 horas", "4+ horas", "Todo el día"
                        }), "Seleccionar...", new { @class = "form-control", required = "required" })
                    </div>

                    <div class="form-group">
                        <label>¿Quién cuidará de la mascota durante el día? *</label>
                        @Html.TextArea("QuienCuidaraMascota", new { @class = "form-control", rows = "2", required = "required", placeholder = "Ej: Yo trabajo desde casa, mi esposa/o, etc." })
                    </div>

                    <h5 class="border-bottom pb-2 mb-3 mt-4">
                        <i class="fas fa-question-circle"></i> Preguntas Importantes
                    </h5>

                    <div class="form-group">
                        <label>¿Por qué deseas adoptar esta mascota? *</label>
                        @Html.TextArea("MotivoAdopcion", new { @class = "form-control", rows = "3", maxlength = "500", required = "required", placeholder = "Explícanos por qué quieres adoptar a esta mascota en particular..." })
                        <small class="form-text text-muted">Mínimo 50 caracteres</small>
                    </div>

                    <div class="form-group">
                        <label>¿Qué harías si cambias de residencia? *</label>
                        @Html.TextArea("QuePasaSiCambiaResidencia", new { @class = "form-control", rows = "2", required = "required", placeholder = "Describe tus planes si te mudas..." })
                    </div>

                    <div class="form-group">
                        <label>¿Qué harías ante problemas de comportamiento? *</label>
                        @Html.TextArea("QuePasaSiProblemasComportamiento", new { @class = "form-control", rows = "2", required = "required", placeholder = "Ej: Consultaría con un veterinario, buscaría entrenamiento..." })
                    </div>

                    <h5 class="border-bottom pb-2 mb-3 mt-4">
                        <i class="fas fa-user-md"></i> Referencias Veterinarias
                    </h5>

                    <div class="form-group">
                        <label>Veterinario de referencia (opcional)</label>
                        @Html.TextBox("VeterinarioReferencia", "", new { @class = "form-control", placeholder = "Nombre del veterinario o clínica" })
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>Referencia personal 1 *</label>
                                @Html.TextBox("ReferenciaPersonal1", "", new { @class = "form-control", required = "required", placeholder = "Nombre completo" })
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>Teléfono referencia 1 *</label>
                                @Html.TextBox("TelefonoReferencia1", "", new { @class = "form-control", required = "required", placeholder = "0999999999" })
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>Referencia personal 2 (opcional)</label>
                                @Html.TextBox("ReferenciaPersonal2", "", new { @class = "form-control", placeholder = "Nombre completo" })
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>Teléfono referencia 2 (opcional)</label>
                                @Html.TextBox("TelefonoReferencia2", "", new { @class = "form-control", placeholder = "0999999999" })
                            </div>
                        </div>
                    </div>

                    <h5 class="border-bottom pb-2 mb-3 mt-4">
                        <i class="fas fa-gavel"></i> Compromisos Legales
                    </h5>

                    <div class="form-check mb-3">
                        @Html.CheckBox("AceptaEsterilizacion", false, new { @class = "form-check-input", required = "required" })
                        <label class="form-check-label">
                            <strong>* Acepto esterilizar a la mascota si aún no lo está</strong>
                        </label>
                    </div>

                    <div class="form-check mb-3">
                        @Html.CheckBox("AceptaVisitasSeguimiento", false, new { @class = "form-check-input", required = "required" })
                        <label class="form-check-label">
                            <strong>* Acepto visitas de seguimiento del refugio</strong>
                        </label>
                    </div>

                    <div class="form-check mb-3">
                        @Html.CheckBox("AceptaCondicionesLOBA", false, new { @class = "form-check-input", required = "required" })
                        <label class="form-check-label">
                            <strong>* Acepto las condiciones establecidas en la Ley Orgánica de Bienestar Animal</strong>
                        </label>
                    </div>

                    <div class="form-check mb-3">
                        @Html.CheckBox("AceptaDevolucionSiNoPuedeAtender", false, new { @class = "form-check-input", required = "required" })
                        <label class="form-check-label">
                            <strong>* Me comprometo a devolver la mascota al refugio si no puedo continuar atendiéndola</strong>
                        </label>
                    </div>

                    <div class="alert alert-warning mt-4">
                        <i class="fas fa-exclamation-triangle"></i> <strong>Importante:</strong> La información proporcionada será verificada. Proporcionar información falsa resultará en el rechazo automático de la solicitud.
                    </div>

                    <div class="form-group mt-4">
                        <button type="submit" class="btn btn-success btn-lg btn-block">
                            <i class="fas fa-paper-plane"></i> Enviar Solicitud
                        </button>
                        <a href="@Url.Action("Detalle", "Mascotas", new { id = Model.MascotaId })" class="btn btn-secondary btn-lg btn-block">
                            <i class="fas fa-times"></i> Cancelar
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
    <script>
        $(document).ready(function () {
            // Mostrar/ocultar tamaño del jardín
            $('#TieneJardin').change(function () {
                if ($(this).is(':checked')) {
                    $('#tamanio-jardin').slideDown();
                } else {
                    $('#tamanio-jardin').slideUp();
                }
            });

            // Mostrar/ocultar edades de niños
            $('#HayNinios').change(function () {
                if ($(this).is(':checked')) {
                    $('#edades-ninios').slideDown();
                } else {
                    $('#edades-ninios').slideUp();
                }
            });

            // Mostrar/ocultar detalle de experiencia
            $('#ExperienciaPreviaConMascotas').change(function () {
                if ($(this).is(':checked')) {
                    $('#detalle-experiencia').slideDown();
                } else {
                    $('#detalle-experiencia').slideUp();
                }
            });

            // Mostrar/ocultar sección de mascotas actuales
            $('#TieneMascotasActualmente').change(function () {
                if ($(this).is(':checked')) {
                    $('#mascotas-actuales').slideDown();
                } else {
                    $('#mascotas-actuales').slideUp();
                }
            });

            // Validación antes de enviar
            $('form').submit(function (e) {
                var isValid = true;
                var mensaje = '';

                // Validar motivo de adopción (mínimo 50 caracteres)
                var motivo = $('#MotivoAdopcion').val();
                if (motivo.length < 50) {
                    mensaje += 'El motivo de adopción debe tener al menos 50 caracteres.\n';
                    isValid = false;
                }

                // Validar si tiene experiencia previa, debe tener detalle
                if ($('#ExperienciaPreviaConMascotas').is(':checked')) {
                    var detalle = $('#DetalleExperiencia').val();
                    if (!detalle || detalle.trim() === '') {
                        mensaje += 'Debe describir su experiencia previa con mascotas.\n';
                        isValid = false;
                    }
                }

                if (!isValid) {
                    alert('Por favor corrija los siguientes errores:\n\n' + mensaje);
                    e.preventDefault();
                }
            });
        });
    </script>
}