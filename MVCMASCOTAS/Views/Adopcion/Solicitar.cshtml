@model MVCMASCOTAS.Models.ViewModels.SolicitudAdopcionViewModel

@{
    ViewBag.Title = "Solicitar Adopción";
}

<div class="row justify-content-center">
    <div class="col-md-10">
        <div class="alert alert-info">
            <h4><i class="fas fa-info-circle"></i> Proceso de Adopción</h4>
            <p>Estás a punto de solicitar la adopción de <strong>@ViewBag.NombreMascota</strong>. Por favor completa el siguiente formulario con información veraz y detallada.</p>
            <p>Nuestro equipo revisará tu solicitud y te contactaremos en un plazo de 3 a 5 días hábiles.</p>
        </div>

        <div class="card shadow-custom">
            <div class="card-header">
                <h3><i class="fas fa-file-alt"></i> Formulario de Adopción</h3>
            </div>
            <div class="card-body">
                @using (Html.BeginForm("Solicitar", "Adopcion", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(m => m.MascotaId)
                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                    <h5 class="border-bottom pb-2 mb-3">
                        <i class="fas fa-home"></i> Información de Vivienda
                    </h5>

                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label>Tipo de Vivienda *</label>
                                @Html.DropDownListFor(m => m.TipoVivienda, new SelectList(new[] {
                                    "Casa", "Departamento", "Finca/Quinta", "Otro"
                                }), "Seleccionar...", new { @class = "form-control", required = "required" })
                                @Html.ValidationMessageFor(m => m.TipoVivienda, "", new { @class = "text-danger" })
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="form-check mt-4">
                                @Html.CheckBoxFor(m => m.ViviendaPropia, new { @class = "form-check-input" })
                                <label class="form-check-label">Vivienda Propia</label>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="form-check mt-4">
                                @Html.CheckBoxFor(m => m.TieneJardin, new { @class = "form-check-input" })
                                <label class="form-check-label">Tiene Jardín/Patio</label>
                            </div>
                        </div>
                    </div>

                    <div class="form-check mb-3">
                        @Html.CheckBoxFor(m => m.PermisoMascotas, new { @class = "form-check-input", required = "required" })
                        <label class="form-check-label">
                            <strong>* Tengo permiso del propietario/condominio para tener mascotas</strong>
                        </label>
                    </div>

                    <h5 class="border-bottom pb-2 mb-3 mt-4">
                        <i class="fas fa-users"></i> Composición del Hogar
                    </h5>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>Número de Personas en el Hogar *</label>
                                @Html.TextBoxFor(m => m.NumeroPersonasHogar, new { @class = "form-control", type = "number", min = "1", required = "required" })
                                @Html.ValidationMessageFor(m => m.NumeroPersonasHogar, "", new { @class = "text-danger" })
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-check mt-4">
                                @Html.CheckBoxFor(m => m.HayNinos, new { @class = "form-check-input" })
                                <label class="form-check-label">Hay niños en el hogar</label>
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label>¿Todos están de acuerdo con la adopción? *</label>
                        @Html.DropDownListFor(m => m.TodosDeAcuerdo, new SelectList(new[] { "Sí", "No", "Algunos no" }), "Seleccionar...", new { @class = "form-control", required = "required" })
                        @Html.ValidationMessageFor(m => m.TodosDeAcuerdo, "", new { @class = "text-danger" })
                    </div>

                    <h5 class="border-bottom pb-2 mb-3 mt-4">
                        <i class="fas fa-paw"></i> Experiencia con Mascotas
                    </h5>

                    <div class="form-check mb-3">
                        @Html.CheckBoxFor(m => m.ExperienciaPreviaConMascotas, new { @class = "form-check-input" })
                        <label class="form-check-label">Tengo experiencia previa con mascotas</label>
                    </div>

                    <div class="form-check mb-3">
                        @Html.CheckBoxFor(m => m.TieneMascotasActualmente, new { @class = "form-check-input" })
                        <label class="form-check-label">Actualmente tengo otras mascotas</label>
                    </div>

                    <div id="mascotas-actuales" style="display: none;">
                        <div class="form-group">
                            <label>Describe tus mascotas actuales</label>
                            @Html.TextAreaFor(m => m.MascotasActualesDescripcion, new { @class = "form-control", rows = "2" })
                        </div>

                        <div class="form-check mb-3">
                            @Html.CheckBoxFor(m => m.MascotasEsterilizadas, new { @class = "form-check-input" })
                            <label class="form-check-label">Mis mascotas están esterilizadas</label>
                        </div>
                    </div>

                    <h5 class="border-bottom pb-2 mb-3 mt-4">
                        <i class="fas fa-clock"></i> Disponibilidad y Compromiso
                    </h5>

                    <div class="form-group">
                        <label>Tiempo disponible para la mascota diariamente *</label>
                        @Html.DropDownListFor(m => m.TiempoDisponibleDiario, new SelectList(new[] {
                            "Menos de 1 hora", "1-2 horas", "2-4 horas", "4+ horas", "Todo el día"
                        }), "Seleccionar...", new { @class = "form-control", required = "required" })
                        @Html.ValidationMessageFor(m => m.TiempoDisponibleDiario, "", new { @class = "text-danger" })
                    </div>

                    <div class="form-group">
                        <label>¿Quién cuidará de la mascota durante el día? *</label>
                        @Html.TextAreaFor(m => m.QuienCuidara, new { @class = "form-control", rows = "2", required = "required" })
                        @Html.ValidationMessageFor(m => m.QuienCuidara, "", new { @class = "text-danger" })
                    </div>

                    <h5 class="border-bottom pb-2 mb-3 mt-4">
                        <i class="fas fa-question-circle"></i> Preguntas Importantes
                    </h5>

                    <div class="form-group">
                        <label>¿Por qué deseas adoptar esta mascota? *</label>
                        @Html.TextAreaFor(m => m.MotivoAdopcion, new { @class = "form-control", rows = "3", maxlength = "500", required = "required" })
                        @Html.ValidationMessageFor(m => m.MotivoAdopcion, "", new { @class = "text-danger" })
                        <small class="form-text text-muted">Mínimo 50 caracteres</small>
                    </div>

                    <div class="form-group">
                        <label>¿Qué harías si cambias de residencia? *</label>
                        @Html.TextAreaFor(m => m.QuePasaSiCambiaResidencia, new { @class = "form-control", rows = "2", required = "required" })
                        @Html.ValidationMessageFor(m => m.QuePasaSiCambiaResidencia, "", new { @class = "text-danger" })
                    </div>

                    <div class="form-group">
                        <label>¿Qué harías ante problemas de comportamiento? *</label>
                        @Html.TextAreaFor(m => m.QuePasaSiProblemasComportamiento, new { @class = "form-control", rows = "2", required = "required" })
                        @Html.ValidationMessageFor(m => m.QuePasaSiProblemasComportamiento, "", new { @class = "text-danger" })
                    </div>

                    <div class="form-group">
                        <label>¿Cómo manejarías gastos veterinarios inesperados? *</label>
                        @Html.TextAreaFor(m => m.ComoManejariaGastosVeterinarios, new { @class = "form-control", rows = "2", required = "required" })
                        @Html.ValidationMessageFor(m => m.ComoManejariaGastosVeterinarios, "", new { @class = "text-danger" })
                    </div>

                    <h5 class="border-bottom pb-2 mb-3 mt-4">
                        <i class="fas fa-gavel"></i> Compromisos Legales
                    </h5>

                    <div class="form-check mb-3">
                        @Html.CheckBoxFor(m => m.AceptaEsterilizacion, new { @class = "form-check-input", required = "required" })
                        <label class="form-check-label">
                            <strong>* Acepto esterilizar a la mascota si aún no lo está</strong>
                        </label>
                    </div>

                    <div class="form-check mb-3">
                        @Html.CheckBoxFor(m => m.AceptaVisitasSeguimiento, new { @class = "form-check-input", required = "required" })
                        <label class="form-check-label">
                            <strong>* Acepto visitas de seguimiento del refugio</strong>
                        </label>
                    </div>

                    <div class="form-check mb-3">
                        @Html.CheckBoxFor(m => m.AceptaCondicionesLOBA, new { @class = "form-check-input", required = "required" })
                        <label class="form-check-label">
                            <strong>* Acepto las condiciones establecidas en la Ley Orgánica de Bienestar Animal</strong>
                        </label>
                    </div>

                    <div class="form-check mb-3">
                        @Html.CheckBoxFor(m => m.AceptaDevolucionSiNoPuedeAtender, new { @class = "form-check-input", required = "required" })
                        <label class="form-check-label">
                            <strong>* Me comprometo a devolver la mascota al refugio si no puedo continuar atendiéndola</strong>
                        </label>
                    </div>

                    <div class="alert alert-warning mt-4">
                        <i class="fas fa-exclamation-triangle"></i> <strong>Importante:</strong> La información proporcionada será verificada. Proporcionar información falsa resultará en el rechazo automático de la solicitud.
                    </div>

                    <div class="form-group mt-4">
                        <button type="submit" class="btn btn-success btn-lg btn-block">
                            <i class="fas fa-paper-plane"></i> Enviar Solicitud
                        </button>
                        <a href="@Url.Action("Detalle", "Mascotas", new { id = Model.MascotaId })" class="btn btn-secondary btn-lg btn-block">
                            <i class="fas fa-times"></i> Cancelar
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
    <script>
        $(document).ready(function () {
            // Mostrar/ocultar sección de mascotas actuales
            $('#TieneMascotasActualmente').change(function () {
                if ($(this).is(':checked')) {
                    $('#mascotas-actuales').slideDown();
                } else {
                    $('#mascotas-actuales').slideUp();
                }
            });

            // Trigger al cargar
            if ($('#TieneMascotasActualmente').is(':checked')) {
                $('#mascotas-actuales').show();
            }
        });
    </script>
}
