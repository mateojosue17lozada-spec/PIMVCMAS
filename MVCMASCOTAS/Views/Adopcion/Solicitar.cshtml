@model MVCMASCOTAS.Models.ViewModels.FormularioAdopcionViewModel

@{
    ViewBag.Title = "Solicitar Adopción - ADOPTAMANÍA";
    ViewData["Title"] = "Solicitar Adopción";
}

<!-- Hero Section -->
<section class="solicitar-hero py-4">
    <div class="container">
        <div class="text-center">
            <i class="fas fa-file-alt fa-3x text-green mb-3"></i>
            <h1 class="display-5 fw-bold mb-2 text-brown">Solicitar Adopción</h1>
            <p class="lead mb-3 text-secondary">Completa el formulario para adoptar a <strong class="text-green">@ViewBag.NombreMascota</strong></p>
        </div>
    </div>
</section>

<!-- Main Content -->
<section class="py-5 bg-beige">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <!-- Alerta informativa -->
                <div class="alert alert-beige border-green d-flex align-items-start mb-4">
                    <i class="fas fa-info-circle fa-2x text-green me-3 mt-1"></i>
                    <div>
                        <h4 class="text-brown mb-2">Proceso de Adopción</h4>
                        <p class="text-secondary mb-1">Estás a punto de solicitar la adopción de <strong class="text-brown">@ViewBag.NombreMascota</strong>. Por favor completa el siguiente formulario con información veraz y detallada.</p>
                        <p class="text-secondary mb-0">Nuestro equipo revisará tu solicitud y te contactaremos en un plazo de 3 a 5 días hábiles.</p>
                    </div>
                </div>

                <!-- Formulario principal -->
                <div class="form-card">
                    <div class="form-card-header bg-green text-white">
                        <i class="fas fa-file-alt me-2"></i>Formulario de Adopción
                    </div>
                    <div class="form-card-body">
                        @using (Html.BeginForm("Solicitar", "Adopcion", FormMethod.Post))
                        {
                            @Html.AntiForgeryToken()
                            @Html.HiddenFor(m => m.MascotaId)
                            @Html.ValidationSummary(true, "", new { @class = "alert alert-beige border-green" })

                            <!-- Información de Vivienda -->
                            <h5 class="section-title">
                                <i class="fas fa-home text-green me-2"></i>Información de Vivienda
                            </h5>

                            <div class="row g-3 mb-3">
                                <div class="col-md-4">
                                    <label class="form-label text-brown fw-medium">Tipo de Vivienda *</label>
                                    @Html.DropDownListFor(m => m.TipoVivienda, new SelectList(new[] {
                                        "Casa", "Departamento", "Finca/Quinta", "Otro"
                                    }), "Seleccionar...", new { @class = "form-select border-green", required = "required" })
                                    @Html.ValidationMessageFor(m => m.TipoVivienda, "", new { @class = "text-danger small mt-1" })
                                </div>

                                <div class="col-md-4 d-flex align-items-end">
                                    <div class="form-check mb-2">
                                        @Html.CheckBoxFor(m => m.ViviendaPropia, new { @class = "form-check-input" })
                                        <label class="form-check-label text-brown">Vivienda Propia</label>
                                    </div>
                                </div>

                                <div class="col-md-4 d-flex align-items-end">
                                    <div class="form-check mb-2">
                                        @Html.CheckBoxFor(m => m.TieneJardin, new { @class = "form-check-input" })
                                        <label class="form-check-label text-brown">Tiene Jardín/Patio</label>
                                    </div>
                                </div>
                            </div>

                            <div id="tamanio-jardin" class="mb-3" style="display: none;">
                                <div class="row">
                                    <div class="col-md-6">
                                        <label class="form-label text-brown fw-medium">Tamaño del Jardín/Patio</label>
                                        @Html.DropDownListFor(m => m.TamanioJardin, new SelectList(new[] {
                                            "Pequeño (< 50m²)", "Mediano (50-100m²)", "Grande (> 100m²)"
                                        }), "Seleccionar...", new { @class = "form-select border-green" })
                                    </div>
                                </div>
                            </div>

                            <div class="form-check mb-4">
                                @Html.CheckBoxFor(m => m.PermisoMascotas, new { @class = "form-check-input", required = "required" })
                                <label class="form-check-label text-brown fw-medium">
                                    <i class="fas fa-check-circle text-green me-1"></i> Tengo permiso del propietario/condominio para tener mascotas *
                                </label>
                                @Html.ValidationMessageFor(m => m.PermisoMascotas, "", new { @class = "text-danger small d-block mt-1" })
                            </div>

                            <!-- Composición del Hogar -->
                            <h5 class="section-title mt-5">
                                <i class="fas fa-users text-green me-2"></i>Composición del Hogar
                            </h5>

                            <div class="row g-3 mb-3">
                                <div class="col-md-6">
                                    <label class="form-label text-brown fw-medium">Número de Personas en el Hogar *</label>
                                    @Html.TextBoxFor(m => m.PersonasEnCasa, new { @class = "form-control border-green", type = "number", min = "1", required = "required" })
                                    @Html.ValidationMessageFor(m => m.PersonasEnCasa, "", new { @class = "text-danger small mt-1" })
                                </div>
                                <div class="col-md-6 d-flex align-items-end">
                                    <div class="form-check mb-2">
                                        @Html.CheckBoxFor(m => m.HayNinios, new { @class = "form-check-input" })
                                        <label class="form-check-label text-brown">Hay niños en el hogar</label>
                                    </div>
                                </div>
                            </div>

                            <div id="edades-ninios" class="mb-4" style="display: none;">
                                <label class="form-label text-brown fw-medium">Edades de los niños</label>
                                @Html.TextBoxFor(m => m.EdadesNinios, new { @class = "form-control border-green", placeholder = "Ej: 5, 8 y 12 años" })
                            </div>

                            <!-- Experiencia con Mascotas -->
                            <h5 class="section-title mt-5">
                                <i class="fas fa-paw text-green me-2"></i>Experiencia con Mascotas
                            </h5>

                            <div class="form-check mb-3">
                                @Html.CheckBoxFor(m => m.ExperienciaPreviaConMascotas, new { @class = "form-check-input" })
                                <label class="form-check-label text-brown">Tengo experiencia previa con mascotas</label>
                            </div>

                            <div id="detalle-experiencia" class="mb-4" style="display: none;">
                                <label class="form-label text-brown fw-medium">Describe tu experiencia previa *</label>
                                @Html.TextAreaFor(m => m.DetalleExperiencia, new { @class = "form-control border-green", rows = "3", required = "required", placeholder = "Describe las mascotas que has tenido anteriormente..." })
                                @Html.ValidationMessageFor(m => m.DetalleExperiencia, "", new { @class = "text-danger small mt-1" })
                            </div>

                            <div class="form-check mb-3">
                                @Html.CheckBoxFor(m => m.TieneMascotasActualmente, new { @class = "form-check-input" })
                                <label class="form-check-label text-brown">Actualmente tengo otras mascotas</label>
                            </div>

                            <div id="mascotas-actuales" class="mb-4" style="display: none;">
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label class="form-label text-brown fw-medium">Cantidad de Perros</label>
                                        @Html.TextBoxFor(m => m.CantidadPerros, "0", new { @class = "form-control border-green", type = "number", min = "0" })
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label text-brown fw-medium">Cantidad de Gatos</label>
                                        @Html.TextBoxFor(m => m.CantidadGatos, "0", new { @class = "form-control border-green", type = "number", min = "0" })
                                    </div>
                                </div>
                                <div class="mt-3">
                                    <label class="form-label text-brown fw-medium">Otras mascotas</label>
                                    @Html.TextBoxFor(m => m.OtrasMascotas, new { @class = "form-control border-green", placeholder = "Ej: Conejos, pájaros, etc." })
                                </div>
                                <div class="form-check mt-3">
                                    @Html.CheckBoxFor(m => m.MascotasEsterilizadas, new { @class = "form-check-input" })
                                    <label class="form-check-label text-brown">Mis mascotas están esterilizadas</label>
                                </div>
                            </div>

                            <!-- Disponibilidad y Compromiso -->
                            <h5 class="section-title mt-5">
                                <i class="fas fa-clock text-green me-2"></i>Disponibilidad y Compromiso
                            </h5>

                            <div class="row g-3 mb-3">
                                <div class="col-md-6">
                                    <label class="form-label text-brown fw-medium">Tiempo disponible para la mascota diariamente *</label>
                                    @Html.DropDownListFor(m => m.TiempoDisponibleDiario, new SelectList(new[] {
                                        "Menos de 1 hora", "1-2 horas", "2-4 horas", "4+ horas", "Todo el día"
                                    }), "Seleccionar...", new { @class = "form-select border-green", required = "required" })
                                    @Html.ValidationMessageFor(m => m.TiempoDisponibleDiario, "", new { @class = "text-danger small mt-1" })
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label text-brown fw-medium">¿Quién cuidará de la mascota durante el día? *</label>
                                    @Html.DropDownListFor(m => m.QuienCuidaraMascota,
                                        new SelectList(Enum.GetValues(typeof(QuienCuidaraEnum))
                                            .Cast<QuienCuidaraEnum>()
                                            .Select(e => new SelectListItem
                                            {
                                                Value = e.ToString(),
                                                Text = e.GetDisplayName()
                                            }), "Value", "Text"),
                                        "Seleccionar...",
                                        new { @class = "form-select border-green", required = "required" })
                                    @Html.ValidationMessageFor(m => m.QuienCuidaraMascota, "", new { @class = "text-danger small mt-1" })
                                </div>
                            </div>

                            <div id="otro-cuidador" class="mb-4" style="display: none;">
                                <label class="form-label text-brown fw-medium">Especifique quién cuidará la mascota</label>
                                @Html.TextBoxFor(m => m.OtroQuienCuidaraMascota, new { @class = "form-control border-green", placeholder = "Ej: Vecino, empleada doméstica, etc." })
                            </div>

                            <!-- Preguntas Importantes -->
                            <h5 class="section-title mt-5">
                                <i class="fas fa-question-circle text-green me-2"></i>Preguntas Importantes
                            </h5>

                            <div class="row g-3 mb-3">
                                <div class="col-md-6">
                                    <label class="form-label text-brown fw-medium">¿Por qué deseas adoptar esta mascota? *</label>
                                    @Html.DropDownListFor(m => m.MotivoAdopcion,
                                        new SelectList(Enum.GetValues(typeof(MotivoAdopcionEnum))
                                            .Cast<MotivoAdopcionEnum>()
                                            .Select(e => new SelectListItem
                                            {
                                                Value = e.ToString(),
                                                Text = e.GetDisplayName()
                                            }), "Value", "Text"),
                                        "Seleccionar...",
                                        new { @class = "form-select border-green", required = "required" })
                                    @Html.ValidationMessageFor(m => m.MotivoAdopcion, "", new { @class = "text-danger small mt-1" })
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label text-brown fw-medium">¿Qué harías si cambias de residencia? *</label>
                                    @Html.DropDownListFor(m => m.QuePasaSiCambiaResidencia,
                                        new SelectList(Enum.GetValues(typeof(PlanCambioResidenciaEnum))
                                            .Cast<PlanCambioResidenciaEnum>()
                                            .Select(e => new SelectListItem
                                            {
                                                Value = e.ToString(),
                                                Text = e.GetDisplayName()
                                            }), "Value", "Text"),
                                        "Seleccionar...",
                                        new { @class = "form-select border-green", required = "required" })
                                    @Html.ValidationMessageFor(m => m.QuePasaSiCambiaResidencia, "", new { @class = "text-danger small mt-1" })
                                </div>
                            </div>

                            <div id="otro-motivo" class="mb-4" style="display: none;">
                                <label class="form-label text-brown fw-medium">Especifique otro motivo</label>
                                @Html.TextBoxFor(m => m.OtroMotivoAdopcion, new { @class = "form-control border-green", placeholder = "Describa su motivo..." })
                            </div>

                            <div class="mb-4">
                                <label class="form-label text-brown fw-medium">¿Qué harías ante problemas de comportamiento? *</label>
                                @Html.DropDownListFor(m => m.QuePasaSiProblemasComportamiento,
                                    new SelectList(Enum.GetValues(typeof(PlanProblemasComportamientoEnum))
                                        .Cast<PlanProblemasComportamientoEnum>()
                                        .Select(e => new SelectListItem
                                        {
                                            Value = e.ToString(),
                                            Text = e.GetDisplayName()
                                        }), "Value", "Text"),
                                    "Seleccionar...",
                                    new { @class = "form-select border-green", required = "required" })
                                @Html.ValidationMessageFor(m => m.QuePasaSiProblemasComportamiento, "", new { @class = "text-danger small mt-1" })
                            </div>

                            <!-- Referencias Veterinarias -->
                            <h5 class="section-title mt-5">
                                <i class="fas fa-user-md text-green me-2"></i>Referencias Veterinarias
                            </h5>

                            <div class="mb-4">
                                <label class="form-label text-brown fw-medium">¿Tiene veterinario de referencia?</label>
                                @Html.DropDownListFor(m => m.VeterinarioReferencia,
                                    new SelectList(Enum.GetValues(typeof(VeterinarioReferenciaEnum))
                                        .Cast<VeterinarioReferenciaEnum>()
                                        .Select(e => new SelectListItem
                                        {
                                            Value = e.ToString(),
                                            Text = e.GetDisplayName()
                                        }), "Value", "Text"),
                                    "Seleccionar...",
                                    new { @class = "form-select border-green" })
                            </div>

                            <div class="row g-3 mb-4">
                                <div class="col-md-6">
                                    <label class="form-label text-brown fw-medium">Referencia personal 1 *</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-white border-green"><i class="fas fa-user text-green"></i></span>
                                        @Html.TextBoxFor(m => m.ReferenciaPersonal1, new { @class = "form-control border-green", required = "required", placeholder = "Nombre completo" })
                                    </div>
                                    @Html.ValidationMessageFor(m => m.ReferenciaPersonal1, "", new { @class = "text-danger small mt-1" })
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label text-brown fw-medium">Teléfono referencia 1 *</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-white border-green"><i class="fas fa-phone text-green"></i></span>
                                        @Html.TextBoxFor(m => m.TelefonoReferencia1, new { @class = "form-control border-green", required = "required", placeholder = "0999999999" })
                                    </div>
                                    @Html.ValidationMessageFor(m => m.TelefonoReferencia1, "", new { @class = "text-danger small mt-1" })
                                </div>
                            </div>

                            <div class="row g-3 mb-4">
                                <div class="col-md-6">
                                    <label class="form-label text-brown fw-medium">Referencia personal 2 (opcional)</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-white border-green"><i class="fas fa-user text-green"></i></span>
                                        @Html.TextBoxFor(m => m.ReferenciaPersonal2, new { @class = "form-control border-green", placeholder = "Nombre completo" })
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label text-brown fw-medium">Teléfono referencia 2 (opcional)</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-white border-green"><i class="fas fa-phone text-green"></i></span>
                                        @Html.TextBoxFor(m => m.TelefonoReferencia2, new { @class = "form-control border-green", placeholder = "0999999999" })
                                    </div>
                                </div>
                            </div>

                            <!-- Compromisos Legales -->
                            <h5 class="section-title mt-5">
                                <i class="fas fa-gavel text-green me-2"></i>Compromisos Legales
                            </h5>

                            <div class="form-check mb-3">
                                @Html.CheckBoxFor(m => m.AceptaEsterilizacion, new { @class = "form-check-input", required = "required" })
                                <label class="form-check-label text-brown fw-medium">
                                    <i class="fas fa-check-circle text-green me-1"></i> Acepto esterilizar a la mascota si aún no lo está *
                                </label>
                                @Html.ValidationMessageFor(m => m.AceptaEsterilizacion, "", new { @class = "text-danger small d-block mt-1" })
                            </div>

                            <div class="form-check mb-3">
                                @Html.CheckBoxFor(m => m.AceptaVisitasSeguimiento, new { @class = "form-check-input", required = "required" })
                                <label class="form-check-label text-brown fw-medium">
                                    <i class="fas fa-check-circle text-green me-1"></i> Acepto visitas de seguimiento del refugio *
                                </label>
                                @Html.ValidationMessageFor(m => m.AceptaVisitasSeguimiento, "", new { @class = "text-danger small d-block mt-1" })
                            </div>

                            <div class="form-check mb-3">
                                @Html.CheckBoxFor(m => m.AceptaCondicionesLOBA, new { @class = "form-check-input", required = "required" })
                                <label class="form-check-label text-brown fw-medium">
                                    <i class="fas fa-check-circle text-green me-1"></i> Acepto las condiciones establecidas en la Ley Orgánica de Bienestar Animal *
                                </label>
                                @Html.ValidationMessageFor(m => m.AceptaCondicionesLOBA, "", new { @class = "text-danger small d-block mt-1" })
                            </div>

                            <div class="form-check mb-4">
                                @Html.CheckBoxFor(m => m.AceptaDevolucionSiNoPuedeAtender, new { @class = "form-check-input", required = "required" })
                                <label class="form-check-label text-brown fw-medium">
                                    <i class="fas fa-check-circle text-green me-1"></i> Me comprometo a devolver la mascota al refugio si no puedo continuar atendiéndola *
                                </label>
                                @Html.ValidationMessageFor(m => m.AceptaDevolucionSiNoPuedeAtender, "", new { @class = "text-danger small d-block mt-1" })
                            </div>

                            <!-- Alerta de advertencia -->
                            <div class="alert alert-beige border-yellow d-flex align-items-start mb-4">
                                <i class="fas fa-exclamation-triangle fa-2x text-yellow me-3"></i>
                                <div>
                                    <strong class="text-brown">Importante:</strong>
                                    <span class="text-secondary">La información proporcionada será verificada. Proporcionar información falsa resultará en el rechazo automático de la solicitud.</span>
                                </div>
                            </div>

                            <!-- Botones de acción -->
                            <div class="d-flex flex-column flex-md-row gap-3 mt-4">
                                <button type="submit" class="btn btn-green btn-lg flex-grow-1">
                                    <i class="fas fa-paper-plane me-2"></i>Enviar Solicitud
                                </button>
                                <a href="@Url.Action("Detalle", "Mascotas", new { id = Model.MascotaId })" class="btn btn-outline-green btn-lg flex-grow-1">
                                    <i class="fas fa-times me-2"></i>Cancelar
                                </a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Styles {
    <style>
        :root {
            --green: #97C78B;
            --yellow: #F2C66D;
            --pink: #FBCDC0;
            --brown: #2F2F2F;
            --bg-light: #F2E9D8;
            --beige: #F5E6D3;
            --text-secondary: #555555;
        }

        body {
            background-color: var(--beige);
        }

        /* Hero */
        .solicitar-hero {
            background-color: var(--beige);
            border-radius: 0 0 30px 30px;
            margin-bottom: 1rem;
        }

        /* Tarjeta del formulario */
        .form-card {
            background: white;
            border-radius: 30px;
            overflow: hidden;
            box-shadow: 0 20px 40px rgba(151,199,139,0.15);
            border: none;
        }

        .form-card-header {
            background-color: var(--green);
            color: white;
            padding: 1.5rem 2rem;
            font-weight: 600;
            font-size: 1.3rem;
        }

        .form-card-body {
            padding: 2rem;
        }

        /* Títulos de sección */
        .section-title {
            font-size: 1.2rem;
            font-weight: 600;
            color: var(--brown);
            border-bottom: 2px solid var(--green);
            padding-bottom: 0.5rem;
            margin-bottom: 1.5rem;
            display: flex;
            align-items: center;
        }

        /* Alertas personalizadas */
        .alert-beige {
            background-color: var(--bg-light);
            border: 1px solid var(--green);
            color: var(--brown);
            border-radius: 16px;
        }

        .border-yellow {
            border-color: var(--yellow) !important;
        }

        /* Formularios */
        .form-control, .form-select {
            border: 2px solid var(--green);
            border-radius: 16px;
            padding: 0.75rem 1rem;
            transition: border-color 0.2s, box-shadow 0.2s;
            background-color: white;
        }

            .form-control:focus, .form-select:focus {
                border-color: var(--green);
                box-shadow: 0 0 0 0.2rem rgba(151,199,139,0.25);
                outline: none;
            }

        /* Input group */
        .input-group-text {
            border: 2px solid var(--green);
            border-radius: 16px 0 0 16px;
            background-color: white;
        }

        .input-group .form-control {
            border-left: none;
            border-radius: 0 16px 16px 0;
        }

        /* Checkboxes */
        .form-check-input {
            width: 1.2rem;
            height: 1.2rem;
            margin-top: 0.15rem;
            border: 2px solid var(--green);
            transition: background-color 0.2s;
        }

            .form-check-input:checked {
                background-color: var(--green);
                border-color: var(--green);
            }

            .form-check-input:focus {
                border-color: var(--green);
                box-shadow: 0 0 0 0.2rem rgba(151,199,139,0.25);
            }

        /* Botones */
        .btn-green {
            background-color: var(--green);
            border: none;
            border-radius: 50px;
            padding: 0.8rem 2rem;
            font-weight: 600;
            transition: all 0.3s;
            color: white;
        }

            .btn-green:hover {
                background-color: #86b57a;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(151,199,139,0.4);
            }

        .btn-outline-green {
            border: 2px solid var(--green);
            background: transparent;
            color: var(--green);
            border-radius: 50px;
            padding: 0.8rem 2rem;
            font-weight: 600;
            transition: all 0.3s;
        }

            .btn-outline-green:hover {
                background-color: var(--green);
                color: white;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(151,199,139,0.3);
            }

        /* Etiquetas */
        .form-label {
            font-weight: 500;
            color: var(--brown);
            margin-bottom: 0.5rem;
        }

        /* Texto de error */
        .text-danger {
            color: #dc3545 !important;
        }

        /* Responsive */
        @@media (max-width: 768px) {
            .form-card-body {
                padding: 1.5rem;
            }

            .btn-lg {
                width: 100%;
            }
        }
    </style>
}

@section Scripts {
    <script src="~/Scripts/jquery.validate.min.js"></script>
    <script src="~/Scripts/jquery.validate.unobtrusive.min.js"></script>

    <script>
        $(document).ready(function () {
            console.log('Formulario de adopción cargado');

            // Mostrar/ocultar tamaño del jardín
            $('#TieneJardin').change(function () {
                if ($(this).is(':checked')) {
                    $('#tamanio-jardin').slideDown();
                } else {
                    $('#tamanio-jardin').slideUp();
                }
            });

            // Mostrar/ocultar edades de niños
            $('#HayNinios').change(function () {
                if ($(this).is(':checked')) {
                    $('#edades-ninios').slideDown();
                } else {
                    $('#edades-ninios').slideUp();
                }
            });

            // Mostrar/ocultar detalle de experiencia
            $('#ExperienciaPreviaConMascotas').change(function () {
                if ($(this).is(':checked')) {
                    $('#detalle-experiencia').slideDown();
                } else {
                    $('#detalle-experiencia').slideUp();
                }
            });

            // Mostrar/ocultar sección de mascotas actuales
            $('#TieneMascotasActualmente').change(function () {
                if ($(this).is(':checked')) {
                    $('#mascotas-actuales').slideDown();
                } else {
                    $('#mascotas-actuales').slideUp();
                }
            });

            // Mostrar/ocultar campo "Otro" para QuienCuidara
            $('#QuienCuidaraMascota').change(function () {
                if ($(this).val() === 'Otro') {
                    $('#otro-cuidador').slideDown();
                } else {
                    $('#otro-cuidador').slideUp();
                }
            });

            // Mostrar/ocultar campo "Otro" para MotivoAdopcion
            $('#MotivoAdopcion').change(function () {
                if ($(this).val() === 'Otro') {
                    $('#otro-motivo').slideDown();
                } else {
                    $('#otro-motivo').slideUp();
                }
            });

            // Validación simplificada
            $('form').submit(function (e) {
                var isValid = true;
                var mensaje = '';

                var motivo = $('#MotivoAdopcion').val();
                var cambioResidencia = $('#QuePasaSiCambiaResidencia').val();
                var problemasComportamiento = $('#QuePasaSiProblemasComportamiento').val();
                var quienCuidara = $('#QuienCuidaraMascota').val();

                if (!motivo || motivo === '') {
                    mensaje += 'Debe seleccionar un motivo de adopción.\n';
                    isValid = false;
                }

                if (!cambioResidencia || cambioResidencia === '') {
                    mensaje += 'Debe seleccionar qué haría si cambia de residencia.\n';
                    isValid = false;
                }

                if (!problemasComportamiento || problemasComportamiento === '') {
                    mensaje += 'Debe seleccionar cómo manejaría problemas de comportamiento.\n';
                    isValid = false;
                }

                if (!quienCuidara || quienCuidara === '') {
                    mensaje += 'Debe seleccionar quién cuidará a la mascota.\n';
                    isValid = false;
                }

                if (motivo === 'Otro' && !$('#OtroMotivoAdopcion').val()) {
                    mensaje += 'Debe especificar otro motivo de adopción.\n';
                    isValid = false;
                }

                if (quienCuidara === 'Otro' && !$('#OtroQuienCuidaraMascota').val()) {
                    mensaje += 'Debe especificar otro cuidador.\n';
                    isValid = false;
                }

                if ($('#ExperienciaPreviaConMascotas').is(':checked')) {
                    var detalle = $('#DetalleExperiencia').val();
                    if (!detalle || detalle.trim() === '') {
                        mensaje += 'Debe describir su experiencia previa con mascotas.\n';
                        isValid = false;
                    }
                }

                if (!isValid) {
                    Swal.fire({
                        icon: 'warning',
                        title: 'Por favor corrija los siguientes errores:',
                        text: mensaje,
                        confirmButtonColor: '#97C78B'
                    });
                    e.preventDefault();
                }
            });
        });
    </script>
}