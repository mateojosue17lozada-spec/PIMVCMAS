@model MVCMASCOTAS.Controllers.CategoriaSimuladoController.CategoriaItem
@{
    ViewBag.Title = "Editar Categoría";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card form-card">
                <div class="form-card-header bg-yellow text-white">
                    <i class="fas fa-edit me-2"></i>Editar Categoría
                </div>
                <div class="card-body">
                    @using (Html.BeginForm())
                    {
                        @Html.AntiForgeryToken()
                        @Html.HiddenFor(m => m.Id) @* Solo el Id es necesario *@

                        <div class="mb-3">
                            <label class="form-label text-brown fw-medium">Nombre *</label>
                            @Html.TextBoxFor(m => m.Nombre, new { @class = "form-control border-green", required = "required" })
                            @Html.ValidationMessageFor(m => m.Nombre, "", new { @class = "text-danger small" })
                        </div>

                        <div class="mb-3">
                            <label class="form-label text-brown fw-medium">Descripción</label>
                            @Html.TextAreaFor(m => m.Descripcion, new { @class = "form-control border-green", rows = "3" })
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-green flex-grow-1">
                                <i class="fas fa-save me-2"></i>Guardar cambios
                            </button>
                            <a href="@Url.Action("Index")" class="btn btn-outline-green flex-grow-1">
                                <i class="fas fa-arrow-left me-2"></i>Volver
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>