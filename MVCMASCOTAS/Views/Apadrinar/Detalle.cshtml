@model MVCMASCOTAS.Models.ViewModels.ApadrinamientoDetalleViewModel

@{
    ViewBag.Title = "Detalle del Apadrinamiento";
    ViewData["Title"] = "Detalle del Apadrinamiento";
}

<!-- Contenido principal -->
<div class="container body-content mt-4">
    <div class="row">
        <div class="col-md-4">
            <!-- Información de la mascota -->
            <div class="card shadow-hover border-green mb-4">
                <div class="card-header bg-green text-white">
                    <h5 class="mb-0"><i class="fa fa-paw me-2"></i> Mascota Apadrinada</h5>
                </div>
                <div class="card-body bg-light-mint text-center">
                    @if (Model.MascotaImagen != null && Model.MascotaImagen.Length > 0)
                    {
                        <div class="card-img-top">
                            <img src="data:image/jpeg;base64,@Convert.ToBase64String(Model.MascotaImagen)"
                                 class="img-fluid rounded mb-3"
                                 style="max-height: 200px; width: 100%; object-fit: cover;"
                                 alt="@Model.MascotaNombre">
                        </div>
                    }
                    else
                    {
                        <div class="card-img-top">
                            <img src="~/Content/images/no-image.png"
                                 class="img-fluid rounded mb-3"
                                 style="max-height: 200px; width: 100%; object-fit: cover;"
                                 alt="Sin imagen">
                        </div>
                    }

                    <h4 class="text-brown">@Model.MascotaNombre</h4>
                    <p class="text-secondary">@Model.MascotaEspecie</p>

                    <div class="text-left">
                        <p>
                            <i class="fa fa-heart me-2 text-green"></i> <strong class="text-brown">Estado:</strong>
                            <span class="badge @(Model.Estado == "Activo" ? "bg-green" :
                                                 Model.Estado == "Pausado" ? "bg-yellow" :
                                                 "bg-secondary")">
                                @Model.Estado
                            </span>
                        </p>

                        <p>
                            <i class="fa fa-calendar-alt me-2 text-green"></i> <strong class="text-brown">Inicio:</strong>
                            @Model.FechaInicio.ToString("dd/MM/yyyy")
                        </p>

                        @if (Model.FechaFin.HasValue)
                        {
                            <p>
                                <i class="fa fa-calendar-times me-2 text-green"></i> <strong class="text-brown">Fin:</strong>
                                @Model.FechaFin.Value.ToString("dd/MM/yyyy")
                            </p>
                        }
                    </div>
                </div>
            </div>

            <!-- Acciones -->
            <div class="card shadow-hover border-green">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0"><i class="fa fa-cogs me-2"></i> Acciones</h5>
                </div>
                <div class="card-body bg-light-mint">
                    @if (Model.Estado == "Activo")
                    {
                        using (Html.BeginForm("Pausar", "Apadrinar", new { id = Model.ApadrinamientoId }, FormMethod.Post))
                        {
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-yellow btn-block mb-2">
                                <i class="fa fa-pause me-2"></i> Pausar Apadrinamiento
                            </button>
                        }
                    }
                    else if (Model.Estado == "Pausado")
                    {
                        using (Html.BeginForm("Reactivar", "Apadrinar", new { id = Model.ApadrinamientoId }, FormMethod.Post))
                        {
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-green btn-block mb-2">
                                <i class="fa fa-play me-2"></i> Reactivar Apadrinamiento
                            </button>
                        }
                    }

                    @if (Model.Estado == "Activo" || Model.Estado == "Pausado")
                    {
                        using (Html.BeginForm("Cancelar", "Apadrinar", new { id = Model.ApadrinamientoId }, FormMethod.Post))
                        {
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-green btn-block"
                                    onclick="return confirmCancelarApadrinamiento()">
                                <i class="fa fa-times-circle me-2"></i> Cancelar Apadrinamiento
                            </button>
                        }
                    }

                    <a href="@Url.Action("MisApadrinamientos", "Apadrinar")" class="btn btn-outline-green btn-block mt-3">
                        <i class="fa fa-arrow-left me-2"></i> Volver a la lista
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <!-- Información del apadrinamiento -->
            <div class="card shadow-hover border-green mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="fa fa-info-circle me-2"></i> Detalles del Apadrinamiento</h5>
                </div>
                <div class="card-body bg-light-mint">
                    <div class="row">
                        <div class="col-md-6">
                            <p>
                                <i class="fa fa-dollar-sign me-2 text-green"></i> <strong class="text-brown">Monto Mensual:</strong>
                                <span class="h5 text-green">$@Model.MontoMensual.ToString("N2")</span>
                            </p>
                        </div>
                        <div class="col-md-6">
                            <p>
                                <i class="fa fa-credit-card me-2 text-info"></i> <strong class="text-brown">Método de Pago:</strong>
                                @Model.MetodoPagoPreferido
                            </p>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <p>
                                <i class="fa fa-calendar-day me-2 text-yellow"></i> <strong class="text-brown">Día de Cobro:</strong>
                                Día @Model.DiaCobroMensual de cada mes
                            </p>
                        </div>
                        <div class="col-md-6">
                            <p>
                                <i class="fa fa-hand-holding-usd me-2 text-green"></i> <strong class="text-brown">Total Contribuido:</strong>
                                <span class="h5 text-green">$@Model.TotalContribuido.ToString("N2")</span>
                            </p>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.Observaciones))
                    {
                        <div class="mt-3">
                            <h6 class="text-brown"><i class="fa fa-sticky-note me-2"></i> Observaciones:</h6>
                            <div class="alert-green p-3 rounded">
                                @Html.Raw(Model.Observaciones.Replace("\n", "<br/>"))
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Historial de pagos -->
            <div class="card shadow-hover border-green">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0"><i class="fa fa-history me-2"></i> Historial de Pagos</h5>
                </div>
                <div class="card-body bg-light-mint">
                    @if (Model.Pagos != null && Model.Pagos.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead class="thead-light">
                                    <tr>
                                        <th><i class="fa fa-calendar text-green me-1"></i> <span class="text-brown">Fecha</span></th>
                                        <th><i class="fa fa-dollar-sign text-green me-1"></i> <span class="text-brown">Monto</span></th>
                                        <th><i class="fa fa-credit-card text-green me-1"></i> <span class="text-brown">Método</span></th>
                                        <th><i class="fa fa-tags text-green me-1"></i> <span class="text-brown">Mes Pagado</span></th>
                                        <th><i class="fa fa-check-circle text-green me-1"></i> <span class="text-brown">Estado</span></th>
                                        <th><i class="fa fa-receipt text-green me-1"></i> <span class="text-brown">Comprobante</span></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var pago in Model.Pagos)
                                    {
                                        <tr>
                                            <td class="text-secondary">@pago.FechaPago.ToString("dd/MM/yyyy")</td>
                                            <td class="font-weight-bold text-green">$@pago.Monto.ToString("N2")</td>
                                            <td class="text-secondary">@pago.MetodoPago</td>
                                            <td class="text-secondary">@pago.MesPagado</td>
                                            <td>
                                                <span class="badge @(pago.Estado == "Completado" ? "bg-green" :
                                                                     pago.Estado == "Pendiente" ? "bg-yellow" :
                                                                     "bg-danger")">
                                                    @pago.Estado
                                                </span>
                                            </td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(pago.NumeroTransaccion))
                                                {
                                                    <span class="badge bg-info" title="@pago.NumeroTransaccion">
                                                        @pago.NumeroTransaccion.Substring(0, Math.Min(10, pago.NumeroTransaccion.Length))...
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="text-secondary">N/A</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot class="bg-light">
                                    <tr>
                                        <td colspan="6" class="text-right">
                                            <strong class="text-brown">Total pagado: <span class="text-green">$@Model.TotalContribuido.ToString("N2")</span></strong>
                                        </td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert-green p-4 text-center rounded">
                            <i class="fa fa-info-circle fa-2x text-green mb-3"></i>
                            <h5 class="text-brown">No hay pagos registrados</h5>
                            <p class="text-secondary mb-0">Todavía no se han realizado pagos para este apadrinamiento.</p>
                        </div>
                    }
                </div>
            </div>

            <!-- Información adicional -->
            <div class="card shadow-hover border-green mt-4">
                <div class="card-header bg-yellow text-dark">
                    <h5 class="mb-0"><i class="fa fa-question-circle me-2"></i> Información Importante</h5>
                </div>
                <div class="card-body bg-light-mint">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="alert alert-light border border-green">
                                <h6 class="text-brown"><i class="fa fa-pause-circle text-yellow me-2"></i> Pausar Apadrinamiento</h6>
                                <p class="small text-secondary mb-0">Al pausar, se detendrán los cobros automáticos pero mantendrás todos tus beneficios.</p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="alert alert-light border border-green">
                                <h6 class="text-brown"><i class="fa fa-times-circle text-danger me-2"></i> Cancelar Apadrinamiento</h6>
                                <p class="small text-secondary mb-0">La cancelación es permanente. Perderás acceso a los beneficios del programa.</p>
                            </div>
                        </div>
                    </div>
                    <div class="alert alert-light border border-green mt-2">
                        <h6 class="text-brown"><i class="fa fa-phone-alt text-info me-2"></i> ¿Necesitas ayuda?</h6>
                        <p class="small text-secondary mb-0">
                            Contacta a nuestro equipo de soporte en <strong class="text-brown">soporte@refugiomascotas.com</strong> o llama al
                            <strong class="text-brown">(123) 456-7890</strong> para asistencia con tu apadrinamiento.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .thead-light th {
            background-color: var(--bg-light);
            border-color: var(--green);
            color: var(--brown);
        }

        .table-hover tbody tr:hover {
            background-color: rgba(151, 199, 139, 0.1);
        }

        .table tfoot {
            background-color: var(--bg-light) !important;
        }

        .badge.bg-info {
            background-color: #17a2b8 !important;
            color: white !important;
        }

        .badge.bg-danger {
            background-color: #dc3545 !important;
            color: white !important;
        }

        .badge.bg-primary {
            background-color: #007bff !important;
            color: white !important;
        }

        .badge.bg-success {
            background-color: #28a745 !important;
            color: white !important;
        }

        .card-header.bg-primary {
            background-color: #007bff !important;
        }

        .card-header.bg-info {
            background-color: #17a2b8 !important;
        }

        .card-header.bg-success {
            background-color: #28a745 !important;
        }

        .card-header.bg-yellow {
            background-color: var(--yellow) !important;
            color: var(--brown) !important;
        }

        .alert-light {
            background-color: white !important;
        }

        .border {
            border: 1px solid #dee2e6 !important;
        }

        .me-1 {
            margin-right: 0.25rem !important;
        }

        .me-2 {
            margin-right: 0.5rem !important;
        }

        .table-responsive {
            border-radius: 8px;
            overflow: hidden;
        }

        .card-img-top {
            overflow: hidden;
        }

            .card-img-top img {
                transition: transform 0.5s ease;
            }

            .card-img-top:hover img {
                transform: scale(1.05);
            }

        .btn-yellow {
            background-color: var(--yellow) !important;
            border-color: var(--yellow) !important;
            color: var(--brown) !important;
        }

            .btn-yellow:hover {
                background-color: #e6b85c !important;
                border-color: #e6b85c !important;
            }
    </style>
}

@section Scripts {
    <script>
        $(document).ready(function () {
            console.log('Detalle de apadrinamiento cargado');

            // Tooltips
            $('[title]').tooltip();

            // Auto cerrar alertas después de 5 segundos
            setTimeout(function () {
                $('.alert').alert('close');
            }, 5000);
        });

        // Función para confirmar cancelación con SweetAlert2
        function confirmCancelarApadrinamiento() {
            return new Promise((resolve) => {
                Swal.fire({
                    title: '¿Cancelar apadrinamiento?',
                    html: '<div class="text-center">' +
                        '<i class="fa fa-times-circle fa-3x text-green mb-3"></i>' +
                        '<h5 class="text-brown">¿Estás seguro de que deseas cancelar este apadrinamiento?</h5>' +
                        '<div class="alert alert-light border border-green text-left p-3 mt-3">' +
                        '<p class="text-secondary small mb-1"><i class="fa fa-exclamation-triangle text-yellow me-2"></i> La cancelación es permanente</p>' +
                        '<p class="text-secondary small mb-1"><i class="fa fa-heart-broken text-green me-2"></i> Perderás acceso a los beneficios del programa</p>' +
                        '<p class="text-secondary small mb-0"><i class="fa fa-undo text-green me-2"></i> Esta acción no se puede deshacer</p>' +
                        '</div>' +
                        '</div>',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#97C78B',
                    cancelButtonColor: '#5C4B43',
                    confirmButtonText: '<i class="fa fa-times-circle me-2"></i> Sí, cancelar',
                    cancelButtonText: '<i class="fa fa-arrow-left me-2"></i> Volver',
                    reverseButtons: true
                }).then((result) => {
                    if (result.isConfirmed) {
                        // Encontrar el formulario de cancelar y enviarlo
                        var form = $('button[onclick*="confirmCancelarApadrinamiento"]').closest('form');
                        if (form.length > 0) {
                            // Agregar token anti-forgery si no está presente
                            if (form.find('input[name="__RequestVerificationToken"]').length === 0) {
                                var token = $('input[name="__RequestVerificationToken"]').val();
                                if (token) {
                                    form.append('<input type="hidden" name="__RequestVerificationToken" value="' + token + '">');
                                }
                            }
                            form.submit();
                        }
                    }
                });
            });

            // Prevenir el comportamiento por defecto del botón
            return false;
        }

        // Actualizar el onclick del botón de cancelar para usar SweetAlert2
        $(document).on('click', 'button[onclick*="confirmCancelarApadrinamiento"]', function (e) {
            e.preventDefault();
            confirmCancelarApadrinamiento();
        });
    </script>
}