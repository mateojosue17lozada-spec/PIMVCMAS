@model IEnumerable<MVCMASCOTAS.Models.Mascotas>

@{
    ViewBag.Title = "Apadrinar una Mascota";
    ViewData["Title"] = "Apadrinar una Mascota";
}

<!-- Contenido principal -->
<div class="container body-content mt-4">
    <div class="page-header mb-4">
        <h2 class="text-brown font-weight-bold"><i class="fa fa-heart text-green"></i> Programa de Apadrinamiento</h2>
        <p class="lead text-secondary">Ayuda a cubrir los gastos de cuidado de una mascota con una contribución mensual</p>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-green border-green alert-dismissible fade show" role="alert">
            <i class="fa fa-exclamation-triangle text-green"></i> <strong class="text-brown">@TempData["ErrorMessage"]</strong>
            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
    }

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-green border-green alert-dismissible fade show" role="alert">
            <i class="fa fa-check-circle text-green"></i> <strong class="text-brown">@TempData["SuccessMessage"]</strong>
            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
    }

    <div class="alert alert-green border-green mb-4">
        <div class="d-flex">
            <i class="fa fa-info-circle fa-2x text-green me-3 align-self-start mt-1"></i>
            <div>
                <h5 class="text-brown mb-2">¿Cómo funciona el apadrinamiento?</h5>
                <div class="row">
                    <div class="col-md-6">
                        <ul class="mb-0 text-secondary">
                            <li><i class="fa fa-check-circle text-green me-2"></i>Eliges una mascota para apadrinar</li>
                            <li><i class="fa fa-check-circle text-green me-2"></i>Contribución mensual mínima de $10</li>
                            <li><i class="fa fa-check-circle text-green me-2"></i>Actualizaciones mensuales con fotos</li>
                        </ul>
                    </div>
                    <div class="col-md-6">
                        <ul class="mb-0 text-secondary">
                            <li><i class="fa fa-check-circle text-green me-2"></i>Certificado de apadrinamiento digital</li>
                            <li><i class="fa fa-check-circle text-green me-2"></i>Visitas programadas (con cita previa)</li>
                            <li><i class="fa fa-check-circle text-green me-2"></i>Tu nombre en nuestro muro de honor</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        @if (Model != null && Model.Any())
        {
            foreach (var mascota in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100 shadow-hover border-green">
                        @if (mascota.ImagenPrincipal != null && mascota.ImagenPrincipal.Length > 0)
                        {
                            <div class="card-img-top">
                                <img src="data:image/jpeg;base64,@Convert.ToBase64String(mascota.ImagenPrincipal)"
                                     style="height: 250px; object-fit: cover; width: 100%;"
                                     alt="@mascota.Nombre">
                            </div>
                        }
                        else
                        {
                            <div class="card-img-top">
                                <img src="~/Content/images/no-image.png"
                                     style="height: 250px; object-fit: cover; width: 100%;"
                                     alt="Sin imagen">
                            </div>
                        }
                        <div class="card-body bg-light-mint">
                            <h5 class="card-title text-brown">
                                <i class="fa fa-paw text-green me-2"></i>@mascota.Nombre
                            </h5>
                            <p class="card-text text-secondary">
                                <i class="fa fa-dog text-green me-2"></i> <strong>Especie:</strong> @mascota.Especie<br />
                                <i class="fa fa-venus-mars text-green me-2"></i> <strong>Sexo:</strong> @mascota.Sexo<br />
                                <i class="fa fa-calendar text-green me-2"></i> <strong>Edad:</strong> @mascota.EdadAproximada<br />
                                <i class="fa fa-heartbeat text-green me-2"></i> <strong>Estado:</strong>
                                <span class="badge
                                    @(mascota.Estado == "Rescatada" ? "bg-yellow" :
                                      mascota.Estado == "En tratamiento" ? "bg-info" :
                                      mascota.Estado == "Disponible para adopción" ? "bg-green" : "bg-secondary")">
                                    @mascota.Estado
                                </span>
                            </p>
                            @if (!string.IsNullOrEmpty(mascota.DescripcionGeneral))
                            {
                                <div class="mt-3">
                                    <p class="text-secondary small mb-0">
                                        <strong class="text-brown"><i class="fa fa-file-alt text-green me-2"></i>Descripción:</strong><br>
                                        @(mascota.DescripcionGeneral.Length > 100 ? mascota.DescripcionGeneral.Substring(0, 100) + "..." : mascota.DescripcionGeneral)
                                    </p>
                                </div>
                            }

                            <!-- Mostrar mensaje si el usuario ya apadrina esta mascota -->
                            @if (ViewBag.ApadrinamientosUsuario != null)
                            {
                                var apadrinamientosUsuario = ViewBag.ApadrinamientosUsuario as System.Collections.Generic.List<int> ?? new List<int>();
                                if (apadrinamientosUsuario.Contains(mascota.MascotaId))
                                {
                                    <div class="mt-3">
                                        <div class="alert-green p-2 rounded small mb-0">
                                            <i class="fa fa-check-circle text-green me-1"></i> <span class="text-brown">Ya apadrinas a esta mascota</span>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                        <div class="card-footer bg-white border-top border-green">
                            <button type="button" class="btn btn-green btn-block"
                                    data-toggle="modal"
                                    data-target="#modalApadrinar"
                                    data-mascota-id="@mascota.MascotaId"
                                    data-mascota-nombre="@mascota.Nombre"
                                    data-mascota-especie="@mascota.Especie"
                                    @if (!User.Identity.IsAuthenticated) { <text> onclick="showLoginAlert()" </text> }>
                                <i class="fa fa-heart me-2"></i> Apadrinar a @mascota.Nombre
                            </button>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="card shadow-hover border-green text-center py-4">
                    <div class="card-body bg-light-mint">
                        <i class="fa fa-exclamation-triangle fa-3x text-secondary mb-3"></i>
                        <h4 class="text-brown mb-2">No hay mascotas disponibles para apadrinamiento</h4>
                        <p class="text-secondary mb-2">Todas nuestras mascotas tienen padrinos activos en este momento.</p>
                        <p class="text-secondary mb-0">
                            ¡Puedes realizar una
                            <a href="@Url.Action("Donar", "Donaciones")" class="text-green font-weight-bold">
                                donación general
                            </a>
                            para ayudar a todas!
                        </p>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Modal de Apadrinamiento -->
    <div class="modal fade" id="modalApadrinar" tabindex="-1" role="dialog" aria-labelledby="modalApadrinarLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content">
                <div class="modal-header bg-green text-white">
                    <h5 class="modal-title" id="modalApadrinarLabel">
                        <i class="fa fa-heart me-2"></i> Apadrinar Mascota
                    </h5>
                    <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                @using (Html.BeginForm("ConfirmarApadrinamiento", "Donaciones", FormMethod.Post, new { id = "formApadrinar" }))
                {
                    @Html.AntiForgeryToken()
                    <div class="modal-body bg-light-mint">
                        <div class="text-center mb-4">
                            <h4 class="text-brown">Estás a punto de apadrinar a</h4>
                            <h3 id="nombreMascota" class="text-green"></h3>
                            <p id="especieMascota" class="text-secondary"></p>
                        </div>

                        <input type="hidden" name="mascotaId" id="mascotaIdInput" />

                        <div class="form-group">
                            <label for="montoMensualInput" class="font-weight-bold text-brown">
                                <i class="fa fa-dollar-sign text-green me-2"></i>Monto Mensual (USD) *
                            </label>
                            <div class="input-group input-group-lg">
                                <div class="input-group-prepend">
                                    <span class="input-group-text bg-light">
                                        <i class="fa fa-hand-holding-usd text-green"></i>
                                    </span>
                                </div>
                                <input type="number"
                                       name="montoMensual"
                                       id="montoMensualInput"
                                       class="form-control border-green"
                                       min="10"
                                       step="0.01"
                                       value="10.00"
                                       required
                                       oninput="validateMonto(this)" />
                                <div class="input-group-append">
                                    <span class="input-group-text">/mes</span>
                                </div>
                            </div>
                            <small class="form-text text-secondary">
                                <i class="fa fa-info-circle text-green me-1"></i> Monto mínimo: <strong class="text-brown">$10.00</strong> mensuales
                            </small>
                            <div id="montoError" class="text-danger small mt-1" style="display: none;">
                                <i class="fa fa-exclamation-triangle me-1"></i> El monto mínimo es $10.00
                            </div>
                        </div>

                        <div class="alert-green p-3 rounded">
                            <div class="d-flex">
                                <i class="fa fa-gift fa-2x text-green me-3 align-self-start mt-1"></i>
                                <div>
                                    <h5 class="text-brown mb-2"><i class="fa fa-check-circle text-green me-2"></i>¿Qué incluye tu apadrinamiento?</h5>
                                    <div class="row">
                                        <div class="col-md-6">
                                            <ul class="mb-2 text-secondary">
                                                <li><strong>📸 Actualizaciones mensuales</strong> con fotos y videos</li>
                                                <li><strong>🏆 Certificado digital</strong> de apadrinamiento</li>
                                                <li><strong>📧 Reportes periódicos</strong> sobre su salud y bienestar</li>
                                            </ul>
                                        </div>
                                        <div class="col-md-6">
                                            <ul class="mb-2 text-secondary">
                                                <li><strong>🎁 Tarjeta de agradecimiento</strong> personalizada</li>
                                                <li><strong>👑 Tu nombre</strong> en nuestro muro de honor</li>
                                                <li><strong>💝 Visitas especiales</strong> (con cita previa)</li>
                                            </ul>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="alert alert-warning border border-warning">
                            <div class="d-flex">
                                <i class="fa fa-exclamation-triangle fa-2x text-warning me-3 align-self-start mt-1"></i>
                                <div>
                                    <h5 class="text-brown mb-2"><i class="fa fa-shield-alt text-warning me-2"></i>Importante</h5>
                                    <ul class="mb-0 text-secondary">
                                        <li>El cargo se realizará <strong class="text-brown">mensualmente</strong> el día que elijas</li>
                                        <li>Puedes <strong class="text-brown">pausar, reactivar o cancelar</strong> en cualquier momento</li>
                                        <li>Recibirás <strong class="text-brown">notificaciones por email</strong> de cada transacción</li>
                                        <li>Tus datos están <strong class="text-brown">protegidos y encriptados</strong></li>
                                    </ul>
                                </div>
                            </div>
                        </div>

                        @if (!User.Identity.IsAuthenticated)
                        {
                            <div class="alert alert-danger border border-danger">
                                <div class="d-flex">
                                    <i class="fa fa-user-lock fa-2x text-danger me-3 align-self-start mt-1"></i>
                                    <div>
                                        <h5 class="text-brown mb-2">¡Necesitas iniciar sesión!</h5>
                                        <p class="mb-2 text-secondary">Para apadrinar una mascota, debes tener una cuenta registrada.</p>
                                        <a href="@Url.Action("Login", "Account")" class="btn btn-green btn-sm">
                                            <i class="fa fa-sign-in-alt me-2"></i> Iniciar Sesión
                                        </a>
                                        <a href="@Url.Action("Register", "Account")" class="btn btn-outline-green btn-sm ml-2">
                                            <i class="fa fa-user-plus me-2"></i> Crear Cuenta
                                        </a>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-green" data-dismiss="modal">
                            <i class="fa fa-times me-2"></i> Cancelar
                        </button>

                        @if (User.Identity.IsAuthenticated)
                        {
                            <button type="submit" class="btn btn-green" id="btnConfirmar">
                                <i class="fa fa-heart me-2"></i> Confirmar Apadrinamiento
                            </button>
                        }
                        else
                        {
                            <button type="button" class="btn btn-green disabled" disabled>
                                <i class="fa fa-lock me-2"></i> Inicia sesión para continuar
                            </button>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        /* Eliminé las clases duplicadas ya que están en el layout */
        .text-danger {
            color: #dc3545 !important;
        }

        .bg-danger {
            background-color: #dc3545 !important;
            color: white !important;
        }

        .border-danger {
            border-color: #dc3545 !important;
        }

        .alert-warning {
            background-color: rgba(255, 193, 7, 0.1) !important;
        }

        .text-warning {
            color: #ffc107 !important;
        }

        .border-warning {
            border-color: #ffc107 !important;
        }

        .me-2 {
            margin-right: 0.5rem !important;
        }

        .me-3 {
            margin-right: 1rem !important;
        }

        .ml-2 {
            margin-left: 0.5rem !important;
        }

        .ms-2 {
            margin-left: 0.5rem !important;
        }

        .mt-1 {
            margin-top: 0.25rem !important;
        }

        .align-self-start {
            align-self: flex-start !important;
        }

        .input-group-prepend {
            margin-right: -1px;
        }

        .input-group-append {
            margin-left: -1px;
        }

        .input-group-text {
            background-color: var(--bg-light);
            border: 1px solid var(--green);
        }

        .form-control.border-green:focus {
            border-color: var(--green);
            box-shadow: 0 0 0 0.2rem rgba(151, 199, 139, 0.25);
        }

        .form-control.is-valid {
            border-color: var(--green);
        }

        .form-control.is-invalid {
            border-color: #dc3545;
        }

        .badge.bg-info {
            background-color: #17a2b8 !important;
            color: white !important;
        }

        .badge.bg-secondary {
            background-color: #6c757d !important;
            color: white !important;
        }

        .card-img-top {
            overflow: hidden;
        }

            .card-img-top img {
                transition: transform 0.5s ease;
            }

            .card-img-top:hover img {
                transform: scale(1.05);
            }
    </style>
}

@section Scripts {
    <script>
        $(document).ready(function() {
            console.log('Página de apadrinamiento cargada');

            // Configurar el modal
            $('#modalApadrinar').on('show.bs.modal', function (event) {
                var button = $(event.relatedTarget);
                var mascotaId = button.data('mascota-id');
                var mascotaNombre = button.data('mascota-nombre');
                var mascotaEspecie = button.data('mascota-especie');

                var modal = $(this);
                modal.find('#nombreMascota').text(mascotaNombre);
                modal.find('#especieMascota').text(mascotaEspecie);
                modal.find('#mascotaIdInput').val(mascotaId);

                // Resetear validaciones
                $('#montoError').hide();
                $('#montoMensualInput').removeClass('is-invalid').addClass('is-valid');
            });

            // Auto-ocultar alertas después de 5 segundos
            setTimeout(function() {
                $('.alert-dismissible').alert('close');
            }, 5000);
        });

        // Validar monto en tiempo real
        function validateMonto(input) {
            var monto = parseFloat(input.value) || 0;
            var montoError = $('#montoError');

            if (monto < 10) {
                $(input).removeClass('is-valid').addClass('is-invalid');
                montoError.show();
                return false;
            } else {
                $(input).removeClass('is-invalid').addClass('is-valid');
                montoError.hide();
                return true;
            }
        }

        // Validar formulario antes de enviar
        $('#formApadrinar').submit(function (e) {
            var montoInput = $('#montoMensualInput');
            var monto = parseFloat(montoInput.val()) || 0;

            if (!validateMonto(montoInput[0])) {
                e.preventDefault();
                montoInput.focus();
                return false;
            }

            // Confirmación final
            e.preventDefault();
            var mascotaNombre = $('#nombreMascota').text();

            Swal.fire({
                title: '¡Un último paso!',
                html: '<div class="text-center">' +
                      '<i class="fa fa-heart fa-3x text-green mb-3"></i>' +
                      '<h4 class="text-brown">¿Confirmas apadrinar a <strong class="text-green">' + mascotaNombre + '</strong>?</h4>' +
                      '<p class="text-secondary">Monto mensual: <strong class="text-brown">$' + monto.toFixed(2) + '</strong></p>' +
                      '</div>',
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#97C78B',
                cancelButtonColor: '#5C4B43',
                confirmButtonText: '<i class="fa fa-heart me-2"></i> Sí, confirmar',
                cancelButtonText: '<i class="fa fa-times me-2"></i> Revisar',
                reverseButtons: true
            }).then((result) => {
                if (result.isConfirmed) {
                    // Deshabilitar botón para evitar doble envío
                    $('#btnConfirmar').prop('disabled', true)
                        .html('<i class="fa fa-spinner fa-spin me-2"></i> Procesando...');

                    // Enviar formulario
                    $('#formApadrinar').off('submit').submit();
                }
            });
        });

        // Alerta para usuarios no autenticados
        function showLoginAlert() {
            if (!@(User.Identity.IsAuthenticated ? "true" : "false")) {
                Swal.fire({
                    title: '¡Necesitas iniciar sesión!',
                    html: '<div class="text-center">' +
                          '<i class="fa fa-user-lock fa-3x text-green mb-3"></i>' +
                          '<h4 class="text-brown">Para apadrinar una mascota necesitas una cuenta</h4>' +
                          '<p class="text-secondary">Puedes iniciar sesión o crear una cuenta gratuita en segundos.</p>' +
                          '</div>',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#97C78B',
                    cancelButtonColor: '#5C4B43',
                    confirmButtonText: '<i class="fa fa-sign-in-alt me-2"></i> Iniciar Sesión',
                    cancelButtonText: '<i class="fa fa-user-plus me-2"></i> Crear Cuenta'
                }).then((result) => {
                    if (result.isConfirmed) {
                        window.location.href = '@Url.Action("Login", "Account")';
                    } else if (result.dismiss === Swal.DismissReason.cancel) {
                        window.location.href = '@Url.Action("Register", "Account")';
                    }
                });
            }
        }
    </script>
}