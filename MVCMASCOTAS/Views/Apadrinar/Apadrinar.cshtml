@model IEnumerable<MVCMASCOTAS.Models.Mascotas>

@{
    ViewBag.Title = "Apadrinar una Mascota - ADOPTAMANÍA";
    ViewData["Title"] = "Apadrinar una Mascota";
}

<!-- Hero Section -->
<section class="apadrinar-hero py-5">
    <div class="container text-center">
        <i class="fas fa-heart fa-4x text-white mb-4"></i>
        <h1 class="display-4 fw-bold mb-3 text-white">Programa de Apadrinamiento</h1>
        <p class="lead mb-0 text-white">Ayuda a cubrir los gastos de cuidado de una mascota con una contribución mensual</p>
    </div>
</section>

<!-- Main Content -->
<section class="py-5 bg-beige">
    <div class="container">
        <!-- Mensajes de TempData -->
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-beige border-green alert-dismissible fade show mb-4" role="alert">
                <i class="fas fa-exclamation-triangle text-green me-2"></i>
                <strong class="text-brown">@TempData["ErrorMessage"]</strong>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-beige border-green alert-dismissible fade show mb-4" role="alert">
                <i class="fas fa-check-circle text-green me-2"></i>
                <strong class="text-brown">@TempData["SuccessMessage"]</strong>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <!-- Información del programa -->
        <div class="info-card mb-5">
            <div class="info-card-header bg-green text-white">
                <i class="fas fa-info-circle me-2"></i>¿Cómo funciona el apadrinamiento?
            </div>
            <div class="info-card-body">
                <div class="row g-4">
                    <div class="col-md-6">
                        <ul class="list-unstyled">
                            <li class="mb-3"><i class="fas fa-check-circle text-green fa-lg me-3"></i> <span class="text-brown">Eliges una mascota para apadrinar</span></li>
                            <li class="mb-3"><i class="fas fa-check-circle text-green fa-lg me-3"></i> <span class="text-brown">Contribución mensual mínima de $10</span></li>
                            <li class="mb-3"><i class="fas fa-check-circle text-green fa-lg me-3"></i> <span class="text-brown">Actualizaciones mensuales con fotos</span></li>
                        </ul>
                    </div>
                    <div class="col-md-6">
                        <ul class="list-unstyled">
                            <li class="mb-3"><i class="fas fa-check-circle text-green fa-lg me-3"></i> <span class="text-brown">Certificado de apadrinamiento digital</span></li>
                            <li class="mb-3"><i class="fas fa-check-circle text-green fa-lg me-3"></i> <span class="text-brown">Visitas programadas (con cita previa)</span></li>
                            <li class="mb-3"><i class="fas fa-check-circle text-green fa-lg me-3"></i> <span class="text-brown">Tu nombre en nuestro muro de honor</span></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tarjetas de mascotas -->
        <div class="row g-4">
            @if (Model != null && Model.Any())
            {
                foreach (var mascota in Model)
                {
                    <div class="col-md-4">
                        <div class="pet-card h-100">
                            <div class="pet-card-img">
                                @if (mascota.ImagenPrincipal != null && mascota.ImagenPrincipal.Length > 0)
                                {
                                    <img src="data:image/jpeg;base64,@Convert.ToBase64String(mascota.ImagenPrincipal)"
                                         alt="@mascota.Nombre">
                                }
                                else
                                {
                                    <img src="~/Content/images/no-image.png" alt="Sin imagen">
                                }
                            </div>
                            <div class="pet-card-body">
                                <h5 class="pet-card-title">
                                    <i class="fas fa-paw text-green me-2"></i>@mascota.Nombre
                                </h5>
                                <div class="pet-card-info">
                                    <p><i class="fas fa-dog text-green me-2"></i> <strong>Especie:</strong> @mascota.Especie</p>
                                    <p><i class="fas fa-venus-mars text-green me-2"></i> <strong>Sexo:</strong> @mascota.Sexo</p>
                                    <p><i class="fas fa-calendar-alt text-green me-2"></i> <strong>Edad:</strong> @mascota.EdadAproximada</p>
                                    <p>
                                        <i class="fas fa-heartbeat text-green me-2"></i> <strong>Estado:</strong>
                                        <span class="badge @(mascota.Estado == "Rescatada" ? "bg-yellow text-brown" :
                                                            mascota.Estado == "En tratamiento" ? "bg-info text-white" :
                                                            mascota.Estado == "Disponible para adopción" ? "bg-green text-white" :
                                                            "bg-secondary text-white") px-3 py-2">
                                            @mascota.Estado
                                        </span>
                                    </p>
                                </div>
                                @if (!string.IsNullOrEmpty(mascota.DescripcionGeneral))
                                {
                                    <p class="pet-card-descripcion">
                                        <i class="fas fa-file-alt text-green me-2"></i>
                                        <span class="text-secondary">@(mascota.DescripcionGeneral.Length > 100 ? mascota.DescripcionGeneral.Substring(0, 100) + "..." : mascota.DescripcionGeneral)</span>
                                    </p>
                                }

                                @if (ViewBag.ApadrinamientosUsuario != null)
                                {
                                    var apadrinamientosUsuario = ViewBag.ApadrinamientosUsuario as List<int> ?? new List<int>();
                                    if (apadrinamientosUsuario.Contains(mascota.MascotaId))
                                    {
                                        <div class="alert alert-beige border-green small mt-3">
                                            <i class="fas fa-check-circle text-green me-1"></i>
                                            <span class="text-brown">Ya apadrinas a esta mascota</span>
                                        </div>
                                    }
                                }
                            </div>
                            <div class="pet-card-footer">
                                <button type="button" class="btn btn-green w-100"
                                        data-bs-toggle="modal"
                                        data-bs-target="#modalApadrinar"
                                        data-mascota-id="@mascota.MascotaId"
                                        data-mascota-nombre="@mascota.Nombre"
                                        data-mascota-especie="@mascota.Especie"
                                        @(!User.Identity.IsAuthenticated ? "onclick=showLoginAlert()" : "")>
                                    <i class="fas fa-heart me-2"></i> Apadrinar a @mascota.Nombre
                                </button>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12">
                    <div class="info-card text-center py-5">
                        <div class="info-card-body">
                            <i class="fas fa-exclamation-triangle fa-4x text-secondary mb-3"></i>
                            <h4 class="text-brown mb-2">No hay mascotas disponibles para apadrinamiento</h4>
                            <p class="text-secondary mb-2">Todas nuestras mascotas tienen padrinos activos en este momento.</p>
                            <p class="text-secondary">
                                ¡Puedes realizar una
                                <a href="@Url.Action("Donar", "Donaciones")" class="text-green fw-bold">
                                    donación general
                                </a>
                                para ayudar a todas!
                            </p>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- Modal de Apadrinamiento -->
<div class="modal fade" id="modalApadrinar" tabindex="-1" aria-labelledby="modalApadrinarLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-green text-white">
                <h5 class="modal-title" id="modalApadrinarLabel">
                    <i class="fas fa-heart me-2"></i> Apadrinar Mascota
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            @using (Html.BeginForm("ConfirmarApadrinamiento", "Donaciones", FormMethod.Post, new { id = "formApadrinar" }))
            {
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="text-center mb-4">
                        <h4 class="text-brown">Estás a punto de apadrinar a</h4>
                        <h3 id="nombreMascota" class="text-green"></h3>
                        <p id="especieMascota" class="text-secondary"></p>
                    </div>

                    <input type="hidden" name="mascotaId" id="mascotaIdInput" />

                    <div class="mb-4">
                        <label for="montoMensualInput" class="form-label text-brown fw-medium">
                            <i class="fas fa-dollar-sign text-green me-2"></i>Monto Mensual (USD) *
                        </label>
                        <div class="input-group input-group-lg">
                            <span class="input-group-text bg-white border-green"><i class="fas fa-hand-holding-heart text-green"></i></span>
                            <input type="number"
                                   name="montoMensual"
                                   id="montoMensualInput"
                                   class="form-control border-green"
                                   min="10"
                                   step="0.01"
                                   value="10.00"
                                   required
                                   oninput="validateMonto(this)" />
                            <span class="input-group-text bg-white border-green">/mes</span>
                        </div>
                        <small class="text-secondary">
                            <i class="fas fa-info-circle text-green me-1"></i> Monto mínimo: <strong class="text-brown">$10.00</strong> mensuales
                        </small>
                        <div id="montoError" class="text-danger small mt-1" style="display: none;">
                            <i class="fas fa-exclamation-triangle me-1"></i> El monto mínimo es $10.00
                        </div>
                    </div>

                    <div class="alert alert-beige border-green p-3 mb-4">
                        <div class="d-flex">
                            <i class="fas fa-gift fa-2x text-green me-3"></i>
                            <div>
                                <h5 class="text-brown mb-2"><i class="fas fa-check-circle text-green me-2"></i>¿Qué incluye tu apadrinamiento?</h5>
                                <div class="row">
                                    <div class="col-md-6">
                                        <ul class="list-unstyled text-secondary">
                                            <li><i class="fas fa-camera me-2 text-green"></i> Actualizaciones mensuales con fotos</li>
                                            <li><i class="fas fa-certificate me-2 text-green"></i> Certificado digital de apadrinamiento</li>
                                            <li><i class="fas fa-envelope me-2 text-green"></i> Reportes periódicos sobre su salud</li>
                                        </ul>
                                    </div>
                                    <div class="col-md-6">
                                        <ul class="list-unstyled text-secondary">
                                            <li><i class="fas fa-gift me-2 text-green"></i> Tarjeta de agradecimiento personalizada</li>
                                            <li><i class="fas fa-star me-2 text-green"></i> Tu nombre en el muro de honor</li>
                                            <li><i class="fas fa-calendar-check me-2 text-green"></i> Visitas especiales (con cita previa)</li>
                                        </ul>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="alert alert-beige border-yellow p-3">
                        <div class="d-flex">
                            <i class="fas fa-exclamation-triangle fa-2x text-yellow me-3"></i>
                            <div>
                                <h5 class="text-brown mb-2"><i class="fas fa-shield-alt text-yellow me-2"></i>Importante</h5>
                                <ul class="list-unstyled text-secondary">
                                    <li><i class="fas fa-check me-2 text-green"></i> El cargo se realizará <strong>mensualmente</strong> el día que elijas</li>
                                    <li><i class="fas fa-check me-2 text-green"></i> Puedes <strong>pausar, reactivar o cancelar</strong> en cualquier momento</li>
                                    <li><i class="fas fa-check me-2 text-green"></i> Recibirás <strong>notificaciones por email</strong> de cada transacción</li>
                                    <li><i class="fas fa-check me-2 text-green"></i> Tus datos están <strong>protegidos y encriptados</strong></li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    @if (!User.Identity.IsAuthenticated)
                    {
                        <div class="alert alert-pink border-pink mt-4">
                            <div class="d-flex">
                                <i class="fas fa-user-lock fa-2x text-brown me-3"></i>
                                <div>
                                    <h5 class="text-brown mb-2">¡Necesitas iniciar sesión!</h5>
                                    <p class="mb-2 text-secondary">Para apadrinar una mascota, debes tener una cuenta registrada.</p>
                                    <a href="@Url.Action("Login", "Account")" class="btn btn-green btn-sm me-2">
                                        <i class="fas fa-sign-in-alt me-2"></i> Iniciar Sesión
                                    </a>
                                    <a href="@Url.Action("Register", "Account")" class="btn btn-outline-green btn-sm">
                                        <i class="fas fa-user-plus me-2"></i> Crear Cuenta
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-green" data-bs-dismiss="modal">
                        <i class="fas fa-times me-2"></i> Cancelar
                    </button>
                    @if (User.Identity.IsAuthenticated)
                    {
                        <button type="submit" class="btn btn-green" id="btnConfirmar">
                            <i class="fas fa-heart me-2"></i> Confirmar Apadrinamiento
                        </button>
                    }
                    else
                    {
                        <button type="button" class="btn btn-green disabled" disabled>
                            <i class="fas fa-lock me-2"></i> Inicia sesión para continuar
                        </button>
                    }
                </div>
            }
        </div>
    </div>
</div>

@section Styles {
    <style>
        :root {
            --green: #97C78B;
            --yellow: #F2C66D;
            --pink: #FBCDC0;
            --brown: #2F2F2F;
            --bg-light: #F2E9D8;
            --beige: #F5E6D3;
            --text-secondary: #555555;
        }

        body {
            background-color: var(--beige);
        }

        /* Hero */
        .apadrinar-hero {
            background: linear-gradient(135deg, rgba(151,199,139,0.9), rgba(242,198,109,0.8)), url('https://images.unsplash.com/photo-1450778869180-41d0601e046e?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80');
            background-size: cover;
            background-position: center;
            border-radius: 0 0 30px 30px;
            margin-bottom: 1rem;
        }

        /* Tarjetas de información */
        .info-card {
            background: white;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 15px 35px rgba(151,199,139,0.15);
            border: none;
        }

        .info-card-header {
            padding: 1rem 1.5rem;
            font-weight: 600;
            font-size: 1.1rem;
        }

        .info-card-body {
            padding: 1.5rem;
        }

        /* Tarjetas de mascotas */
        .pet-card {
            background: white;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 15px 35px rgba(151,199,139,0.15);
            transition: transform 0.3s, box-shadow 0.3s;
            border: none;
            height: 100%;
            display: flex;
            flex-direction: column;
        }

            .pet-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 20px 40px rgba(151,199,139,0.25);
            }

        .pet-card-img {
            height: 250px;
            overflow: hidden;
        }

            .pet-card-img img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                transition: transform 0.5s;
            }

            .pet-card-img:hover img {
                transform: scale(1.05);
            }

        .pet-card-body {
            padding: 1.5rem;
            flex: 1;
        }

        .pet-card-title {
            font-size: 1.3rem;
            color: var(--brown);
            margin-bottom: 1rem;
            font-weight: 600;
        }

        .pet-card-info p {
            margin-bottom: 0.5rem;
            color: var(--text-secondary);
        }

        .pet-card-descripcion {
            margin-top: 1rem;
            font-size: 0.9rem;
            border-top: 1px dashed var(--green);
            padding-top: 1rem;
        }

        .pet-card-footer {
            padding: 1rem 1.5rem;
            border-top: 2px solid var(--green);
            background-color: var(--bg-light);
        }

        /* Badges */
        .badge.bg-green {
            background-color: var(--green) !important;
            color: white !important;
        }

        .badge.bg-yellow {
            background-color: var(--yellow) !important;
            color: var(--brown) !important;
        }

        .badge.bg-pink {
            background-color: var(--pink) !important;
            color: var(--brown) !important;
        }

        .badge.bg-info {
            background-color: #17a2b8 !important;
            color: white !important;
        }

        .badge.bg-secondary {
            background-color: #6c757d !important;
            color: white !important;
        }

        /* Alertas personalizadas */
        .alert-beige {
            background-color: var(--bg-light);
            border: 1px solid var(--green);
            color: var(--brown);
            border-radius: 16px;
        }

        .alert-pink {
            background-color: var(--pink);
            border: 1px solid var(--green);
            color: var(--brown);
            border-radius: 16px;
        }

        .border-yellow {
            border-color: var(--yellow) !important;
        }

        .border-pink {
            border-color: var(--pink) !important;
        }

        /* Botones */
        .btn-green {
            background-color: var(--green);
            border: none;
            border-radius: 50px;
            padding: 0.6rem 1.8rem;
            font-weight: 500;
            transition: all 0.3s;
            color: white;
        }

            .btn-green:hover {
                background-color: #86b57a;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(151,199,139,0.4);
            }

        .btn-outline-green {
            border: 2px solid var(--green);
            background: transparent;
            color: var(--green);
            border-radius: 50px;
            padding: 0.6rem 1.8rem;
            font-weight: 500;
            transition: all 0.3s;
        }

            .btn-outline-green:hover {
                background-color: var(--green);
                color: white;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(151,199,139,0.3);
            }

        /* Formularios */
        .form-control, .form-select {
            border: 2px solid var(--green);
            border-radius: 16px;
            padding: 0.6rem 1rem;
            transition: border-color 0.2s, box-shadow 0.2s;
            background-color: white;
        }

            .form-control:focus, .form-select:focus {
                border-color: var(--green);
                box-shadow: 0 0 0 0.2rem rgba(151,199,139,0.25);
                outline: none;
            }

        .input-group-text {
            border: 2px solid var(--green);
            border-radius: 16px;
            background-color: white;
        }

        .input-group .form-control {
            border-left: none;
            border-right: none;
            border-radius: 0;
        }

        .input-group .input-group-text:first-child {
            border-radius: 16px 0 0 16px;
        }

        .input-group .input-group-text:last-child {
            border-radius: 0 16px 16px 0;
        }

        /* Modal */
        .modal-content {
            border-radius: 24px;
            overflow: hidden;
            border: none;
            box-shadow: 0 20px 40px rgba(0,0,0,0.2);
        }

        .modal-header {
            padding: 1.2rem 1.5rem;
            border-bottom: none;
        }

        .modal-footer {
            border-top: 1px solid var(--green);
            padding: 1rem 1.5rem;
        }

        /* Responsive */
        @@media (max-width: 768px) {
            .pet-card-img {
                height: 200px;
            }
        }
    </style>
}

@section Scripts {
    <script>
        $(document).ready(function () {
            console.log('Página de apadrinamiento cargada');

            // Configurar el modal
            $('#modalApadrinar').on('show.bs.modal', function (event) {
                var button = $(event.relatedTarget);
                var mascotaId = button.data('mascota-id');
                var mascotaNombre = button.data('mascota-nombre');
                var mascotaEspecie = button.data('mascota-especie');

                var modal = $(this);
                modal.find('#nombreMascota').text(mascotaNombre);
                modal.find('#especieMascota').text(mascotaEspecie);
                modal.find('#mascotaIdInput').val(mascotaId);

                // Resetear validaciones
                $('#montoError').hide();
                $('#montoMensualInput').removeClass('is-invalid').addClass('is-valid');
            });

            // Auto-ocultar alertas después de 5 segundos
            setTimeout(function () {
                $('.alert-dismissible').alert('close');
            }, 5000);
        });

        // Validar monto en tiempo real
        function validateMonto(input) {
            var monto = parseFloat(input.value) || 0;
            var montoError = $('#montoError');

            if (monto < 10) {
                $(input).removeClass('is-valid').addClass('is-invalid');
                montoError.show();
                return false;
            } else {
                $(input).removeClass('is-invalid').addClass('is-valid');
                montoError.hide();
                return true;
            }
        }

        // Validar formulario antes de enviar
        $('#formApadrinar').submit(function (e) {
            var montoInput = $('#montoMensualInput');
            var monto = parseFloat(montoInput.val()) || 0;

            if (!validateMonto(montoInput[0])) {
                e.preventDefault();
                montoInput.focus();
                return false;
            }

            // Confirmación final
            e.preventDefault();
            var mascotaNombre = $('#nombreMascota').text();

            Swal.fire({
                title: '¡Un último paso!',
                html: '<div class="text-center">' +
                      '<i class="fas fa-heart fa-3x text-green mb-3"></i>' +
                      '<h4 class="text-brown">¿Confirmas apadrinar a <strong class="text-green">' + mascotaNombre + '</strong>?</h4>' +
                      '<p class="text-secondary">Monto mensual: <strong class="text-brown">$' + monto.toFixed(2) + '</strong></p>' +
                      '</div>',
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#97C78B',
                cancelButtonColor: '#5C4B43',
                confirmButtonText: '<i class="fas fa-heart me-2"></i> Sí, confirmar',
                cancelButtonText: '<i class="fas fa-times me-2"></i> Revisar',
                reverseButtons: true
            }).then((result) => {
                if (result.isConfirmed) {
                    // Deshabilitar botón para evitar doble envío
                    $('#btnConfirmar').prop('disabled', true)
                        .html('<i class="fas fa-spinner fa-spin me-2"></i> Procesando...');

                    // Enviar formulario
                    $('#formApadrinar').off('submit').submit();
                }
            });
        });

        // Alerta para usuarios no autenticados
        function showLoginAlert() {
            if (!@(User.Identity.IsAuthenticated ? "true" : "false")) {
                Swal.fire({
                    title: '¡Necesitas iniciar sesión!',
                    html: '<div class="text-center">' +
                          '<i class="fas fa-user-lock fa-3x text-green mb-3"></i>' +
                          '<h4 class="text-brown">Para apadrinar una mascota necesitas una cuenta</h4>' +
                          '<p class="text-secondary">Puedes iniciar sesión o crear una cuenta gratuita en segundos.</p>' +
                          '</div>',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#97C78B',
                    cancelButtonColor: '#5C4B43',
                    confirmButtonText: '<i class="fas fa-sign-in-alt me-2"></i> Iniciar Sesión',
                    cancelButtonText: '<i class="fas fa-user-plus me-2"></i> Crear Cuenta'
                }).then((result) => {
                    if (result.isConfirmed) {
                        window.location.href = '@Url.Action("Login", "Account")';
                    } else if (result.dismiss === Swal.DismissReason.cancel) {
                        window.location.href = '@Url.Action("Register", "Account")';
                    }
                });
            }
        }
    </script>
}