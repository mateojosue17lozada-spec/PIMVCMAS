@model MVCMASCOTAS.Models.ViewModels.MisApadrinamientosViewModel

@{
    ViewBag.Title = "Mis Apadrinamientos - ADOPTAMANÍA";
}

<!-- Hero Section -->
<section class="apadrinamientos-hero py-5">
    <div class="container text-center">
        <i class="fas fa-heart fa-4x text-white mb-4"></i>
        <h1 class="display-4 fw-bold mb-3 text-white">Mis Apadrinamientos</h1>
        <p class="lead mb-0 text-white">Aquí puedes ver y gestionar todos tus apadrinamientos activos</p>
    </div>
</section>

<!-- Main Content -->
<section class="py-5 bg-beige">
    <div class="container">
        <!-- Mensajes de TempData -->
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-beige border-green alert-dismissible fade show mb-4" role="alert">
                <i class="fas fa-exclamation-triangle text-green me-2"></i>
                <strong class="text-brown">@TempData["ErrorMessage"]</strong>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-beige border-green alert-dismissible fade show mb-4" role="alert">
                <i class="fas fa-check-circle text-green me-2"></i>
                <strong class="text-brown">@TempData["SuccessMessage"]</strong>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <!-- Resumen Financiero -->
        @if (Model.Resumen != null)
        {
            <div class="row g-3 mb-4">
                <div class="col-lg-3 col-md-6">
                    <div class="resumen-card text-center">
                        <i class="fas fa-paw fa-3x text-pink mb-2"></i>
                        <div class="resumen-valor">@Model.Resumen.MascotasApadrinadas</div>
                        <div class="resumen-label">Mascotas Apadrinadas</div>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6">
                    <div class="resumen-card text-center">
                        <i class="fas fa-hand-holding-heart fa-3x text-green mb-2"></i>
                        <div class="resumen-valor">$@Model.Resumen.TotalMensual.ToString("N2")</div>
                        <div class="resumen-label">Total Mensual</div>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6">
                    <div class="resumen-card text-center">
                        <i class="fas fa-chart-line fa-3x text-yellow mb-2"></i>
                        <div class="resumen-valor">$@Model.Resumen.TotalHistorico.ToString("N2")</div>
                        <div class="resumen-label">Total Contribuido</div>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6">
                    <div class="resumen-card text-center">
                        <i class="fas fa-history fa-3x text-info mb-2"></i>
                        <div class="resumen-valor">@Model.Resumen.PagosRealizados</div>
                        <div class="resumen-label">Pagos Realizados</div>
                    </div>
                </div>
            </div>
        }

        <!-- Pestañas -->
        <ul class="nav nav-tabs mb-4" id="myTab" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="activos-tab" data-bs-toggle="tab" data-bs-target="#activos" type="button" role="tab">
                    <i class="fas fa-heart me-2"></i> Activos (@Model.ApadrinamientosActivos.Count)
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="historial-tab" data-bs-toggle="tab" data-bs-target="#historial" type="button" role="tab">
                    <i class="fas fa-history me-2"></i> Historial (@Model.ApadrinamientosHistorial.Count)
                </button>
            </li>
        </ul>

        <div class="tab-content" id="myTabContent">
            <!-- Apadrinamientos Activos -->
            <div class="tab-pane fade show active" id="activos" role="tabpanel">
                @if (Model.ApadrinamientosActivos.Any())
                {
                    <div class="row g-4">
                        @foreach (var apadrinamiento in Model.ApadrinamientosActivos)
                        {
                            <div class="col-lg-6">
                                <div class="mascota-card h-100">
                                    <div class="row g-0">
                                        <div class="col-md-5">
                                            @if (apadrinamiento.MascotaImagen != null && apadrinamiento.MascotaImagen.Length > 0)
                                            {
                                                <img src="data:image/jpeg;base64,@Convert.ToBase64String(apadrinamiento.MascotaImagen)"
                                                     class="mascota-img"
                                                     alt="@apadrinamiento.MascotaNombre">
                                            }
                                            else
                                            {
                                                <div class="mascota-img-placeholder">
                                                    <i class="fas fa-paw fa-3x text-green"></i>
                                                </div>
                                            }
                                        </div>
                                        <div class="col-md-7">
                                            <div class="mascota-info">
                                                <div class="d-flex justify-content-between align-items-start mb-2">
                                                    <h5 class="mascota-nombre">@apadrinamiento.MascotaNombre</h5>
                                                    <span class="badge @(apadrinamiento.Estado == "Activo" ? "bg-green text-white" : "bg-yellow text-brown") px-3 py-2">
                                                        @apadrinamiento.Estado
                                                    </span>
                                                </div>
                                                <p class="mascota-especie">@apadrinamiento.MascotaEspecie</p>

                                                <div class="detalle-item">
                                                    <i class="fas fa-dollar-sign text-green me-2"></i>
                                                    <span class="text-brown">Monto mensual:</span>
                                                    <span class="fw-bold text-green">$@apadrinamiento.MontoMensual.ToString("N2")</span>
                                                </div>
                                                <div class="detalle-item">
                                                    <i class="fas fa-hand-holding-heart text-green me-2"></i>
                                                    <span class="text-brown">Total contribuido:</span>
                                                    <span class="fw-bold text-green">$@apadrinamiento.TotalContribuido.ToString("N2")</span>
                                                </div>
                                                <div class="detalle-item">
                                                    <i class="fas fa-calendar-alt text-green me-2"></i>
                                                    <span class="text-brown">Desde:</span> @apadrinamiento.FechaInicio.ToString("dd/MM/yyyy")
                                                </div>
                                                <div class="detalle-item">
                                                    <i class="fas fa-clock text-green me-2"></i>
                                                    <span class="text-brown">Meses activo:</span> @apadrinamiento.MesesActivo
                                                </div>

                                                @if (apadrinamiento.ProximoPago.HasValue)
                                                {
                                                    <div class="alert alert-beige border-green small mt-2">
                                                        <i class="fas fa-calendar-check text-green me-2"></i>
                                                        <strong class="text-brown">Próximo pago:</strong>
                                                        <span class="text-brown">@apadrinamiento.ProximoPago.Value.ToString("dd/MM/yyyy")</span>
                                                    </div>
                                                }

                                                <div class="d-flex flex-wrap gap-2 mt-3">
                                                    <a href="@Url.Action("Detalle", "Apadrinar", new { id = apadrinamiento.ApadrinamientoId })"
                                                       class="btn btn-outline-green btn-sm">
                                                        <i class="fas fa-info-circle me-2"></i> Ver Detalle
                                                    </a>

                                                    @if (apadrinamiento.Estado == "Activo")
                                                    {
                                                        using (Html.BeginForm("Pausar", "Apadrinar", new { id = apadrinamiento.ApadrinamientoId }, FormMethod.Post, new { @class = "d-inline" }))
                                                        {
                                                            @Html.AntiForgeryToken()
                                                            <button type="submit" class="btn btn-yellow btn-sm">
                                                                <i class="fas fa-pause me-2"></i> Pausar
                                                            </button>
                                                        }
                                                    }
                                                    else if (apadrinamiento.Estado == "Pausado")
                                                    {
                                                        using (Html.BeginForm("Reactivar", "Apadrinar", new { id = apadrinamiento.ApadrinamientoId }, FormMethod.Post, new { @class = "d-inline" }))
                                                        {
                                                            @Html.AntiForgeryToken()
                                                            <button type="submit" class="btn btn-green btn-sm">
                                                                <i class="fas fa-play me-2"></i> Reactivar
                                                            </button>
                                                        }
                                                    }

                                                    <button type="button" class="btn btn-pink btn-sm"
                                                            onclick="confirmarCancelacion(@apadrinamiento.ApadrinamientoId, '@apadrinamiento.MascotaNombre')">
                                                        <i class="fas fa-times-circle me-2"></i> Cancelar
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-state">
                        <i class="fas fa-heart"></i>
                        <h4>No tienes apadrinamientos activos</h4>
                        <p>¡Es un excelente momento para apadrinar a una mascota que necesita tu ayuda!</p>
                        <a href="@Url.Action("Index", "Apadrinar")" class="btn btn-green btn-lg">
                            <i class="fas fa-paw me-2"></i> Apadrinar una Mascota
                        </a>
                    </div>
                }
            </div>

            <!-- Historial -->
            <div class="tab-pane fade" id="historial" role="tabpanel">
                @if (Model.ApadrinamientosHistorial.Any())
                {
                    <div class="row g-3">
                        @foreach (var apadrinamiento in Model.ApadrinamientosHistorial)
                        {
                            <div class="col-md-4">
                                <div class="historial-card">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <h6 class="text-brown mb-0">@apadrinamiento.MascotaNombre</h6>
                                        <span class="badge @(apadrinamiento.Estado == "Completado" ? "bg-green text-white" : "bg-pink text-brown") px-2 py-1">
                                            @apadrinamiento.Estado
                                        </span>
                                    </div>
                                    <div class="small">
                                        <div><i class="fas fa-dog text-green me-2"></i> @apadrinamiento.MascotaEspecie</div>
                                        <div><i class="fas fa-dollar-sign text-green me-2"></i> $@apadrinamiento.MontoMensual.ToString("N2")/mes</div>
                                        <div><i class="fas fa-hand-holding-heart text-green me-2"></i> Total: $@apadrinamiento.TotalContribuido.ToString("N2")</div>
                                        <div><i class="fas fa-clock text-green me-2"></i> @apadrinamiento.MesesActivo meses</div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-state">
                        <i class="fas fa-history"></i>
                        <h4>No hay historial de apadrinamientos</h4>
                        <p>Aquí aparecerán tus apadrinamientos completados o cancelados.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

@section Styles {
    <style>
        :root {
            --green: #97C78B;
            --yellow: #F2C66D;
            --pink: #FBCDC0;
            --brown: #2F2F2F;
            --bg-light: #F2E9D8;
            --beige: #F5E6D3;
            --text-secondary: #555555;
            --info: #17a2b8;
        }

        body {
            background-color: var(--beige);
        }

        /* Hero */
        .apadrinamientos-hero {
            background: linear-gradient(135deg, rgba(151,199,139,0.9), rgba(242,198,109,0.8)), url('https://images.unsplash.com/photo-1548199973-03cce0bbc87b?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80');
            background-size: cover;
            background-position: center;
            border-radius: 0 0 30px 30px;
            margin-bottom: 1rem;
        }

        /* Tarjetas de resumen */
        .resumen-card {
            background: white;
            border-radius: 24px;
            padding: 1.5rem;
            box-shadow: 0 8px 20px rgba(151,199,139,0.15);
            transition: transform 0.3s, box-shadow 0.3s;
            border: none;
        }

            .resumen-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 15px 30px rgba(151,199,139,0.25);
            }

        .resumen-valor {
            font-size: 2.5rem;
            font-weight: 700;
            color: var(--brown);
            line-height: 1.2;
            margin: 0.5rem 0 0.2rem;
        }

        .resumen-label {
            font-size: 1rem;
            color: var(--text-secondary);
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        /* Pestañas */
        .nav-tabs {
            border-bottom: 2px solid var(--green);
            gap: 0.5rem;
        }

            .nav-tabs .nav-link {
                border: none;
                color: var(--text-secondary);
                font-weight: 500;
                border-radius: 30px 30px 0 0;
                padding: 0.8rem 1.8rem;
                transition: background-color 0.2s, color 0.2s;
            }

                .nav-tabs .nav-link:hover {
                    background-color: var(--bg-light);
                    color: var(--brown);
                }

                .nav-tabs .nav-link.active {
                    background-color: var(--green);
                    color: white;
                }

        /* Tarjetas de mascotas */
        .mascota-card {
            background: white;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 8px 20px rgba(151,199,139,0.15);
            transition: transform 0.3s, box-shadow 0.3s;
            border: none;
        }

            .mascota-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 15px 30px rgba(151,199,139,0.25);
            }

        .mascota-img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            min-height: 250px;
        }

        .mascota-img-placeholder {
            background-color: var(--bg-light);
            width: 100%;
            height: 100%;
            min-height: 250px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-right: 2px solid var(--green);
        }

        .mascota-info {
            padding: 1.5rem;
        }

        .mascota-nombre {
            font-size: 1.3rem;
            color: var(--brown);
            font-weight: 600;
        }

        .mascota-especie {
            color: var(--text-secondary);
            margin-bottom: 1rem;
            font-size: 0.9rem;
        }

        .detalle-item {
            margin-bottom: 0.4rem;
            font-size: 0.95rem;
            color: var(--text-secondary);
        }

            .detalle-item i {
                width: 1.2rem;
            }

        /* Historial */
        .historial-card {
            background: white;
            border-radius: 16px;
            padding: 1rem;
            box-shadow: 0 4px 12px rgba(151,199,139,0.1);
            border-left: 4px solid var(--green);
        }

        /* Badges */
        .badge.bg-green {
            background-color: var(--green) !important;
            color: white !important;
        }

        .badge.bg-yellow {
            background-color: var(--yellow) !important;
            color: var(--brown) !important;
        }

        .badge.bg-pink {
            background-color: var(--pink) !important;
            color: var(--brown) !important;
        }

        /* Alertas */
        .alert-beige {
            background-color: var(--bg-light);
            border: 1px solid var(--green);
            color: var(--brown);
            border-radius: 16px;
        }

        /* Botones */
        .btn-green {
            background-color: var(--green);
            border: none;
            border-radius: 50px;
            padding: 0.5rem 1.5rem;
            font-weight: 500;
            transition: all 0.3s;
            color: white;
        }

            .btn-green:hover {
                background-color: #86b57a;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(151,199,139,0.4);
            }

        .btn-yellow {
            background-color: var(--yellow);
            border: none;
            border-radius: 50px;
            padding: 0.5rem 1.5rem;
            font-weight: 500;
            transition: all 0.3s;
            color: var(--brown);
        }

            .btn-yellow:hover {
                background-color: #e6b85c;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(242,198,109,0.4);
            }

        .btn-pink {
            background-color: var(--pink);
            border: none;
            border-radius: 50px;
            padding: 0.5rem 1.5rem;
            font-weight: 500;
            transition: all 0.3s;
            color: var(--brown);
        }

            .btn-pink:hover {
                background-color: #f9c2b0;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(249,194,176,0.4);
            }

        .btn-outline-green {
            border: 2px solid var(--green);
            background: transparent;
            color: var(--green);
            border-radius: 50px;
            padding: 0.5rem 1.5rem;
            font-weight: 500;
            transition: all 0.3s;
        }

            .btn-outline-green:hover {
                background-color: var(--green);
                color: white;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(151,199,139,0.3);
            }

        /* Empty state */
        .empty-state {
            background: white;
            border-radius: 24px;
            padding: 4rem 2rem;
            text-align: center;
            box-shadow: 0 8px 20px rgba(151,199,139,0.15);
            border: 2px dashed var(--green);
        }

            .empty-state i {
                font-size: 5rem;
                color: var(--green);
                margin-bottom: 1rem;
                opacity: 0.5;
            }

            .empty-state h4 {
                color: var(--brown);
                margin-bottom: 0.5rem;
                font-weight: 600;
            }

            .empty-state p {
                color: var(--text-secondary);
                margin-bottom: 1.5rem;
            }

        /* Responsive */
        @@media (max-width: 768px) {
            .mascota-img, .mascota-img-placeholder {
                min-height: 200px;
            }

            .mascota-img-placeholder {
                border-right: none;
                border-bottom: 2px solid var(--green);
            }
        }
    </style>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function () {
            // Confirmación para cancelar apadrinamiento
            window.confirmarCancelacion = function (id, mascotaNombre) {
                Swal.fire({
                    title: '¿Cancelar apadrinamiento?',
                    html: `<div class="text-center">
                              <i class="fas fa-exclamation-triangle fa-3x text-yellow mb-3"></i>
                              <h4 class="text-brown">¿Estás seguro de cancelar el apadrinamiento de <strong>${mascotaNombre}</strong>?</h4>
                              <p class="text-secondary">Esta acción no se puede deshacer.</p>
                           </div>`,
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#FBCDC0',
                    cancelButtonColor: '#97C78B',
                    confirmButtonText: '<i class="fas fa-times-circle me-2"></i> Sí, cancelar',
                    cancelButtonText: '<i class="fas fa-times me-2"></i> No, mantener',
                    reverseButtons: true
                }).then((result) => {
                    if (result.isConfirmed) {
                        // Crear formulario dinámico para enviar la cancelación
                        const form = document.createElement('form');
                        form.method = 'POST';
                        form.action = '@Url.Action("Cancelar", "Apadrinar")' + '/' + id;

                        const token = document.createElement('input');
                        token.type = 'hidden';
                        token.name = '__RequestVerificationToken';
                        token.value = $('input[name="__RequestVerificationToken"]').first().val();

                        form.appendChild(token);
                        document.body.appendChild(form);
                        form.submit();
                    }
                });
            };

            // Auto-ocultar alertas después de 5 segundos
            setTimeout(function () {
                $('.alert-dismissible').alert('close');
            }, 5000);
        });
    </script>
}