@{
    ViewBag.Title = "Registrar Consulta Veterinaria";
}

<div class="page-header mb-4">
    <h2><i class="fas fa-stethoscope"></i> Registrar Consulta Veterinaria</h2>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card shadow-custom">
            <div class="card-body">
                @using (Html.BeginForm("RegistrarConsulta", "Veterinario", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()

                    <div class="form-group">
                        <label><i class="fas fa-paw"></i> Mascota *</label>
                        <select name="MascotaId" class="form-control" required>
                            <option value="">Seleccione una mascota...</option>
                            @if (ViewBag.Mascotas != null)
                            {
                                foreach (var mascota in ViewBag.Mascotas)
                                {
                                    <option value="@mascota.MascotaId"
                                            @(ViewBag.MascotaId != null && ViewBag.MascotaId == mascota.MascotaId ? "selected" : "")>
                                        @mascota.Nombre - @mascota.Especie (@mascota.Raza)
                                    </option>
                                }
                            }
                        </select>
                    </div>

                    <div class="form-group">
                        <label><i class="fas fa-calendar"></i> Fecha de Consulta *</label>
                        <input type="date" name="FechaConsulta" class="form-control"
                               value="@DateTime.Now.ToString("yyyy-MM-dd")" required />
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label><i class="fas fa-weight"></i> Peso (kg):</label>
                                <input type="number" name="Peso" class="form-control"
                                       step="0.1" min="0" max="200" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label><i class="fas fa-thermometer-half"></i> Temperatura (°C):</label>
                                <input type="number" name="Temperatura" class="form-control"
                                       step="0.1" min="30" max="45" />
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label><i class="fas fa-notes-medical"></i> Motivo de Consulta *</label>
                        <textarea name="MotivoConsulta" class="form-control" rows="2"
                                  placeholder="Ej: Control rutinario, síntomas de enfermedad, etc." required></textarea>
                    </div>

                    <div class="form-group">
                        <label><i class="fas fa-diagnoses"></i> Diagnóstico *</label>
                        <textarea name="Diagnostico" class="form-control" rows="3"
                                  placeholder="Diagnóstico médico detallado" required></textarea>
                    </div>

                    <div class="form-group">
                        <label><i class="fas fa-pills"></i> Tratamiento *</label>
                        <textarea name="Tratamiento" class="form-control" rows="3"
                                  placeholder="Medicamentos, dosis, frecuencia, etc." required></textarea>
                    </div>

                    <div class="form-group">
                        <label><i class="fas fa-comment-medical"></i> Observaciones:</label>
                        <textarea name="Observaciones" class="form-control" rows="2"
                                  placeholder="Observaciones adicionales"></textarea>
                    </div>

                    <div class="form-group">
                        <label><i class="fas fa-calendar-check"></i> Próxima Consulta:</label>
                        <input type="date" name="ProximaConsulta" class="form-control" />
                    </div>

                    <div class="text-center">
                        <button type="submit" class="btn btn-success btn-lg">
                            <i class="fas fa-save"></i> Guardar Consulta
                        </button>
                        <a href="@Url.Action("Dashboard", "Veterinario")" class="btn btn-secondary btn-lg ml-2">
                            <i class="fas fa-times"></i> Cancelar
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-md-4">
        @if (ViewBag.Mascota != null)
        {
            <div class="card shadow-custom mb-3">
                <div class="card-header bg-primary text-white">
                    <h5><i class="fas fa-paw"></i> Datos de la Mascota</h5>
                </div>
                <div class="card-body">
                    @if (ViewBag.ImagenBase64 != null)
                    {
                        <img src="@ViewBag.ImagenBase64" class="img-fluid rounded mb-3"
                             alt="@ViewBag.Mascota.Nombre" />
                    }
                    <p><strong>Nombre:</strong> @ViewBag.Mascota.Nombre</p>
                    <p><strong>Especie:</strong> @ViewBag.Mascota.Especie</p>
                    <p><strong>Raza:</strong> @ViewBag.Mascota.Raza</p>
                    <p><strong>Edad:</strong> @ViewBag.Mascota.EdadAproximada</p>
                    <p><strong>Sexo:</strong> @ViewBag.Mascota.Sexo</p>
                </div>
            </div>
        }

        <div class="card shadow-custom">
            <div class="card-header bg-info text-white">
                <h5><i class="fas fa-info-circle"></i> Información</h5>
            </div>
            <div class="card-body">
                <p><strong>Veterinario:</strong> @User.Identity.Name</p>
                <p><strong>Fecha:</strong> @DateTime.Now.ToString("dd/MM/yyyy")</p>
                <hr />
                <h6>Valores de Referencia:</h6>
                <ul class="small">
                    <li><strong>Temperatura:</strong> 38-39°C</li>
                    <li><strong>Frec. cardíaca:</strong> 60-140 lpm</li>
                    <li><strong>Frec. respiratoria:</strong> 10-30 rpm</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .shadow-custom {
            box-shadow: 0 0.125rem 0.25rem rgba(0,0,0,0.075);
        }
    </style>
}