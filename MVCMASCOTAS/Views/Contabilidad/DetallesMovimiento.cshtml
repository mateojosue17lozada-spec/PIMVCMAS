@model MVCMASCOTAS.Models.MovimientosContables

@{
    ViewBag.Title = "Detalles del Movimiento";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="page-header mb-4">
        <h2><i class="fas fa-file-invoice-dollar"></i> Detalles del Movimiento</h2>
        <p class="text-muted">Información completa del movimiento contable</p>
    </div>

    <div class="mb-4">
        <a href="@Url.Action("Movimientos", "Contabilidad")" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left"></i> Volver a Movimientos
        </a>
        <a href="@Url.Action("EditarMovimiento", "Contabilidad", new { id = Model?.MovimientoId })" class="btn btn-warning">
            <i class="fas fa-edit"></i> Editar
        </a>
    </div>

    @if (Model == null)
    {
        <div class="alert alert-danger">
            <i class="fas fa-exclamation-triangle"></i> No se encontró el movimiento solicitado.
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-md-8">
                <div class="card shadow-custom mb-4">
                    <div class="card-header @(Model.TipoMovimiento == "Ingreso" ? "bg-success" : "bg-danger") text-white">
                        <h4 class="mb-0">
                            <i class="fas fa-@(Model.TipoMovimiento == "Ingreso" ? "arrow-up" : "arrow-down")"></i>
                            @Model.TipoMovimiento
                        </h4>
                    </div>
                    <div class="card-body">
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="text-muted"><strong>ID del Movimiento:</strong></label>
                                <p class="mb-0">#@Model.MovimientoId</p>
                            </div>
                            <div class="col-md-6">
                                <label class="text-muted"><strong>Fecha del Movimiento:</strong></label>
                                <p class="mb-0">
                                    @if (Model.FechaMovimiento.HasValue)
                                    {
                                        @Model.FechaMovimiento.Value.ToString("dddd, dd 'de' MMMM 'de' yyyy")
                                    }
                                    else
                                    {
                                        <span class="text-muted">No especificada</span>
                                    }
                                </p>
                            </div>
                        </div>

                        <hr />

                        <div class="row mb-3">
                            <div class="col-md-12">
                                <label class="text-muted"><strong>Categoría:</strong></label>
                                <p class="mb-0">
                                    <span class="badge bg-primary badge-lg">@Model.Categoria</span>
                                </p>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-12">
                                <label class="text-muted"><strong>Concepto:</strong></label>
                                <p class="mb-0">@Model.Concepto</p>
                            </div>
                        </div>

                        <hr />

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="text-muted"><strong>Monto:</strong></label>
                                <h3 class="@(Model.TipoMovimiento == "Ingreso" ? "text-success" : "text-danger") mb-0">
                                    @(Model.TipoMovimiento == "Ingreso" ? "+" : "-")$@Model.Monto.ToString("N2")
                                </h3>
                            </div>
                            <div class="col-md-6">
                                <label class="text-muted"><strong>Método de Pago:</strong></label>
                                <p class="mb-0">
                                    @if (!string.IsNullOrEmpty(Model.MetodoPago))
                                    {
                                        <i class="fas fa-credit-card"></i> @Model.MetodoPago
                                    }
                                    else
                                    {
                                        <span class="text-muted">No especificado</span>
                                    }
                                </p>
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(Model.NumeroComprobante))
                        {
                            <div class="row mb-3">
                                <div class="col-md-12">
                                    <label class="text-muted"><strong>Número de Comprobante:</strong></label>
                                    <p class="mb-0">
                                        <code>@Model.NumeroComprobante</code>
                                    </p>
                                </div>
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(Model.Observaciones))
                        {
                            <hr />
                            <div class="row mb-3">
                                <div class="col-md-12">
                                    <label class="text-muted"><strong>Observaciones:</strong></label>
                                    <p class="mb-0">@Model.Observaciones</p>
                                </div>
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(Model.TipoReferencia))
                        {
                            <hr />
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label class="text-muted"><strong>Tipo de Referencia:</strong></label>
                                    <p class="mb-0">@Model.TipoReferencia</p>
                                </div>
                                @if (Model.ReferenciaId.HasValue)
                                {
                                    <div class="col-md-6">
                                        <label class="text-muted"><strong>ID de Referencia:</strong></label>
                                        <p class="mb-0">#@Model.ReferenciaId.Value</p>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card shadow-custom mb-4">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0"><i class="fas fa-user"></i> Información del Registro</h5>
                    </div>
                    <div class="card-body">
                        <label class="text-muted"><strong>Responsable del Registro:</strong></label>
                        <p class="mb-3">
                            @if (Model.Usuarios != null)
                            {
                                <i class="fas fa-user-circle"></i> @Model.Usuarios.NombreCompleto
                                <br />
                                <small class="text-muted">@Model.Usuarios.Email</small>
                            }
                            else
                            {
                                <span class="text-muted">No especificado</span>
                            }
                        </p>

                        @if (!string.IsNullOrEmpty(Model.ComprobanteAdjunto))
                        {
                            <hr />
                            <label class="text-muted"><strong>Comprobante Adjunto:</strong></label>
                            <p>
                                <a href="@Model.ComprobanteAdjunto" target="_blank" class="btn btn-sm btn-outline-primary">
                                    <i class="fas fa-file-pdf"></i> Ver Comprobante
                                </a>
                            </p>
                        }
                    </div>
                </div>

                <div class="card shadow-custom">
                    <div class="card-header bg-secondary text-white">
                        <h5 class="mb-0"><i class="fas fa-cog"></i> Acciones</h5>
                    </div>
                    <div class="card-body">
                        <a href="@Url.Action("EditarMovimiento", "Contabilidad", new { id = Model.MovimientoId })"
                           class="btn btn-warning btn-block mb-2">
                            <i class="fas fa-edit"></i> Editar Movimiento
                        </a>
                        <a href="@Url.Action("Movimientos", "Contabilidad")"
                           class="btn btn-outline-secondary btn-block mb-2">
                            <i class="fas fa-list"></i> Ver Todos los Movimientos
                        </a>
                        <a href="@Url.Action("Dashboard", "Contabilidad")"
                           class="btn btn-outline-primary btn-block">
                            <i class="fas fa-chart-line"></i> Ir al Dashboard
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .shadow-custom {
        box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
        border: 1px solid rgba(0, 0, 0, 0.125);
    }

    .card {
        border-radius: 8px;
    }

    .page-header h2 {
        color: #2c3e50;
        font-weight: 600;
    }

    .badge-lg {
        padding: 0.5rem 1rem;
        font-size: 1rem;
    }

    label.text-muted {
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 0.3rem;
    }

    code {
        background-color: #f8f9fa;
        padding: 0.2rem 0.5rem;
        border-radius: 3px;
        color: #495057;
    }

    .btn-block {
        width: 100%;
    }
</style>