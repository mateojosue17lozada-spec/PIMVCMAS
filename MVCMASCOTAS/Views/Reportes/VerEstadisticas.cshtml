@model MVCMASCOTAS.Models.CustomModels.Reportes.EstadisticasGeneralesReporteModel
@{ ViewBag.Title = "Estadísticas Generales"; Layout = "~/Views/Shared/_Layout.cshtml"; }
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-chart-pie text-purple"></i> Estadísticas Generales</h2>
        <div>
            <a href="@Url.Action("ReporteEstadisticas", "Reportes")" class="btn btn-purple mr-2" style="background:#9C27B0;color:white;">
                <i class="fas fa-file-pdf"></i> Exportar PDF
            </a>
            <a href="@Url.Action("Index", "Reportes")" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Volver</a>
        </div>
    </div>

    <!-- KPIs principales -->
    <div class="row mb-4">
        <div class="col-md-3"><div class="card text-white" style="background:#9C27B0"><div class="card-body text-center"><h2>@Model.TotalMascotas</h2><p class="mb-0">Total Mascotas</p></div></div></div>
        <div class="col-md-3"><div class="card text-white bg-danger"><div class="card-body text-center"><h2>@Model.TotalAdopciones</h2><p class="mb-0">Total Adopciones</p></div></div></div>
        <div class="col-md-3"><div class="card text-white bg-warning"><div class="card-body text-center"><h2>@Model.SolicitudesPendientes</h2><p class="mb-0">Solicitudes Pendientes</p></div></div></div>
        <div class="col-md-3"><div class="card text-white bg-info"><div class="card-body text-center"><h2>@Model.SeguimientosPendientes</h2><p class="mb-0">Seguimientos Pendientes</p></div></div></div>
    </div>

    <!-- Este mes -->
    <div class="row mb-4">
        <div class="col-md-4"><div class="card border-success"><div class="card-body text-center"><h4 class="text-success">@Model.AdopcionesEsteMes</h4><p>Adopciones este mes</p></div></div></div>
        <div class="col-md-4"><div class="card border-primary"><div class="card-body text-center"><h4 class="text-primary">@Model.SolicitudesEsteMes</h4><p>Solicitudes este mes</p></div></div></div>
        <div class="col-md-4"><div class="card border-info"><div class="card-body text-center"><h4 class="text-info">@Model.IngresosEsteMes</h4><p>Ingresos este mes</p></div></div></div>
    </div>

    <!-- Gráficas -->
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-header text-white" style="background:#9C27B0">Distribución por Especie</div>
                <div class="card-body"><canvas id="graficaEspecie" height="220"></canvas></div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-header text-white" style="background:#9C27B0">Distribución por Estado</div>
                <div class="card-body"><canvas id="graficaEstado" height="220"></canvas></div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-header text-white" style="background:#9C27B0">Métricas Clave</div>
                <div class="card-body">
                    <table class="table table-sm">
                        <tr><td>Promedio días adopción</td><td><strong>@Model.PromedioDiasAdopcion.ToString("F1") días</strong></td></tr>
                        <tr><td>Sin adoptar +6 meses</td><td><strong class="text-danger">@Model.MascotasSinAdoptarLargoPlazo</strong></td></tr>
                        <tr><td>Perros</td><td><strong>@Model.TotalPerros</strong></td></tr>
                        <tr><td>Gatos</td><td><strong>@Model.TotalGatos</strong></td></tr>
                        <tr><td>Otros</td><td><strong>@Model.TotalOtros</strong></td></tr>
                        <tr><td>Disponibles</td><td><strong class="text-success">@Model.Disponibles</strong></td></tr>
                        <tr><td>En tratamiento</td><td><strong class="text-warning">@Model.EnTratamiento</strong></td></tr>
                        <tr><td>Adoptadas</td><td><strong class="text-primary">@Model.Adoptadas</strong></td></tr>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <small class="text-muted">Generado el @Model.FechaGeneracion.ToString("dd/MM/yyyy HH:mm")</small>
</div>

@section scripts {
    <script>
    new Chart(document.getElementById('graficaEspecie'),{type:'doughnut',data:{labels:['Perros','Gatos','Otros'],datasets:[{data:[@Model.TotalPerros,@Model.TotalGatos,@Model.TotalOtros],backgroundColor:['#FF6B6B','#4CAF50','#2196F3']}]}});
    new Chart(document.getElementById('graficaEstado'),{type:'doughnut',data:{labels:['Disponibles','En Tratamiento','Adoptadas','Rescatadas'],datasets:[{data:[@Model.Disponibles,@Model.EnTratamiento,@Model.Adoptadas,@Model.Rescatadas],backgroundColor:['#4CAF50','#FF9800','#2196F3','#9C27B0']}]}});
    </script>
}