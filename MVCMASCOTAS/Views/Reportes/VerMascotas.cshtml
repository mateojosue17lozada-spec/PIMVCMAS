@model List<MVCMASCOTAS.Models.CustomModels.Reportes.MascotaRegistradaReporteModel>
@{
    ViewBag.Title = "Reporte de Mascotas";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <style>
        @@media print {
            nav, .navbar, footer, .no-print, hr {
                display: none !important;
            }

            .container-fluid {
                width: 100% !important;
                padding: 0 !important;
            }

            .table {
                font-size: 9px;
            }

            .card {
                border: none !important;
                box-shadow: none !important;
            }

            .card-header {
                -webkit-print-color-adjust: exact;
                print-color-adjust: exact;
            }

            body {
                margin: 0;
                background: white !important;
            }
        }

        #titulo-impresion {
            display: none;
        }
    </style>
}

<div class="container-fluid">

    <!-- Título visible SOLO al imprimir -->
    <div id="titulo-impresion" class="text-center mb-3">
        <h3>ADOPTAMANÍA — Reporte de Mascotas</h3>
        <p>Generado el @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</p>
        <hr />
    </div>

    <!-- Cabecera de pantalla -->
    <div class="d-flex justify-content-between align-items-center mb-4 no-print">
        <h2><i class="fas fa-paw text-success"></i> Reporte de Mascotas</h2>
        <div>
            <a href="@Url.Action("ExportarExcelMascotas", "Reportes", new { especie = ViewBag.Especie, estado = ViewBag.Estado, sexo = ViewBag.Sexo, soloActivas = ViewBag.SoloActivas })"
               class="btn btn-success mr-2">
                <i class="fas fa-file-excel"></i> Exportar Excel
            </a>
            <button onclick="window.print()" class="btn btn-danger mr-2">
                <i class="fas fa-file-pdf"></i> Exportar PDF
            </button>
            <a href="@Url.Action("Index", "Reportes")" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Volver
            </a>
        </div>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-warning">No hay mascotas para los filtros seleccionados.</div>
    }
    else
    {
        <!-- Cards resumen (solo pantalla) -->
        <div class="row mb-4 no-print">
            <div class="col-md-3">
                <div class="card text-white bg-success">
                    <div class="card-body text-center">
                        <h3>@Model.Count</h3><p class="mb-0">Total Mascotas</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-white bg-primary">
                    <div class="card-body text-center">
                        <h3>@Model.Count(m => m.Especie == "Perro")</h3><p class="mb-0">Perros</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-white bg-info">
                    <div class="card-body text-center">
                        <h3>@Model.Count(m => m.Especie == "Gato")</h3><p class="mb-0">Gatos</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-white bg-warning">
                    <div class="card-body text-center">
                        <h3>@Model.Count(m => m.Estado == "Disponible para adopción")</h3><p class="mb-0">Disponibles</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Gráficas (solo pantalla) -->
        <div class="row mb-4 no-print">
            <div class="col-md-4">
                <div class="card shadow-sm">
                    <div class="card-header bg-success text-white">Por Especie</div>
                    <div class="card-body"><canvas id="graficaEspecie" height="220"></canvas></div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card shadow-sm">
                    <div class="card-header bg-success text-white">Por Estado</div>
                    <div class="card-body"><canvas id="graficaEstado" height="220"></canvas></div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card shadow-sm">
                    <div class="card-header bg-success text-white">Por Sexo</div>
                    <div class="card-body"><canvas id="graficaSexo" height="220"></canvas></div>
                </div>
            </div>
        </div>

        <!-- Tabla -->
        <div class="card shadow-sm">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0">Detalle de Mascotas (@Model.Count registros)</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-striped table-bordered mb-0">
                        <thead class="thead-dark">
                            <tr>
                                <th>Nombre</th>
                                <th>Especie</th>
                                <th>Raza</th>
                                <th>Sexo</th>
                                <th>Edad</th>
                                <th>Tamaño</th>
                                <th>Color</th>
                                <th>Estado</th>
                                <th>Esterilizado</th>
                                <th>Microchip</th>
                                <th>F. Ingreso</th>
                                <th>Días Refugio</th>
                                <th>Veterinario</th>
                                <th>Tratamientos</th>
                                <th>Vacunas</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td><strong>@item.Nombre</strong></td>
                                    <td>@item.Especie</td>
                                    <td>@item.Raza</td>
                                    <td>@item.Sexo</td>
                                    <td>@item.EdadAproximada</td>
                                    <td>@item.Tamanio</td>
                                    <td>@item.Color</td>
                                    <td>
                                        <span class="badge @(item.Estado == "Disponible para adopción" ? "badge-success" : item.Estado == "Adoptada" ? "badge-primary" : "badge-warning")">
                                            @item.Estado
                                        </span>
                                    </td>
                                    <td>@(item.Esterilizado == true ? "Sí" : "No")</td>
                                    <td>@item.Microchip</td>
                                    <td>@(item.FechaIngreso.HasValue ? item.FechaIngreso.Value.ToString("dd/MM/yyyy") : "-")</td>
                                    <td>@item.DiasEnRefugio días</td>
                                    <td>@item.VeterinarioAsignado</td>
                                    <td>@item.TotalTratamientos</td>
                                    <td>@item.TotalVacunas</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <small class="text-muted no-print">Generado el @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</small>
    }
</div>

@section Scripts {
    <script>
    window.onbeforeprint = function () { document.getElementById('titulo-impresion').style.display = 'block'; };
    window.onafterprint  = function () { document.getElementById('titulo-impresion').style.display = 'none'; };

    @if (Model != null && Model.Any())
    {
        <text>
        var colores = ['#4CAF50','#2196F3','#FF9800','#FF6B6B','#9C27B0','#00BCD4'];
        var especies = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.GroupBy(m => m.Especie).Select(g => new { label = g.Key, count = g.Count() }).ToList()));
        var estados  = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.GroupBy(m => m.Estado).Select(g => new { label = g.Key, count = g.Count() }).ToList()));
        var sexos    = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.GroupBy(m => m.Sexo).Select(g => new { label = g.Key, count = g.Count() }).ToList()));
        new Chart(document.getElementById('graficaEspecie'), { type: 'doughnut', data: { labels: especies.map(e=>e.label), datasets: [{ data: especies.map(e=>e.count), backgroundColor: colores }] } });
        new Chart(document.getElementById('graficaEstado'),  { type: 'doughnut', data: { labels: estados.map(e=>e.label),  datasets: [{ data: estados.map(e=>e.count),  backgroundColor: colores }] } });
        new Chart(document.getElementById('graficaSexo'),    { type: 'pie',      data: { labels: sexos.map(e=>e.label),    datasets: [{ data: sexos.map(e=>e.count),    backgroundColor: ['#2196F3','#FF6B6B'] }] } });
        </text>
    }
    </script>
}
