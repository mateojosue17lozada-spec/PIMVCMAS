@model List<MVCMASCOTAS.Models.CustomModels.Reportes.SeguimientoPostAdopcionReporteModel>
@{
    ViewBag.Title = "Reporte de Seguimientos";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <style>
        @@media print {
            nav, .navbar, footer, .no-print, hr {
                display: none !important;
            }

            .container-fluid {
                width: 100% !important;
                padding: 0 !important;
            }

            .table {
                font-size: 9px;
            }

            .card {
                border: none !important;
                box-shadow: none !important;
            }

            .card-header {
                -webkit-print-color-adjust: exact;
                print-color-adjust: exact;
            }

            body {
                margin: 0;
                background: white !important;
            }
        }

        #titulo-impresion {
            display: none;
        }
    </style>
}

<div class="container-fluid">

    <!-- Título visible SOLO al imprimir -->
    <div id="titulo-impresion" class="text-center mb-3">
        <h3>ADOPTAMANÍA — Reporte de Seguimientos Post-Adopción</h3>
        <p>Generado el @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</p>
        <hr />
    </div>

    <!-- Cabecera de pantalla -->
    <div class="d-flex justify-content-between align-items-center mb-4 no-print">
        <h2><i class="fas fa-chart-line text-info"></i> Reporte de Seguimientos</h2>
        <div>
            <a href="@Url.Action("ExportarExcelSeguimientos", "Reportes", new { tipo = ViewBag.Tipo, fechaDesde = ViewBag.FechaDesde, fechaHasta = ViewBag.FechaHasta })"
               class="btn btn-success mr-2">
                <i class="fas fa-file-excel"></i> Exportar Excel
            </a>
            <button onclick="window.print()" class="btn btn-danger mr-2">
                <i class="fas fa-file-pdf"></i> Exportar PDF
            </button>
            <a href="@Url.Action("Index", "Reportes")" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Volver
            </a>
        </div>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-warning">No hay seguimientos para los filtros seleccionados.</div>
    }
    else
    {
        <!-- Cards resumen (solo pantalla) -->
        <div class="row mb-4 no-print">
            <div class="col-md-3">
                <div class="card text-white bg-info">
                    <div class="card-body text-center">
                        <h3>@Model.Count</h3><p class="mb-0">Total</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-white bg-success">
                    <div class="card-body text-center">
                        <h3>@Model.Count(s => s.EstadoSeguimiento == "Realizado")</h3><p class="mb-0">Realizados</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-white bg-warning">
                    <div class="card-body text-center">
                        <h3>@Model.Count(s => s.EstadoSeguimiento == "Pendiente")</h3><p class="mb-0">Pendientes</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-white bg-danger">
                    <div class="card-body text-center">
                        <h3>@Model.Count(s => s.EstadoSeguimiento == "Vencido")</h3><p class="mb-0">Vencidos</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Gráficas (solo pantalla) -->
        <div class="row mb-4 no-print">
            <div class="col-md-6">
                <div class="card shadow-sm">
                    <div class="card-header bg-info text-white">Estado de Seguimientos</div>
                    <div class="card-body"><canvas id="graficaEstado" height="200"></canvas></div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card shadow-sm">
                    <div class="card-header bg-info text-white">Requieren Intervención</div>
                    <div class="card-body"><canvas id="graficaIntervencion" height="200"></canvas></div>
                </div>
            </div>
        </div>

        <!-- Tabla -->
        <div class="card shadow-sm">
            <div class="card-header bg-info text-white">
                <h5 class="mb-0">Detalle de Seguimientos (@Model.Count registros)</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-striped table-bordered mb-0">
                        <thead class="thead-dark">
                            <tr>
                                <th>N° Contrato</th>
                                <th>Mascota</th>
                                <th>Especie</th>
                                <th>Adoptante</th>
                                <th>Teléfono</th>
                                <th>Tipo</th>
                                <th>Fecha Seguim.</th>
                                <th>Próximo</th>
                                <th>Estado Mascota</th>
                                <th>Cond. Vivienda</th>
                                <th>Relación</th>
                                <th>Estado</th>
                                <th>Intervención</th>
                                <th>Responsable</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.NumeroContrato</td>
                                    <td>@item.NombreMascota</td>
                                    <td>@item.EspecieMascota</td>
                                    <td>@item.NombreAdoptante</td>
                                    <td>@item.TelefonoAdoptante</td>
                                    <td>@item.TipoSeguimiento</td>
                                    <td>@(item.FechaSeguimiento.HasValue ? item.FechaSeguimiento.Value.ToString("dd/MM/yyyy") : "PENDIENTE")</td>
                                    <td>@(item.ProximoSeguimiento.HasValue ? item.ProximoSeguimiento.Value.ToString("dd/MM/yyyy") : "-")</td>
                                    <td>@item.EstadoMascota</td>
                                    <td>@item.CondicionesVivienda</td>
                                    <td>@item.RelacionConAdoptante</td>
                                    <td>
                                        <span class="badge @(item.EstadoSeguimiento == "Realizado" ? "badge-success" : item.EstadoSeguimiento == "Vencido" ? "badge-danger" : "badge-warning")">
                                            @item.EstadoSeguimiento
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge @(item.RequiereIntervencion ? "badge-danger" : "badge-success")">
                                            @(item.RequiereIntervencion ? "Sí" : "No")
                                        </span>
                                    </td>
                                    <td>@item.ResponsableNombre</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <small class="text-muted no-print">Generado el @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</small>
    }
</div>

@section Scripts {
    <script>
    window.onbeforeprint = function () { document.getElementById('titulo-impresion').style.display = 'block'; };
    window.onafterprint  = function () { document.getElementById('titulo-impresion').style.display = 'none'; };

    @if (Model != null && Model.Any())
    {
        <text>
        var estados = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.GroupBy(m=>m.EstadoSeguimiento).Select(g=>new{label=g.Key,count=g.Count()}).ToList()));
        var interv  = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(new[]{ new{label="Requiere",count=Model.Count(m=>m.RequiereIntervencion)}, new{label="No Requiere",count=Model.Count(m=>!m.RequiereIntervencion)} }));
        new Chart(document.getElementById('graficaEstado'),       { type: 'doughnut', data: { labels: estados.map(e=>e.label), datasets: [{ data: estados.map(e=>e.count), backgroundColor: ['#4CAF50','#FF9800','#F44336'] }] } });
        new Chart(document.getElementById('graficaIntervencion'), { type: 'pie',      data: { labels: interv.map(e=>e.label),  datasets: [{ data: interv.map(e=>e.count),  backgroundColor: ['#F44336','#4CAF50'] }] } });
        </text>
    }
    </script>
}
