@model System.Web.Mvc.HandleErrorInfo
@{
    ViewBag.Title = "Error";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg">
                <div class="card-body text-center py-5">
                    <i class="fas fa-exclamation-triangle fa-5x text-danger mb-4"></i>
                    <h1 class="display-4 text-danger">¡Oops!</h1>
                    <h3>Ha ocurrido un error inesperado</h3>
                    <p class="text-muted mt-3">
                        Lo sentimos, algo salió mal. Por favor, intente nuevamente o contacte al soporte técnico.
                    </p>

                    @if (Model != null && (Request.IsLocal || User.IsInRole("Administrador")))
                    {
                        <div class="alert alert-warning mt-4 text-left">
                            <h5>Información técnica:</h5>
                            <p><strong>Controller:</strong> @Model.ControllerName</p>
                            <p><strong>Action:</strong> @Model.ActionName</p>
                            <p><strong>Error:</strong> @Model.Exception?.Message</p>
                        </div>
                    }

                    <div class="mt-4">
                        <a href="@Url.Action("Index", "Home")" class="btn btn-primary btn-lg">
                            <i class="fas fa-home"></i> Volver al Inicio
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
