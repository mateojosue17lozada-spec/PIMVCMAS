<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@(ViewBag.Title ?? "Refugio de Mascotas") - Refugio de Mascotas</title>

    <!-- Bootstrap CSS desde CDN (temporal hasta arreglar bundles) -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css">

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <!-- Site CSS local -->
    <link href="~/Content/site.css" rel="stylesheet" />

    <style>
        body {
            padding-top: 70px;
        }

        .navbar-brand img {
            height: 30px;
            margin-right: 10px;
        }

        .card {
            margin-bottom: 20px;
            transition: transform 0.3s;
        }

            .card:hover {
                transform: translateY(-5px);
                box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            }

        .shadow-custom {
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        }

        .alert {
            margin-top: 20px;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark fixed-top">
        <div class="container">
            <a class="navbar-brand" href="@Url.Action("Index", "Home")">
                <i class="fas fa-paw"></i>
                <span>Refugio de Mascotas</span>
            </a>
            <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav mr-auto">
                    <li class="nav-item">@Html.ActionLink("Inicio", "Index", "Home", null, new { @class = "nav-link" })</li>
                    <li class="nav-item">@Html.ActionLink("Mascotas", "Index", "Mascotas", null, new { @class = "nav-link" })</li>
                    <li class="nav-item">@Html.ActionLink("Adopciones", "Index", "Adopcion", null, new { @class = "nav-link" })</li>
                    <li class="nav-item">@Html.ActionLink("Donaciones", "Index", "Donaciones", null, new { @class = "nav-link" })</li>
                    <li class="nav-item">@Html.ActionLink("Contacto", "Contact", "Home", null, new { @class = "nav-link" })</li>
                </ul>
                <ul class="navbar-nav">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button" data-toggle="dropdown">
                                <i class="fas fa-user"></i> @(User.Identity.Name ?? "Usuario")
                            </a>
                            <div class="dropdown-menu">
                                @Html.ActionLink("Mi Perfil", "MiPerfil", "Account", null, new { @class = "dropdown-item" })
                                @Html.ActionLink("Mis Solicitudes", "MisSolicitudes", "Adopcion", null, new { @class = "dropdown-item" })
                                @Html.ActionLink("Cambiar Contraseña", "ChangePassword", "Account", null, new { @class = "dropdown-item" })
                                <div class="dropdown-divider"></div>
                                @Html.ActionLink("Cerrar Sesión", "Logout", "Account", null, new { @class = "dropdown-item" })
                            </div>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">@Html.ActionLink("Registrarse", "Register", "Account", null, new { @class = "nav-link" })</li>
                        <li class="nav-item">@Html.ActionLink("Iniciar Sesión", "Login", "Account", null, new { @class = "nav-link" })</li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <div class="container body-content">
        <!-- Mensajes de alerta -->
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="fas fa-exclamation-circle"></i> @TempData["ErrorMessage"]
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }

        @if (TempData["InfoMessage"] != null)
        {
            <div class="alert alert-info alert-dismissible fade show" role="alert">
                <i class="fas fa-info-circle"></i> @TempData["InfoMessage"]
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }

        @RenderBody()

        <hr />
        <footer class="mt-5">
            <div class="row">
                <div class="col-md-6">
                    <p>&copy; @DateTime.Now.Year - Refugio de Mascotas. Todos los derechos reservados.</p>
                </div>
                <div class="col-md-6 text-right">
                    <p>
                        <i class="fas fa-envelope"></i> contacto@refugiomascotas.com |
                        <i class="fas fa-phone"></i> (02) 123-4567
                    </p>
                </div>
            </div>
        </footer>
    </div>

    <!-- jQuery desde CDN -->
    <script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>

    <!-- Bootstrap JS desde CDN -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("scripts", required: false)

    <script>
        $(document).ready(function () {
            // Auto-ocultar alertas después de 5 segundos
            setTimeout(function () {
                $('.alert').alert('close');
            }, 5000);

            // Inicializar tooltips de Bootstrap
            $('[data-toggle="tooltip"]').tooltip();

            // Inicializar popovers de Bootstrap
            $('[data-toggle="popover"]').popover();
        });
    </script>
</body>
</html>