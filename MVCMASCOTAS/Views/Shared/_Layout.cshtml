<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Mi Aplicación MVC</title>

    <!-- Bootstrap 4.6.2 CSS Local (YA instalado) -->
    <link href="~/Content/bootstrap.min.css" rel="stylesheet" />

    <!-- Font Awesome 4.7.0 Local (YA instalado) -->
    <link href="~/Content/font-awesome.min.css" rel="stylesheet" />

    <!-- Tu CSS personalizado del proyecto -->
    <link href="~/Content/site.css" rel="stylesheet" />

    <!-- CSS específico de la vista (opcional) -->
    @RenderSection("styles", required: false)
</head>
<body>
    <!-- Barra de navegación -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            @Html.ActionLink("Mi App", "Index", "Home", new { area = "" }, new { @class = "navbar-brand" })
            <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarNav"
                    aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav mr-auto">
                    <li class="nav-item">@Html.ActionLink("Inicio", "Index", "Home", null, new { @class = "nav-link" })</li>
                    <li class="nav-item">@Html.ActionLink("Acerca de", "About", "Home", null, new { @class = "nav-link" })</li>
                    <li class="nav-item">@Html.ActionLink("Contacto", "Contact", "Home", null, new { @class = "nav-link" })</li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Contenido principal -->
    <div class="container body-content mt-4">
        @RenderBody()

        <hr class="mt-5" />

        <!-- Footer -->
        <footer class="mt-4 mb-4">
            <p>&copy; @DateTime.Now.Year - Mi Aplicación MVC</p>
        </footer>
    </div>

    <!-- Scripts - EN ESTE ORDEN EXACTO -->
    <!-- jQuery 3.6.0 (la versión que YA tienes) -->
    <script src="~/Scripts/jquery-3.6.0.min.js"></script>

    <!-- Bootstrap 4.6.2 JS Bundle (YA instalado) -->
    <script src="~/Scripts/bootstrap.bundle.min.js"></script>

    <!-- jQuery Validation 1.21.0 (YA instalado) -->
    <script src="~/Scripts/jquery.validate.min.js"></script>
    <script src="~/Scripts/jquery.validate.unobtrusive.min.js"></script>

    <!-- Tu JS personalizado -->
    <script src="~/Scripts/site.js"></script>

    <!-- Scripts específicos de la vista -->
    @RenderSection("scripts", required: false)

    <!-- Inicializaciones generales -->
    <script>
        $(document).ready(function () {
            // Inicializa tooltips de Bootstrap
            $('[data-toggle="tooltip"]').tooltip();

            // Inicializa popovers de Bootstrap
            $('[data-toggle="popover"]').popover();
        });
    </script>
</body>
</html>