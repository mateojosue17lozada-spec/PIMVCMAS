@model MVCMASCOTAS.Models.Pedidos

@{
    ViewBag.Title = "Mi Carrito";
}

<div class="page-header mb-4">
    <h2><i class="fas fa-shopping-cart"></i> Mi Carrito de Compras</h2>
</div>

@if (ViewBag.CarritoVacio == true || Model == null || !Model.PedidoDetalle.Any())
{
    <div class="card shadow-custom">
        <div class="card-body text-center py-5">
            <i class="fas fa-shopping-cart fa-5x text-muted mb-3"></i>
            <h4>Tu carrito está vacío</h4>
            <p class="text-muted">¿Qué tal si empiezas a comprar?</p>
            <a href="@Url.Action("Index", "Tienda")" class="btn btn-primary btn-lg">
                <i class="fas fa-shopping-bag"></i> Ir a la Tienda
            </a>
        </div>
    </div>
}
else
{
    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-custom mb-4">
                <div class="card-header">
                    <h5>Productos en tu Carrito</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Producto</th>
                                    <th>Precio</th>
                                    <th>Cantidad</th>
                                    <th>Subtotal</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var detalle in Model.PedidoDetalle)
                                {
                                    <tr>
                                        <td>
                                            <strong>@detalle.Productos.NombreProducto</strong><br />
                                            <small class="text-muted">@detalle.Productos.CategoriasProducto.NombreCategoria</small>
                                        </td>
                                        <td>$@detalle.PrecioUnitario.ToString("N2")</td>
                                        <td>
                                            <input type="number" class="form-control cantidad-carrito" style="width: 80px;"
                                                   value="@detalle.Cantidad" min="1" max="@detalle.Productos.Stock"
                                                   data-detalle-id="@detalle.DetalleId" />
                                        </td>
                                        <td class="subtotal"><strong>$@detalle.Subtotal.ToString("N2")</strong></td>
                                        <td>
                                            <button class="btn btn-sm btn-danger btn-remove-from-cart" data-detalle-id="@detalle.DetalleId">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-custom">
                <div class="card-header bg-primary text-white">
                    <h5>Resumen del Pedido</h5>
                </div>
                <div class="card-body">
                    <table class="table table-borderless">
                        <tr>
                            <td>Subtotal:</td>
                            <td class="text-right" id="total-carrito"><strong>$@Model.Total.ToString("N2")</strong></td>
                        </tr>
                        <tr>
                            <td>Envío:</td>
                            <td class="text-right"><strong>A coordinar</strong></td>
                        </tr>
                        <tr class="border-top">
                            <td><strong>Total:</strong></td>
                            <td class="text-right"><h4 class="text-success mb-0">$@Model.Total.ToString("N2")</h4></td>
                        </tr>
                    </table>

                    <button type="button" class="btn btn-success btn-lg btn-block mt-3" data-toggle="modal" data-target="#modalConfirmar">
                        <i class="fas fa-check"></i> Confirmar Pedido
                    </button>

                    <a href="@Url.Action("Index", "Tienda")" class="btn btn-outline-secondary btn-block">
                        <i class="fas fa-shopping-bag"></i> Seguir Comprando
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal Confirmar Pedido -->
    <div class="modal fade" id="modalConfirmar" tabindex="-1" role="dialog">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title"><i class="fas fa-check"></i> Confirmar Pedido</h5>
                    <button type="button" class="close text-white" data-dismiss="modal">
                        <span>&times;</span>
                    </button>
                </div>
                @using (Html.BeginForm("ConfirmarPedido", "Tienda", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    <div class="modal-body">
                        <div class="form-group">
                            <label>Dirección de Envío *</label>
                            <textarea name="direccionEnvio" class="form-control" rows="3" required>@ViewBag.DireccionUsuario</textarea>
                        </div>

                        <div class="form-group">
                            <label>Método de Pago *</label>
                            <select name="metodoPago" class="form-control" required>
                                <option value="">Seleccionar...</option>
                                <option value="Transferencia">Transferencia Bancaria</option>
                                <option value="Depósito">Depósito</option>
                                <option value="Efectivo">Efectivo contra entrega</option>
                            </select>
                        </div>

                        <div class="form-group">
                            <label>Observaciones</label>
                            <textarea name="observaciones" class="form-control" rows="2"></textarea>
                        </div>

                        <div class="alert alert-info">
                            <i class="fas fa-info-circle"></i> Nos pondremos en contacto contigo para coordinar la entrega y el pago.
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-success">
                            <i class="fas fa-check"></i> Confirmar
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>
}
