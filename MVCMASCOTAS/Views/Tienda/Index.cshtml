@model IEnumerable<MVCMASCOTAS.Models.Productos>

@{
    ViewBag.Title = "Tienda Solidaria";
}

<div class="page-header mb-4">
    <h1 class="text-center"><i class="fas fa-shopping-cart"></i> Tienda Solidaria</h1>
    <p class="text-center text-muted">Compra productos y apoya al refugio al mismo tiempo</p>
</div>

<!-- Filtros -->
<div class="card mb-4 shadow-custom">
    <div class="card-body">
        <form method="get" action="@Url.Action("Index")" class="form-inline justify-content-center">
            <div class="form-group mx-2 mb-2">
                <label class="mr-2">Categoría:</label>
                <select name="categoriaId" class="form-control">
                    <option value="">Todas</option>
                    @if (ViewBag.Categorias != null)
                    {
                        foreach (var cat in ViewBag.Categorias)
                        {
                            <option value="@cat.CategoriaId"
                                    @(ViewBag.CategoriaSeleccionada == cat.CategoriaId ? "selected" : "")>
                                @cat.NombreCategoria
                            </option>
                        }
                    }
                </select>
            </div>

            <div class="form-group mx-2 mb-2">
                <input type="text" name="buscar" class="form-control"
                       placeholder="Buscar producto..." value="@ViewBag.Buscar" />
            </div>

            <button type="submit" class="btn btn-primary mx-2 mb-2">
                <i class="fas fa-search"></i> Buscar
            </button>
        </form>
    </div>
</div>

<!-- Productos -->
<div class="row">
    @if (Model != null && Model.Any())
    {
        foreach (var producto in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-custom">
                    @if (producto.ImagenPrincipal != null && producto.ImagenPrincipal.Length > 0)
                    {
                        <img src="@MVCMASCOTAS.Helpers.ImageHelper.GetImageDataUri(producto.ImagenPrincipal)"
                             class="card-img-top" style="height: 250px; object-fit: cover;"
                             alt="@producto.NombreProducto">
                    }
                    else
                    {
                        <div class="card-img-top d-flex align-items-center justify-content-center bg-light"
                             style="height: 250px;">
                            <i class="fas fa-box fa-5x text-muted"></i>
                        </div>
                    }
                    <div class="card-body">
                        <h5 class="card-title">@producto.NombreProducto</h5>
                        <p class="text-muted small">@producto.CategoriasProducto.NombreCategoria</p>
                        <p class="card-text">
                            @if (!string.IsNullOrEmpty(producto.Descripcion))
                            {
                                @(producto.Descripcion.Length > 80 ? producto.Descripcion.Substring(0, 80) + "..." : producto.Descripcion)
                            }
                        </p>

                        <div class="d-flex justify-content-between align-items-center mt-3">
                            <h4 class="text-success mb-0">$@producto.Precio.ToString("N2")</h4>
                            <span class="badge badge-info">Stock: @producto.Stock</span>
                        </div>
                    </div>
                    <div class="card-footer bg-white">
                        <a href="@Url.Action("Detalle", "Tienda", new { id = producto.ProductoId })"
                           class="btn btn-primary btn-block">
                            <i class="fas fa-eye"></i> Ver Detalles
                        </a>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12">
            <div class="alert alert-info text-center">
                <i class="fas fa-info-circle"></i> No hay productos disponibles en este momento.
            </div>
        </div>
    }
</div>

<!-- Paginación -->
@if (ViewBag.TotalPages > 1)
{
    <nav aria-label="Paginación">
        <ul class="pagination justify-content-center">
            @if (ViewBag.CurrentPage > 1)
            {
                <li class="page-item">
                    <a class="page-link" href="@Url.Action("Index", new {
                        page = ViewBag.CurrentPage - 1,
                        categoriaId = ViewBag.CategoriaSeleccionada,
                        buscar = ViewBag.Buscar
                    })">Anterior</a>
                </li>
            }

            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                    <a class="page-link" href="@Url.Action("Index", new {
                        page = i,
                        categoriaId = ViewBag.CategoriaSeleccionada,
                        buscar = ViewBag.Buscar
                    })">@i</a>
                </li>
            }

            @if (ViewBag.CurrentPage < ViewBag.TotalPages)
            {
                <li class="page-item">
                    <a class="page-link" href="@Url.Action("Index", new {
                        page = ViewBag.CurrentPage + 1,
                        categoriaId = ViewBag.CategoriaSeleccionada,
                        buscar = ViewBag.Buscar
                    })">Siguiente</a>
                </li>
            }
        </ul>
    </nav>
}

@section Styles {
    <style>
        .shadow-custom {
            box-shadow: 0 0.125rem 0.25rem rgba(0,0,0,0.075);
        }
    </style>
}