@model MVCMASCOTAS.Models.Productos

@{
    ViewBag.Title = Model.NombreProducto;
}

<div class="row">
    <div class="col-md-6">
        <div class="card shadow-custom">
            @if (ViewBag.ImagenBase64 != null)
            {
                <img src="@ViewBag.ImagenBase64" class="card-img-top img-preview"
                     alt="@Model.NombreProducto" style="max-height: 500px; object-fit: contain;">
            }
            else
            {
                <div class="card-img-top d-flex align-items-center justify-content-center bg-light"
                     style="height: 400px;">
                    <i class="fas fa-box fa-10x text-muted"></i>
                </div>
            }
        </div>
    </div>

    <div class="col-md-6">
        <div class="card shadow-custom">
            <div class="card-body">
                <h2>@Model.NombreProducto</h2>
                <p class="text-muted">
                    <i class="fas fa-tag"></i> @Model.CategoriasProducto.NombreCategoria
                </p>

                <hr />

                <h3 class="text-success">$@Model.Precio.ToString("N2")</h3>

                <p class="mt-3">
                    <strong><i class="fas fa-box"></i> Stock Disponible:</strong>
                    @if (Model.Stock > 10)
                    {
                        <span class="badge badge-success">@Model.Stock unidades</span>
                    }
                    else if (Model.Stock > 0)
                    {
                        <span class="badge badge-warning">Solo quedan @Model.Stock unidades</span>
                    }
                    else
                    {
                        <span class="badge badge-danger">Agotado</span>
                    }
                </p>

                <hr />

                <h5>Descripción</h5>
                <p>@(Model.Descripcion ?? "Sin descripción disponible")</p>

                @if (Model.Stock > 0)
                {
                    if (Request.IsAuthenticated)
                    {
                        <div class="mt-4">
                            <div class="form-group">
                                <label>Cantidad:</label>
                                <input type="number" class="form-control cantidad-input"
                                       min="1" max="@Model.Stock" value="1" />
                            </div>
                            <button class="btn btn-success btn-lg btn-block btn-add-to-cart"
                                    data-producto-id="@Model.ProductoId">
                                <i class="fas fa-cart-plus"></i> Agregar al Carrito
                            </button>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning mt-4">
                            <i class="fas fa-exclamation-triangle"></i>
                            Debes <a href="@Url.Action("Login", "Account")">iniciar sesión</a> para comprar
                        </div>
                    }
                }

                <a href="@Url.Action("Index", "Tienda")" class="btn btn-secondary btn-lg btn-block mt-2">
                    <i class="fas fa-arrow-left"></i> Volver a la Tienda
                </a>

                <div class="alert alert-info mt-4">
                    <i class="fas fa-info-circle"></i> <strong>Nota:</strong>
                    Todas las ganancias de la tienda son destinadas al cuidado de los animales del refugio.
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('.btn-add-to-cart').click(function() {
                var productoId = $(this).data('producto-id');
                var cantidad = $('.cantidad-input').val();

                $.ajax({
                    url: '@Url.Action("AgregarAlCarrito", "Tienda")',
                    type: 'POST',
                    data: {
                        productoId: productoId,
                        cantidad: cantidad,
                        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function(response) {
                        if (response.success) {
                            toastr.success(response.message);
                        } else {
                            toastr.error(response.message);
                        }
                    },
                    error: function() {
                        toastr.error('Error al agregar al carrito');
                    }
                });
            });
        });
    </script>
}

@section Styles {
    <style>
        .shadow-custom {
            box-shadow: 0 0.125rem 0.25rem rgba(0,0,0,0.075);
        }
    </style>
}