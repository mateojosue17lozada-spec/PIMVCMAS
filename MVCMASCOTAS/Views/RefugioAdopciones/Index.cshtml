@model IEnumerable<MVCMASCOTAS.Models.RefugioAdopcion>

@{
    ViewBag.Title = "Refugios de Adopción - ADOPTAMANÍA";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Hero Section -->
<section class="refugios-hero py-4">
    <div class="container">
        <div class="d-flex flex-wrap justify-content-between align-items-center">
            <div>
                <h1 class="h2 text-brown mb-1">
                    <i class="fas fa-home text-green me-2"></i>Gestión de Refugios
                </h1>
                <p class="text-secondary mb-0">Administra los refugios asociados</p>
            </div>
            <div class="mt-2 mt-sm-0">
                <a href="@Url.Action("Create")" class="btn btn-green">
                    <i class="fas fa-plus me-2"></i>Nuevo Refugio
                </a>
            </div>
        </div>
    </div>
</section>

<!-- Main Content -->
<section class="py-4 bg-beige">
    <div class="container">
        <div class="table-card">
            <div class="table-card-header bg-green text-white">
                <i class="fas fa-list me-2"></i>Listado de Refugios
            </div>
            <div class="table-card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th><i class="fas fa-home me-2"></i>Nombre del Refugio</th>
                                <th><i class="fas fa-phone me-2"></i>Contacto</th>
                                <th><i class="fas fa-map-marker-alt me-2"></i>Dirección</th>
                                <th><i class="fas fa-user me-2"></i>Encargado</th>
                                <th><i class="fas fa-toggle-on me-2"></i>Estado</th>
                                <th class="text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td><span class="fw-medium text-brown">@item.NombreRefugio</span></td>
                                    <td class="text-secondary">@item.Contacto</td>
                                    <td class="text-secondary">@item.Direccion</td>
                                    <td class="text-secondary">@item.PersonaEncargada</td>
                                    <td>
                                        @if (item.Estado == true)
                                        {
                                            <span class="badge bg-green text-white px-3 py-2">
                                                <i class="fas fa-check-circle me-1"></i>Activo
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-pink text-brown px-3 py-2">
                                                <i class="fas fa-times-circle me-1"></i>Inactivo
                                            </span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="d-flex justify-content-center gap-2">
                                            <a href="@Url.Action("Edit", new { id = item.IdRefugio })"
                                               class="btn btn-sm btn-yellow" title="Editar">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <a href="@Url.Action("Details", new { id = item.IdRefugio })"
                                               class="btn btn-sm btn-outline-green" title="Ver detalles">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <a href="@Url.Action("Delete", new { id = item.IdRefugio })"
                                               class="btn btn-sm btn-pink" title="Eliminar">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</section>

@section Styles {
    <style>
        :root {
            --green: #97C78B;
            --yellow: #F2C66D;
            --pink: #FBCDC0;
            --brown: #2F2F2F;
            --bg-light: #F2E9D8;
            --beige: #F5E6D3;
            --text-secondary: #555555;
        }

        body {
            background-color: var(--beige);
        }

        /* Hero */
        .refugios-hero {
            background-color: var(--beige);
            border-radius: 0 0 30px 30px;
            margin-bottom: 1rem;
        }

        /* Tarjeta de tabla */
        .table-card {
            background: white;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 15px 35px rgba(151,199,139,0.15);
            border: none;
        }

        .table-card-header {
            padding: 1rem 1.5rem;
            font-weight: 600;
            font-size: 1.1rem;
        }

        .table-card-body {
            padding: 0;
        }

        /* Tabla */
        .table {
            margin-bottom: 0;
        }

            .table th {
                background-color: var(--bg-light);
                color: var(--brown);
                font-weight: 600;
                border-bottom: 2px solid var(--green);
                padding: 1rem 0.5rem;
            }

            .table td {
                padding: 1rem 0.5rem;
                border-bottom: 1px solid var(--bg-light);
            }

        .table-hover tbody tr:hover {
            background-color: rgba(151,199,139,0.05);
        }

        /* Badges */
        .badge.bg-green {
            background-color: var(--green) !important;
            color: white !important;
        }

        .badge.bg-pink {
            background-color: var(--pink) !important;
            color: var(--brown) !important;
        }

        /* Botones */
        .btn-green {
            background-color: var(--green);
            border: none;
            border-radius: 50px;
            padding: 0.6rem 1.8rem;
            font-weight: 500;
            transition: all 0.3s;
            color: white;
        }

            .btn-green:hover {
                background-color: #86b57a;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(151,199,139,0.4);
            }

        .btn-yellow {
            background-color: var(--yellow);
            border: none;
            border-radius: 50px;
            padding: 0.4rem 0.8rem;
            font-weight: 500;
            transition: all 0.3s;
            color: var(--brown);
        }

            .btn-yellow:hover {
                background-color: #e6b85c;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(242,198,109,0.4);
            }

        .btn-pink {
            background-color: var(--pink);
            border: none;
            border-radius: 50px;
            padding: 0.4rem 0.8rem;
            font-weight: 500;
            transition: all 0.3s;
            color: var(--brown);
        }

            .btn-pink:hover {
                background-color: #f9c2b0;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(249,194,176,0.4);
            }

        .btn-outline-green {
            border: 2px solid var(--green);
            background: transparent;
            color: var(--green);
            border-radius: 50px;
            padding: 0.4rem 0.8rem;
            font-weight: 500;
            transition: all 0.3s;
        }

            .btn-outline-green:hover {
                background-color: var(--green);
                color: white;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(151,199,139,0.3);
            }

        /* Gap para acciones */
        .gap-2 {
            gap: 0.5rem;
        }

        /* Responsive */
        @@media (max-width: 768px) {
            .table th, .table td {
                white-space: nowrap;
            }
        }
    </style>
}