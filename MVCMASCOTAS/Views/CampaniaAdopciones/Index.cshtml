@model IEnumerable<MVCMASCOTAS.Models.CampaniaAdopcion>

@{
    ViewBag.Title = "Campañas de Adopción";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header mb-4">
    <h2><i class="fas fa-calendar-alt"></i> Gestión de Campañas de Adopción</h2>
    <p class="text-muted">Administra las campañas de adopción del refugio</p>
</div>

<div class="mb-3">
    <a href="@Url.Action("Create")" class="btn btn-success">
        <i class="fas fa-plus"></i> Nueva Campaña
    </a>
</div>

<div class="card shadow-custom">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead class="thead-light">
                    <tr>
                        <th><i class="fas fa-tag"></i> Nombre</th>
                        <th><i class="fas fa-map-marker-alt"></i> Lugar</th>
                        <th><i class="fas fa-calendar"></i> Fecha</th>
                        <th><i class="fas fa-clock"></i> Hora</th>
                        <th><i class="fas fa-toggle-on"></i> Estado</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><strong>@item.NombreCampania</strong></td>
                            <td>@item.Lugar</td>
                            <td>@item.Fecha.ToString("dd/MM/yyyy")</td>
                            <td>@item.Hora</td>
                            <td>
                                @if (item.Estado == true)
                                {
                                    <span class="badge badge-success">Activa</span>
                                }
                                else
                                {
                                    <span class="badge badge-secondary">Inactiva</span>
                                }
                            </td>
                            <td class="text-center">
                                <a href="@Url.Action("Edit", new { id = item.IdCampania })"
                                   class="btn btn-sm btn-warning" title="Editar">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <a href="@Url.Action("Details", new { id = item.IdCampania })"
                                   class="btn btn-sm btn-info" title="Ver detalles">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a href="@Url.Action("Delete", new { id = item.IdCampania })"
                                   class="btn btn-sm btn-danger" title="Eliminar">
                                    <i class="fas fa-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>