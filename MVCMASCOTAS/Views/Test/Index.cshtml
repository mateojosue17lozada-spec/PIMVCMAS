@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Página de Prueba - Todas las Vistas";
}

<style>
    .section-title {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 15px;
        border-radius: 5px;
        margin-top: 30px;
        margin-bottom: 20px;
    }

    .view-card {
        transition: transform 0.2s, box-shadow 0.2s;
        border-left: 4px solid #667eea;
    }

        .view-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 4px 15px rgba(0,0,0,0.2);
        }

    .view-link {
        text-decoration: none;
        color: #333;
    }

        .view-link:hover {
            text-decoration: none;
            color: #667eea;
        }

    .badge-count {
        background: #667eea;
        color: white;
    }

    .controller-icon {
        font-size: 24px;
        margin-right: 10px;
    }

    .btn-warning-id {
        background-color: #ffc107;
        border-color: #ffc107;
        color: #000;
    }

    @@media (max-width: 768px) {
        .controller-icon {
            font-size: 20px;
        }

        .section-title {
            font-size: 1.3rem;
            padding: 12px;
        }
    }
</style>

<div class="container-fluid">
    <div class="jumbotron bg-gradient text-white" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
        <h1 class="display-4">🧪 Página de Prueba de Vistas</h1>
        <p class="lead">Navegación rápida a todas las vistas del sistema Refugio de Mascotas</p>
        <hr class="my-4" style="border-color: rgba(255,255,255,0.3);">
        <p>Total de vistas disponibles: <strong>81 vistas</strong> en <strong>15 carpetas</strong></p>
    </div>

    <!-- ALERTA IMPORTANTE -->
    <div class="alert alert-warning" role="alert">
        <h4 class="alert-heading">⚠️ Importante sobre vistas con ID</h4>
        <p>
            Las vistas marcadas con <span class="badge badge-warning">⚠️ Requiere ID</span> necesitan un parámetro ID válido.
            Los enlaces usan <strong>ID = 1</strong> como ejemplo.
        </p>
        <hr>
        <p class="mb-0">
            <strong>Si ves error "No encontrado":</strong> Primero crea registros desde las vistas Index o Create,
            luego accede a Details/Edit/Delete con IDs reales.
        </p>
    </div>

