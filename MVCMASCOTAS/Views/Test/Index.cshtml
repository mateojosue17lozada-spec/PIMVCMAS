<style>
    .section-title {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 15px;
        border-radius: 5px;
        margin-top: 30px;
        margin-bottom: 20px;
    }
    .view-card {
        transition: transform 0.2s, box-shadow 0.2s;
        border-left: 4px solid #667eea;
    }
    .view-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 4px 15px rgba(0,0,0,0.2);
    }
    .view-link {
        text-decoration: none;
        color: #333;
    }
    .view-link:hover {
        text-decoration: none;
        color: #667eea;
    }
    .badge-count {
        background: #667eea;
        color: white;
    }
    .controller-icon {
        font-size: 24px;
        margin-right: 10px;
    }
</style>

