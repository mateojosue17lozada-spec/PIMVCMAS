@model MVCMASCOTAS.Models.Usuarios
@{
    ViewBag.Title = "Detalles del Usuario - ADOPTAMANÍA";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Hero Section (simple) -->
<section class="details-hero py-4">
    <div class="container">
        <div class="d-flex flex-wrap justify-content-between align-items-center">
            <div>
                <h1 class="h2 text-brown mb-1">
                    <i class="fas fa-user-circle text-green me-2"></i>Detalles del Usuario
                </h1>
                <p class="text-secondary mb-0">Información completa del usuario en el sistema</p>
            </div>
            <div class="mt-2 mt-sm-0">
                <a href="@Url.Action("EditarUsuario", "Admin", new { id = Model.UsuarioId })" class="btn btn-yellow me-2">
                    <i class="fas fa-edit me-2"></i>Editar
                </a>
                <a href="@Url.Action("Usuarios", "Admin")" class="btn btn-outline-green">
                    <i class="fas fa-arrow-left me-2"></i>Volver
                </a>
            </div>
        </div>
    </div>
</section>

<!-- Main Content -->
<section class="py-4 bg-beige">
    <div class="container">
        <div class="row g-4">
            <!-- Columna Izquierda - Información Personal -->
            <div class="col-md-4">
                <!-- Perfil -->
                <div class="profile-card mb-4">
                    <div class="profile-card-header bg-green text-white">
                        <i class="fas fa-id-card me-2"></i>Perfil
                    </div>
                    <div class="profile-card-body text-center">
                        @if (Model.ImagenPerfil != null && Model.ImagenPerfil.Length > 0)
                        {
                            <img src="data:image/jpeg;base64,@Convert.ToBase64String(Model.ImagenPerfil)"
                                 class="profile-img rounded-circle mb-3 border-green"
                                 alt="@Model.NombreCompleto" />
                        }
                        else
                        {
                            <div class="profile-img-placeholder rounded-circle mx-auto mb-3 border-green">
                                <i class="fas fa-user fa-5x text-green"></i>
                            </div>
                        }

                        <h4 class="text-brown mb-2">@Model.NombreCompleto</h4>
                        <p class="text-secondary mb-3">@Model.Email</p>

                        <!-- Badges de estado -->
                        <div class="mb-3">
                            @if (Model.Activo == true)
                            {
                                <span class="badge bg-green text-white px-3 py-2 me-1">
                                    <i class="fas fa-check-circle me-1"></i>Activo
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-pink text-brown px-3 py-2 me-1">
                                    <i class="fas fa-ban me-1"></i>Inactivo
                                </span>
                            }

                            @if (Model.EmailConfirmado == true)
                            {
                                <span class="badge bg-green text-white px-3 py-2 me-1">
                                    <i class="fas fa-envelope me-1"></i>Email Confirmado
                                </span>
                            }

                            @if (Model.TelefonoConfirmado == true)
                            {
                                <span class="badge bg-green text-white px-3 py-2">
                                    <i class="fas fa-phone me-1"></i>Teléfono Confirmado
                                </span>
                            }
                        </div>

                        <!-- ID del Usuario -->
                        <div class="alert alert-beige border-green text-start">
                            <i class="fas fa-fingerprint text-green me-2"></i>
                            <span class="text-brown fw-medium">ID:</span>
                            <span class="text-brown fw-bold">#@Model.UsuarioId</span>
                        </div>
                    </div>
                </div>

                <!-- Contacto -->
                <div class="info-card mb-4">
                    <div class="info-card-header bg-green text-white">
                        <i class="fas fa-address-book me-2"></i>Contacto
                    </div>
                    <div class="info-card-body">
                        <div class="d-flex align-items-center mb-3">
                            <div class="info-icon bg-light-mint me-3">
                                <i class="fas fa-phone text-green"></i>
                            </div>
                            <div>
                                <div class="text-brown fw-medium">Teléfono</div>
                                <div class="text-secondary">@(Model.Telefono ?? "No registrado")</div>
                            </div>
                        </div>
                        <div class="d-flex align-items-center">
                            <div class="info-icon bg-light-mint me-3">
                                <i class="fas fa-id-card text-green"></i>
                            </div>
                            <div>
                                <div class="text-brown fw-medium">Cédula</div>
                                <div class="text-secondary">@(Model.Cedula ?? "No registrada")</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Columna Derecha - Información Detallada -->
            <div class="col-md-8">
                <!-- Dirección -->
                <div class="info-card mb-4">
                    <div class="info-card-header bg-green text-white">
                        <i class="fas fa-map-marker-alt me-2"></i>Dirección
                    </div>
                    <div class="info-card-body">
                        <div class="mb-3">
                            <div class="text-brown fw-medium">Dirección Completa</div>
                            <div class="text-secondary">@(Model.Direccion ?? "No registrada")</div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="text-brown fw-medium">Ciudad</div>
                                <div class="text-secondary">@(Model.Ciudad ?? "No registrada")</div>
                            </div>
                            <div class="col-md-6">
                                <div class="text-brown fw-medium">Provincia</div>
                                <div class="text-secondary">@(Model.Provincia ?? "No registrada")</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Roles Asignados -->
                <div class="roles-card mb-4">
                    <div class="roles-card-header bg-yellow">
                        <i class="fas fa-user-tag me-2"></i>Roles Asignados
                    </div>
                    <div class="roles-card-body">
                        @if (Model.UsuariosRoles != null && Model.UsuariosRoles.Any())
                        {
                            <div class="row g-3">
                                @foreach (var userRole in Model.UsuariosRoles)
                                {
                                    var role = userRole.Roles;
                                    string bgClass = role.NombreRol switch
                                    {
                                        "Administrador" => "role-admin",
                                        "Veterinario" => "role-vet",
                                        "Voluntario" => "role-vol",
                                        _ => "role-default"
                                    };
                                    <div class="col-md-4">
                                        <div class="role-card @bgClass">
                                            <i class="fas @(role.NombreRol switch
                                                            {
                                                                "Administrador" => "fa-user-shield",
                                                                "Veterinario" => "fa-user-md",
                                                                "Voluntario" => "fa-hands-helping",
                                                                _ => "fa-user"
                                                            }) fa-2x mb-2"></i>
                                            <h6 class="fw-bold">@role.NombreRol</h6>
                                            @if (userRole.FechaAsignacion.HasValue)
                                            {
                                                <small class="opacity-75">
                                                    <i class="fas fa-calendar-alt me-1"></i>@userRole.FechaAsignacion.Value.ToString("dd/MM/yyyy")
                                                </small>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-beige border-green">
                                <i class="fas fa-exclamation-triangle text-green me-2"></i>
                                <span class="text-brown">Este usuario no tiene roles asignados.</span>
                            </div>
                        }
                    </div>
                </div>

                <!-- Información del Sistema -->
                <div class="info-card">
                    <div class="info-card-header bg-green text-white">
                        <i class="fas fa-cogs me-2"></i>Información del Sistema
                    </div>
                    <div class="info-card-body">
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <div class="d-flex align-items-center">
                                    <i class="fas fa-calendar-plus text-green fa-lg me-3"></i>
                                    <div>
                                        <div class="text-brown fw-medium">Fecha de Registro</div>
                                        <div class="text-secondary">
                                            @if (Model.FechaRegistro.HasValue)
                                            {
                                                @Model.FechaRegistro.Value.ToString("dd/MM/yyyy HH:mm")
                                            }
                                            else
                                            {
                                                <span>No registrada</span>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="d-flex align-items-center">
                                    <i class="fas fa-sign-in-alt text-green fa-lg me-3"></i>
                                    <div>
                                        <div class="text-brown fw-medium">Último Acceso</div>
                                        <div class="text-secondary">
                                            @if (Model.UltimoAcceso.HasValue)
                                            {
                                                @Model.UltimoAcceso.Value.ToString("dd/MM/yyyy HH:mm")
                                            }
                                            else
                                            {
                                                <span>No registrado</span>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(Model.PasswordHash))
                        {
                            <div class="security-card mt-3">
                                <h6 class="text-brown mb-3"><i class="fas fa-key text-green me-2"></i>Información de Seguridad</h6>
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <small class="text-brown d-block mb-1">Password Hash:</small>
                                        <code class="d-block p-2 bg-beige rounded">@Model.PasswordHash</code>
                                    </div>
                                    <div class="col-md-6">
                                        <small class="text-brown d-block mb-1">Salt:</small>
                                        <code class="d-block p-2 bg-beige rounded">@Model.Salt</code>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Botones de Acción -->
        <div class="action-card mt-4">
            <div class="action-card-body d-flex flex-wrap justify-content-between align-items-center">
                <div>
                    @if (Model.Activo == true)
                    {
                        <button type="button" class="btn btn-pink me-2 btn-toggle"
                                data-id="@Model.UsuarioId"
                                data-nombre="@Model.NombreCompleto"
                                data-accion="Desactivar"
                                data-actual="true">
                            <i class="fas fa-ban me-2"></i>Desactivar Usuario
                        </button>
                    }
                    else
                    {
                        <button type="button" class="btn btn-green me-2 btn-toggle"
                                data-id="@Model.UsuarioId"
                                data-nombre="@Model.NombreCompleto"
                                data-accion="Activar"
                                data-actual="false">
                            <i class="fas fa-check me-2"></i>Activar Usuario
                        </button>

                        <button type="button" class="btn btn-pink me-2 btn-eliminar"
                                data-id="@Model.UsuarioId"
                                data-nombre="@Model.NombreCompleto">
                            <i class="fas fa-trash me-2"></i>Eliminar Permanentemente
                        </button>
                    }
                </div>
                <div>
                    <a href="@Url.Action("Usuarios", "Admin")" class="btn btn-outline-green">
                        <i class="fas fa-users me-2"></i>Ver Todos los Usuarios
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Formulario oculto para AntiForgeryToken (usado por AJAX) -->
<form id="__AjaxAntiForgeryForm" method="post">@Html.AntiForgeryToken()</form>

@section Styles {
    <style>
        :root {
            --green: #97C78B;
            --yellow: #F2C66D;
            --pink: #FBCDC0;
            --brown: #2F2F2F;
            --bg-light: #F2E9D8;
            --beige: #F5E6D3;
            --text-secondary: #555555;
        }

        body {
            background-color: var(--beige);
        }

        /* Hero */
        .details-hero {
            background-color: var(--beige);
            border-radius: 0 0 30px 30px;
            margin-bottom: 1rem;
        }

        /* Tarjetas de perfil */
        .profile-card {
            background: white;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 15px 35px rgba(151,199,139,0.15);
            border: none;
        }

        .profile-card-header {
            background-color: var(--green);
            color: white;
            padding: 1rem 1.5rem;
            font-weight: 600;
            font-size: 1.1rem;
        }

        .profile-card-body {
            padding: 1.5rem;
        }

        .profile-img {
            width: 200px;
            height: 200px;
            object-fit: cover;
            border: 4px solid var(--green);
            box-shadow: 0 8px 20px rgba(151,199,139,0.3);
        }

        .profile-img-placeholder {
            width: 200px;
            height: 200px;
            background-color: var(--bg-light);
            border: 4px solid var(--green);
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
        }

        /* Tarjetas de información */
        .info-card {
            background: white;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 15px 35px rgba(151,199,139,0.15);
            border: none;
        }

        .info-card-header {
            background-color: var(--green);
            color: white;
            padding: 1rem 1.5rem;
            font-weight: 600;
            font-size: 1.1rem;
        }

        .info-card-body {
            padding: 1.5rem;
        }

        .info-icon {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            background-color: var(--bg-light);
        }

        /* Tarjetas de roles */
        .roles-card {
            background: white;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 15px 35px rgba(151,199,139,0.15);
            border: none;
        }

        .roles-card-header {
            background-color: var(--yellow);
            color: var(--brown);
            padding: 1rem 1.5rem;
            font-weight: 600;
            font-size: 1.1rem;
        }

        .roles-card-body {
            padding: 1.5rem;
        }

        .role-card {
            background: var(--bg-light);
            border-radius: 16px;
            padding: 1.2rem 1rem;
            text-align: center;
            transition: transform 0.3s;
            height: 100%;
        }

            .role-card:hover {
                transform: translateY(-5px);
            }

        .role-admin {
            background: linear-gradient(135deg, #f9c2b0, var(--pink));
            color: var(--brown);
        }

        .role-vet {
            background: linear-gradient(135deg, #86b57a, var(--green));
            color: white;
        }

        .role-vol {
            background: linear-gradient(135deg, #e6b85c, var(--yellow));
            color: var(--brown);
        }

        .role-default {
            background: var(--bg-light);
            color: var(--brown);
        }

        /* Tarjeta de seguridad */
        .security-card {
            background-color: var(--bg-light);
            border-radius: 16px;
            padding: 1.5rem;
            border: 1px solid var(--green);
        }

        code {
            background-color: white;
            border: 1px solid var(--green);
            border-radius: 8px;
            padding: 0.5rem;
            font-size: 0.8rem;
            word-break: break-all;
        }

        /* Tarjeta de acciones */
        .action-card {
            background: white;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 15px 35px rgba(151,199,139,0.15);
            border: none;
        }

        .action-card-body {
            padding: 1.5rem;
        }

        /* Badges */
        .badge.bg-green {
            background-color: var(--green) !important;
            color: white !important;
        }

        .badge.bg-pink {
            background-color: var(--pink) !important;
            color: var(--brown) !important;
        }

        .badge.bg-yellow {
            background-color: var(--yellow) !important;
            color: var(--brown) !important;
        }

        /* Alertas */
        .alert-beige {
            background-color: var(--bg-light);
            border: 1px solid var(--green);
            color: var(--brown);
            border-radius: 16px;
        }

        /* Botones */
        .btn-green {
            background-color: var(--green);
            border: none;
            border-radius: 50px;
            padding: 0.6rem 1.8rem;
            font-weight: 500;
            transition: all 0.3s;
        }

            .btn-green:hover {
                background-color: #86b57a;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(151,199,139,0.4);
            }

        .btn-yellow {
            background-color: var(--yellow);
            border: none;
            border-radius: 50px;
            padding: 0.6rem 1.8rem;
            font-weight: 500;
            transition: all 0.3s;
            color: var(--brown);
        }

            .btn-yellow:hover {
                background-color: #e6b85c;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(242,198,109,0.4);
            }

        .btn-pink {
            background-color: var(--pink);
            border: none;
            border-radius: 50px;
            padding: 0.6rem 1.8rem;
            font-weight: 500;
            transition: all 0.3s;
            color: var(--brown);
        }

            .btn-pink:hover {
                background-color: #f9c2b0;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(249,194,176,0.4);
            }

        .btn-outline-green {
            border: 2px solid var(--green);
            background: transparent;
            color: var(--green);
            border-radius: 50px;
            padding: 0.6rem 1.8rem;
            font-weight: 500;
            transition: all 0.3s;
        }

            .btn-outline-green:hover {
                background-color: var(--green);
                color: white;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(151,199,139,0.3);
            }

        /* Responsive */
        @@media (max-width: 768px) {
            .profile-img, .profile-img-placeholder {
                width: 150px;
                height: 150px;
            }

                .profile-img-placeholder i {
                    font-size: 3rem;
                }

            .action-card-body {
                flex-direction: column;
                gap: 1rem;
            }

                .action-card-body .btn {
                    width: 100%;
                    margin: 0 !important;
                }
        }
    </style>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function () {
            console.log('Vista Detalles de Usuario cargada');

            // Obtener token AntiForgery
            function getAntiForgeryToken() {
                var tokenInput = $('#__AjaxAntiForgeryForm input[name="__RequestVerificationToken"]').first();
                if (tokenInput.length > 0) return tokenInput.val();
                tokenInput = $('input[name="__RequestVerificationToken"]').first();
                if (tokenInput.length > 0) return tokenInput.val();
                return null;
            }
            var antiForgeryToken = getAntiForgeryToken();

            // Activar/Desactivar usuario con SweetAlert2
            $('.btn-toggle').click(function (e) {
                e.preventDefault();

                var usuarioId = $(this).data('id');
                var usuarioNombre = $(this).data('nombre');
                var accion = $(this).data('accion');
                var actual = $(this).data('actual');

                var actionText = accion.toLowerCase();
                var actionColor = accion === 'Activar' ? '#97C78B' : '#F2C66D';
                var actionIcon = accion === 'Activar' ? 'fa-check' : 'fa-ban';
                var infoText = actual ?
                    'El usuario perderá acceso al sistema pero sus datos se mantendrán.' :
                    'El usuario recuperará acceso al sistema con sus roles asignados.';

                Swal.fire({
                    title: `¿${accion} usuario?`,
                    html: `<p class="text-brown">¿Está seguro de ${actionText} al usuario <strong>${usuarioNombre}</strong>?</p>
                          <div class="alert alert-beige border-green mt-2">
                              <small><i class="fas fa-info-circle text-green"></i> ${infoText}</small>
                          </div>`,
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonColor: actionColor,
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: `<i class="fas ${actionIcon}"></i> Sí, ${actionText}`,
                    cancelButtonText: '<i class="fas fa-times"></i> Cancelar'
                }).then((result) => {
                    if (result.isConfirmed) {
                        var form = $('<form>', {
                            method: 'POST',
                            action: '@Url.Action("ToggleUsuario", "Admin")'
                        }).append(
                            $('<input>', { type: 'hidden', name: '__RequestVerificationToken', value: antiForgeryToken }),
                            $('<input>', { type: 'hidden', name: 'id', value: usuarioId })
                        );
                        $('body').append(form);
                        form.submit();
                    }
                });
            });

            // Eliminar usuario con SweetAlert2
            $('.btn-eliminar').click(function (e) {
                e.preventDefault();
                var usuarioId = $(this).data('id');
                var usuarioNombre = $(this).data('nombre');

                Swal.fire({
                    title: '¿Eliminar usuario permanentemente?',
                    html: `<p class="text-brown">¿Está absolutamente seguro de eliminar permanentemente al usuario <strong>${usuarioNombre}</strong>?</p>
                          <div class="alert alert-beige border-green mt-2">
                              <small><i class="fas fa-exclamation-circle text-green"></i> <strong class="text-brown">ADVERTENCIA:</strong> Esta acción es irreversible</small>
                              <ul class="mt-2 mb-0 text-secondary">
                                  <li>Se eliminarán todos los datos personales</li>
                                  <li>Se eliminarán todos los roles asignados</li>
                                  <li>Se eliminará el historial de actividades</li>
                                  <li>Se eliminarán todas las solicitudes asociadas</li>
                              </ul>
                          </div>
                          <p class="text-brown mt-3">Para confirmar, escriba <strong>ELIMINAR</strong> en el campo a continuación:</p>
                          <input type="text" id="confirmDeleteInput" class="form-control border-green" placeholder="Escriba ELIMINAR aquí">`,
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#FBCDC0',
                    cancelButtonColor: '#97C78B',
                    confirmButtonText: '<i class="fas fa-trash"></i> Confirmar eliminación',
                    cancelButtonText: '<i class="fas fa-times"></i> Cancelar',
                    preConfirm: () => {
                        const confirmText = document.getElementById('confirmDeleteInput').value;
                        if (confirmText !== 'ELIMINAR') {
                            Swal.showValidationMessage('Debe escribir exactamente "ELIMINAR" para confirmar');
                            return false;
                        }
                        return true;
                    }
                }).then((result) => {
                    if (result.isConfirmed) {
                        var form = $('<form>', {
                            method: 'POST',
                            action: '@Url.Action("EliminarUsuario", "Admin")/' + usuarioId
                        }).append(
                            $('<input>', { type: 'hidden', name: '__RequestVerificationToken', value: antiForgeryToken })
                        );
                        $('body').append(form);

                        Swal.fire({
                            title: 'Eliminando usuario...',
                            text: 'Por favor espere mientras se procesa la solicitud',
                            icon: 'info',
                            showConfirmButton: false,
                            allowOutsideClick: false,
                            didOpen: () => Swal.showLoading()
                        });

                        setTimeout(() => form.submit(), 1000);
                    }
                });
            });

            // Notificaciones de TempData
            @if (TempData["SuccessMessage"] != null)
            {
                <text>
                Swal.fire({
                    icon: 'success',
                    title: '¡Éxito!',
                    text: '@Html.Raw(TempData["SuccessMessage"])',
                    confirmButtonColor: '#97C78B',
                    timer: 3000
                });
                </text>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <text>
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: '@Html.Raw(TempData["ErrorMessage"])',
                    confirmButtonColor: '#FBCDC0'
                });
                </text>
            }
        });
    </script>
}