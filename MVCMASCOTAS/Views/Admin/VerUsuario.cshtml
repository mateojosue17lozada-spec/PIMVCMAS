@model MVCMASCOTAS.Models.Usuarios
@{
    ViewBag.Title = "Detalles del Usuario";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header mb-4 fade-in-up">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h2 class="text-brown"><i class="fa fa-user text-green"></i> Detalles del Usuario</h2>
            <p class="text-secondary">Información completa del usuario en el sistema</p>
        </div>
        <div>
            <a href="@Url.Action("EditarUsuario", "Admin", new { id = Model.UsuarioId })"
               class="btn btn-yellow">
                <i class="fa fa-edit"></i> Editar
            </a>
            <a href="@Url.Action("Usuarios", "Admin")" class="btn btn-outline-green">
                <i class="fa fa-arrow-left"></i> Volver
            </a>
        </div>
    </div>
</div>

<div class="row">
    <!-- Columna Izquierda - Información Personal -->
    <div class="col-md-4">
        <div class="card shadow-hover border-green mb-4">
            <div class="card-header bg-green text-white">
                <h5 class="mb-0"><i class="fa fa-id-card"></i> Perfil</h5>
            </div>
            <div class="card-body text-center bg-light-mint">
                <!-- Imagen de Perfil -->
                @if (Model.ImagenPerfil != null && Model.ImagenPerfil.Length > 0)
                {
                    <img src="data:image/jpeg;base64,@Convert.ToBase64String(Model.ImagenPerfil)"
                         class="rounded-circle mb-3 border-green"
                         style="width: 200px; height: 200px; object-fit: cover;"
                         alt="@Model.NombreCompleto" />
                }
                else
                {
                    <div class="rounded-circle bg-light-mint d-flex align-items-center justify-content-center mb-3 mx-auto border-green"
                         style="width: 200px; height: 200px;">
                        <i class="fa fa-user fa-5x text-secondary"></i>
                    </div>
                }

                <h4 class="mb-2 text-brown">@Model.NombreCompleto</h4>
                <p class="text-secondary mb-3">@Model.Email</p>

                <!-- Estado -->
                <div class="mb-3">
                    @if (Model.Activo == true)
                    {
                        <span class="badge bg-green p-2 mr-1">
                            <i class="fa fa-check-circle"></i> Activo
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-pink p-2 mr-1">
                            <i class="fa fa-ban"></i> Inactivo
                        </span>
                    }

                    @if (Model.EmailConfirmado == true)
                    {
                        <span class="badge bg-green p-2 mr-1">
                            <i class="fa fa-envelope"></i> Email Confirmado
                        </span>
                    }

                    @if (Model.TelefonoConfirmado == true)
                    {
                        <span class="badge bg-green p-2">
                            <i class="fa fa-phone"></i> Teléfono Confirmado
                        </span>
                    }
                </div>

                <!-- ID del Usuario -->
                <div class="alert alert-green border-green">
                    <i class="fa fa-fingerprint text-green"></i> <span class="text-brown">ID: <strong>#@Model.UsuarioId</strong></span>
                </div>
            </div>
        </div>

        <!-- Información de Contacto -->
        <div class="card shadow-hover border-green mb-4">
            <div class="card-header bg-green text-white">
                <h5 class="mb-0"><i class="fa fa-address-book"></i> Contacto</h5>
            </div>
            <div class="card-body bg-light-mint">
                <div class="mb-3">
                    <h6 class="text-brown"><i class="fa fa-phone text-green"></i> Teléfono</h6>
                    <p class="mb-0 text-brown">@(Model.Telefono ?? "No registrado")</p>
                </div>

                <div class="mb-3">
                    <h6 class="text-brown"><i class="fa fa-id-card text-green"></i> Cédula</h6>
                    <p class="mb-0 text-brown">@(Model.Cedula ?? "No registrada")</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Columna Derecha - Información Detallada -->
    <div class="col-md-8">
        <!-- Información de Dirección -->
        <div class="card shadow-hover border-green mb-4">
            <div class="card-header bg-green text-white">
                <h5 class="mb-0"><i class="fa fa-map-marker-alt"></i> Dirección</h5>
            </div>
            <div class="card-body bg-light-mint">
                <div class="row">
                    <div class="col-md-12">
                        <div class="mb-3">
                            <h6 class="text-brown">Dirección Completa</h6>
                            <p class="mb-0 text-brown">@(Model.Direccion ?? "No registrada")</p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <h6 class="text-brown">Ciudad</h6>
                            <p class="mb-0 text-brown">@(Model.Ciudad ?? "No registrada")</p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <h6 class="text-brown">Provincia</h6>
                            <p class="mb-0 text-brown">@(Model.Provincia ?? "No registrada")</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Roles Asignados -->
        <div class="card shadow-hover border-green mb-4">
            <div class="card-header bg-yellow">
                <h5 class="mb-0 text-brown"><i class="fa fa-user-tag"></i> Roles Asignados</h5>
            </div>
            <div class="card-body bg-light-mint">
                @if (Model.UsuariosRoles != null && Model.UsuariosRoles.Any())
                {
                    <div class="row">
                        @foreach (var userRole in Model.UsuariosRoles)
                        {
                            var role = userRole.Roles;
                            var cardClass = role.NombreRol == "Administrador" ? "bg-pink" :
                                           role.NombreRol == "Veterinario" ? "bg-green" :
                                           role.NombreRol == "Voluntario" ? "bg-yellow" : "bg-light-mint";
                            var textClass = role.NombreRol == "Administrador" ? "text-brown" :
                                           role.NombreRol == "Veterinario" ? "text-white" :
                                           role.NombreRol == "Voluntario" ? "text-brown" : "text-brown";

                            <div class="col-md-4 mb-3">
                                <div class="card border-green shadow-hover @cardClass">
                                    <div class="card-body text-center">
                                        <h5 class="@textClass">
                                            <i class="fa @(role.NombreRol == "Administrador" ? "fa-user-shield" :
                                                  role.NombreRol == "Veterinario" ? "fa-user-md" :
                                                  role.NombreRol == "Voluntario" ? "fa-hands-helping" : "fa-user")"></i>
                                        </h5>
                                        <h6 class="mb-2 @textClass">@role.NombreRol</h6>
                                        <small class="@(textClass == "text-white" ? "text-light" : "text-secondary")">
                                            @if (userRole.FechaAsignacion.HasValue)
                                            {
                                                <i class="fa fa-calendar"></i>
                                                @userRole.FechaAsignacion.Value.ToString("dd/MM/yyyy")
                                            }
                                        </small>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="alert alert-green border-green">
                        <i class="fa fa-exclamation-triangle text-green"></i> <span class="text-brown">Este usuario no tiene roles asignados.</span>
                    </div>
                }
            </div>
        </div>

        <!-- Información del Sistema -->
        <div class="card shadow-hover border-green">
            <div class="card-header bg-green text-white">
                <h5 class="mb-0"><i class="fa fa-cogs"></i> Información del Sistema</h5>
            </div>
            <div class="card-body bg-light-mint">
                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <h6 class="text-brown"><i class="fa fa-calendar-plus text-green"></i> Fecha de Registro</h6>
                            <p class="mb-0 text-brown">
                                @if (Model.FechaRegistro.HasValue)
                                {
                                    @Model.FechaRegistro.Value.ToString("dd/MM/yyyy HH:mm")
                                }
                                else
                                {
                                    <span class="text-secondary">No registrada</span>
                                }
                            </p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <h6 class="text-brown"><i class="fa fa-sign-in-alt text-green"></i> Último Acceso</h6>
                            <p class="mb-0 text-brown">
                                @if (Model.UltimoAcceso.HasValue)
                                {
                                    @Model.UltimoAcceso.Value.ToString("dd/MM/yyyy HH:mm")
                                }
                                else
                                {
                                    <span class="text-secondary">No registrado</span>
                                }
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Información de seguridad (Hash y Salt) -->
                @if (!string.IsNullOrEmpty(Model.PasswordHash))
                {
                    <div class="alert alert-green border-green mt-3">
                        <h6 class="text-brown"><i class="fa fa-key text-green"></i> Información de Seguridad</h6>
                        <div class="row">
                            <div class="col-md-6">
                                <small class="text-brown">Password Hash:</small><br>
                                <code class="small text-truncate d-block text-secondary">@Model.PasswordHash</code>
                            </div>
                            <div class="col-md-6">
                                <small class="text-brown">Salt:</small><br>
                                <code class="small text-truncate d-block text-secondary">@Model.Salt</code>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Botones de Acción -->
<div class="card shadow-hover border-green mt-4 fade-in-up">
    <div class="card-body bg-light-mint">
        <div class="d-flex justify-content-between">
            <div>
                @if (Model.Activo == true)
                {
                    <button type="button" class="btn btn-pink btn-toggle"
                            data-id="@Model.UsuarioId"
                            data-nombre="@Model.NombreCompleto"
                            data-accion="Desactivar"
                            data-actual="true">
                        <i class="fa fa-ban"></i> Desactivar Usuario
                    </button>
                }
                else
                {
                    <button type="button" class="btn btn-green btn-toggle"
                            data-id="@Model.UsuarioId"
                            data-nombre="@Model.NombreCompleto"
                            data-accion="Activar"
                            data-actual="false">
                        <i class="fa fa-check"></i> Activar Usuario
                    </button>

                    <button type="button" class="btn btn-pink ml-2 btn-eliminar"
                            data-id="@Model.UsuarioId"
                            data-nombre="@Model.NombreCompleto">
                        <i class="fa fa-trash"></i> Eliminar Permanentemente
                    </button>
                }
            </div>

            <div>
                <a href="@Url.Action("Usuarios", "Admin")" class="btn btn-outline-green">
                    <i class="fa fa-users"></i> Ver Todos los Usuarios
                </a>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .page-header {
            border-bottom: 2px solid var(--green);
            padding-bottom: 1rem;
        }

        .card {
            border-radius: 12px !important;
            border: 2px solid var(--green) !important;
        }

        .card-header {
            border-radius: 10px 10px 0 0 !important;
            padding: 1rem 1.35rem !important;
        }

        .rounded-circle.border-green {
            border: 2px solid var(--green) !important;
        }

        .badge.bg-green {
            background-color: var(--green) !important;
            color: white !important;
        }

        .badge.bg-pink {
            background-color: var(--pink) !important;
            color: var(--brown) !important;
        }

        .badge.bg-yellow {
            background-color: var(--yellow) !important;
            color: var(--brown) !important;
        }

        .badge.bg-light-mint {
            background-color: var(--bg-light) !important;
            color: var(--brown) !important;
            border: 1px solid var(--green) !important;
        }

        /* Estilos para las tarjetas de roles */
        .card.bg-pink {
            background-color: var(--pink) !important;
        }

        .card.bg-green {
            background-color: var(--green) !important;
        }

        .card.bg-yellow {
            background-color: var(--yellow) !important;
        }

        .card.bg-light-mint {
            background-color: var(--bg-light) !important;
        }

        /* Animaciones */
        .fade-in-up {
            animation: fadeInUp 0.6s ease-out;
        }

        /* Código de seguridad */
        code {
            background-color: rgba(151, 199, 139, 0.1);
            padding: 5px 10px;
            border-radius: 4px;
            border: 1px solid rgba(151, 199, 139, 0.3);
            font-family: 'Courier New', monospace;
        }

        /* Responsive */
        @@media (max-width: 768px) {
            .page-header .d-flex {
                flex-direction: column;
                align-items: flex-start !important;
            }

                .page-header .d-flex > div {
                    margin-bottom: 10px;
                    width: 100%;
                }

                .page-header .d-flex .btn {
                    width: 100%;
                    margin-bottom: 5px;
                }

            .card-body .row .col-md-6,
            .card-body .row .col-md-4 {
                margin-bottom: 15px;
            }

            .rounded-circle {
                width: 150px !important;
                height: 150px !important;
            }

            .card-footer .btn {
                width: 100%;
                margin-bottom: 10px;
            }
        }

        @@media (max-width: 576px) {
            .d-flex.justify-content-between {
                flex-direction: column !important;
            }

                .d-flex.justify-content-between > div {
                    width: 100% !important;
                    margin-bottom: 15px;
                }

                .d-flex.justify-content-between .btn {
                    width: 100% !important;
                    margin-bottom: 10px !important;
                }

            .col-md-4, .col-md-8 {
                padding-left: 15px !important;
                padding-right: 15px !important;
            }
        }

        /* Efectos hover */
        .shadow-hover:hover {
            transform: translateY(-3px);
            border-color: var(--green) !important;
        }

        /* Estilo para las alertas de seguridad */
        .alert-green code {
            background-color: rgba(255, 255, 255, 0.1);
            border-color: rgba(255, 255, 255, 0.2);
        }
    </style>
}

@section Scripts {
    <script>
        $(document).ready(function () {
            console.log('Vista Detalles de Usuario cargada');

            // Efecto hover en tarjetas
            $('.shadow-hover').hover(
                function () {
                    $(this).addClass('shadow-lg');
                },
                function () {
                    $(this).removeClass('shadow-lg');
                }
            );

            // Confirmación para activar/desactivar usuario con SweetAlert2
            $('.btn-toggle').click(function (e) {
                e.preventDefault();

                var usuarioId = $(this).data('id');
                var usuarioNombre = $(this).data('nombre');
                var accion = $(this).data('accion');
                var actual = $(this).data('actual');

                var actionText = accion.toLowerCase();
                var actionColor = accion === 'Activar' ? '#97C78B' : '#F2C66D';
                var actionIcon = accion === 'Activar' ? 'fa-check' : 'fa-ban';
                var infoText = actual ?
                    'El usuario perderá acceso al sistema pero sus datos se mantendrán.' :
                    'El usuario recuperará acceso al sistema con sus roles asignados.';

                Swal.fire({
                    title: `¿${accion} usuario?`,
                    html: `<p class="text-brown">¿Está seguro de ${actionText} al usuario <strong>${usuarioNombre}</strong>?</p>
                          <div class="alert alert-green border-green mt-2">
                              <small><i class="fa fa-info-circle text-green"></i> ${infoText}</small>
                          </div>`,
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonColor: actionColor,
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: `<i class="fa ${actionIcon}"></i> Sí, ${actionText}`,
                    cancelButtonText: '<i class="fa fa-times"></i> Cancelar',
                    showClass: {
                        popup: 'animate__animated animate__fadeInDown'
                    },
                    hideClass: {
                        popup: 'animate__animated animate__fadeOutUp'
                    }
                }).then((result) => {
                    if (result.isConfirmed) {
                        // Crear formulario dinámico para enviar
                        var form = document.createElement('form');
                        form.method = 'POST';
                        form.action = '@Url.Action("ToggleUsuario", "Admin")';

                        var token = document.createElement('input');
                        token.type = 'hidden';
                        token.name = '__RequestVerificationToken';
                        token.value = $('input[name="__RequestVerificationToken"]').val();

                        var idInput = document.createElement('input');
                        idInput.type = 'hidden';
                        idInput.name = 'id';
                        idInput.value = usuarioId;

                        form.appendChild(token);
                        form.appendChild(idInput);
                        document.body.appendChild(form);
                        form.submit();
                    }
                });
            });

            // Confirmación para eliminar usuario con SweetAlert2
            $('.btn-eliminar').click(function (e) {
                e.preventDefault();
                var usuarioId = $(this).data('id');
                var usuarioNombre = $(this).data('nombre');

                Swal.fire({
                    title: '¿Eliminar usuario permanentemente?',
                    html: `<p class="text-brown">¿Está absolutamente seguro de eliminar permanentemente al usuario <strong>${usuarioNombre}</strong>?</p>
                          <div class="alert alert-green border-green mt-2">
                              <small><i class="fa fa-exclamation-circle text-green"></i> <strong class="text-brown">ADVERTENCIA:</strong> Esta acción es irreversible</small>
                              <ul class="mt-2 mb-0 text-secondary">
                                  <li>Se eliminarán todos los datos personales</li>
                                  <li>Se eliminarán todos los roles asignados</li>
                                  <li>Se eliminará el historial de actividades</li>
                                  <li>Se eliminarán todas las solicitudes asociadas</li>
                              </ul>
                          </div>
                          <p class="text-brown mt-3">Para confirmar, escriba <strong>ELIMINAR</strong> en el campo a continuación:</p>
                          <input type="text" id="confirmDeleteInput" class="form-control border-green" placeholder="Escriba ELIMINAR aquí">`,
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#FBCDC0',
                    cancelButtonColor: '#97C78B',
                    confirmButtonText: '<i class="fa fa-trash"></i> Confirmar eliminación',
                    cancelButtonText: '<i class="fa fa-times"></i> Cancelar',
                    showClass: {
                        popup: 'animate__animated animate__fadeInDown'
                    },
                    hideClass: {
                        popup: 'animate__animated animate__fadeOutUp'
                    },
                    preConfirm: () => {
                        const confirmText = document.getElementById('confirmDeleteInput').value;
                        if (confirmText !== 'ELIMINAR') {
                            Swal.showValidationMessage('Debe escribir exactamente "ELIMINAR" para confirmar');
                            return false;
                        }
                        return true;
                    }
                }).then((result) => {
                    if (result.isConfirmed) {
                        // Crear formulario dinámico para enviar
                        var form = document.createElement('form');
                        form.method = 'POST';
                        form.action = '@Url.Action("EliminarUsuario", "Admin")/' + usuarioId;

                        var token = document.createElement('input');
                        token.type = 'hidden';
                        token.name = '__RequestVerificationToken';
                        token.value = $('input[name="__RequestVerificationToken"]').val();

                        form.appendChild(token);
                        document.body.appendChild(form);

                        // Mostrar loader
                        Swal.fire({
                            title: 'Eliminando usuario...',
                            text: 'Por favor espere mientras se procesa la solicitud',
                            icon: 'info',
                            showConfirmButton: false,
                            allowOutsideClick: false,
                            allowEscapeKey: false,
                            didOpen: () => {
                                Swal.showLoading();
                            }
                        });

                        // Enviar formulario después de un breve delay
                        setTimeout(() => {
                            form.submit();
                        }, 1000);
                    }
                });
            });

            // Tooltips para badges
            $('[title]').tooltip({
                trigger: 'hover'
            });

            // Notificaciones de TempData
            @if (TempData["SuccessMessage"] != null)
            {
                <text>
                Swal.fire({
                    icon: 'success',
                    title: '¡Éxito!',
                    text: '@Html.Raw(TempData["SuccessMessage"])',
                    confirmButtonColor: '#97C78B',
                    timer: 3000
                });
                </text>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <text>
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: '@Html.Raw(TempData["ErrorMessage"])',
                    confirmButtonColor: '#FBCDC0'
                });
                </text>
            }
        });
    </script>
}