@model MVCMASCOTAS.Models.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard Administrativo - ADOPTAMANÍA";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Hero Section -->
<section class="dashboard-hero py-4">
    <div class="container text-center">
        <i class="fas fa-user-shield fa-3x text-green mb-3"></i>
        <h1 class="display-5 fw-bold mb-2 text-brown">Panel de Control Administrativo</h1>
        <p class="lead mb-3 text-secondary">Bienvenido al sistema integral de gestión del refugio</p>
    </div>
</section>

<!-- Main Content -->
<section class="py-5 bg-beige">
    <div class="container">
        <!-- Alertas del Sistema -->
        @{
            var alertasSistema = Model.Alertas as List<string>;
            var alertasMascotasPerdidas = Model.AlertasMascotasPerdidas as List<string>;
        }

        @if (alertasSistema != null && alertasSistema.Any())
        {
            <div class="alert alert-beige border-green alert-dismissible fade show mb-4" role="alert">
                <div class="d-flex align-items-start">
                    <i class="fas fa-exclamation-triangle fa-2x text-yellow me-3"></i>
                    <div>
                        <h5 class="text-brown mb-2"><i class="fas fa-bell text-green me-2"></i> Alertas del Sistema</h5>
                        <ul class="mb-0">
                            @foreach (var alerta in alertasSistema)
                            {
                                <li class="text-secondary">@alerta</li>
                            }
                        </ul>
                    </div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <!-- Alertas de Mascotas Perdidas -->
        @if (Model.HayAlertasMascotasPerdidas && alertasMascotasPerdidas != null && alertasMascotasPerdidas.Any())
        {
            <div class="alert alert-beige border-green alert-dismissible fade show mb-4" role="alert">
                <div class="d-flex align-items-start">
                    <i class="fas fa-search fa-2x text-yellow me-3"></i>
                    <div>
                        <h5 class="text-brown mb-2"><i class="fas fa-paw text-green me-2"></i> Alertas de Mascotas Perdidas</h5>
                        <ul class="mb-0">
                            @foreach (var alerta in alertasMascotasPerdidas)
                            {
                                <li class="text-secondary">@alerta</li>
                            }
                        </ul>
                    </div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <!-- Widgets de Acceso Rápido -->
    <div class="row mb-4">
        <div class="col-12">
            <h4 class="mb-3 text-brown"><i class="fas fa-rocket text-green me-2"></i> Acceso Rápido</h4>
        </div>

        <div class="col-md-2 col-sm-4 col-6 mb-3">
            <a href="/Admin/Usuarios" class="text-decoration-none">
                <div class="quick-card text-center">
                    <i class="fas fa-users fa-2x text-green mb-2"></i>
                    <h6 class="text-brown">Usuarios</h6>
                    <small class="text-secondary">Gestionar usuarios</small>
                </div>
            </a>
        </div>

        <div class="col-md-2 col-sm-4 col-6 mb-3">
            <a href="/Mascotas/Gestionar" class="text-decoration-none">
                <div class="quick-card text-center">
                    <i class="fas fa-paw fa-2x text-green mb-2"></i>
                    <h6 class="text-brown">Gestionar Mascotas</h6>
                    <small class="text-secondary">@Model.TotalMascotas total</small>
                </div>
            </a>
        </div>

        <div class="col-md-2 col-sm-4 col-6 mb-3">
            <a href="/Mascotas/Crear" class="text-decoration-none">
                <div class="quick-card text-center">
                    <i class="fas fa-plus-circle fa-2x text-green mb-2"></i>
                    <h6 class="text-brown">Nueva Mascota</h6>
                    <small class="text-secondary">Registrar nueva</small>
                </div>
            </a>
        </div>

        <div class="col-md-2 col-sm-4 col-6 mb-3">
            <a href="/Mascotas/Listado?tipo=Disponibles" class="text-decoration-none">
                <div class="quick-card text-center">
                    <i class="fas fa-list fa-2x text-green mb-2"></i>
                    <h6 class="text-brown">Mascotas Disponibles</h6>
                    <small class="text-secondary">@Model.MascotasDisponibles disponibles</small>
                </div>
            </a>
        </div>

        <div class="col-md-2 col-sm-4 col-6 mb-3">
            <a href="/Mascotas/SeguimientoAdopciones" class="text-decoration-none">
                <div class="quick-card text-center">
                    <i class="fas fa-heartbeat fa-2x text-green mb-2"></i>
                    <h6 class="text-brown">Seguimiento Adopciones</h6>
                    <small class="text-secondary">Monitorear adoptados</small>
                </div>
            </a>
        </div>

        <div class="col-md-2 col-sm-4 col-6 mb-3">
            <a href="/Mascotas/ContratosAdopcion" class="text-decoration-none">
                <div class="quick-card text-center">
                    <i class="fas fa-file-contract fa-2x text-green mb-2"></i>
                    <h6 class="text-brown">Contratos Adopción</h6>
                    <small class="text-secondary">Gestión de contratos</small>
                </div>
            </a>
        </div>


        <div class="col-md-2 col-sm-4 col-6 mb-3">
            <a href="/Mascotas/MascotasArchivadas" class="text-decoration-none">
                <div class="quick-card text-center">
                    <i class="fas fa-archive fa-2x text-green mb-2"></i>
                    <h6 class="text-brown">Mascotas Archivadas</h6>
                    <small class="text-secondary">Ver historial archivado</small>
                </div>
            </a>
        </div>

        <div class="col-md-2 col-sm-4 col-6 mb-3">
            <a href="/Mascotas/ExportarMascotas" class="text-decoration-none">
                <div class="quick-card text-center">
                    <i class="fas fa-file-export fa-2x text-green mb-2"></i>
                    <h6 class="text-brown">Exportar Mascotas</h6>
                    <small class="text-secondary">Generar reportes CSV</small>
                </div>
            </a>
        </div>

        <div class="col-md-2 col-sm-4 col-6 mb-3">
            <a href="/Admin/SolicitudAdopcion" class="text-decoration-none">
                <div class="quick-card text-center">
                    <i class="fas fa-heart fa-2x text-green mb-2"></i>
                    <h6 class="text-brown">Adopciones</h6>
                    <small class="text-secondary">@Model.SolicitudesPendientes pendientes</small>
                </div>
            </a>
        </div>

        <div class="col-md-2 col-sm-4 col-6 mb-3">
            <a href="/Admin/PanelVeterinario" class="text-decoration-none">
                <div class="quick-card text-center">
                    <i class="fas fa-user-md fa-2x text-green mb-2"></i>
                    <h6 class="text-brown">Veterinaria</h6>
                    <small class="text-secondary">@Model.ConsultasPendientes pendientes</small>
                </div>
            </a>
        </div>

        <div class="col-md-2 col-sm-4 col-6 mb-3">
            <a href="/Admin/GestionDonaciones" class="text-decoration-none">
                <div class="quick-card text-center">
                    <i class="fas fa-donate fa-2x text-green mb-2"></i>
                    <h6 class="text-brown">Donaciones</h6>
                    <small class="text-secondary">$@Model.TotalDonacionesMes.ToString("N2") este mes</small>
                </div>
            </a>
        </div>

        <div class="col-md-2 col-sm-4 col-6 mb-3">
            <a href="/Admin/PanelContabilidad" class="text-decoration-none">
                <div class="quick-card text-center">
                    <i class="fas fa-calculator fa-2x text-green mb-2"></i>
                    <h6 class="text-brown">Contabilidad</h6>
                    <small class="text-secondary">Balance: $@Model.BalanceMes.ToString("N2")</small>
                </div>
            </a>
        </div>

        <div class="col-md-2 col-sm-4 col-6 mb-3">
            <a href="/Admin/Roles" class="text-decoration-none">
                <div class="quick-card text-center">
                    <i class="fas fa-user-tag fa-2x text-green mb-2"></i>
                    <h6 class="text-brown">Roles</h6>
                    <small class="text-secondary">Gestionar roles</small>
                </div>
            </a>
        </div>

        <div class="col-md-2 col-sm-4 col-6 mb-3">
            <a href="/Admin/Configuracion" class="text-decoration-none">
                <div class="quick-card text-center">
                    <i class="fas fa-cogs fa-2x text-green mb-2"></i>
                    <h6 class="text-brown">Configuración</h6>
                    <small class="text-secondary">@Model.AjustesSistema ajustes</small>
                </div>
            </a>
        </div>

        <div class="col-md-2 col-sm-4 col-6 mb-3">
            <a href="/Admin/Auditoria" class="text-decoration-none">
                <div class="quick-card text-center">
                    <i class="fas fa-clipboard-list fa-2x text-green mb-2"></i>
                    <h6 class="text-brown">Auditoría</h6>
                    <small class="text-secondary">@Model.RegistrosAuditoriaDia hoy</small>
                </div>
            </a>
        </div>

        <div class="col-md-2 col-sm-4 col-6 mb-3">
            <a href="/Rescate/MascotasPerdidas" class="text-decoration-none">
                <div class="quick-card text-center">
                    <i class="fas fa-search fa-2x text-green mb-2"></i>
                    <h6 class="text-brown">Mascotas Perdidas</h6>
                    <small class="text-secondary">@Model.MascotasPerdidasActivas activas</small>
                </div>
            </a>
        </div>

        <div class="col-md-2 col-sm-4 col-6 mb-3">
            <a href="@Url.Action("Index", "CategoriaSimulado")" class="text-decoration-none">
                <div class="quick-card text-center">
                    <i class="fas fa-tags fa-2x text-green mb-2"></i>
                    <h6 class="text-brown">Categorías</h6>
                    <small class="text-secondary">Administrar</small>
                </div>
            </a>
        </div>

        <div class="col-md-2 col-sm-4 col-6 mb-3">
            <a href="@Url.Action("Index", "FormularioSimulado")" class="text-decoration-none">
                <div class="quick-card text-center">
                    <i class="fas fa-file-alt fa-2x text-green mb-2"></i>
                    <h6 class="text-brown">Formularios</h6>
                    <small class="text-secondary">Gestionar</small>
                </div>
            </a>
        </div>

        <div class="col-md-2 col-sm-4 col-6 mb-3">
            <a href="/Rescate/ReportarMascotaPerdida" class="text-decoration-none">
                <div class="quick-card text-center">
                    <i class="fas fa-exclamation-triangle fa-2x text-green mb-2"></i>
                    <h6 class="text-brown">Reportar Pérdida</h6>
                    <small class="text-secondary">Nuevo reporte</small>
                </div>
            </a>
        </div>

        <div class="col-md-2 col-sm-4 col-6 mb-3">
            <a href="/Reportes/Index" class="text-decoration-none">
                <div class="quick-card text-center">
                    <i class="fas fa-chart-bar fa-2x text-green mb-2"></i>
                    <h6 class="text-brown">Reportes</h6>
                    <small class="text-secondary">Ver reportes del sistema</small>
                </div>
            </a>
        </div>
    </div>

        <!-- Estadísticas Principales -->
        <div class="row g-3 mb-5">
            <div class="col-md-6 col-lg-3">
                <div class="stat-card bg-green text-white">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-white">MASCOTAS TOTAL</h6>
                            <div class="h3 mb-0">@Model.TotalMascotas</div>
                        </div>
                        <i class="fas fa-paw fa-2x opacity-50"></i>
                    </div>
                    <div class="mt-3 d-flex gap-2">
                        <span class="badge bg-yellow text-brown"><i class="fas fa-heart me-1"></i> @Model.MascotasAdoptadas adoptadas</span>
                        <span class="badge bg-yellow text-brown"><i class="fas fa-medkit me-1"></i> @Model.MascotasEnTratamiento en tratamiento</span>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-3">
                <div class="stat-card bg-green text-white">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-white">ADOPCIONES</h6>
                            <div class="h3 mb-0">@Model.AdopcionesEsteMes</div>
                            <small>este mes</small>
                        </div>
                        <i class="fas fa-heart fa-2x opacity-50"></i>
                    </div>
                    <div class="mt-3 d-flex gap-2">
                        <span class="badge bg-yellow text-brown"><i class="fas fa-clock me-1"></i> @Model.SolicitudesPendientes pendientes</span>
                        <span class="badge bg-yellow text-brown"><i class="fas fa-check me-1"></i> @Model.SolicitudesAprobadas aprobadas</span>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-3">
                <div class="stat-card bg-green text-white">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-white">DONACIONES</h6>
                            <div class="h3 mb-0">$@Model.TotalDonacionesMes.ToString("N2")</div>
                            <small>este mes</small>
                        </div>
                        <i class="fas fa-donate fa-2x opacity-50"></i>
                    </div>
                    <div class="mt-3 d-flex gap-2">
                        <span class="badge bg-yellow text-brown"><i class="fas fa-users me-1"></i> @Model.NumeroDonantesMes donantes</span>
                        <span class="badge bg-yellow text-brown"><i class="fas fa-hands-helping me-1"></i> @Model.ApadrinamientosActivos apadrinamientos</span>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-3">
                <div class="stat-card bg-green text-white">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-white">CONTABILIDAD</h6>
                            <div class="h3 mb-0">$@Model.BalanceMes.ToString("N2")</div>
                            <small>balance mensual</small>
                        </div>
                        <i class="fas fa-calculator fa-2x opacity-50"></i>
                    </div>
                    <div class="mt-3 d-flex gap-2">
                        <span class="badge bg-yellow text-brown"><i class="fas fa-arrow-up me-1"></i> $@Model.IngresosMes.ToString("N2") ingresos</span>
                        <span class="badge bg-yellow text-brown"><i class="fas fa-arrow-down me-1"></i> $@Model.EgresosMes.ToString("N2") egresos</span>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-3">
                <div class="stat-card bg-green text-white">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-white">MASCOTAS PERDIDAS</h6>
                            <div class="h3 mb-0">@Model.MascotasPerdidasActivas</div>
                            <small>activas</small>
                        </div>
                        <i class="fas fa-search fa-2x opacity-50"></i>
                    </div>
                    <div class="mt-3 d-flex gap-2">
                        <span class="badge bg-yellow text-brown"><i class="fas fa-eye me-1"></i> @Model.ReportesAvistamiento avistamientos</span>
                        <span class="badge bg-yellow text-brown"><i class="fas fa-check-circle me-1"></i> @Model.MascotasEncontradas encontradas</span>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-3">
                <div class="stat-card bg-green text-white">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-white">SEGUIMIENTO</h6>
                            <div class="h3 mb-0">@(Model.SeguimientosPendientes ?? 0)</div>
                            <small>pendientes</small>
                        </div>
                        <i class="fas fa-heartbeat fa-2x opacity-50"></i>
                    </div>
                    <div class="mt-3 d-flex gap-2">
                        <span class="badge bg-yellow text-brown"><i class="fas fa-file-contract me-1"></i> @(Model.ContratosActivos ?? 0) contratos</span>
                        <span class="badge bg-yellow text-brown"><i class="fas fa-history me-1"></i> @(Model.HistorialEstados ?? 0) cambios</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Gráficos y Listas -->
        <div class="row g-4">
            <!-- Columna Izquierda (8 columnas) -->
            <div class="col-lg-8">
                <!-- Gráfico de Mascotas por Especie -->
                <div class="chart-card mb-4">
                    <div class="chart-card-header bg-green text-white">
                        <i class="fas fa-chart-pie me-2"></i> Distribución de Mascotas por Especie
                    </div>
                    <div class="chart-card-body">
                        @if (Model.MascotasPorEspecie != null && Model.MascotasPorEspecie.Any())
                        {
                            <div class="chart-container">
                                <canvas id="mascotasEspecieChart"></canvas>
                            </div>
                            <div class="mt-4 text-center small">
                                @foreach (var item in Model.MascotasPorEspecie)
                                {
                                    <span class="me-3">
                                        <i class="fas fa-circle text-green me-1"></i>
                                        @item.Key: @item.Value
                                    </span>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-beige border-green text-center">
                                <i class="fas fa-info-circle text-green me-2"></i> No hay datos de mascotas para mostrar.
                            </div>
                        }
                    </div>
                </div>

                <!-- Gráfico de Mascotas Perdidas por Especie -->
                <div class="chart-card mb-4">
                    <div class="chart-card-header bg-green text-white">
                        <i class="fas fa-chart-bar me-2"></i> Mascotas Perdidas por Especie
                    </div>
                    <div class="chart-card-body">
                        @if (Model.MascotasPerdidasPorEspecie != null && Model.MascotasPerdidasPorEspecie.Any())
                        {
                            <div class="chart-container" style="height: 300px;">
                                <canvas id="mascotasPerdidasChart"></canvas>
                            </div>
                            <div class="mt-4 text-center small">
                                @foreach (var item in Model.MascotasPerdidasPorEspecie)
                                {
                                    <span class="me-3">
                                        <i class="fas fa-circle text-green me-1"></i>
                                        @item.Key: @item.Value
                                    </span>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-beige border-green text-center">
                                <i class="fas fa-info-circle text-green me-2"></i> No hay datos de mascotas perdidas para mostrar.
                            </div>
                        }
                    </div>
                </div>

                <!-- Últimas Solicitudes de Adopción -->
                <div class="list-card mb-4">
                    <div class="list-card-header bg-green text-white">
                        <i class="fas fa-heart me-2"></i> Últimas Solicitudes de Adopción
                    </div>
                    <div class="list-card-body">
                        @if (Model.UltimasSolicitudes != null && Model.UltimasSolicitudes.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-hover align-middle">
                                    <thead>
                                        <tr>
                                            <th>Solicitante</th>
                                            <th>Mascota</th>
                                            <th>Fecha</th>
                                            <th>Estado</th>
                                            <th class="text-center">Acción</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var solicitud in Model.UltimasSolicitudes)
                                        {
                                            <tr>
                                                <td>
                                                    <strong class="text-brown">@(solicitud.Usuarios?.NombreCompleto ?? "N/A")</strong>
                                                    <br><small class="text-secondary">@(solicitud.Usuarios?.Email ?? "")</small>
                                                </td>
                                                <td>
                                                    <i class="fas @(solicitud.Mascotas?.Especie == "Perro" ? "fa-dog" : "fa-cat") text-green me-1"></i>
                                                    @(solicitud.Mascotas?.Nombre ?? "N/A")
                                                </td>
                                                <td class="text-secondary">@(solicitud.FechaSolicitud?.ToString("dd/MM/yy") ?? "")</td>
                                                <td>
                                                    @if (solicitud.Estado == "Pendiente")
                                                    {
                                                        <span class="badge bg-yellow text-brown">Pendiente</span>
                                                    }
                                                    else if (solicitud.Estado == "Aprobada")
                                                    {
                                                        <span class="badge bg-green text-white">Aprobada</span>
                                                    }
                                                    else if (solicitud.Estado == "Rechazada")
                                                    {
                                                        <span class="badge bg-pink text-brown">Rechazada</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-light-mint text-brown">@solicitud.Estado</span>
                                                    }
                                                </td>
                                                <td class="text-center">
                                                    <a href="/Admin/DetallesSolicitud/@solicitud.SolicitudId" class="btn btn-sm btn-outline-green">
                                                        <i class="fas fa-eye"></i>
                                                    </a>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                            <div class="text-center mt-3">
                                <a href="/Admin/SolicitudAdopcion" class="btn btn-sm btn-outline-green">
                                    <i class="fas fa-list me-2"></i> Ver todas las solicitudes
                                </a>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-beige border-green text-center">
                                <i class="fas fa-info-circle text-green me-2"></i> No hay solicitudes recientes.
                            </div>
                        }
                    </div>
                </div>

                <!-- Últimos Movimientos Contables -->
                <div class="list-card">
                    <div class="list-card-header bg-green text-white">
                        <i class="fas fa-file-invoice-dollar me-2"></i> Últimos Movimientos Contables
                    </div>
                    <div class="list-card-body">
                        @if (Model.UltimosMovimientos != null && Model.UltimosMovimientos.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-hover align-middle">
                                    <thead>
                                        <tr>
                                            <th>Fecha</th>
                                            <th>Concepto</th>
                                            <th>Tipo</th>
                                            <th class="text-end">Monto</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var movimiento in Model.UltimosMovimientos)
                                        {
                                            <tr>
                                                <td class="text-secondary">@(movimiento.FechaMovimiento?.ToString("dd/MM/yy") ?? "")</td>
                                                <td>
                                                    <span class="text-brown">@movimiento.Concepto</span>
                                                    @if (!string.IsNullOrEmpty(movimiento.NumeroComprobante))
                                                    {
                                                        <br><small class="text-secondary">#@movimiento.NumeroComprobante</small>
                                                    }
                                                </td>
                                                <td>
                                                    @if (movimiento.TipoMovimiento == "Ingreso")
                                                    {
                                                        <span class="badge bg-green text-white">Ingreso</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-pink text-brown">Egreso</span>
                                                    }
                                                </td>
                                                <td class="text-end fw-bold @(movimiento.TipoMovimiento == "Ingreso" ? "text-green" : "text-brown")">
                                                    $@movimiento.Monto.ToString("N2")
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-beige border-green text-center">
                                <i class="fas fa-info-circle text-green me-2"></i> No hay movimientos recientes.
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Columna Derecha (4 columnas) -->
            <div class="col-lg-4">
                <!-- Últimas Mascotas Perdidas -->
                <div class="list-card mb-4">
                    <div class="list-card-header bg-green text-white">
                        <i class="fas fa-search me-2"></i> Últimas Mascotas Perdidas
                    </div>
                    <div class="list-card-body">
                        @if (Model.UltimasMascotasPerdidas != null && Model.UltimasMascotasPerdidas.Any())
                        {
                            <div class="list-group">
                                @foreach (var mascota in Model.UltimasMascotasPerdidas)
                                {
                                    <a href="/Rescate/DetalleMascotaPerdida/@mascota.MascotaPerdidaId" class="list-group-item list-group-item-action">
                                        <div class="d-flex align-items-center">
                                            @if (mascota.ImagenMascota != null && mascota.ImagenMascota.Length > 0)
                                            {
                                                <img src="data:image/jpeg;base64,@Convert.ToBase64String(mascota.ImagenMascota)"
                                                     alt="@mascota.NombreMascota"
                                                     class="rounded me-3"
                                                     style="width: 50px; height: 50px; object-fit: cover;">
                                            }
                                            else
                                            {
                                                <div class="avatar-placeholder bg-light-mint me-3">
                                                    <i class="fas @(mascota.Especie == "Perro" ? "fa-dog" : "fa-cat") text-secondary"></i>
                                                </div>
                                            }
                                            <div class="flex-grow-1">
                                                <h6 class="mb-0 text-brown">@mascota.NombreMascota</h6>
                                                <small class="text-secondary">
                                                    @mascota.Especie • Perdida: @mascota.FechaPerdida.ToString("dd/MM")
                                                </small>
                                            </div>
                                            @if (mascota.Recompensa.HasValue && mascota.Recompensa > 0)
                                            {
                                                <span class="badge bg-yellow text-brown">$@mascota.Recompensa.Value.ToString("N0")</span>
                                            }
                                        </div>
                                        <div class="mt-2">
                                            <small class="text-secondary">
                                                <i class="fas fa-map-marker-alt me-1"></i> @mascota.UbicacionPerdida
                                            </small>
                                        </div>
                                    </a>
                                }
                            </div>
                            <div class="text-center mt-3">
                                <a href="/Rescate/MascotasPerdidas" class="btn btn-sm btn-outline-green">
                                    <i class="fas fa-list me-2"></i> Ver todas
                                </a>
                                <a href="/Rescate/ReportarMascotaPerdida" class="btn btn-sm btn-green">
                                    <i class="fas fa-plus me-2"></i> Nuevo reporte
                                </a>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-beige border-green text-center">
                                <i class="fas fa-info-circle text-green me-2"></i> No hay mascotas perdidas recientes.
                                <div class="mt-2">
                                    <a href="/Rescate/ReportarMascotaPerdida" class="btn btn-sm btn-green">
                                        <i class="fas fa-plus me-2"></i> Reportar mascota perdida
                                    </a>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <!-- Últimas Donaciones -->
                <div class="list-card mb-4">
                    <div class="list-card-header bg-green text-white">
                        <i class="fas fa-donate me-2"></i> Últimas Donaciones
                    </div>
                    <div class="list-card-body">
                        @if (Model.UltimasDonaciones != null && Model.UltimasDonaciones.Any())
                        {
                            <div class="list-group">
                                @foreach (var donacion in Model.UltimasDonaciones)
                                {
                                    <div class="list-group-item">
                                        <div class="d-flex w-100 justify-content-between align-items-center">
                                            <div>
                                                <h6 class="mb-1 text-brown">@(donacion.Usuarios?.NombreCompleto ?? "Donante anónimo")</h6>
                                                <small class="text-secondary">
                                                    <i class="fas fa-calendar-alt me-1"></i> @(donacion.FechaDonacion?.ToString("dd/MM/yyyy HH:mm") ?? "")
                                                </small>
                                            </div>
                                            <span class="badge bg-green text-white">$@donacion.Monto.ToString("N2")</span>
                                        </div>
                                        @if (!string.IsNullOrEmpty(donacion.TipoDonacion))
                                        {
                                            <div class="mt-2">
                                                <span class="badge bg-light-mint text-brown me-1">@donacion.TipoDonacion</span>
                                                @if (donacion.Anonima == true)
                                                {
                                                    <span class="badge bg-pink text-brown">Anónima</span>
                                                }
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                            <div class="text-center mt-3">
                                <a href="/Admin/GestionDonaciones" class="btn btn-sm btn-outline-green">
                                    <i class="fas fa-hand-holding-usd me-2"></i> Ver todas las donaciones
                                </a>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-beige border-green text-center">
                                <i class="fas fa-info-circle text-green me-2"></i> No hay donaciones recientes.
                            </div>
                        }
                    </div>
                </div>

                <!-- Mascotas Recientes -->
                <div class="list-card mb-4">
                    <div class="list-card-header bg-green text-white">
                        <i class="fas fa-paw me-2"></i> Mascotas Recientes
                    </div>
                    <div class="list-card-body">
                        @if (Model.MascotasRecientes != null && Model.MascotasRecientes.Any())
                        {
                            <div class="list-group">
                                @foreach (var mascota in Model.MascotasRecientes)
                                {
                                    <a href="/Mascotas/Detalle/@mascota.MascotaId" class="list-group-item list-group-item-action">
                                        <div class="d-flex align-items-center">
                                            @if (mascota.ImagenPrincipal != null && mascota.ImagenPrincipal.Length > 0)
                                            {
                                                <img src="data:image/jpeg;base64,@Convert.ToBase64String(mascota.ImagenPrincipal)"
                                                     alt="@mascota.Nombre"
                                                     class="rounded me-3"
                                                     style="width: 50px; height: 50px; object-fit: cover;">
                                            }
                                            else
                                            {
                                                <div class="avatar-placeholder bg-light-mint me-3">
                                                    <i class="fas @(mascota.Especie == "Perro" ? "fa-dog" : "fa-cat") text-secondary"></i>
                                                </div>
                                            }
                                            <div class="flex-grow-1">
                                                <h6 class="mb-0 text-brown">@mascota.Nombre</h6>
                                                <small class="text-secondary">@mascota.Especie • @mascota.Raza</small>
                                            </div>
                                            <div>
                                                @if (mascota.Estado == "Disponible para adopción")
                                                {
                                                    <span class="badge bg-green text-white">Disponible</span>
                                                }
                                                else if (mascota.Estado == "En tratamiento")
                                                {
                                                    <span class="badge bg-yellow text-brown">Tratamiento</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-light-mint text-brown">@mascota.Estado</span>
                                                }
                                            </div>
                                        </div>
                                    </a>
                                }
                            </div>
                            <div class="text-center mt-3">
                                <a href="/Mascotas/Gestionar" class="btn btn-sm btn-outline-green">
                                    <i class="fas fa-list me-2"></i> Ver todas
                                </a>
                                <a href="/Mascotas/Crear" class="btn btn-sm btn-green">
                                    <i class="fas fa-plus me-2"></i> Nueva mascota
                                </a>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-beige border-green text-center">
                                <i class="fas fa-info-circle text-green me-2"></i> No hay mascotas recientes.
                                <div class="mt-2">
                                    <a href="/Mascotas/Crear" class="btn btn-sm btn-green">
                                        <i class="fas fa-plus me-2"></i> Registrar nueva mascota
                                    </a>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <!-- Estado del Sistema -->
                <div class="system-card">
                    <div class="system-card-header bg-green text-white">
                        <i class="fas fa-cogs me-2"></i> Estado del Sistema
                    </div>
                    <div class="system-card-body">
                        <!-- Estado General -->
                        <div class="mb-3">
                            <div class="d-flex justify-content-between mb-1">
                                <span><i class="fas fa-heartbeat text-green me-2"></i> Estado General</span>
                                <span class="fw-bold @(Model.SistemaSaludable ? "text-green" : "text-brown")">
                                    @(Model.SistemaSaludable ? "SALUDABLE" : "REQUIERE ATENCIÓN")
                                </span>
                            </div>
                            <small class="text-secondary">
                                @if (Model.SistemaSaludable)
                                {
                                    <i class="fas fa-check-circle text-green me-1"></i> @:Todas las áreas funcionan correctamente
                                }
                                else
                                {
                                    <i class="fas fa-exclamation-triangle text-brown me-1"></i> @:Algunas áreas requieren atención
                                }
                            </small>
                        </div>

                        <!-- Mascotas Perdidas -->
                        <div class="mb-3">
                            <div class="d-flex justify-content-between mb-1">
                                <span><i class="fas fa-search text-green me-2"></i> Mascotas Perdidas</span>
                                <span class="fw-bold @(Model.MascotasPerdidasRequiereAtencion ? "text-brown" : "text-green")">
                                    @(Model.EstadoMascotasPerdidas ?? "N/A")
                                </span>
                            </div>
                            <div class="progress" style="height: 6px;">
                                @{
                                    var widthMascotasPerdidas = Math.Min(Model.MascotasPerdidasActivas * 5, 100);
                                }
                                <div class="progress-bar bg-green" role="progressbar" style="width: @widthMascotasPerdidas%"
                                     aria-valuenow="@Model.MascotasPerdidasActivas" aria-valuemin="0" aria-valuemax="20"></div>
                            </div>
                            <small class="text-secondary">
                                @Model.MascotasPerdidasActivas activas • @Model.TasaEncuentros.ToString("N1")% encontradas
                            </small>
                        </div>

                        <!-- Tasa de Adopción -->
                        <div class="mb-3">
                            <div class="d-flex justify-content-between mb-1">
                                <span><i class="fas fa-heart text-green me-2"></i> Tasa de Adopción</span>
                                <span class="fw-bold">@Model.TasaAdopcion.ToString("N1")%</span>
                            </div>
                            <div class="progress" style="height: 6px;">
                                <div class="progress-bar bg-green" role="progressbar" style="width: @Model.TasaAdopcion%"
                                     aria-valuenow="@Model.TasaAdopcion" aria-valuemin="0" aria-valuemax="100"></div>
                            </div>
                            <small class="text-secondary">
                                @if (Model.TasaAdopcion >= 40)
                                {
                                    <i class="fas fa-check text-green me-1"></i> @:Excelente
                                }
                                else if (Model.TasaAdopcion >= 20)
                                {
                                    <i class="fas fa-check-circle text-yellow me-1"></i> @:Aceptable
                                }
                                else
                                {
                                    <i class="fas fa-exclamation-triangle text-brown me-1"></i> @:Necesita mejorar
                                }
                            </small>
                        </div>

                        <!-- Balance Mensual -->
                        <div class="mb-3">
                            <div class="d-flex justify-content-between mb-1">
                                <span><i class="fas fa-chart-line text-green me-2"></i> Balance Mensual</span>
                                <span class="fw-bold @(Model.BalanceMes >= 0 ? "text-green" : "text-brown")">
                                    $@Model.BalanceMes.ToString("N2")
                                </span>
                            </div>
                            <small class="text-secondary">
                                @if (Model.BalanceMes >= 0)
                                {
                                    <i class="fas fa-arrow-up text-green me-1"></i> @:Superávit
                                }
                                else
                                {
                                    <i class="fas fa-arrow-down text-brown me-1"></i> @:Déficit
                                }
                            </small>
                        </div>

                        <!-- Gestión Mascotas -->
                        <div class="mb-3">
                            <div class="d-flex justify-content-between mb-1">
                                <span><i class="fas fa-paw text-green me-2"></i> Gestión Mascotas</span>
                                <span class="fw-bold">@Model.EstadoGestionMascotasCalculado</span>
                            </div>
                            <small class="text-secondary">
                                <i class="fas fa-check-circle me-1"></i> @Model.MascotasDisponibles disponibles
                                <i class="fas fa-archive ms-2 me-1"></i> @Model.MascotasArchivadas archivadas
                            </small>
                        </div>

                        <!-- Auditoría -->
                        <div class="mb-3">
                            <div class="d-flex justify-content-between mb-1">
                                <span><i class="fas fa-clipboard-check text-green me-2"></i> Actividad Auditoría</span>
                                <span class="fw-bold">@(Model.EstadoAuditoria ?? "N/A")</span>
                            </div>
                            <small class="text-secondary">
                                <i class="fas fa-database me-1"></i> @Model.RegistrosAuditoriaDia registros hoy
                            </small>
                        </div>

                        <!-- Configuración -->
                        <div class="mb-3">
                            <div class="d-flex justify-content-between mb-1">
                                <span><i class="fas fa-cogs text-green me-2"></i> Configuración</span>
                                <span class="fw-bold">@(Model.EstadoConfiguracion ?? "N/A")</span>
                            </div>
                            <small class="text-secondary">
                                @Model.AjustesSistema ajustes activos
                                @if (Model.ConfiguracionesCriticas > 0)
                                {
                                    <span class="badge bg-pink text-brown ms-1">@Model.ConfiguracionesCriticas críticas</span>
                                }
                            </small>
                        </div>

                        <!-- Resumen -->
                        <div class="alert alert-beige border-green small mb-0">
                            @if (Model.HayAlertasCriticas)
                            {
                                <i class="fas fa-exclamation-triangle text-brown me-1"></i>
                                <strong class="text-brown">Atención:</strong> <span>Hay áreas que requieren atención inmediata</span>
                            }
                            else
                            {
                                <i class="fas fa-check-circle text-green me-1"></i>
                                <strong class="text-brown">Sistema OK:</strong> <span>Todas las áreas funcionan correctamente</span>
                            }
                        </div>

                        <div class="mt-3 text-center">
                            <small class="text-secondary">
                                <i class="fas fa-clock me-1"></i> Última actualización: @DateTime.Now.ToString("dd/MM/yyyy HH:mm")
                            </small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Styles {
    <style>
        /* Hero */
        .dashboard-hero {
            background-color: var(--fondo-beige);
            border-radius: 0 0 30px 30px;
            margin-bottom: 1rem;
        }

        /* Tarjetas de acceso rápido */
        .quick-card {
            background: white;
            border-radius: 20px;
            padding: 1.2rem 0.5rem;
            box-shadow: 0 8px 20px rgba(151,199,139,0.15);
            transition: all 0.3s ease;
            height: 100%;
        }

            .quick-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 15px 30px rgba(151,199,139,0.25);
            }

        /* Tarjetas de estadísticas principales */
        .stat-card {
            border-radius: 24px;
            padding: 1.5rem;
            box-shadow: 0 8px 20px rgba(151,199,139,0.15);
            transition: transform 0.3s;
            height: 100%;
        }

            .stat-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 15px 30px rgba(151,199,139,0.25);
            }

        .opacity-50 {
            opacity: 0.5;
        }

        /* Tarjetas de gráficos y listas */
        .chart-card, .list-card, .system-card {
            background: white;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 8px 20px rgba(151,199,139,0.15);
            border: none;
        }

        .chart-card-header, .list-card-header, .system-card-header {
            background-color: var(--verde-menta);
            color: white;
            padding: 1rem 1.5rem;
            font-weight: 600;
            font-size: 1.1rem;
        }

        .chart-card-body, .list-card-body, .system-card-body {
            padding: 1.5rem;
        }

        .chart-container {
            position: relative;
            height: 250px;
            width: 100%;
        }

        /* Listas */
        .list-group-item {
            border: 1px solid var(--plomo-calido);
            border-radius: 12px;
            margin-bottom: 0.5rem;
            transition: background-color 0.2s;
        }

            .list-group-item:hover {
                background-color: var(--fondo-beige);
            }

        .avatar-placeholder {
            width: 50px;
            height: 50px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        /* Alertas */
        .alert-beige {
            background-color: var(--fondo-beige);
            border: 1px solid var(--verde-menta);
            color: var(--texto-oscuro);
            border-radius: 16px;
        }

        /* Badges */
        .badge {
            font-size: 0.8rem;
            font-weight: 500;
            border-radius: 30px;
            padding: 0.4rem 0.8rem;
        }

        /* Botones */
        .btn-green {
            background-color: var(--verde-menta);
            border: none;
            border-radius: 50px;
            padding: 0.4rem 1.2rem;
            font-weight: 500;
            transition: all 0.3s;
        }

            .btn-green:hover {
                background-color: #86b57a;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(151,199,139,0.4);
            }

        .btn-outline-green {
            border: 2px solid var(--verde-menta);
            background: transparent;
            color: var(--verde-menta);
            border-radius: 50px;
            padding: 0.4rem 1.2rem;
            font-weight: 500;
            transition: all 0.3s;
        }

            .btn-outline-green:hover {
                background-color: var(--verde-menta);
                color: white;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(151,199,139,0.3);
            }

        /* Progreso */
        .progress {
            background-color: var(--plomo-calido);
            border-radius: 30px;
        }

        .progress-bar {
            background-color: var(--verde-menta);
        }

        /* Responsive */
        @@media (max-width: 768px) {
            .chart-container {
                height: 200px;
            }

            .stat-card {
                padding: 1rem;
            }

            .quick-card {
                padding: 1rem 0.25rem;
            }
        }
    </style>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@3.9.1/dist/chart.min.js"></script>
    <script>
        $(document).ready(function () {
            // Auto cerrar alertas después de 5 segundos
            setTimeout(function () {
                $('.alert').fadeOut('slow');
            }, 5000);

            // Gráfico de Mascotas por Especie
            @if (Model.MascotasPorEspecie != null && Model.MascotasPorEspecie.Any())
            {
                <text>
                var ctx = document.getElementById('mascotasEspecieChart');
                if (ctx) {
                    var labels = [];
                    var data = [];

                    @foreach (var item in Model.MascotasPorEspecie)
                    {
                        @:labels.push('@item.Key');
                        @:data.push(@item.Value);
                    }

                    new Chart(ctx, {
                        type: 'pie',
                        data: {
                            labels: labels,
                            datasets: [{
                                data: data,
                                backgroundColor: ['#97C78B', '#F2C66D', '#FBCDC0', '#D9A8A8', '#5C4B43'],
                                borderColor: '#fff',
                                borderWidth: 2
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: {
                                    position: 'bottom',
                                    labels: {
                                        color: '#2F2F2F',
                                        padding: 15,
                                        font: { size: 12 }
                                    }
                                }
                            }
                        }
                    });
                }
                </text>
            }

            // Gráfico de Mascotas Perdidas por Especie
            @if (Model.MascotasPerdidasPorEspecie != null && Model.MascotasPerdidasPorEspecie.Any())
            {
                <text>
                var ctx2 = document.getElementById('mascotasPerdidasChart');
                if (ctx2) {
                    var labels2 = [];
                    var data2 = [];

                    @foreach (var item in Model.MascotasPerdidasPorEspecie)
                    {
                        @:labels2.push('@item.Key');
                        @:data2.push(@item.Value);
                    }

                    new Chart(ctx2, {
                        type: 'bar',
                        data: {
                            labels: labels2,
                            datasets: [{
                                label: 'Mascotas Perdidas',
                                data: data2,
                                backgroundColor: '#97C78B',
                                borderColor: '#86b57a',
                                borderWidth: 2
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            scales: {
                                y: {
                                    beginAtZero: true,
                                    ticks: {
                                        precision: 0
                                    }
                                }
                            },
                            plugins: {
                                legend: {
                                    display: false
                                }
                            }
                        }
                    });
                }
                </text>
            }
        });
    </script>
}