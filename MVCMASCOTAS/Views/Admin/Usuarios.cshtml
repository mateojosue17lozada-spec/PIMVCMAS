@model IEnumerable<MVCMASCOTAS.Models.Usuarios>

@{
    ViewBag.Title = "Gestión de Usuarios";
}

<div class="page-header mb-4">
    <h2><i class="fas fa-users"></i> Gestión de Usuarios</h2>
    <p class="text-muted">Administración completa de usuarios del sistema</p>
</div>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <a href="@Url.Action("CrearUsuario", "Admin")" class="btn btn-success">
            <i class="fas fa-user-plus"></i> Crear Nuevo Usuario
        </a>
        <a href="@Url.Action("Dashboard", "Admin")" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left"></i> Volver al Dashboard
        </a>
    </div>
</div>

<!-- Filtros -->
<div class="card shadow-custom mb-4">
    <div class="card-header bg-primary text-white">
        <h5 class="mb-0"><i class="fas fa-filter"></i> Filtros de Búsqueda</h5>
    </div>
    <div class="card-body">
        <form method="get" action="@Url.Action("Usuarios", "Admin")" class="row">
            <div class="col-md-3 mb-2">
                <label>Rol:</label>
                <select name="rol" class="form-control">
                    <option value="Todos" @(ViewBag.FiltroRol == "Todos" || string.IsNullOrEmpty(ViewBag.FiltroRol) ? "selected" : "")>Todos</option>
                    <option value="Administrador" @(ViewBag.FiltroRol == "Administrador" ? "selected" : "")>Administrador</option>
                    <option value="Veterinario" @(ViewBag.FiltroRol == "Veterinario" ? "selected" : "")>Veterinario</option>
                    <option value="Voluntario" @(ViewBag.FiltroRol == "Voluntario" ? "selected" : "")>Voluntario</option>
                    <option value="Usuario" @(ViewBag.FiltroRol == "Usuario" ? "selected" : "")>Usuario</option>
                </select>
            </div>

            <div class="col-md-3 mb-2">
                <label>Estado:</label>
                <select name="activo" class="form-control">
                    <option value="Todos" @(ViewBag.FiltroActivo == "Todos" || string.IsNullOrEmpty(ViewBag.FiltroActivo) ? "selected" : "")>Todos</option>
                    <option value="true" @(ViewBag.FiltroActivo == "true" ? "selected" : "")>Activos</option>
                    <option value="false" @(ViewBag.FiltroActivo == "false" ? "selected" : "")>Inactivos</option>
                </select>
            </div>

            <div class="col-md-4 mb-2">
                <label>Buscar:</label>
                <input type="text" name="buscar" class="form-control" placeholder="Nombre, email o cédula" value="@ViewBag.FiltroBuscar" />
            </div>

            <div class="col-md-2 mb-2 d-flex align-items-end">
                <button type="submit" class="btn btn-primary btn-block">
                    <i class="fas fa-search"></i> Buscar
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Estadísticas -->
<div class="row mb-4">
    <div class="col-md-3">
        <div class="card text-white bg-primary shadow-custom">
            <div class="card-body text-center">
                <i class="fas fa-users fa-2x mb-2"></i>
                <h4>@ViewBag.TotalUsuarios</h4>
                <p class="mb-0">Total Usuarios</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-success shadow-custom">
            <div class="card-body text-center">
                <i class="fas fa-user-check fa-2x mb-2"></i>
                <h4>@ViewBag.UsuariosActivos</h4>
                <p class="mb-0">Activos</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-warning shadow-custom">
            <div class="card-body text-center">
                <i class="fas fa-user-shield fa-2x mb-2"></i>
                <h4>@ViewBag.TotalAdministradores</h4>
                <p class="mb-0">Administradores</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-info shadow-custom">
            <div class="card-body text-center">
                <i class="fas fa-user-md fa-2x mb-2"></i>
                <h4>@ViewBag.TotalVeterinarios</h4>
                <p class="mb-0">Veterinarios</p>
            </div>
        </div>
    </div>
</div>

<!-- Tabla de usuarios -->
<div class="card shadow-custom">
    <div class="card-header bg-dark text-white">
        <h5 class="mb-0"><i class="fas fa-table"></i> Listado de Usuarios</h5>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover table-striped">
                <thead class="thead-dark">
                    <tr>
                        <th>ID</th>
                        <th>Foto</th>
                        <th>Nombre</th>
                        <th>Email</th>
                        <th>Cédula</th>
                        <th>Teléfono</th>
                        <th>Rol</th>
                        <th>Estado</th>
                        <th>Fecha Registro</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var usuario in Model)
                        {
                            // Obtener el rol principal del usuario
                            var rolPrincipal = "Sin rol";
                            var usuarioRoles = usuario.UsuariosRoles?.ToList();
                            if (usuarioRoles != null && usuarioRoles.Any())
                            {
                                rolPrincipal = usuarioRoles.FirstOrDefault()?.Roles?.NombreRol ?? "Sin rol";
                            }

                            <tr>
                                <td><strong>#@usuario.UsuarioId</strong></td>
                                <td>
                                    @if (usuario.ImagenPerfil != null)
                                    {
                                        <img src="@MVCMASCOTAS.Helpers.ImageHelper.GetImageDataUri(usuario.ImagenPerfil)"
                                             alt="@usuario.NombreCompleto"
                                             class="rounded-circle img-thumbnail"
                                             style="width: 40px; height: 40px; object-fit: cover;" />
                                    }
                                    else
                                    {
                                        <div class="rounded-circle bg-secondary d-inline-flex align-items-center justify-content-center"
                                             style="width: 40px; height: 40px;">
                                            <i class="fas fa-user text-white"></i>
                                        </div>
                                    }
                                </td>
                                <td><strong>@usuario.NombreCompleto</strong></td>
                                <td>@usuario.Email</td>
                                <td>@usuario.Cedula</td>
                                <td>@usuario.Telefono</td>
                                <td>
                                    @switch (rolPrincipal)
                                    {
                                        case "Administrador":
                                            <span class="badge badge-danger"><i class="fas fa-user-shield"></i> @rolPrincipal</span>
                                            break;
                                        case "Veterinario":
                                            <span class="badge badge-success"><i class="fas fa-user-md"></i> @rolPrincipal</span>
                                            break;
                                        case "Voluntario":
                                            <span class="badge badge-info"><i class="fas fa-hands-helping"></i> @rolPrincipal</span>
                                            break;
                                        default:
                                            <span class="badge badge-secondary"><i class="fas fa-user"></i> @rolPrincipal</span>
                                            break;
                                    }
                                </td>
                                <td>
                                    @if (usuario.Activo == true)
                                    {
                                        <span class="badge badge-success"><i class="fas fa-check-circle"></i> Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-danger"><i class="fas fa-times-circle"></i> Inactivo</span>
                                    }
                                </td>
                                <td>@(usuario.FechaRegistro?.ToString("dd/MM/yyyy") ?? "N/A")</td>
                                <td class="text-center">
                                    <div class="btn-group" role="group">
                                        <a href="@Url.Action("VerUsuario", "Admin", new { id = usuario.UsuarioId })"
                                           class="btn btn-sm btn-info"
                                           title="Ver Detalles"
                                           data-toggle="tooltip">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a href="@Url.Action("EditarUsuario", "Admin", new { id = usuario.UsuarioId })"
                                           class="btn btn-sm btn-warning"
                                           title="Editar"
                                           data-toggle="tooltip">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        @if (usuario.Activo == true)
                                        {
                                            <button type="button"
                                                    class="btn btn-sm btn-danger"
                                                    title="Desactivar"
                                                    data-toggle="modal"
                                                    data-target="#toggleModal"
                                                    data-id="@usuario.UsuarioId"
                                                    data-nombre="@usuario.NombreCompleto"
                                                    data-accion="Desactivar">
                                                <i class="fas fa-ban"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="button"
                                                    class="btn btn-sm btn-success"
                                                    title="Activar"
                                                    data-toggle="modal"
                                                    data-target="#toggleModal"
                                                    data-id="@usuario.UsuarioId"
                                                    data-nombre="@usuario.NombreCompleto"
                                                    data-accion="Activar">
                                                <i class="fas fa-check"></i>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="10" class="text-center">
                                <div class="alert alert-info mb-0">
                                    <i class="fas fa-info-circle"></i> No se encontraron usuarios con los filtros seleccionados.
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (Model != null && Model.Any())
        {
            <div class="mt-3">
                <p class="text-muted">
                    <i class="fas fa-info-circle"></i>
                    Mostrando @Model.Count() usuarios de un total de @ViewBag.TotalItems
                </p>
            </div>
        }
    </div>
</div>

<!-- Paginación -->
@if (ViewBag.TotalPages != null && ViewBag.TotalPages > 1)
{
    <nav aria-label="Paginación de usuarios" class="mt-4">
        <ul class="pagination justify-content-center">
            @if (ViewBag.CurrentPage > 1)
            {
                <li class="page-item">
                    <a class="page-link" href="@Url.Action("Usuarios", "Admin", new {
                        page = ViewBag.CurrentPage - 1,
                        rol = ViewBag.FiltroRol,
                        activo = ViewBag.FiltroActivo,
                        buscar = ViewBag.FiltroBuscar
                    })">
                        <i class="fas fa-chevron-left"></i> Anterior
                    </a>
                </li>
            }

            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                    <a class="page-link" href="@Url.Action("Usuarios", "Admin", new {
                        page = i,
                        rol = ViewBag.FiltroRol,
                        activo = ViewBag.FiltroActivo,
                        buscar = ViewBag.FiltroBuscar
                    })">@i</a>
                </li>
            }

            @if (ViewBag.CurrentPage < ViewBag.TotalPages)
            {
                <li class="page-item">
                    <a class="page-link" href="@Url.Action("Usuarios", "Admin", new {
                        page = ViewBag.CurrentPage + 1,
                        rol = ViewBag.FiltroRol,
                        activo = ViewBag.FiltroActivo,
                        buscar = ViewBag.FiltroBuscar
                    })">
                        Siguiente <i class="fas fa-chevron-right"></i>
                    </a>
                </li>
            }
        </ul>
    </nav>
}

<!-- Modal de confirmación -->
<div class="modal fade" id="toggleModal" tabindex="-1" role="dialog" aria-labelledby="toggleModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header bg-warning text-white">
                <h5 class="modal-title" id="toggleModalLabel">
                    <i class="fas fa-exclamation-triangle"></i> Confirmar Acción
                </h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <p>¿Está seguro que desea <span id="accionTexto"></span> al usuario <strong id="usuarioNombre"></strong>?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    <i class="fas fa-times"></i> Cancelar
                </button>
                @using (Html.BeginForm("ToggleUsuario", "Admin", FormMethod.Post, new { id = "toggleForm" }))
                {
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="usuarioIdInput" name="id" />
                    <button type="submit" class="btn btn-warning">
                        <i class="fas fa-check"></i> Confirmar
                    </button>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Inicializar tooltips
            $('[data-toggle="tooltip"]').tooltip();

            // Modal de toggle (activar/desactivar)
            $('#toggleModal').on('show.bs.modal', function (event) {
                var button = $(event.relatedTarget);
                var usuarioId = button.data('id');
                var usuarioNombre = button.data('nombre');
                var accion = button.data('accion');
                var modal = $(this);

                modal.find('#usuarioNombre').text(usuarioNombre);
                modal.find('#accionTexto').text(accion.toLowerCase());
                modal.find('#usuarioIdInput').val(usuarioId);
                modal.find('#toggleForm').attr('action', '@Url.Action("ToggleUsuario", "Admin")/' + usuarioId);
            });

            // Confirmación para eliminar usuario
            $('.btn-eliminar').click(function (e) {
                e.preventDefault();
                var usuarioNombre = $(this).data('nombre');
                var usuarioId = $(this).data('id');

                if (confirm('¿Está seguro que desea eliminar permanentemente al usuario "' + usuarioNombre + '"? Esta acción no se puede deshacer.')) {
                    var form = $('<form>', {
                        'method': 'POST',
                        'action': '@Url.Action("EliminarUsuario", "Admin")/' + usuarioId
                    });

                    var token = $('input[name="__RequestVerificationToken"]').val();
                    form.append($('<input>', {
                        'type': 'hidden',
                        'name': '__RequestVerificationToken',
                        'value': token
                    }));

                    form.appendTo('body').submit();
                }
            });
        });
    </script>
}