@model MVCMASCOTAS.Models.Roles
@{
    ViewBag.Title = "Permisos del Rol - ADOPTAMANÍA";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var permisosActuales = ViewBag.PermisosActuales as List<string> ?? new List<string>();
}

<!-- Hero Section -->
<section class="permisos-hero py-4">
    <div class="container text-center">
        <i class="fas fa-key fa-3x text-green mb-3"></i>
        <h1 class="display-5 fw-bold mb-2 text-brown">Permisos del Rol</h1>
        <p class="lead mb-3 text-secondary">
            <span class="fw-bold text-green">@Model.NombreRol</span> – Configura los permisos de acceso para este rol
        </p>
    </div>
</section>

<!-- Main Content -->
<section class="py-5 bg-beige">
    <div class="container">
        <div class="row g-4">
            <!-- Columna izquierda: Información del Rol -->
            <div class="col-md-4">
                <div class="info-card h-100">
                    <div class="info-card-header bg-green text-white">
                        <i class="fas fa-info-circle me-2"></i> Información del Rol
                    </div>
                    <div class="info-card-body">
                        <h5 class="text-brown mb-3">
                            <i class="fas fa-user-tag text-green me-2"></i>@Model.NombreRol
                        </h5>
                        <p class="text-secondary mb-4">
                            <i class="fas fa-align-left text-green me-2"></i>
                            @(Model.Descripcion ?? "Sin descripción")
                        </p>

                        <hr class="border-green" />

                        <h6 class="text-brown mb-3">
                            <i class="fas fa-cog text-green me-2"></i> Detalles del Rol
                        </h6>

                        <ul class="info-list list-unstyled">
                            <li class="d-flex justify-content-between align-items-center mb-2">
                                <span><i class="fas fa-hashtag text-green me-2"></i> <strong>ID:</strong></span>
                                <span class="badge bg-green text-white">@Model.RolId</span>
                            </li>
                            <li class="d-flex justify-content-between align-items-center mb-2">
                                <span><i class="fas fa-calendar-plus text-green me-2"></i> <strong>Creado:</strong></span>
                                <span class="text-brown">@(Model.FechaCreacion?.ToString("dd/MM/yyyy") ?? "No registrado")</span>
                            </li>
                            <li class="d-flex justify-content-between align-items-center">
                                <span><i class="fas fa-check-circle text-green me-2"></i> <strong>Estado:</strong></span>
                                <span>
                                    @if (Model.Activo == true)
                                    {
                                        <span class="badge bg-green text-white">Activo</span>
                                    }
                                    else if (Model.Activo == false)
                                    {
                                        <span class="badge bg-pink text-brown">Inactivo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light-mint text-brown">No definido</span>
                                    }
                                </span>
                            </li>
                        </ul>

                        <hr class="border-green" />

                        <div class="text-center mt-4">
                            <a href="@Url.Action("Roles", "Admin")" class="btn btn-outline-green">
                                <i class="fas fa-arrow-left me-2"></i> Volver a Roles
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Consejo informativo -->
                <div class="alert alert-beige border-green mt-4">
                    <div class="d-flex">
                        <i class="fas fa-lightbulb fa-2x text-yellow me-3"></i>
                        <div>
                            <strong class="text-brown">Consejo:</strong>
                            <p class="text-secondary mb-0 small">
                                Los permisos definen qué acciones puede realizar un usuario con este rol en el sistema.
                                Asigna solo los permisos necesarios según las responsabilidades del rol.
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Columna derecha: Permisos del Sistema -->
            <div class="col-md-8">
                <div class="permisos-card">
                    <div class="permisos-card-header bg-green text-white">
                        <i class="fas fa-shield-alt me-2"></i> Permisos del Sistema
                    </div>
                    <div class="permisos-card-body">
                        @using (Html.BeginForm("GuardarPermisos", "Admin", FormMethod.Post, new { id = "formPermisos" }))
                        {
                            @Html.AntiForgeryToken()
                            @Html.Hidden("rolId", Model.RolId)

                            <!-- Módulo: Mascotas -->
                            <div class="module-card mb-4">
                                <div class="module-header d-flex justify-content-between align-items-center" data-bs-toggle="collapse" data-bs-target="#mascotasPermisos" aria-expanded="true">
                                    <h6 class="mb-0 text-brown">
                                        <i class="fas fa-paw text-green me-2"></i> Módulo: Mascotas
                                    </h6>
                                    <span class="select-all-module" data-target="mascotas">Seleccionar Todo</span>
                                </div>
                                <div id="mascotasPermisos" class="collapse show">
                                    <div class="module-body">
                                        <div class="row g-3">
                                            <div class="col-md-6">
                                                <div class="permiso-item">
                                                    <input class="form-check-input permiso-checkbox" type="checkbox" name="permisos" value="Mascotas_Ver" id="permiso1" data-module="mascotas" @(permisosActuales.Contains("Mascotas_Ver") ? "checked" : "")>
                                                    <label class="form-check-label" for="permiso1">
                                                        <span class="permiso-icon icon-ver"><i class="fas fa-eye"></i></span>
                                                        Ver mascotas
                                                    </label>
                                                </div>
                                                <div class="permiso-item">
                                                    <input class="form-check-input permiso-checkbox" type="checkbox" name="permisos" value="Mascotas_Crear" id="permiso2" data-module="mascotas" @(permisosActuales.Contains("Mascotas_Crear") ? "checked" : "")>
                                                    <label class="form-check-label" for="permiso2">
                                                        <span class="permiso-icon icon-crear"><i class="fas fa-plus-circle"></i></span>
                                                        Crear mascotas
                                                    </label>
                                                </div>
                                                <div class="permiso-item">
                                                    <input class="form-check-input permiso-checkbox" type="checkbox" name="permisos" value="Mascotas_Editar" id="permiso3" data-module="mascotas" @(permisosActuales.Contains("Mascotas_Editar") ? "checked" : "")>
                                                    <label class="form-check-label" for="permiso3">
                                                        <span class="permiso-icon icon-editar"><i class="fas fa-edit"></i></span>
                                                        Editar mascotas
                                                    </label>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="permiso-item">
                                                    <input class="form-check-input permiso-checkbox" type="checkbox" name="permisos" value="Mascotas_Eliminar" id="permiso4" data-module="mascotas" @(permisosActuales.Contains("Mascotas_Eliminar") ? "checked" : "")>
                                                    <label class="form-check-label" for="permiso4">
                                                        <span class="permiso-icon icon-eliminar"><i class="fas fa-trash-alt"></i></span>
                                                        Eliminar mascotas
                                                    </label>
                                                </div>
                                                <div class="permiso-item">
                                                    <input class="form-check-input permiso-checkbox" type="checkbox" name="permisos" value="Mascotas_Exportar" id="permiso5" data-module="mascotas" @(permisosActuales.Contains("Mascotas_Exportar") ? "checked" : "")>
                                                    <label class="form-check-label" for="permiso5">
                                                        <span class="permiso-icon icon-exportar"><i class="fas fa-file-export"></i></span>
                                                        Exportar datos
                                                    </label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Módulo: Usuarios -->
                            <div class="module-card mb-4">
                                <div class="module-header d-flex justify-content-between align-items-center" data-bs-toggle="collapse" data-bs-target="#usuariosPermisos" aria-expanded="true">
                                    <h6 class="mb-0 text-brown">
                                        <i class="fas fa-users text-green me-2"></i> Módulo: Usuarios
                                    </h6>
                                    <span class="select-all-module" data-target="usuarios">Seleccionar Todo</span>
                                </div>
                                <div id="usuariosPermisos" class="collapse show">
                                    <div class="module-body">
                                        <div class="row g-3">
                                            <div class="col-md-6">
                                                <div class="permiso-item">
                                                    <input class="form-check-input permiso-checkbox" type="checkbox" name="permisos" value="Usuarios_Ver" id="permiso6" data-module="usuarios" @(permisosActuales.Contains("Usuarios_Ver") ? "checked" : "")>
                                                    <label class="form-check-label" for="permiso6">
                                                        <span class="permiso-icon icon-ver"><i class="fas fa-eye"></i></span>
                                                        Ver usuarios
                                                    </label>
                                                </div>
                                                <div class="permiso-item">
                                                    <input class="form-check-input permiso-checkbox" type="checkbox" name="permisos" value="Usuarios_Crear" id="permiso7" data-module="usuarios" @(permisosActuales.Contains("Usuarios_Crear") ? "checked" : "")>
                                                    <label class="form-check-label" for="permiso7">
                                                        <span class="permiso-icon icon-crear"><i class="fas fa-plus-circle"></i></span>
                                                        Crear usuarios
                                                    </label>
                                                </div>
                                                <div class="permiso-item">
                                                    <input class="form-check-input permiso-checkbox" type="checkbox" name="permisos" value="Usuarios_Editar" id="permiso8" data-module="usuarios" @(permisosActuales.Contains("Usuarios_Editar") ? "checked" : "")>
                                                    <label class="form-check-label" for="permiso8">
                                                        <span class="permiso-icon icon-editar"><i class="fas fa-edit"></i></span>
                                                        Editar usuarios
                                                    </label>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="permiso-item">
                                                    <input class="form-check-input permiso-checkbox" type="checkbox" name="permisos" value="Usuarios_Eliminar" id="permiso9" data-module="usuarios" @(permisosActuales.Contains("Usuarios_Eliminar") ? "checked" : "")>
                                                    <label class="form-check-label" for="permiso9">
                                                        <span class="permiso-icon icon-eliminar"><i class="fas fa-trash-alt"></i></span>
                                                        Eliminar usuarios
                                                    </label>
                                                </div>
                                                <div class="permiso-item">
                                                    <input class="form-check-input permiso-checkbox" type="checkbox" name="permisos" value="Usuarios_Roles" id="permiso10" data-module="usuarios" @(permisosActuales.Contains("Usuarios_Roles") ? "checked" : "")>
                                                    <label class="form-check-label" for="permiso10">
                                                        <span class="permiso-icon icon-crear"><i class="fas fa-user-tag"></i></span>
                                                        Asignar roles
                                                    </label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Módulo: Administración -->
                            <div class="module-card mb-4">
                                <div class="module-header d-flex justify-content-between align-items-center" data-bs-toggle="collapse" data-bs-target="#adminPermisos" aria-expanded="true">
                                    <h6 class="mb-0 text-brown">
                                        <i class="fas fa-cogs text-green me-2"></i> Módulo: Administración
                                    </h6>
                                    <span class="select-all-module" data-target="admin">Seleccionar Todo</span>
                                </div>
                                <div id="adminPermisos" class="collapse show">
                                    <div class="module-body">
                                        <div class="row g-3">
                                            <div class="col-md-6">
                                                <div class="permiso-item">
                                                    <input class="form-check-input permiso-checkbox" type="checkbox" name="permisos" value="Admin_Dashboard" id="permiso11" data-module="admin" @(permisosActuales.Contains("Admin_Dashboard") ? "checked" : "")>
                                                    <label class="form-check-label" for="permiso11">
                                                        <span class="permiso-icon icon-ver"><i class="fas fa-tachometer-alt"></i></span>
                                                        Ver dashboard
                                                    </label>
                                                </div>
                                                <div class="permiso-item">
                                                    <input class="form-check-input permiso-checkbox" type="checkbox" name="permisos" value="Admin_Configuracion" id="permiso12" data-module="admin" @(permisosActuales.Contains("Admin_Configuracion") ? "checked" : "")>
                                                    <label class="form-check-label" for="permiso12">
                                                        <span class="permiso-icon icon-config"><i class="fas fa-cog"></i></span>
                                                        Configuración
                                                    </label>
                                                </div>
                                                <div class="permiso-item">
                                                    <input class="form-check-input permiso-checkbox" type="checkbox" name="permisos" value="Admin_Auditoria" id="permiso13" data-module="admin" @(permisosActuales.Contains("Admin_Auditoria") ? "checked" : "")>
                                                    <label class="form-check-label" for="permiso13">
                                                        <span class="permiso-icon icon-auditoria"><i class="fas fa-clipboard-list"></i></span>
                                                        Ver auditoría
                                                    </label>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="permiso-item">
                                                    <input class="form-check-input permiso-checkbox" type="checkbox" name="permisos" value="Admin_Reportes" id="permiso14" data-module="admin" @(permisosActuales.Contains("Admin_Reportes") ? "checked" : "")>
                                                    <label class="form-check-label" for="permiso14">
                                                        <span class="permiso-icon icon-reportes"><i class="fas fa-chart-bar"></i></span>
                                                        Generar reportes
                                                    </label>
                                                </div>
                                                <div class="permiso-item">
                                                    <input class="form-check-input permiso-checkbox" type="checkbox" name="permisos" value="Admin_Backup" id="permiso15" data-module="admin" @(permisosActuales.Contains("Admin_Backup") ? "checked" : "")>
                                                    <label class="form-check-label" for="permiso15">
                                                        <span class="permiso-icon icon-backup"><i class="fas fa-database"></i></span>
                                                        Backup sistema
                                                    </label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Botones de acción -->
                            <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mt-5 pt-4 border-top border-green">
                                <a href="@Url.Action("Roles", "Admin")" class="btn btn-outline-green">
                                    <i class="fas fa-times me-2"></i> Cancelar
                                </a>
                                <button type="submit" class="btn btn-green" id="btnGuardarPermisos">
                                    <i class="fas fa-save me-2"></i> Guardar Permisos
                                </button>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Styles {
    <style>
        /* Hero */
        .permisos-hero {
            background-color: var(--fondo-beige);
            border-radius: 0 0 30px 30px;
            margin-bottom: 1rem;
        }

        /* Tarjeta de información del rol */
        .info-card {
            background: white;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 15px 35px rgba(151,199,139,0.15);
            border: none;
        }

        .info-card-header {
            background-color: var(--verde-menta);
            color: white;
            padding: 1rem 1.5rem;
            font-weight: 600;
            font-size: 1.1rem;
        }

        .info-card-body {
            padding: 1.5rem;
        }

        /* Tarjeta de permisos */
        .permisos-card {
            background: white;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 15px 35px rgba(151,199,139,0.15);
            border: none;
        }

        .permisos-card-header {
            background-color: var(--verde-menta);
            color: white;
            padding: 1rem 1.5rem;
            font-weight: 600;
            font-size: 1.1rem;
        }

        .permisos-card-body {
            padding: 1.5rem;
        }

        /* Módulos */
        .module-card {
            background: #f9f9f9;
            border-radius: 20px;
            overflow: hidden;
            border: 1px solid var(--plomo-calido);
        }

        .module-header {
            background-color: var(--fondo-beige);
            padding: 0.8rem 1.2rem;
            cursor: pointer;
            transition: background-color 0.2s;
            border-bottom: 2px solid var(--verde-menta);
        }

            .module-header:hover {
                background-color: #e6d5b8;
            }

        .module-body {
            padding: 1.2rem;
        }

        /* Ítems de permiso */
        .permiso-item {
            display: flex;
            align-items: center;
            padding: 0.6rem 0.8rem;
            margin-bottom: 0.5rem;
            border-radius: 12px;
            transition: background-color 0.2s;
        }

            .permiso-item:hover {
                background-color: var(--fondo-beige);
            }

        .form-check-input {
            width: 1.2rem;
            height: 1.2rem;
            margin-right: 0.8rem;
            border: 2px solid var(--verde-menta);
            cursor: pointer;
        }

            .form-check-input:checked {
                background-color: var(--verde-menta);
                border-color: var(--verde-menta);
            }

            .form-check-input:focus {
                border-color: var(--verde-menta);
                box-shadow: 0 0 0 0.2rem rgba(151,199,139,0.25);
            }

        .form-check-label {
            cursor: pointer;
            font-weight: 500;
            color: var(--texto-oscuro);
            display: flex;
            align-items: center;
        }

        .permiso-icon {
            width: 30px;
            height: 30px;
            border-radius: 8px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            margin-right: 0.8rem;
            font-size: 0.9rem;
        }

        .icon-ver {
            background-color: rgba(151,199,139,0.2);
            color: var(--verde-menta);
        }

        .icon-crear {
            background-color: rgba(242,198,109,0.2);
            color: var(--amarillo-pastel);
        }

        .icon-editar {
            background-color: rgba(251,205,192,0.2);
            color: var(--rosado-claro);
        }

        .icon-eliminar {
            background-color: rgba(217,168,168,0.3);
            color: #b35f5f;
        }

        .icon-exportar {
            background-color: rgba(151,199,139,0.3);
            color: var(--verde-menta);
        }

        .icon-config {
            background-color: rgba(242,198,109,0.3);
            color: var(--amarillo-pastel);
        }

        .icon-auditoria {
            background-color: rgba(251,205,192,0.2);
            color: var(--rosado-claro);
        }

        .icon-reportes {
            background-color: rgba(151,199,139,0.3);
            color: var(--verde-menta);
        }

        .icon-backup {
            background-color: rgba(242,198,109,0.2);
            color: var(--amarillo-pastel);
        }

        /* Selector todo */
        .select-all-module {
            color: var(--verde-menta);
            font-weight: 600;
            cursor: pointer;
            font-size: 0.9rem;
            transition: color 0.2s;
        }

            .select-all-module:hover {
                color: var(--texto-oscuro);
                text-decoration: underline;
            }

        /* Alertas */
        .alert-beige {
            background-color: var(--fondo-beige);
            border: 1px solid var(--verde-menta);
            color: var(--texto-oscuro);
            border-radius: 16px;
        }

        /* Botones */
        .btn-green {
            background-color: var(--verde-menta);
            border: none;
            border-radius: 50px;
            padding: 0.6rem 2rem;
            font-weight: 600;
            transition: all 0.3s;
        }

            .btn-green:hover {
                background-color: #86b57a;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(151,199,139,0.4);
            }

        .btn-outline-green {
            border: 2px solid var(--verde-menta);
            background: transparent;
            color: var(--verde-menta);
            border-radius: 50px;
            padding: 0.6rem 2rem;
            font-weight: 600;
            transition: all 0.3s;
        }

            .btn-outline-green:hover {
                background-color: var(--verde-menta);
                color: white;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(151,199,139,0.3);
            }

        /* Badges */
        .badge.bg-green {
            background-color: var(--verde-menta);
            color: white;
            font-size: 0.8rem;
            padding: 0.4rem 0.8rem;
            border-radius: 30px;
        }

        .badge.bg-pink {
            background-color: var(--rosado-claro);
            color: var(--texto-oscuro);
            font-size: 0.8rem;
            padding: 0.4rem 0.8rem;
            border-radius: 30px;
        }

        .badge.bg-light-mint {
            background-color: var(--plomo-calido);
            color: var(--texto-oscuro);
            font-size: 0.8rem;
            padding: 0.4rem 0.8rem;
            border-radius: 30px;
        }

        /* Responsive */
        @@media (max-width: 768px) {
            .module-body .row {
                flex-direction: column;
            }

            .permiso-item {
                padding: 0.5rem;
            }

            .btn-outline-green, .btn-green {
                width: 100%;
                margin-bottom: 0.5rem;
            }
        }
    </style>
}

@section Scripts {
    <script>
        $(document).ready(function () {
            console.log('Vista Permisos del Rol cargada');

            // Función para actualizar el texto "Seleccionar Todo"
            function updateSelectAllText(target) {
                var checkboxes = $('.permiso-checkbox[data-module="' + target + '"]');
                var allChecked = checkboxes.length === checkboxes.filter(':checked').length;
                var text = allChecked ? 'Deseleccionar Todo' : 'Seleccionar Todo';
                $('.select-all-module[data-target="' + target + '"]').text(text);
            }

            // Inicializar textos
            updateSelectAllText('mascotas');
            updateSelectAllText('usuarios');
            updateSelectAllText('admin');

            // Seleccionar/Deseleccionar todos los checkboxes de un módulo
            $('.select-all-module').click(function (e) {
                e.stopPropagation();
                var target = $(this).data('target');
                var checkboxes = $('.permiso-checkbox[data-module="' + target + '"]');
                var allChecked = checkboxes.length === checkboxes.filter(':checked').length;
                checkboxes.prop('checked', !allChecked);
                updateSelectAllText(target);
            });

            // Actualizar texto cuando se marca/desmarca un checkbox individual
            $('.permiso-checkbox').change(function () {
                var target = $(this).data('module');
                updateSelectAllText(target);
            });

            // Validación del formulario con SweetAlert2
            $('#formPermisos').submit(function (e) {
                var permisosSeleccionados = $('input[name="permisos"]:checked').length;

                if (permisosSeleccionados === 0) {
                    e.preventDefault();
                    Swal.fire({
                        icon: 'warning',
                        title: 'Permisos requeridos',
                        text: 'Debe seleccionar al menos un permiso para el rol.',
                        confirmButtonColor: '#97C78B'
                    });
                    return false;
                }

                e.preventDefault();
                Swal.fire({
                    title: '¿Guardar permisos?',
                    text: "Se actualizarán los permisos para el rol " + '@Model.NombreRol',
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonColor: '#97C78B',
                    cancelButtonColor: '#FBCDC0',
                    confirmButtonText: '<i class="fas fa-save"></i> Sí, guardar',
                    cancelButtonText: '<i class="fas fa-times"></i> Cancelar'
                }).then((result) => {
                    if (result.isConfirmed) {
                        $('#btnGuardarPermisos').prop('disabled', true)
                            .html('<i class="fas fa-spinner fa-spin me-2"></i> Guardando...');
                        $(this).unbind('submit').submit();
                    }
                });
                return false;
            });

            // Tooltips para módulos (Bootstrap 5)
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            tooltipTriggerList.map(function (el) {
                return new bootstrap.Tooltip(el);
            });

            // Notificaciones de TempData (opcional)
            @if (TempData["SuccessMessage"] != null)
            {
                <text>
                Swal.fire({
                    icon: 'success',
                    title: '¡Éxito!',
                    text: '@Html.Raw(TempData["SuccessMessage"])',
                    confirmButtonColor: '#97C78B',
                    timer: 3000
                });
                </text>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <text>
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: '@Html.Raw(TempData["ErrorMessage"])',
                    confirmButtonColor: '#FBCDC0'
                });
                </text>
            }
        });
    </script>
}