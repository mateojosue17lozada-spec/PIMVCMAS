@model MVCMASCOTAS.Models.ViewModels.EditarUsuarioViewModel
@{
    ViewBag.Title = "Editar Usuario";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <!-- Encabezado de página -->
    <div class="page-header mb-4 fade-in-up">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h1><i class="fa fa-user-edit text-green"></i> Editar Usuario</h1>
                <p class="text-secondary">Modifique la información del usuario del sistema</p>
            </div>
            <div>
                <a href="@Url.Action("Usuarios", "Admin")" class="btn btn-outline-green">
                    <i class="fa fa-arrow-left"></i> Volver a la lista
                </a>
            </div>
        </div>
    </div>

    <!-- Mensajes de alerta -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-green border-green alert-dismissible fade show fade-in-up" role="alert">
            <i class="fa fa-check-circle text-green"></i> <strong class="text-brown">@TempData["SuccessMessage"]</strong>
            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-green border-green alert-dismissible fade show fade-in-up" role="alert">
            <i class="fa fa-exclamation-circle text-green"></i> <strong class="text-brown">@TempData["ErrorMessage"]</strong>
            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
    }

    @using (Html.BeginForm("EditarUsuario", "Admin", FormMethod.Post, new { enctype = "multipart/form-data", id = "formEditarUsuario" }))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(model => model.UsuarioId)
        @Html.HiddenFor(model => model.Email)

        <div class="row">
            <!-- Columna izquierda: Información básica -->
            <div class="col-lg-8">
                <div class="card shadow-hover border-green mb-4">
                    <div class="card-header bg-green text-white">
                        <h5 class="mb-0"><i class="fa fa-id-card"></i> Información Personal</h5>
                    </div>
                    <div class="card-body bg-light-mint">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    @Html.LabelFor(model => model.NombreCompleto, new { @class = "font-weight-bold text-brown required-field" })
                                    @Html.TextBoxFor(model => model.NombreCompleto, new { @class = "form-control border-green", placeholder = "Nombre completo del usuario" })
                                    @Html.ValidationMessageFor(model => model.NombreCompleto, "", new { @class = "text-danger small" })
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="form-group">
                                    @Html.LabelFor(model => model.Email, new { @class = "font-weight-bold text-brown" })
                                    <div class="input-group">
                                        @Html.TextBoxFor(model => model.Email, new { @class = "form-control border-green", @readonly = "readonly" })
                                        <div class="input-group-append">
                                            <span class="input-group-text border-green">
                                                @if (Model.EmailConfirmado)
                                                {
                                                    <i class="fa fa-check-circle text-green" title="Email confirmado"></i>
                                                }
                                                else
                                                {
                                                    <i class="fa fa-exclamation-triangle text-yellow" title="Email no confirmado"></i>
                                                }
                                            </span>
                                        </div>
                                    </div>
                                    <small class="form-text text-secondary">
                                        <i class="fa fa-info-circle"></i> El email no se puede modificar
                                    </small>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    @Html.LabelFor(model => model.Telefono, new { @class = "font-weight-bold text-brown required-field" })
                                    <div class="input-group">
                                        @Html.TextBoxFor(model => model.Telefono, new { @class = "form-control border-green", placeholder = "Ej: 0991234567" })
                                        <div class="input-group-append">
                                            <span class="input-group-text border-green">
                                                @if (Model.TelefonoConfirmado)
                                                {
                                                    <i class="fa fa-check-circle text-green" title="Teléfono confirmado"></i>
                                                }
                                                else
                                                {
                                                    <i class="fa fa-exclamation-triangle text-yellow" title="Teléfono no confirmado"></i>
                                                }
                                            </span>
                                        </div>
                                    </div>
                                    @Html.ValidationMessageFor(model => model.Telefono, "", new { @class = "text-danger small" })
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="form-group">
                                    @Html.LabelFor(model => model.Cedula, new { @class = "font-weight-bold text-brown" })
                                    @Html.TextBoxFor(model => model.Cedula, new { @class = "form-control border-green", placeholder = "Ej: 1234567890" })
                                    @Html.ValidationMessageFor(model => model.Cedula, "", new { @class = "text-danger small" })
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-12">
                                <div class="form-group">
                                    @Html.LabelFor(model => model.Direccion, new { @class = "font-weight-bold text-brown" })
                                    @Html.TextAreaFor(model => model.Direccion, new { @class = "form-control border-green", rows = "2", placeholder = "Dirección completa" })
                                    @Html.ValidationMessageFor(model => model.Direccion, "", new { @class = "text-danger small" })
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    @Html.LabelFor(model => model.Ciudad, new { @class = "font-weight-bold text-brown" })
                                    @Html.TextBoxFor(model => model.Ciudad, new { @class = "form-control border-green", placeholder = "Ej: Quito" })
                                    @Html.ValidationMessageFor(model => model.Ciudad, "", new { @class = "text-danger small" })
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="form-group">
                                    @Html.LabelFor(model => model.Provincia, new { @class = "font-weight-bold text-brown" })
                                    @Html.TextBoxFor(model => model.Provincia, new { @class = "form-control border-green", placeholder = "Ej: Pichincha" })
                                    @Html.ValidationMessageFor(model => model.Provincia, "", new { @class = "text-danger small" })
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Sección de Roles -->
                <div class="card shadow-hover border-green mb-4">
                    <div class="card-header bg-yellow">
                        <h5 class="mb-0 text-brown"><i class="fa fa-user-tag"></i> Asignación de Roles</h5>
                    </div>
                    <div class="card-body bg-light-mint">
                        <p class="text-secondary mb-3">Seleccione los roles que desea asignar al usuario:</p>

                        @if (Model.RolesDisponibles != null && Model.RolesDisponibles.Any())
                        {
                            <div class="row">
                                @foreach (var rol in Model.RolesDisponibles)
                                {
                                    <div class="col-md-6 col-lg-4 mb-3">
                                        <div class="custom-control custom-checkbox role-checkbox p-2 border rounded border-green">
                                            <input type="checkbox"
                                                   class="custom-control-input"
                                                   id="rol_@rol.RolId"
                                                   name="RolesSeleccionados"
                                                   value="@rol.RolId"
                                                   @(rol.Seleccionado ? "checked" : "")>
                                            <label class="custom-control-label text-brown" for="rol_@rol.RolId">
                                                <strong>@rol.NombreRol</strong>
                                                @if (!string.IsNullOrEmpty(rol.Descripcion))
                                                {
                                                    <br>
                                                    <small class="text-secondary">@rol.Descripcion</small>
                                                }
                                            </label>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-green border-green">
                                <i class="fa fa-exclamation-triangle"></i> No hay roles disponibles para asignar.
                            </div>
                        }
                        @Html.ValidationMessage("RolesSeleccionados", "", new { @class = "text-danger small" })
                    </div>
                </div>
            </div>

            <!-- Columna derecha: Imagen y estado -->
            <div class="col-lg-4">
                <!-- Imagen de perfil -->
                <div class="card shadow-hover border-green mb-4">
                    <div class="card-header bg-pink">
                        <h5 class="mb-0 text-brown"><i class="fa fa-camera"></i> Imagen de Perfil</h5>
                    </div>
                    <div class="card-body text-center bg-light-mint">
                        <!-- Imagen actual -->
                        <div class="mb-3">
                            @if (!string.IsNullOrEmpty(Model.ImagenPerfilBase64))
                            {
                                <img id="imagenPrevia" src="data:image/jpeg;base64,@Model.ImagenPerfilBase64"
                                     alt="Imagen de perfil"
                                     class="img-thumbnail rounded-circle mb-3 border-green shadow-sm"
                                     style="width: 200px; height: 200px; object-fit: cover;">
                            }
                            else
                            {
                                <div id="imagenPrevia" class="bg-light-mint rounded-circle d-flex align-items-center justify-content-center mb-3 mx-auto border-green shadow-sm"
                                     style="width: 200px; height: 200px;">
                                    <i class="fa fa-user fa-5x text-secondary"></i>
                                </div>
                            }
                        </div>

                        <!-- Input para nueva imagen -->
                        <div class="form-group">
                            <div class="custom-file">
                                <input type="file" class="custom-file-input border-green" id="NuevaImagenPerfil" name="NuevaImagenPerfil" accept="image/*">
                                <label class="custom-file-label text-brown" for="NuevaImagenPerfil" id="fileLabel">
                                    <i class="fa fa-upload"></i> Seleccionar nueva imagen
                                </label>
                            </div>
                            <small class="form-text text-secondary">
                                Formatos permitidos: JPG, PNG, GIF. Tamaño máximo: 2MB
                            </small>
                            @Html.ValidationMessageFor(model => model.NuevaImagenPerfil, "", new { @class = "text-danger small" })
                        </div>

                        <!-- Vista previa de la nueva imagen -->
                        <div id="nuevaImagenContainer" class="mt-3" style="display: none;">
                            <h6 class="text-brown">Vista previa:</h6>
                            <img id="nuevaImagenPrevia" class="img-thumbnail rounded border-green shadow-sm" style="max-width: 150px; max-height: 150px;">
                            <button type="button" id="removerImagen" class="btn btn-sm btn-pink mt-2">
                                <i class="fa fa-times"></i> Remover imagen
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Estado del usuario -->
                <div class="card shadow-hover border-green mb-4">
                    <div class="card-header bg-green text-white">
                        <h5 class="mb-0"><i class="fa fa-cogs"></i> Estado del Usuario</h5>
                    </div>
                    <div class="card-body bg-light-mint">
                        <div class="form-group">
                            <div class="custom-control custom-switch">
                                @Html.CheckBoxFor(model => model.Activo, new { @class = "custom-control-input", id = "Activo" })
                                <label class="custom-control-label font-weight-bold text-brown" for="Activo">
                                    Usuario Activo
                                </label>
                            </div>
                            <small class="form-text">
                                @if (Model.Activo)
                                {
                                    <span class="text-green">
                                        <i class="fa fa-check-circle"></i> El usuario puede acceder al sistema
                                    </span>
                                }
                                else
                                {
                                    <span class="text-secondary">
                                        <i class="fa fa-ban"></i> El usuario no puede acceder al sistema
                                    </span>
                                }
                            </small>
                        </div>

                        <div class="form-group">
                            <div class="custom-control custom-switch">
                                @Html.CheckBoxFor(model => model.EmailConfirmado, new { @class = "custom-control-input", id = "EmailConfirmado" })
                                <label class="custom-control-label text-brown" for="EmailConfirmado">
                                    Email Confirmado
                                </label>
                            </div>
                        </div>

                        <div class="form-group">
                            <div class="custom-control custom-switch">
                                @Html.CheckBoxFor(model => model.TelefonoConfirmado, new { @class = "custom-control-input", id = "TelefonoConfirmado" })
                                <label class="custom-control-label text-brown" for="TelefonoConfirmado">
                                    Teléfono Confirmado
                                </label>
                            </div>
                        </div>

                        <!-- Información adicional -->
                        <hr class="my-3 border-green">

                        <div class="mb-2">
                            <small class="text-brown">
                                <i class="fa fa-calendar"></i>
                                <strong>Fecha de Registro:</strong>
                                @(Model.FechaRegistro?.ToString("dd/MM/yyyy HH:mm") ?? "No registrada")
                            </small>
                        </div>

                        <div>
                            <small class="text-brown">
                                <i class="fa fa-clock"></i>
                                <strong>Último Acceso:</strong>
                                @(Model.UltimoAcceso?.ToString("dd/MM/yyyy HH:mm") ?? "Nunca")
                            </small>
                        </div>
                    </div>
                </div>

                <!-- Botones de acción -->
                <div class="card shadow-hover border-green">
                    <div class="card-body bg-light-mint">
                        <div class="d-flex justify-content-between">
                            <a href="@Url.Action("Usuarios", "Admin")" class="btn btn-outline-green">
                                <i class="fa fa-times"></i> Cancelar
                            </a>

                            <div>
                                <button type="submit" class="btn btn-green">
                                    <i class="fa fa-save"></i> Guardar Cambios
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")

    <script>
        $(document).ready(function () {
            console.log('Vista Editar Usuario cargada');

            // Manejo de la imagen de perfil
            $('#NuevaImagenPerfil').change(function (e) {
                var fileName = e.target.files[0].name;
                $('#fileLabel').html('<i class="fa fa-upload"></i> ' + fileName);

                // Mostrar vista previa
                if (this.files && this.files[0]) {
                    var reader = new FileReader();
                    reader.onload = function (e) {
                        $('#nuevaImagenPrevia').attr('src', e.target.result);
                        $('#nuevaImagenContainer').show();
                    }
                    reader.readAsDataURL(this.files[0]);
                }
            });

            // Remover imagen seleccionada
            $('#removerImagen').click(function () {
                $('#NuevaImagenPerfil').val('');
                $('#fileLabel').html('<i class="fa fa-upload"></i> Seleccionar nueva imagen');
                $('#nuevaImagenContainer').hide();
                $('#nuevaImagenPrevia').attr('src', '');
            });

            // Validación del formulario
            $('#formEditarUsuario').submit(function (e) {
                // Validar que al menos un rol esté seleccionado
                if ($('input[name="RolesSeleccionados"]:checked').length === 0) {
                    e.preventDefault();
                    Swal.fire({
                        icon: 'warning',
                        title: 'Rol requerido',
                        text: 'Debe seleccionar al menos un rol para el usuario.',
                        confirmButtonColor: '#97C78B',
                        confirmButtonText: 'Entendido'
                    });
                    return false;
                }

                // Validar tamaño de imagen
                var imagenInput = document.getElementById('NuevaImagenPerfil');
                if (imagenInput.files.length > 0) {
                    var fileSize = imagenInput.files[0].size; // en bytes
                    var maxSize = 2 * 1024 * 1024; // 2MB

                    if (fileSize > maxSize) {
                        e.preventDefault();
                        Swal.fire({
                            icon: 'error',
                            title: 'Imagen muy grande',
                            text: 'La imagen no puede superar los 2MB.',
                            confirmButtonColor: '#FBCDC0',
                        });
                        return false;
                    }
                }

                // Mostrar confirmación antes de enviar
                e.preventDefault();

                Swal.fire({
                    title: '¿Guardar cambios?',
                    text: "¿Está seguro de que desea guardar los cambios en este usuario?",
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonColor: '#97C78B',
                    cancelButtonColor: '#FBCDC0',
                    confirmButtonText: 'Sí, guardar',
                    cancelButtonText: 'Cancelar',
                    showClass: {
                        popup: 'animate__animated animate__fadeInDown'
                    },
                    hideClass: {
                        popup: 'animate__animated animate__fadeOutUp'
                    }
                }).then((result) => {
                    if (result.isConfirmed) {
                        // Desactivar botón para evitar doble envío
                        $('button[type="submit"]').prop('disabled', true).html('<i class="fa fa-spinner fa-spin"></i> Guardando...');

                        // Enviar formulario
                        $(this).unbind('submit').submit();
                    }
                });
            });

            // Estilo para campos requeridos
            $('.required-field').each(function () {
                $(this).append(' <span class="text-danger">*</span>');
            });

            // Tooltips
            $('[title]').tooltip({
                placement: 'top',
                trigger: 'hover'
            });

            // Efecto hover en todas las tarjetas
            $('.shadow-hover').hover(
                function () {
                    $(this).addClass('shadow-lg');
                },
                function () {
                    $(this).removeClass('shadow-lg');
                }
            );

            // Efecto en checkboxes de roles
            $('.role-checkbox').hover(
                function () {
                    $(this).css('background-color', 'rgba(151, 199, 139, 0.1)');
                },
                function () {
                    $(this).css('background-color', '');
                }
            );
        });
    </script>

    <style>
        .page-header {
            border-bottom: 2px solid var(--green);
            padding-bottom: 1rem;
        }

        .card {
            border-radius: 12px !important;
            border: 2px solid transparent !important;
            transition: all 0.3s ease !important;
        }

        .card-header {
            border-radius: 10px 10px 0 0 !important;
            padding: 1rem 1.35rem;
        }

        .custom-switch {
            padding-left: 2.5rem;
            padding-bottom: 1rem;
        }

        .custom-control-label::before,
        .custom-control-label::after {
            top: 0.25rem;
        }

        .custom-file-label {
            overflow: hidden;
            white-space: nowrap;
            text-overflow: ellipsis;
            border-color: var(--green) !important;
        }

        .img-thumbnail {
            border: 2px solid var(--green) !important;
            background-color: white !important;
        }

        .form-text {
            font-size: 0.85rem;
        }

        .role-checkbox {
            padding: 0.75rem !important;
            border-radius: 8px !important;
            transition: all 0.3s ease !important;
            cursor: pointer !important;
        }

        .custom-control-label {
            cursor: pointer !important;
            width: 100% !important;
        }

        /* Estilos para switches personalizados */
        .custom-control-input:checked ~ .custom-control-label::before {
            background-color: var(--green) !important;
            border-color: var(--green) !important;
        }

        .custom-control-input:focus ~ .custom-control-label::before {
            box-shadow: 0 0 0 0.2rem rgba(151, 199, 139, 0.25) !important;
        }

        /* Responsive */
        @@media (max-width: 768px) {
            .rounded-circle {
                width: 150px !important;
                height: 150px !important;
            }

            .card-body {
                padding: 1rem;
            }

            .display-4 {
                font-size: 2rem;
            }
        }

        /* Animación para los elementos */
        .fade-in-up {
            animation: fadeInUp 0.6s ease-out;
        }

        /* Campo de archivo personalizado */
        .custom-file-input:focus ~ .custom-file-label {
            border-color: var(--green) !important;
            box-shadow: 0 0 0 0.2rem rgba(151, 199, 139, 0.25) !important;
        }

        .custom-file-input:lang(en) ~ .custom-file-label::after {
            content: "Buscar" !important;
        }
    </style>
}