@model IEnumerable<MVCMASCOTAS.Models.Mascotas>

@{
    ViewBag.Title = "Administrar Mascotas";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <!-- Encabezado -->
    <div class="page-header mb-4">
        <h2><i class="fas fa-paw me-2"></i> Administración de Mascotas</h2>
        <p class="text-muted">Gestión completa de todas las mascotas del refugio</p>
    </div>

    <!-- Botones de acción -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <a href="@Url.Action("Crear", "Mascotas")" class="btn btn-success">
                <i class="fas fa-plus-circle me-1"></i> Registrar Nueva Mascota
            </a>
            <a href="@Url.Action("Dashboard", "Admin")" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-1"></i> Volver al Dashboard
            </a>
        </div>
        <div>
            <button type="button" class="btn btn-outline-info" onclick="exportarExcel()">
                <i class="fas fa-file-excel me-1"></i> Exportar a Excel
            </button>
        </div>
    </div>

    <!-- Filtros y búsqueda -->
    <div class="card shadow-custom mb-4">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="fas fa-filter me-2"></i> Filtros de Búsqueda</h5>
        </div>
        <div class="card-body">
            @using (Html.BeginForm("Mascotas", "Admin", FormMethod.Get, new { @class = "row g-3" }))
            {
                <div class="col-md-3">
                    <label class="form-label">Estado:</label>
                    <select name="estado" class="form-select">
                        <option value="">Todos los estados</option>
                        <option value="Rescatada" @(ViewBag.FiltroEstado == "Rescatada" ? "selected" : "")>Rescatada</option>
                        <option value="En tratamiento" @(ViewBag.FiltroEstado == "En tratamiento" ? "selected" : "")>En tratamiento</option>
                        <option value="Disponible para adopción" @(ViewBag.FiltroEstado == "Disponible para adopción" ? "selected" : "")>Disponible para adopción</option>
                        <option value="Adoptada" @(ViewBag.FiltroEstado == "Adoptada" ? "selected" : "")>Adoptada</option>
                        <option value="Fallecida" @(ViewBag.FiltroEstado == "Fallecida" ? "selected" : "")>Fallecida</option>
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Especie:</label>
                    <select name="especie" class="form-select">
                        <option value="">Todas las especies</option>
                        <option value="Perro" @(ViewBag.FiltroEspecie == "Perro" ? "selected" : "")>Perro</option>
                        <option value="Gato" @(ViewBag.FiltroEspecie == "Gato" ? "selected" : "")>Gato</option>
                        <option value="Otro" @(ViewBag.FiltroEspecie == "Otro" ? "selected" : "")>Otro</option>
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Tamaño:</label>
                    <select name="tamanio" class="form-select">
                        <option value="">Todos los tamaños</option>
                        <option value="Pequeño" @(ViewBag.FiltroTamanio == "Pequeño" ? "selected" : "")>Pequeño</option>
                        <option value="Mediano" @(ViewBag.FiltroTamanio == "Mediano" ? "selected" : "")>Mediano</option>
                        <option value="Grande" @(ViewBag.FiltroTamanio == "Grande" ? "selected" : "")>Grande</option>
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Buscar por nombre:</label>
                    <input type="text" name="nombre" class="form-control"
                           placeholder="Nombre de la mascota" value="@ViewBag.FiltroNombre" />
                </div>

                <div class="col-12 text-end mt-3">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-search me-1"></i> Buscar
                    </button>
                    <a href="@Url.Action("Mascotas", "Admin")" class="btn btn-outline-secondary">
                        <i class="fas fa-redo me-1"></i> Limpiar Filtros
                    </a>
                </div>
            }
        </div>
    </div>

    <!-- Estadísticas rápidas -->
    <div class="row mb-4">
        <div class="col-md-3 mb-3">
            <div class="card text-white bg-info shadow-custom">
                <div class="card-body text-center">
                    <i class="fas fa-paw fa-2x mb-2"></i>
                    <h4>@ViewBag.TotalMascotas</h4>
                    <p class="mb-0">Total Mascotas</p>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card text-white bg-success shadow-custom">
                <div class="card-body text-center">
                    <i class="fas fa-check-circle fa-2x mb-2"></i>
                    <h4>@ViewBag.MascotasDisponibles</h4>
                    <p class="mb-0">Disponibles</p>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card text-white bg-warning shadow-custom">
                <div class="card-body text-center">
                    <i class="fas fa-medkit fa-2x mb-2"></i>
                    <h4>@ViewBag.MascotasTratamiento</h4>
                    <p class="mb-0">En Tratamiento</p>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card text-white bg-primary shadow-custom">
                <div class="card-body text-center">
                    <i class="fas fa-heart fa-2x mb-2"></i>
                    <h4>@ViewBag.MascotasAdoptadas</h4>
                    <p class="mb-0">Adoptadas</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabla de Mascotas -->
    <div class="card shadow-custom">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><i class="fas fa-table me-2"></i> Listado de Mascotas</h5>
            <span class="badge bg-light text-dark">
                Mostrando @(Model != null ? Model.Count() : 0) mascotas
            </span>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover table-striped">
                    <thead class="table-dark">
                        <tr>
                            <th width="80">ID</th>
                            <th width="80">Imagen</th>
                            <th>Nombre</th>
                            <th>Especie</th>
                            <th>Raza</th>
                            <th width="100">Sexo</th>
                            <th width="120">Edad</th>
                            <th width="150">Estado</th>
                            <th width="100">Esterilizado</th>
                            <th width="120">Fecha Ingreso</th>
                            <th width="180" class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var mascota in Model)
                            {
                                <tr>
                                    <td><strong>#@mascota.MascotaId</strong></td>
                                    <td>
                                        @if (mascota.ImagenPrincipal != null && mascota.ImagenPrincipal.Length > 0)
                                        {
                                            <img src="data:image/jpeg;base64,@Convert.ToBase64String(mascota.ImagenPrincipal)"
                                                 alt="@mascota.Nombre"
                                                 class="img-thumbnail"
                                                 style="width: 50px; height: 50px; object-fit: cover;" />
                                        }
                                        else
                                        {
                                            <div class="img-thumbnail d-flex align-items-center justify-content-center"
                                                 style="width: 50px; height: 50px; background-color: #f8f9fa;">
                                                <i class="fas fa-paw text-muted"></i>
                                            </div>
                                        }
                                    </td>
                                    <td><strong>@mascota.Nombre</strong></td>
                                    <td>
                                        @if (mascota.Especie == "Perro")
                                        {
                                            <i class="fas fa-dog text-primary me-1"></i>
                                            @:Perro
                                        }
                                        else if (mascota.Especie == "Gato")
                                        {
                                            <i class="fas fa-cat text-info me-1"></i>
                                            @:Gato
                                        }
                                        else
                                        {
                                            <i class="fas fa-paw text-secondary me-1"></i>
                                            @mascota.Especie
                                        }
                                    </td>
                                    <td>@(mascota.Raza ?? "Mestizo")</td>
                                    <td>
                                        @if (mascota.Sexo == "M" || mascota.Sexo == "Macho")
                                        {
                                            <i class="fas fa-mars text-primary me-1"></i>
                                            @:Macho
                                        }
                                        else if (mascota.Sexo == "F" || mascota.Sexo == "Hembra")
                                        {
                                            <i class="fas fa-venus text-danger me-1"></i>
                                            @:Hembra
                                        }
                                        else
                                        {
                                            @mascota.Sexo
                                        }
                                    </td>
                                    <td>@mascota.EdadAproximada</td>
                                    <td>
                                        @if (mascota.Estado == "Rescatada")
                                        {
                                            <span class="badge bg-danger"><i class="fas fa-exclamation-triangle me-1"></i> @mascota.Estado</span>
                                        }
                                        else if (mascota.Estado == "En tratamiento")
                                        {
                                            <span class="badge bg-warning"><i class="fas fa-medkit me-1"></i> @mascota.Estado</span>
                                        }
                                        else if (mascota.Estado == "Disponible para adopción")
                                        {
                                            <span class="badge bg-success"><i class="fas fa-check-circle me-1"></i> Disponible</span>
                                        }
                                        else if (mascota.Estado == "Adoptada")
                                        {
                                            <span class="badge bg-info"><i class="fas fa-heart me-1"></i> @mascota.Estado</span>
                                        }
                                        else if (mascota.Estado == "Fallecida")
                                        {
                                            <span class="badge bg-dark"><i class="fas fa-cross me-1"></i> @mascota.Estado</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">@mascota.Estado</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (mascota.Esterilizado == true)
                                        {
                                            <span class="badge bg-success"><i class="fas fa-check me-1"></i> Sí</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary"><i class="fas fa-times me-1"></i> No</span>
                                        }
                                    </td>
                                    <td>
                                        @if (mascota.FechaIngreso.HasValue)
                                        {
                                            @mascota.FechaIngreso.Value.ToString("dd/MM/yyyy")
                                        }
                                        else
                                        {
                                            <span class="text-muted">N/A</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group btn-group-sm" role="group">
                                            <a href="@Url.Action("Detalle", "Mascotas", new { id = mascota.MascotaId })"
                                               class="btn btn-outline-info"
                                               title="Ver Detalles"
                                               data-bs-toggle="tooltip">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <a href="@Url.Action("Editar", "Mascotas", new { id = mascota.MascotaId })"
                                               class="btn btn-outline-warning"
                                               title="Editar"
                                               data-bs-toggle="tooltip">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <a href="@Url.Action("HistorialMedico", "Veterinario", new { mascotaId = mascota.MascotaId })"
                                               class="btn btn-outline-success"
                                               title="Historial Médico"
                                               data-bs-toggle="tooltip">
                                                <i class="fas fa-stethoscope"></i>
                                            </a>
                                            <button type="button"
                                                    class="btn btn-outline-danger"
                                                    title="Eliminar"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#deleteModal"
                                                    data-id="@mascota.MascotaId"
                                                    data-nombre="@mascota.Nombre">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="11" class="text-center py-5">
                                    <div class="alert alert-info mb-0">
                                        <i class="fas fa-info-circle fa-2x mb-3"></i>
                                        <h5>No se encontraron mascotas</h5>
                                        <p class="mb-0">No hay mascotas registradas con los filtros seleccionados.</p>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (Model != null && Model.Any())
            {
                <div class="mt-3">
                    <p class="text-muted">
                        <i class="fas fa-info-circle me-1"></i>
                        Mostrando @Model.Count() mascotas
                    </p>
                </div>
            }
        </div>
    </div>

    <!-- Paginación -->
    @if (ViewBag.TotalPages != null && ViewBag.TotalPages > 1)
    {
        <nav aria-label="Paginación de mascotas" class="mt-4">
            <ul class="pagination justify-content-center">
                @if (ViewBag.CurrentPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link" href="@Url.Action("Mascotas", "Admin", new {
                            page = ViewBag.CurrentPage - 1,
                            estado = ViewBag.FiltroEstado,
                            especie = ViewBag.FiltroEspecie,
                            tamanio = ViewBag.FiltroTamanio,
                            nombre = ViewBag.FiltroNombre
                        })">
                            <i class="fas fa-chevron-left"></i> Anterior
                        </a>
                    </li>
                }

                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                        <a class="page-link" href="@Url.Action("Mascotas", "Admin", new {
                            page = i,
                            estado = ViewBag.FiltroEstado,
                            especie = ViewBag.FiltroEspecie,
                            tamanio = ViewBag.FiltroTamanio,
                            nombre = ViewBag.FiltroNombre
                        })">@i</a>
                    </li>
                }

                @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                {
                    <li class="page-item">
                        <a class="page-link" href="@Url.Action("Mascotas", "Admin", new {
                            page = ViewBag.CurrentPage + 1,
                            estado = ViewBag.FiltroEstado,
                            especie = ViewBag.FiltroEspecie,
                            tamanio = ViewBag.FiltroTamanio,
                            nombre = ViewBag.FiltroNombre
                        })">
                            Siguiente <i class="fas fa-chevron-right"></i>
                        </a>
                    </li>
                }
            </ul>
        </nav>
    }
</div>

<!-- Modal de confirmación de eliminación -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="deleteModalLabel">
                    <i class="fas fa-exclamation-triangle me-2"></i> Confirmar Eliminación
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>¿Está seguro que desea eliminar la mascota <strong id="mascotaNombre"></strong>?</p>
                <div class="alert alert-danger">
                    <i class="fas fa-exclamation-circle me-2"></i>
                    <strong>¡Advertencia!</strong> Esta acción no se puede deshacer. Se eliminarán todos los registros asociados (solicitudes, historial médico, vacunas, etc.).
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="fas fa-times me-1"></i> Cancelar
                </button>
                <form id="deleteForm" method="post" style="display: inline;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">
                        <i class="fas fa-trash me-1"></i> Eliminar
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Inicializar tooltips de Bootstrap 5
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl);
            });

            // Modal de eliminación
            var deleteModal = document.getElementById('deleteModal');
            if (deleteModal) {
                deleteModal.addEventListener('show.bs.modal', function (event) {
                    var button = event.relatedTarget;
                    var mascotaId = button.getAttribute('data-id');
                    var mascotaNombre = button.getAttribute('data-nombre');

                    var modalTitle = deleteModal.querySelector('.modal-title');
                    var mascotaNombreSpan = deleteModal.querySelector('#mascotaNombre');
                    var deleteForm = deleteModal.querySelector('#deleteForm');

                    mascotaNombreSpan.textContent = mascotaNombre;
                    deleteForm.action = '@Url.Action("Eliminar", "Mascotas")/' + mascotaId;
                });
            }

            // Confirmación adicional al eliminar
            $('#deleteForm').on('submit', function (e) {
                if (!confirm('¿Realmente desea eliminar esta mascota? Esta acción es irreversible.')) {
                    e.preventDefault();
                    return false;
                }
            });

            // Función para exportar a Excel
            window.exportarExcel = function() {
                var params = [];
                if ('@ViewBag.FiltroEstado') params.push('estado=@ViewBag.FiltroEstado');
                if ('@ViewBag.FiltroEspecie') params.push('especie=@ViewBag.FiltroEspecie');
                if ('@ViewBag.FiltroTamanio') params.push('tamanio=@ViewBag.FiltroTamanio');
                if ('@ViewBag.FiltroNombre') params.push('nombre=@ViewBag.FiltroNombre');

                var queryString = params.length > 0 ? '?' + params.join('&') : '';
                window.location.href = '@Url.Action("ExportarMascotas", "Admin")' + queryString;
            };
        });
    </script>

    <style>
        .shadow-custom {
            box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
            border: 1px solid rgba(0, 0, 0, 0.125);
        }

        .table-hover tbody tr:hover {
            background-color: rgba(0, 123, 255, 0.05);
        }

        .badge {
            font-size: 0.85em;
            padding: 0.35em 0.65em;
        }

        .btn-group .btn {
            border-radius: 0.25rem !important;
            margin: 0 2px;
        }
    </style>
}