@model MVCMASCOTAS.Models.ViewModels.RegisterViewModel
@{
    ViewBag.Title = "Crear Nuevo Usuario - ADOPTAMANÍA";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Hero Section -->
<section class="user-hero py-4">
    <div class="container text-center">
        <i class="fas fa-user-plus fa-3x text-green mb-3"></i>
        <h1 class="display-5 fw-bold mb-2 text-brown">Crear Nuevo Usuario</h1>
        <p class="lead mb-3 text-secondary">Complete el formulario para registrar un nuevo usuario en el sistema</p>
    </div>
</section>

<!-- Main Content -->
<section class="py-5 bg-beige">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <div class="user-card">
                    <div class="user-card-header bg-green text-white text-center">
                        <i class="fas fa-user-plus fa-3x mb-3"></i>
                        <h3 class="mb-2">Crear Nuevo Usuario</h3>
                        <p class="mb-0">Registra un nuevo usuario en el sistema</p>
                    </div>
                    <div class="user-card-body p-4 p-md-5">
                        @using (Html.BeginForm("CrearUsuario", "Admin", FormMethod.Post,
                               new
                               {
                                   @class = "needs-validation",
                                   enctype = "multipart/form-data",
                                   novalidate = "novalidate",
                                   id = "crearUsuarioForm"
                               }))
                        {
                            @Html.AntiForgeryToken()

                            if (TempData["SuccessMessage"] != null)
                            {
                                <div class="alert alert-beige border-green alert-dismissible fade show mb-4" role="alert">
                                    <i class="fas fa-check-circle text-green me-2"></i>
                                    <strong class="text-brown">@TempData["SuccessMessage"]</strong>
                                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                                </div>
                            }

                            if (TempData["ErrorMessage"] != null)
                            {
                                <div class="alert alert-beige border-green alert-dismissible fade show mb-4" role="alert">
                                    <i class="fas fa-exclamation-circle text-green me-2"></i>
                                    <strong class="text-brown">@TempData["ErrorMessage"]</strong>
                                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                                </div>
                            }

                            @Html.ValidationSummary(true, "", new { @class = "alert alert-beige border-green" })

                            <!-- Información Personal -->
                            <div class="row g-3 mb-4">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label class="form-label text-brown fw-medium">
                                            <i class="fas fa-user text-green me-2"></i> Nombre Completo *
                                        </label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-white border-green">
                                                <i class="fas fa-user text-green"></i>
                                            </span>
                                            @Html.TextBoxFor(m => m.NombreCompleto, new
                                            {
                                                @class = "form-control border-green",
                                                placeholder = "Ej: Juan Pérez",
                                                required = "required",
                                                maxlength = "150",
                                                autocomplete = "name"
                                            })
                                        </div>
                                        @Html.ValidationMessageFor(m => m.NombreCompleto, "", new { @class = "text-danger small mt-1" })
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label class="form-label text-brown fw-medium">
                                            <i class="fas fa-id-card text-green me-2"></i> Cédula *
                                        </label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-white border-green">
                                                <i class="fas fa-id-card text-green"></i>
                                            </span>
                                            @Html.TextBoxFor(m => m.Cedula, new
                                            {
                                                @class = "form-control border-green",
                                                id = "Cedula",
                                                placeholder = "Ej: 1712345678",
                                                maxlength = "10",
                                                required = "required",
                                                autocomplete = "off",
                                                pattern = "[0-9]{10}",
                                                title = "10 dígitos numéricos"
                                            })
                                        </div>
                                        @Html.ValidationMessageFor(m => m.Cedula, "", new { @class = "text-danger small mt-1" })
                                        <small class="form-text text-secondary mt-2">
                                            <i class="fas fa-info-circle text-green me-1"></i> 10 dígitos sin guiones
                                        </small>
                                    </div>
                                </div>
                            </div>

                            <!-- Contacto -->
                            <div class="row g-3 mb-4">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label class="form-label text-brown fw-medium">
                                            <i class="fas fa-envelope text-green me-2"></i> Email *
                                        </label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-white border-green">
                                                <i class="fas fa-envelope text-green"></i>
                                            </span>
                                            @Html.TextBoxFor(m => m.Email, new
                                            {
                                                @class = "form-control border-green",
                                                type = "email",
                                                placeholder = "Ej: juan@email.com",
                                                required = "required",
                                                maxlength = "150",
                                                autocomplete = "email"
                                            })
                                        </div>
                                        @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger small mt-1" })
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label class="form-label text-brown fw-medium">
                                            <i class="fas fa-phone-alt text-green me-2"></i> Teléfono *
                                        </label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-white border-green">
                                                <i class="fas fa-phone-alt text-green"></i>
                                            </span>
                                            @Html.TextBoxFor(m => m.Telefono, new
                                            {
                                                @class = "form-control border-green",
                                                id = "Telefono",
                                                placeholder = "Ej: 0987654321",
                                                required = "required",
                                                maxlength = "10",
                                                autocomplete = "tel",
                                                pattern = "[0-9]{10}",
                                                title = "10 dígitos numéricos"
                                            })
                                        </div>
                                        @Html.ValidationMessageFor(m => m.Telefono, "", new { @class = "text-danger small mt-1" })
                                        <small class="form-text text-secondary mt-2">
                                            <i class="fas fa-info-circle text-green me-1"></i> 10 dígitos sin guiones
                                        </small>
                                    </div>
                                </div>
                            </div>

                            <!-- Dirección -->
                            <div class="form-group mb-4">
                                <label class="form-label text-brown fw-medium">
                                    <i class="fas fa-map-marker-alt text-green me-2"></i> Dirección *
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white border-green">
                                        <i class="fas fa-map-marker-alt text-green"></i>
                                    </span>
                                    @Html.TextAreaFor(m => m.Direccion, new
                                    {
                                        @class = "form-control border-green",
                                        rows = "2",
                                        placeholder = "Dirección completa incluyendo calles, sector...",
                                        required = "required",
                                        maxlength = "255",
                                        autocomplete = "street-address"
                                    })
                                </div>
                                @Html.ValidationMessageFor(m => m.Direccion, "", new { @class = "text-danger small mt-1" })
                            </div>

                            <!-- Ciudad y Provincia -->
                            <div class="row g-3 mb-4">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label class="form-label text-brown fw-medium">
                                            <i class="fas fa-city text-green me-2"></i> Ciudad
                                        </label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-white border-green">
                                                <i class="fas fa-city text-green"></i>
                                            </span>
                                            @Html.TextBoxFor(m => m.Ciudad, new
                                            {
                                                @class = "form-control border-green",
                                                placeholder = "Ej: Quito",
                                                maxlength = "100",
                                                autocomplete = "address-level2"
                                            })
                                        </div>
                                        @Html.ValidationMessageFor(m => m.Ciudad, "", new { @class = "text-danger small mt-1" })
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label class="form-label text-brown fw-medium">
                                            <i class="fas fa-map text-green me-2"></i> Provincia
                                        </label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-white border-green">
                                                <i class="fas fa-map text-green"></i>
                                            </span>
                                            @Html.TextBoxFor(m => m.Provincia, new
                                            {
                                                @class = "form-control border-green",
                                                placeholder = "Ej: Pichincha",
                                                maxlength = "100",
                                                autocomplete = "address-level1"
                                            })
                                        </div>
                                        @Html.ValidationMessageFor(m => m.Provincia, "", new { @class = "text-danger small mt-1" })
                                    </div>
                                </div>
                            </div>

                            <!-- Contraseñas -->
                            <div class="row g-3 mb-4">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label class="form-label text-brown fw-medium">
                                            <i class="fas fa-lock text-green me-2"></i> Contraseña *
                                        </label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-white border-green">
                                                <i class="fas fa-lock text-green"></i>
                                            </span>
                                            @Html.PasswordFor(m => m.Password, new
                                            {
                                                @class = "form-control border-green",
                                                id = "Password",
                                                placeholder = "Mínimo 8 caracteres",
                                                required = "required",
                                                minlength = "8",
                                                maxlength = "100",
                                                autocomplete = "new-password"
                                            })
                                            <button type="button" class="btn btn-outline-green toggle-password" data-target="#Password">
                                                <i class="fas fa-eye"></i>
                                            </button>
                                        </div>
                                        @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger small mt-1" })
                                        <div class="requirements-box small text-secondary mt-2">
                                            <i class="fas fa-info-circle text-green me-1"></i> Requisitos de contraseña:
                                            <ul class="mb-0 ps-3">
                                                <li>Mínimo 8 caracteres</li>
                                                <li>Al menos una letra</li>
                                                <li>Al menos un número</li>
                                            </ul>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label class="form-label text-brown fw-medium">
                                            <i class="fas fa-check-circle text-green me-2"></i> Confirmar Contraseña *
                                        </label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-white border-green">
                                                <i class="fas fa-check-circle text-green"></i>
                                            </span>
                                            @Html.PasswordFor(m => m.ConfirmPassword, new
                                            {
                                                @class = "form-control border-green",
                                                id = "ConfirmPassword",
                                                placeholder = "Repite tu contraseña",
                                                required = "required",
                                                autocomplete = "new-password"
                                            })
                                            <button type="button" class="btn btn-outline-green toggle-password" data-target="#ConfirmPassword">
                                                <i class="fas fa-eye"></i>
                                            </button>
                                        </div>
                                        @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "text-danger small mt-1" })
                                        <div id="passwordMatch" class="mt-2 d-none">
                                            <small class="text-success">
                                                <i class="fas fa-check-circle me-1"></i> Las contraseñas coinciden
                                            </small>
                                        </div>
                                        <div id="passwordMismatch" class="mt-2 d-none">
                                            <small class="text-danger">
                                                <i class="fas fa-times-circle me-1"></i> Las contraseñas no coinciden
                                            </small>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Sección de Roles -->
                            <div class="form-group mb-4">
                                <label class="form-label text-brown fw-medium">
                                    <i class="fas fa-user-tag text-green me-2"></i> Roles del Usuario *
                                </label>
                                <div class="roles-container border border-green rounded p-3" style="max-height: 200px; overflow-y: auto;">
                                    @if (ViewBag.Roles != null)
                                    {
                                        var rolesList = ViewBag.Roles as IEnumerable<dynamic>;
                                        if (rolesList != null && rolesList.Any())
                                        {
                                            foreach (var rol in rolesList)
                                            {
                                                <div class="form-check mb-2">
                                                    <input class="form-check-input" type="checkbox" name="rolesSeleccionados" id="rol_@rol.RolId" value="@rol.RolId">
                                                    <label class="form-check-label text-brown" for="rol_@rol.RolId">
                                                        @rol.NombreRol
                                                        @if (!string.IsNullOrEmpty(rol.Descripcion))
                                                        {
                                                            <small class="text-secondary d-block">@rol.Descripcion</small>
                                                        }
                                                    </label>
                                                </div>
                                            }
                                        }
                                        else
                                        {
                                            <div class="alert alert-beige border-green mb-0">
                                                <i class="fas fa-exclamation-triangle text-green me-2"></i> No hay roles disponibles en el sistema.
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        <div class="alert alert-beige border-green mb-0">
                                            <i class="fas fa-exclamation-triangle text-green me-2"></i> No hay roles disponibles en el sistema.
                                        </div>
                                    }
                                </div>
                                @if (!ViewData.ModelState.IsValid && ViewData.ModelState["rolesSeleccionados"]?.Errors != null)
                                {
                                    <span class="text-danger small mt-2 d-block">
                                        @ViewData.ModelState["rolesSeleccionados"].Errors.FirstOrDefault()?.ErrorMessage
                                    </span>
                                }
                            </div>

                            <!-- Foto de Perfil -->
                            <div class="form-group mb-4">
                                <label class="form-label text-brown fw-medium">
                                    <i class="fas fa-camera text-green me-2"></i> Foto de Perfil (Opcional)
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white border-green">
                                        <i class="fas fa-camera text-green"></i>
                                    </span>
                                    <input type="file" class="form-control border-green" id="ImagenPerfil" name="ImagenPerfil" accept="image/*" />
                                    <button class="btn btn-outline-green" type="button" onclick="$('#ImagenPerfil').click();">
                                        <i class="fas fa-cloud-upload-alt me-1"></i> Examinar
                                    </button>
                                </div>
                                <small class="form-text text-secondary mt-2">
                                    <i class="fas fa-info-circle text-green me-1"></i> Formatos: JPG, PNG, GIF. Tamaño máximo: 5MB
                                </small>
                                <div id="imagePreview" class="text-center mt-3" style="display: none;">
                                    <p class="mb-2 text-brown">
                                        <i class="fas fa-eye text-green me-1"></i> Vista Previa:
                                    </p>
                                    <img id="previewImage" class="img-thumbnail rounded-circle border-green" style="width: 150px; height: 150px; object-fit: cover;" />
                                </div>
                            </div>

                            <!-- Pregunta de Seguridad -->
                            <div class="form-group mb-4">
                                <label class="form-label text-brown fw-medium">
                                    <i class="fas fa-shield-alt text-green me-2"></i> Pregunta de Seguridad *
                                </label>
                                <div class="security-card p-3">
                                    <p class="mb-2 text-secondary">¿Cuánto es 2 + 2?</p>
                                    <div class="input-group">
                                        <span class="input-group-text bg-white border-green">
                                            <i class="fas fa-shield-alt text-green"></i>
                                        </span>
                                        @Html.TextBoxFor(m => m.PreguntaSeguridad, new
                                        {
                                            @class = "form-control border-green",
                                            type = "number",
                                            placeholder = "Ingresa la respuesta",
                                            required = "required"
                                        })
                                    </div>
                                    @Html.ValidationMessageFor(m => m.PreguntaSeguridad, "", new { @class = "text-danger small mt-1" })
                                    <small class="form-text text-secondary mt-2">
                                        <i class="fas fa-info-circle text-green me-1"></i> Esta pregunta ayuda a verificar que no eres un bot
                                    </small>
                                </div>
                            </div>

                            <!-- Términos y Condiciones -->
                            <div class="form-check mt-4 mb-4">
                                @Html.CheckBoxFor(m => m.AceptaTerminos, new { @class = "form-check-input", id = "AceptaTerminos", required = "required" })
                                <label class="form-check-label text-brown" for="AceptaTerminos">
                                    Acepto los <a href="@Url.Action("Terminos", "Home")" target="_blank" class="text-green">términos y condiciones</a> *
                                </label>
                                @Html.ValidationMessageFor(m => m.AceptaTerminos, "", new { @class = "text-danger d-block" })
                            </div>

                            <!-- Botones -->
                            <div class="d-flex flex-column flex-md-row justify-content-between gap-3 mt-4">
                                <a href="@Url.Action("Usuarios", "Admin")" class="btn btn-outline-green">
                                    <i class="fas fa-arrow-left me-2"></i> Cancelar
                                </a>
                                <button type="submit" class="btn btn-green" id="btnCrearUsuario">
                                    <i class="fas fa-user-plus me-2"></i> Crear Usuario
                                </button>
                            </div>
                        }

                        <div class="text-center mt-4 pt-4 border-top border-green">
                            <p class="text-brown mb-0">
                                <i class="fas fa-info-circle text-green me-1"></i> Todos los campos marcados con * son obligatorios.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Styles {
    <style>
        /* Hero */
        .user-hero {
            background-color: var(--fondo-beige);
            border-radius: 0 0 30px 30px;
            margin-bottom: 1rem;
        }

        /* Tarjeta principal */
        .user-card {
            background: white;
            border-radius: 30px;
            overflow: hidden;
            box-shadow: 0 20px 40px rgba(151,199,139,0.15);
            border: none;
        }

        .user-card-header {
            padding: 2rem 1.5rem 1.5rem;
        }

        .user-card-body {
            padding: 2rem;
        }

        /* Input groups */
        .input-group-text {
            border-radius: 12px 0 0 12px;
            border-right: none;
            background-color: white;
        }

        .form-control {
            border-radius: 0 12px 12px 0;
            border-left: none;
            padding: 0.75rem 1rem;
            transition: border-color 0.2s, box-shadow 0.2s;
        }

            .form-control:focus {
                border-color: var(--verde-menta);
                box-shadow: 0 0 0 0.2rem rgba(151,199,139,0.25);
                outline: none;
            }

        .input-group:focus-within .input-group-text {
            border-color: var(--verde-menta);
            box-shadow: 0 0 0 0.2rem rgba(151,199,139,0.25);
        }

        /* Botón toggle contraseña */
        .btn-outline-green {
            border: 2px solid var(--verde-menta);
            background: transparent;
            color: var(--verde-menta);
            border-radius: 0 12px 12px 0;
            border-left: none;
            transition: all 0.2s;
        }

            .btn-outline-green:hover {
                background-color: var(--verde-menta);
                color: white;
            }

        /* Checkbox personalizado */
        .form-check-input {
            width: 1.2em;
            height: 1.2em;
            margin-top: 0.2em;
            border: 2px solid var(--verde-menta);
            transition: background-color 0.2s;
        }

            .form-check-input:checked {
                background-color: var(--verde-menta);
                border-color: var(--verde-menta);
            }

            .form-check-input:focus {
                border-color: var(--verde-menta);
                box-shadow: 0 0 0 0.2rem rgba(151,199,139,0.25);
            }

        /* Alertas personalizadas */
        .alert-beige {
            background-color: var(--fondo-beige);
            border: 1px solid var(--verde-menta);
            color: var(--texto-oscuro);
            border-radius: 16px;
        }

        /* Requisitos de contraseña */
        .requirements-box {
            background-color: rgba(151,199,139,0.1);
            padding: 0.75rem 1rem;
            border-radius: 12px;
            border-left: 4px solid var(--verde-menta);
        }

            .requirements-box ul {
                padding-left: 1.5rem;
                margin-top: 0.25rem;
            }

        /* Contenedor de roles */
        .roles-container {
            background-color: white;
        }

            .roles-container .form-check {
                padding-left: 2rem;
            }

        /* Tarjeta de seguridad */
        .security-card {
            background-color: var(--fondo-beige);
            border-radius: 16px;
            border: 1px solid var(--verde-menta);
        }

        /* Vista previa de imagen */
        .img-thumbnail {
            border: 2px solid var(--verde-menta);
            border-radius: 50%;
            transition: transform 0.3s;
        }

            .img-thumbnail:hover {
                transform: scale(1.05);
            }

        /* Botones principales */
        .btn-green {
            background-color: var(--verde-menta);
            border: none;
            border-radius: 50px;
            padding: 0.6rem 2rem;
            font-weight: 600;
            transition: all 0.3s;
        }

            .btn-green:hover {
                background-color: #86b57a;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(151,199,139,0.4);
            }

        .btn-outline-green:not(.toggle-password) {
            border-radius: 50px;
            border-left: 2px solid var(--verde-menta);
        }

        /* Responsive */
        @@media (max-width: 768px) {
            .user-card-header {
                padding: 1.5rem 1rem;
            }

            .user-card-body {
                padding: 1.5rem;
            }

            .d-flex.gap-3 {
                flex-direction: column;
            }

            .btn {
                width: 100%;
            }
        }
    </style>
}

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
    <script>
        $(document).ready(function () {
            console.log("Formulario Crear Usuario cargado");

            // Toggle password visibility
            $('.toggle-password').click(function () {
                var target = $(this).data('target');
                var input = $(target);
                var icon = $(this).find('i');

                if (input.attr('type') === 'password') {
                    input.attr('type', 'text');
                    icon.removeClass('fa-eye').addClass('fa-eye-slash');
                } else {
                    input.attr('type', 'password');
                    icon.removeClass('fa-eye-slash').addClass('fa-eye');
                }
            });

            // Vista previa de imagen
            $('#ImagenPerfil').on('change', function () {
                var input = this;
                if (input.files && input.files[0]) {
                    var file = input.files[0];
                    var fileSize = file.size / 1024 / 1024; // en MB

                    if (fileSize > 5) {
                        Swal.fire({
                            icon: 'error',
                            title: 'Archivo demasiado grande',
                            text: 'La imagen no debe exceder 5 MB.',
                            confirmButtonColor: '#97C78B'
                        });
                        $(this).val('');
                        $('#imagePreview').hide();
                        return;
                    }

                    var reader = new FileReader();
                    reader.onload = function (e) {
                        $('#previewImage').attr('src', e.target.result);
                        $('#imagePreview').show();
                    };
                    reader.readAsDataURL(input.files[0]);
                } else {
                    $('#imagePreview').hide();
                }
            });

            // Validación en tiempo real de contraseña
            $('#Password').on('input', function () {
                var password = $(this).val();
                var hasLetter = /[a-zA-Z]/.test(password);
                var hasDigit = /\d/.test(password);
                var isValid = password.length >= 8 && hasLetter && hasDigit;

                if (isValid) {
                    $(this).removeClass('is-invalid').addClass('is-valid');
                } else {
                    $(this).removeClass('is-valid').addClass('is-invalid');
                }

                if ($('#ConfirmPassword').val()) {
                    checkPasswordMatch();
                }
            });

            $('#ConfirmPassword').on('input', checkPasswordMatch);

            function checkPasswordMatch() {
                var password = $('#Password').val();
                var confirmPassword = $('#ConfirmPassword').val();

                if (confirmPassword === '') {
                    $('#ConfirmPassword').removeClass('is-invalid is-valid');
                    $('#passwordMatch, #passwordMismatch').addClass('d-none');
                    return;
                }

                if (password === confirmPassword) {
                    $('#ConfirmPassword').removeClass('is-invalid').addClass('is-valid');
                    $('#passwordMatch').removeClass('d-none');
                    $('#passwordMismatch').addClass('d-none');
                } else {
                    $('#ConfirmPassword').removeClass('is-valid').addClass('is-invalid');
                    $('#passwordMatch').addClass('d-none');
                    $('#passwordMismatch').removeClass('d-none');
                }
            }

            // Validación del formulario
            $('#crearUsuarioForm').on('submit', function (e) {
                // Validar roles
                if ($('input[name="rolesSeleccionados"]:checked').length === 0) {
                    e.preventDefault();
                    Swal.fire({
                        icon: 'error',
                        title: 'Rol requerido',
                        text: 'Debe seleccionar al menos un rol para el usuario.',
                        confirmButtonColor: '#97C78B'
                    });
                    return false;
                }

                // Validar cédula
                var cedula = $('#Cedula').val();
                if (cedula.length !== 10 || !/^\d+$/.test(cedula)) {
                    e.preventDefault();
                    Swal.fire({
                        icon: 'error',
                        title: 'Cédula inválida',
                        text: 'La cédula debe tener exactamente 10 dígitos numéricos.',
                        confirmButtonColor: '#97C78B'
                    });
                    $('#Cedula').focus();
                    return false;
                }

                // Validar teléfono
                var telefono = $('#Telefono').val();
                if (telefono.length !== 10 || !/^\d+$/.test(telefono)) {
                    e.preventDefault();
                    Swal.fire({
                        icon: 'error',
                        title: 'Teléfono inválido',
                        text: 'El teléfono debe tener exactamente 10 dígitos numéricos.',
                        confirmButtonColor: '#97C78B'
                    });
                    $('#Telefono').focus();
                    return false;
                }

                // Validar contraseña
                var password = $('#Password').val();
                var hasLetter = /[a-zA-Z]/.test(password);
                var hasDigit = /\d/.test(password);

                if (password.length < 8) {
                    e.preventDefault();
                    Swal.fire({
                        icon: 'error',
                        title: 'Contraseña muy corta',
                        text: 'La contraseña debe tener al menos 8 caracteres.',
                        confirmButtonColor: '#97C78B'
                    });
                    $('#Password').focus();
                    return false;
                }

                if (!hasLetter || !hasDigit) {
                    e.preventDefault();
                    Swal.fire({
                        icon: 'error',
                        title: 'Contraseña inválida',
                        text: 'La contraseña debe incluir letras y números.',
                        confirmButtonColor: '#97C78B'
                    });
                    $('#Password').focus();
                    return false;
                }

                // Confirmar contraseñas
                if (password !== $('#ConfirmPassword').val()) {
                    e.preventDefault();
                    Swal.fire({
                        icon: 'error',
                        title: 'Contraseñas no coinciden',
                        text: 'Las contraseñas deben ser idénticas.',
                        confirmButtonColor: '#97C78B'
                    });
                    $('#ConfirmPassword').focus();
                    return false;
                }

                // Pregunta de seguridad
                if ($('#PreguntaSeguridad').val() !== "4") {
                    e.preventDefault();
                    Swal.fire({
                        icon: 'error',
                        title: 'Respuesta incorrecta',
                        text: 'La respuesta a la pregunta de seguridad es incorrecta.',
                        confirmButtonColor: '#97C78B'
                    });
                    $('#PreguntaSeguridad').focus();
                    return false;
                }

                // Términos
                if (!$('#AceptaTerminos').is(':checked')) {
                    e.preventDefault();
                    Swal.fire({
                        icon: 'error',
                        title: 'Términos no aceptados',
                        text: 'Debe aceptar los términos y condiciones.',
                        confirmButtonColor: '#97C78B'
                    });
                    $('#AceptaTerminos').focus();
                    return false;
                }

                // Deshabilitar botón
                $('#btnCrearUsuario').prop('disabled', true).html('<i class="fas fa-spinner fa-spin me-2"></i> Creando...');
                return true;
            });

            $('#NombreCompleto').focus();
        });
    </script>
}