@model IEnumerable<MVCMASCOTAS.Models.Roles>

@{
    ViewBag.Title = "Gestión de Roles - ADOPTAMANÍA";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Hero Section con imagen de fondo -->
<section class="roles-hero py-5">
    <div class="container text-center">
        <i class="fas fa-user-tag fa-4x text-white mb-4"></i>
        <h1 class="display-4 fw-bold mb-3 text-white">Gestión de Roles y Permisos</h1>
        <p class="lead mb-0 text-white">Administra los roles del sistema y sus permisos</p>
    </div>
</section>

<!-- Main Content -->
<section class="py-5 bg-beige">
    <div class="container">
        <!-- Botones de acción -->
        <div class="d-flex flex-wrap justify-content-between align-items-center mb-4">
            <a href="@Url.Action("CrearRol", "Admin")" class="btn btn-green btn-lg">
                <i class="fas fa-plus-circle me-2"></i> Crear Nuevo Rol
            </a>
            <a href="@Url.Action("Dashboard", "Admin")" class="btn btn-outline-green btn-lg">
                <i class="fas fa-arrow-left me-2"></i> Volver al Dashboard
            </a>
        </div>

        <!-- Tarjetas de Roles -->
        <div class="row g-4">
            @if (Model != null && Model.Any())
            {
                foreach (var rol in Model)
                {
                    <div class="col-md-6 col-lg-4">
                        <div class="role-card h-100">
                            <!-- Encabezado de la tarjeta con color según rol -->
                            <div class="role-card-header @(rol.NombreRol == "Administrador" ? "role-admin" :
                                                         rol.NombreRol == "Veterinario" ? "role-veterinario" :
                                                         rol.NombreRol == "Voluntario" ? "role-voluntario" :
                                                         rol.NombreRol == "Usuario" ? "role-user" :
                                                         rol.NombreRol == "Rescatista" ? "role-rescatista" : "bg-green")">
                                <i class="fas @(rol.NombreRol == "Administrador" ? "fa-user-shield" :
                                                  rol.NombreRol == "Veterinario" ? "fa-user-md" :
                                                  rol.NombreRol == "Voluntario" ? "fa-hands-helping" :
                                                  rol.NombreRol == "Usuario" ? "fa-user" :
                                                  rol.NombreRol == "Rescatista" ? "fa-first-aid" : "fa-user-tag") me-2"></i>
                                <h5 class="mb-0">@rol.NombreRol</h5>
                            </div>

                            <!-- Cuerpo de la tarjeta -->
                            <div class="role-card-body">
                                <p class="text-secondary mb-3">
                                    <i class="fas fa-align-left text-green me-2"></i>
                                    @(rol.Descripcion ?? "Sin descripción")
                                </p>

                                <hr class="border-green" />

                                <!-- Información del rol -->
                                <div class="role-info">
                                    <div class="info-item d-flex justify-content-between mb-2">
                                        <span><i class="fas fa-calendar-plus text-green me-2"></i> <strong>Creado:</strong></span>
                                        <span class="text-brown">@(rol.FechaCreacion?.ToString("dd/MM/yyyy") ?? "No registrado")</span>
                                    </div>
                                    <div class="info-item d-flex justify-content-between mb-2">
                                        <span><i class="fas fa-check-circle text-green me-2"></i> <strong>Estado:</strong></span>
                                        <span>
                                            @if (rol.Activo == true)
                                            {
                                                <span class="badge bg-green text-white px-3 py-2">Activo</span>
                                            }
                                            else if (rol.Activo == false)
                                            {
                                                <span class="badge bg-pink text-brown px-3 py-2">Inactivo</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-light-mint text-brown px-3 py-2">No definido</span>
                                            }
                                        </span>
                                    </div>
                                    <div class="info-item d-flex justify-content-between">
                                        <span><i class="fas fa-users text-green me-2"></i> <strong>Usuarios:</strong></span>
                                        <span class="user-count">
                                            @if (ViewBag.UsuariosPorRol != null && ViewBag.UsuariosPorRol.ContainsKey(rol.RolId))
                                            {
                                                @ViewBag.UsuariosPorRol[rol.RolId]
                                            }
                                            else
                                            {
                                                <text>0</text>
                                            }
                                        </span>
                                    </div>
                                </div>
                            </div>

                            <!-- Pie de tarjeta con botones -->
                            <div class="role-card-footer">
                                <div class="row g-2">
                                    <div class="col-6">
                                        <a href="@Url.Action("EditarRol", "Admin", new { id = rol.RolId })"
                                           class="btn btn-yellow w-100">
                                            <i class="fas fa-edit me-1"></i> Editar
                                        </a>
                                    </div>
                                    <div class="col-6">
                                        <a href="@Url.Action("PermisosRol", "Admin", new { id = rol.RolId })"
                                           class="btn btn-pink w-100">
                                            <i class="fas fa-key me-1"></i> Permisos
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <!-- Mensaje cuando no hay roles -->
                <div class="col-12">
                    <div class="alert alert-beige border-green text-center py-5">
                        <i class="fas fa-info-circle fa-4x text-green mb-3"></i>
                        <h4 class="text-brown">No hay roles configurados en el sistema</h4>
                        <p class="text-secondary mb-3">Comienza creando el primer rol del sistema</p>
                        <a href="@Url.Action("CrearRol", "Admin")" class="btn btn-green">
                            <i class="fas fa-plus-circle me-2"></i> Crear Primer Rol
                        </a>
                    </div>
                </div>
            }
        </div>

        <!-- Información adicional sobre roles -->
        <div class="info-card mt-5">
            <div class="info-card-header bg-green text-white">
                <i class="fas fa-info-circle me-2"></i> Información sobre Roles del Sistema
            </div>
            <div class="info-card-body">
                <h6 class="text-brown mb-3">Descripción de roles disponibles:</h6>

                <div class="role-descriptions">
                    <div class="role-desc-item d-flex align-items-start mb-3">
                        <span class="badge bg-pink me-3" style="min-width: 50px;">Admin</span>
                        <div class="text-secondary"><strong class="text-brown">Administrador:</strong> Control total del sistema, gestión de usuarios, mascotas y configuración general.</div>
                    </div>
                    <div class="role-desc-item d-flex align-items-start mb-3">
                        <span class="badge bg-green me-3" style="min-width: 50px;">Vet</span>
                        <div class="text-secondary"><strong class="text-brown">Veterinario:</strong> Gestión de historiales médicos, vacunas, tratamientos y consultas veterinarias.</div>
                    </div>
                    <div class="role-desc-item d-flex align-items-start mb-3">
                        <span class="badge bg-yellow me-3" style="min-width: 50px;">Vol</span>
                        <div class="text-secondary"><strong class="text-brown">Voluntario:</strong> Acceso a actividades de voluntariado, reportes de rescate y cuidado de animales.</div>
                    </div>
                    <div class="role-desc-item d-flex align-items-start mb-3">
                        <span class="badge bg-light-mint border-green text-brown me-3" style="min-width: 50px;">User</span>
                        <div class="text-secondary"><strong class="text-brown">Usuario:</strong> Solicitudes de adopción, donaciones, apadrinamientos y seguimiento de procesos.</div>
                    </div>
                    <div class="role-desc-item d-flex align-items-start">
                        <span class="badge bg-green me-3" style="min-width: 50px;">Resc</span>
                        <div class="text-secondary"><strong class="text-brown">Rescatista:</strong> Reportes de rescate, seguimiento de animales rescatados y coordinación de rescates.</div>
                    </div>
                </div>

                <!-- Nota informativa -->
                <div class="alert alert-beige border-green mt-4">
                    <div class="d-flex">
                        <i class="fas fa-lightbulb fa-2x text-yellow me-3"></i>
                        <div>
                            <strong class="text-brown">Nota:</strong>
                            <span class="text-secondary">
                                Para asignar permisos específicos a cada rol, utiliza la opción "Permisos" en cada tarjeta.
                                Los permisos definen qué acciones puede realizar cada tipo de usuario en el sistema.
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Styles {
    <style>
        /* Hero con imagen de fondo */
        .roles-hero {
            background: linear-gradient(135deg, rgba(151,199,139,0.9), rgba(242,198,109,0.8)), url('https://images.unsplash.com/photo-1551288049-bebda4e38f71?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80');
            background-size: cover;
            background-position: center;
            border-radius: 0 0 30px 30px;
            margin-bottom: 1rem;
        }

        /* Tarjetas de roles */
        .role-card {
            background: white;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 8px 20px rgba(151,199,139,0.15);
            transition: transform 0.3s, box-shadow 0.3s;
            border: none;
            height: 100%;
            display: flex;
            flex-direction: column;
        }

            .role-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 15px 30px rgba(151,199,139,0.25);
            }

        .role-card-header {
            padding: 1rem 1.5rem;
            font-weight: 600;
            display: flex;
            align-items: center;
        }

        .role-card-body {
            padding: 1.5rem;
            flex: 1;
        }

        .role-card-footer {
            padding: 1rem 1.5rem;
            border-top: 2px solid var(--verde-menta);
            background-color: var(--fondo-beige);
        }

        /* Colores de cabecera según rol */
        .role-admin {
            background: linear-gradient(135deg, var(--rosado-pastel) 0%, #f9c2b0 100%);
            color: var(--texto-oscuro);
        }

        .role-veterinario {
            background: linear-gradient(135deg, var(--verde-menta) 0%, #86b57a 100%);
            color: white;
        }

        .role-voluntario {
            background: linear-gradient(135deg, var(--amarillo-pastel) 0%, #e6b85c 100%);
            color: var(--texto-oscuro);
        }

        .role-user {
            background: linear-gradient(135deg, var(--plomo-calido) 0%, #e6d9c3 100%);
            color: var(--texto-oscuro);
        }

        .role-rescatista {
            background: linear-gradient(135deg, var(--rosado-claro) 0%, #f9c2b0 100%);
            color: var(--texto-oscuro);
        }

        /* Badges personalizados */
        .badge.bg-green {
            background-color: var(--verde-menta) !important;
            color: white !important;
        }

        .badge.bg-pink {
            background-color: var(--rosado-claro) !important;
            color: var(--texto-oscuro) !important;
        }

        .badge.bg-yellow {
            background-color: var(--amarillo-pastel) !important;
            color: var(--texto-oscuro) !important;
        }

        .badge.bg-light-mint {
            background-color: var(--plomo-calido) !important;
            color: var(--texto-oscuro) !important;
            border: 1px solid var(--verde-menta);
        }

        /* Contador de usuarios */
        .user-count {
            background-color: rgba(151,199,139,0.1);
            padding: 0.2rem 0.8rem;
            border-radius: 30px;
            font-weight: 600;
            color: var(--texto-oscuro);
        }

        /* Tarjeta de información */
        .info-card {
            background: white;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 8px 20px rgba(151,199,139,0.15);
            border: none;
        }

        .info-card-header {
            padding: 1rem 1.5rem;
            font-weight: 600;
            font-size: 1.1rem;
        }

        .info-card-body {
            padding: 1.5rem;
        }

        /* Descripciones de roles */
        .role-desc-item .badge {
            min-width: 50px;
            text-align: center;
        }

        /* Alertas */
        .alert-beige {
            background-color: var(--fondo-beige);
            border: 1px solid var(--verde-menta);
            color: var(--texto-oscuro);
            border-radius: 16px;
        }

        /* Botones */
        .btn-green {
            background-color: var(--verde-menta);
            border: none;
            border-radius: 50px;
            padding: 0.6rem 2rem;
            font-weight: 600;
            transition: all 0.3s;
        }

            .btn-green:hover {
                background-color: #86b57a;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(151,199,139,0.4);
            }

        .btn-pink {
            background-color: var(--rosado-claro);
            border: none;
            border-radius: 50px;
            padding: 0.6rem 1.5rem;
            font-weight: 600;
            transition: all 0.3s;
            color: var(--texto-oscuro);
        }

            .btn-pink:hover {
                background-color: #f9c2b0;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(249,194,176,0.4);
            }

        .btn-yellow {
            background-color: var(--amarillo-pastel);
            border: none;
            border-radius: 50px;
            padding: 0.6rem 1.5rem;
            font-weight: 600;
            transition: all 0.3s;
            color: var(--texto-oscuro);
        }

            .btn-yellow:hover {
                background-color: #e6b85c;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(242,198,109,0.4);
            }

        .btn-outline-green {
            border: 2px solid var(--verde-menta);
            background: transparent;
            color: var(--verde-menta);
            border-radius: 50px;
            padding: 0.6rem 2rem;
            font-weight: 600;
            transition: all 0.3s;
        }

            .btn-outline-green:hover {
                background-color: var(--verde-menta);
                color: white;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(151,199,139,0.3);
            }

        /* Responsive */
        @@media (max-width: 768px) {
            .role-card-footer .row {
                flex-direction: column;
            }

            .role-card-footer .col-6 {
                width: 100%;
            }

            .btn-lg {
                width: 100%;
                margin-bottom: 0.5rem;
            }
        }
    </style>
}

@section Scripts {
    <script>
        $(document).ready(function () {
            console.log('Vista Gestión de Roles cargada');

            // Efecto hover en tarjetas
            $('.role-card').hover(
                function () { $(this).addClass('shadow-lg'); },
                function () { $(this).removeClass('shadow-lg'); }
            );

            // Notificaciones de TempData
            @if (TempData["SuccessMessage"] != null)
            {
                <text>
                Swal.fire({
                    icon: 'success',
                    title: '¡Éxito!',
                    text: '@Html.Raw(TempData["SuccessMessage"])',
                    confirmButtonColor: '#97C78B',
                    timer: 3000
                });
                </text>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <text>
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: '@Html.Raw(TempData["ErrorMessage"])',
                    confirmButtonColor: '#FBCDC0'
                });
                </text>
            }

            // Confirmación para eliminar rol (si se añade botón de eliminar)
            $('.btn-eliminar-rol').click(function (e) {
                e.preventDefault();
                var rolId = $(this).data('id');
                var rolNombre = $(this).data('nombre');

                Swal.fire({
                    title: '¿Eliminar rol?',
                    html: `<p class="text-brown">¿Está seguro de eliminar el rol <strong>${rolNombre}</strong>?</p>
                          <div class="alert alert-beige border-green mt-2">
                              <small><i class="fas fa-exclamation-circle text-green"></i> Esta acción NO se puede deshacer</small>
                          </div>`,
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#FBCDC0',
                    cancelButtonColor: '#97C78B',
                    confirmButtonText: '<i class="fas fa-trash"></i> Sí, eliminar',
                    cancelButtonText: '<i class="fas fa-times"></i> Cancelar'
                }).then((result) => {
                    if (result.isConfirmed) {
                        window.location.href = '@Url.Action("EliminarRol", "Admin")/' + rolId;
                    }
                });
            });
        });
    </script>
}