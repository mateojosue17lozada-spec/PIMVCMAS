@model MVCMASCOTAS.Models.ViewModels.CrearRolViewModel
@{
    ViewBag.Title = "Crear Nuevo Rol - ADOPTAMANÍA";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Hero Section -->
<section class="role-hero py-4">
    <div class="container text-center">
        <i class="fas fa-plus-circle fa-3x text-green mb-3"></i>
        <h1 class="display-5 fw-bold mb-2 text-brown">Crear Nuevo Rol</h1>
        <p class="lead mb-3 text-secondary">Complete los datos para crear un nuevo rol en el sistema</p>
    </div>
</section>

<!-- Main Content -->
<section class="py-5 bg-beige">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8 col-md-10">
                @{
                    var errorMessage = ViewData["ErrorMessage"] as string;
                    var successMessage = ViewData["SuccessMessage"] as string;
                }

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-beige border-green alert-dismissible fade show mb-4" role="alert">
                        <i class="fas fa-exclamation-circle text-green me-2"></i>
                        <strong class="text-brown">@errorMessage</strong>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                @if (!string.IsNullOrEmpty(successMessage))
                {
                    <div class="alert alert-beige border-green alert-dismissible fade show mb-4" role="alert">
                        <i class="fas fa-check-circle text-green me-2"></i>
                        <strong class="text-brown">@successMessage</strong>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <div class="role-card">
                    <div class="role-card-header bg-green text-white">
                        <i class="fas fa-user-tag me-2"></i> Información del Rol
                    </div>
                    <div class="role-card-body p-4">
                        <form action="@Url.Action("CrearRol", "Admin")" method="post" id="crearRolForm">
                            @Html.AntiForgeryToken()

                            <!-- Mostrar errores de validación -->
                            @if (ViewData.ModelState.Any(x => x.Value.Errors.Count > 0))
                            {
                                <div class="alert alert-beige border-green mb-4">
                                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                    {
                                        <div class="d-flex align-items-center mb-1">
                                            <i class="fas fa-exclamation-circle text-green me-2"></i>
                                            <span class="text-brown">@error.ErrorMessage</span>
                                        </div>
                                    }
                                </div>
                            }

                            <!-- Nombre del Rol -->
                            <div class="form-group mb-4">
                                <label class="form-label text-brown fw-medium" for="NombreRol">
                                    <i class="fas fa-tag text-green me-2"></i> Nombre del Rol
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white border-green">
                                        <i class="fas fa-tag text-green"></i>
                                    </span>
                                    <input type="text" class="form-control border-green"
                                           id="NombreRol" name="NombreRol"
                                           value="@(Model?.NombreRol)"
                                           placeholder="Ej: Rescatista, Supervisor, etc."
                                           maxlength="100"
                                           required />
                                </div>
                                <span class="text-danger small mt-1 field-validation-valid" data-valmsg-for="NombreRol" data-valmsg-replace="true"></span>
                                <small class="form-text text-secondary mt-2">
                                    <i class="fas fa-info-circle text-green me-1"></i> Nombre único del rol (no puede repetirse)
                                </small>
                            </div>

                            <!-- Descripción -->
                            <div class="form-group mb-4">
                                <label class="form-label text-brown fw-medium" for="Descripcion">
                                    <i class="fas fa-align-left text-green me-2"></i> Descripción
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white border-green">
                                        <i class="fas fa-align-left text-green"></i>
                                    </span>
                                    <textarea class="form-control border-green"
                                              id="Descripcion" name="Descripcion"
                                              rows="3"
                                              placeholder="Describa las funciones y permisos de este rol"
                                              maxlength="500">@(Model?.Descripcion)</textarea>
                                </div>
                                <span class="text-danger small mt-1 field-validation-valid" data-valmsg-for="Descripcion" data-valmsg-replace="true"></span>
                                <small class="form-text text-secondary mt-2">
                                    <i class="fas fa-info-circle text-green me-1"></i> Máximo 500 caracteres
                                </small>
                            </div>

                            <!-- Activo -->
                            <div class="form-check mb-4">
                                <input type="checkbox" class="form-check-input" id="chkActivo" name="Activo"
                                       @((Model?.Activo ?? true) ? "checked" : "") value="true" />
                                <label class="form-check-label text-brown" for="chkActivo">
                                    <i class="fas fa-check-circle text-green me-1"></i> Activo
                                </label>
                                <input type="hidden" name="Activo" value="false" />
                                <small class="form-text text-secondary d-block mt-2">
                                    <i class="fas fa-info-circle text-green me-1"></i> Los roles inactivos no pueden asignarse a nuevos usuarios
                                </small>
                            </div>

                            <!-- Información adicional -->
                            <div class="alert alert-beige border-green mb-4">
                                <div class="d-flex align-items-start">
                                    <i class="fas fa-info-circle fa-2x text-green me-3"></i>
                                    <div>
                                        <strong class="text-brown">Información:</strong>
                                        <ul class="list-unstyled text-secondary mt-2">
                                            <li class="mb-1"><i class="fas fa-calendar-alt text-green me-2"></i> Fecha de creación: @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</li>
                                            <li class="mb-1"><i class="fas fa-check text-green me-2"></i> Los roles se crean automáticamente como activos</li>
                                            <li class="mb-1"><i class="fas fa-edit text-green me-2"></i> Puede editar esta configuración después de crear el rol</li>
                                        </ul>
                                    </div>
                                </div>
                            </div>

                            <!-- Botones -->
                            <div class="d-flex flex-column flex-md-row justify-content-between gap-3 mt-4">
                                <a href="@Url.Action("Roles", "Admin")" class="btn btn-outline-green">
                                    <i class="fas fa-arrow-left me-2"></i> Cancelar
                                </a>
                                <button type="submit" class="btn btn-green" id="btnCrearRol">
                                    <i class="fas fa-save me-2"></i> Crear Rol
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Styles {
    <style>
        /* Hero */
        .role-hero {
            background-color: var(--fondo-beige);
            border-radius: 0 0 30px 30px;
            margin-bottom: 1rem;
        }

        /* Tarjeta principal */
        .role-card {
            background: white;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 15px 35px rgba(151,199,139,0.15);
            border: none;
        }

        .role-card-header {
            padding: 1.2rem 1.5rem;
            font-weight: 600;
            font-size: 1.2rem;
        }

        .role-card-body {
            padding: 2rem;
        }

        /* Input groups */
        .input-group-text {
            border-radius: 12px 0 0 12px;
            border-right: none;
            background-color: white;
        }

        .form-control {
            border-radius: 0 12px 12px 0;
            border-left: none;
            padding: 0.75rem 1rem;
            transition: border-color 0.2s, box-shadow 0.2s;
        }

            .form-control:focus {
                border-color: var(--verde-menta);
                box-shadow: 0 0 0 0.2rem rgba(151,199,139,0.25);
                outline: none;
            }

        .input-group:focus-within .input-group-text {
            border-color: var(--verde-menta);
            box-shadow: 0 0 0 0.2rem rgba(151,199,139,0.25);
        }

        /* Checkbox personalizado */
        .form-check-input {
            width: 1.2em;
            height: 1.2em;
            margin-top: 0.2em;
            border: 2px solid var(--verde-menta);
            transition: background-color 0.2s;
        }

            .form-check-input:checked {
                background-color: var(--verde-menta);
                border-color: var(--verde-menta);
            }

            .form-check-input:focus {
                border-color: var(--verde-menta);
                box-shadow: 0 0 0 0.2rem rgba(151,199,139,0.25);
            }

        /* Alertas personalizadas */
        .alert-beige {
            background-color: var(--fondo-beige);
            border: 1px solid var(--verde-menta);
            color: var(--texto-oscuro);
            border-radius: 16px;
        }

        /* Botones */
        .btn-green {
            background-color: var(--verde-menta);
            border: none;
            border-radius: 50px;
            padding: 0.6rem 2rem;
            font-weight: 600;
            transition: all 0.3s;
        }

            .btn-green:hover {
                background-color: #86b57a;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(151,199,139,0.4);
            }

        .btn-outline-green {
            border: 2px solid var(--verde-menta);
            background: transparent;
            color: var(--verde-menta);
            border-radius: 50px;
            padding: 0.6rem 2rem;
            font-weight: 600;
            transition: all 0.3s;
        }

            .btn-outline-green:hover {
                background-color: var(--verde-menta);
                color: white;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(151,199,139,0.3);
            }

        /* Responsive */
        @@media (max-width: 768px) {
            .role-card-body {
                padding: 1.5rem;
            }

            .d-flex.gap-3 {
                flex-direction: column;
            }

            .btn {
                width: 100%;
            }
        }
    </style>
}

@section Scripts {
    <script>
        $(document).ready(function () {
            console.log('Crear Rol page loaded');

            // Auto cerrar alertas después de 5 segundos
            setTimeout(function () {
                $('.alert').fadeOut('slow');
            }, 5000);

            // Validación del formulario
            $('#crearRolForm').submit(function (e) {
                var nombre = $('#NombreRol').val().trim();

                if (nombre === '') {
                    e.preventDefault();
                    Swal.fire({
                        icon: 'error',
                        title: 'Nombre requerido',
                        text: 'Por favor, ingrese un nombre para el rol.',
                        confirmButtonColor: '#97C78B'
                    });
                    $('#NombreRol').focus();
                    return false;
                }

                if (nombre.length < 3) {
                    e.preventDefault();
                    Swal.fire({
                        icon: 'error',
                        title: 'Nombre muy corto',
                        text: 'El nombre del rol debe tener al menos 3 caracteres.',
                        confirmButtonColor: '#97C78B'
                    });
                    $('#NombreRol').focus();
                    return false;
                }

                // Deshabilitar botón y mostrar spinner
                $('#btnCrearRol').prop('disabled', true).html('<i class="fas fa-spinner fa-spin me-2"></i> Creando...');
                return true;
            });

            // Auto-focus en el campo de nombre
            $('#NombreRol').focus();
        });
    </script>
}