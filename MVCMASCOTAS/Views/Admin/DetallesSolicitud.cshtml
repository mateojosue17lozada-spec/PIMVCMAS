@model MVCMASCOTAS.Models.SolicitudAdopcion

@{
    ViewBag.Title = "Detalles de Solicitud";
}

<div class="page-header mb-4">
    <h2><i class="fas fa-file-alt"></i> Detalles de Solicitud #@Model.SolicitudId</h2>
</div>

<div class="row">
    <!-- Información de la Mascota -->
    <div class="col-md-4">
        <div class="card shadow-custom mb-4">
            <div class="card-header bg-primary text-white">
                <h5><i class="fas fa-paw"></i> Mascota</h5>
            </div>
            <div class="card-body text-center">
                @if (ViewBag.MascotaImagen != null)
                {
                    <img src="@ViewBag.MascotaImagen" class="img-fluid rounded mb-3" alt="@Model.Mascotas.Nombre">
                }
                <h4>@Model.Mascotas.Nombre</h4>
                <p class="mb-1">@Model.Mascotas.Especie - @Model.Mascotas.Raza</p>
                <p class="mb-1">@Model.Mascotas.Sexo - @Model.Mascotas.EdadAproximada</p>
                <a href="@Url.Action("Detalle", "Mascotas", new { id = Model.MascotaId })" class="btn btn-info btn-sm">
                    <i class="fas fa-eye"></i> Ver Perfil
                </a>
            </div>
        </div>
    </div>

    <!-- Información del Solicitante -->
    <div class="col-md-4">
        <div class="card shadow-custom mb-4">
            <div class="card-header bg-info text-white">
                <h5><i class="fas fa-user"></i> Solicitante</h5>
            </div>
            <div class="card-body">
                @if (ViewBag.UsuarioImagen != null)
                {
                    <div class="text-center mb-3">
                        <img src="@ViewBag.UsuarioImagen" class="rounded-circle" style="width: 100px; height: 100px; object-fit: cover;" alt="@Model.Usuarios.NombreCompleto">
                    </div>
                }
                <p class="mb-1"><strong>Nombre:</strong> @Model.Usuarios.NombreCompleto</p>
                <p class="mb-1"><strong>Cédula:</strong> @Model.Usuarios.Cedula</p>
                <p class="mb-1"><strong>Email:</strong> @Model.Usuarios.Email</p>
                <p class="mb-1"><strong>Teléfono:</strong> @Model.Usuarios.Telefono</p>
                <p class="mb-1"><strong>Dirección:</strong> @Model.Usuarios.Direccion</p>
            </div>
        </div>
    </div>

    <!-- Estado de la Solicitud -->
    <div class="col-md-4">
        <div class="card shadow-custom mb-4">
            <div class="card-header bg-warning text-white">
                <h5><i class="fas fa-info-circle"></i> Estado</h5>
            </div>
            <div class="card-body">
                <p class="mb-2"><strong>Fecha de Solicitud:</strong><br />@Model.FechaSolicitud.ToString("dd/MM/yyyy HH:mm")</p>
                <p class="mb-2">
                    <strong>Estado Actual:</strong><br />
                    @switch (Model.Estado)
                    {
                        case "Pendiente":
                            <span class="badge badge-warning p-2">Pendiente</span>
                            break;
                        case "En evaluación":
                            <span class="badge badge-info p-2">En Evaluación</span>
                            break;
                        case "Aprobada":
                            <span class="badge badge-success p-2">Aprobada</span>
                            break;
                        case "Rechazada":
                            <span class="badge badge-danger p-2">Rechazada</span>
                            break;
                    }
                </p>

                @if (Model.PuntajeEvaluacion.HasValue)
                {
                    <p class="mb-2">
                        <strong>Puntaje de Evaluación:</strong><br />
                        <span class="badge badge-primary p-2">@Model.PuntajeEvaluacion.Value / 100</span>
                    </p>
                }

                @if (Model.FechaAprobacion.HasValue)
                {
                    <p class="mb-2"><strong>Fecha de Aprobación:</strong><br />@Model.FechaAprobacion.Value.ToString("dd/MM/yyyy")</p>
                }

                @if (!string.IsNullOrEmpty(Model.ObservacionesEvaluador))
                {
                    <div class="alert alert-info mt-3">
                        <strong>Observaciones:</strong><br />
                        @Model.ObservacionesEvaluador
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Formulario de Adopción -->
@if (ViewBag.Formulario != null)
{
    var formulario = ViewBag.Formulario as MVCMASCOTAS.Models.FormularioAdopcionDetalle;

    <div class="card shadow-custom mb-4">
        <div class="card-header">
            <h5><i class="fas fa-clipboard-list"></i> Formulario de Adopción</h5>
        </div>
        <div class="card-body">
            <h6 class="border-bottom pb-2 mb-3">Información de Vivienda</h6>
            <div class="row">
                <div class="col-md-6">
                    <p><strong>Tipo de Vivienda:</strong> @formulario.TipoVivienda</p>
                    <p><strong>Vivienda Propia:</strong> @(formulario.ViviendaPropia == true ? "Sí" : "No")</p>
                    <p><strong>Tiene Jardín:</strong> @(formulario.TieneJardin == true ? "Sí" : "No")</p>
                </div>
                <div class="col-md-6">
                    <p><strong>Permiso para Mascotas:</strong> @(formulario.PermisoMascotas == true ? "Sí" : "No")</p>
                </div>
            </div>

            <h6 class="border-bottom pb-2 mb-3 mt-4">Composición del Hogar</h6>
            <div class="row">
                <div class="col-md-6">
                    <p><strong>Personas en el Hogar:</strong> @formulario.NumeroPersonasHogar</p>
                    <p><strong>Hay Niños:</strong> @(formulario.HayNinos == true ? "Sí" : "No")</p>
                </div>
                <div class="col-md-6">
                    <p><strong>Todos de Acuerdo:</strong> @formulario.TodosDeAcuerdo</p>
                </div>
            </div>

            <h6 class="border-bottom pb-2 mb-3 mt-4">Experiencia con Mascotas</h6>
            <p><strong>Experiencia Previa:</strong> @(formulario.ExperienciaPreviaConMascotas == true ? "Sí" : "No")</p>
            <p><strong>Tiene Mascotas Actualmente:</strong> @(formulario.TieneMascotasActualmente == true ? "Sí" : "No")</p>
            @if (formulario.TieneMascotasActualmente == true && !string.IsNullOrEmpty(formulario.MascotasActualesDescripcion))
            {
                <p><strong>Descripción de Mascotas Actuales:</strong> @formulario.MascotasActualesDescripcion</p>
                <p><strong>Mascotas Esterilizadas:</strong> @(formulario.MascotasEsterilizadas == true ? "Sí" : "No")</p>
            }

            <h6 class="border-bottom pb-2 mb-3 mt-4">Disponibilidad</h6>
            <p><strong>Tiempo Disponible Diario:</strong> @formulario.TiempoDisponibleDiario</p>
            <p><strong>Quién Cuidará:</strong> @formulario.QuienCuidara</p>

            <h6 class="border-bottom pb-2 mb-3 mt-4">Motivación</h6>
            <p><strong>Motivo de Adopción:</strong> @formulario.MotivoAdopcion</p>
            <p><strong>Si Cambia de Residencia:</strong> @formulario.QuePasaSiCambiaResidencia</p>
            <p><strong>Ante Problemas de Comportamiento:</strong> @formulario.QuePasaSiProblemasComportamiento</p>
            <p><strong>Gastos Veterinarios:</strong> @formulario.ComoManejariaGastosVeterinarios</p>

            <h6 class="border-bottom pb-2 mb-3 mt-4">Compromisos</h6>
            <p><strong>Acepta Esterilización:</strong> @(formulario.AceptaEsterilizacion == true ? "✓ Sí" : "✗ No")</p>
            <p><strong>Acepta Visitas de Seguimiento:</strong> @(formulario.AceptaVisitasSeguimiento == true ? "✓ Sí" : "✗ No")</p>
            <p><strong>Acepta Condiciones LOBA:</strong> @(formulario.AceptaCondicionesLOBA == true ? "✓ Sí" : "✗ No")</p>
            <p><strong>Acepta Devolución si No Puede Atender:</strong> @(formulario.AceptaDevolucionSiNoPuedeAtender == true ? "✓ Sí" : "✗ No")</p>
        </div>
    </div>
}

<!-- Acciones -->
@if (Model.Estado == "Pendiente" || Model.Estado == "En evaluación")
{
    <div class="card shadow-custom">
        <div class="card-header bg-success text-white">
            <h5><i class="fas fa-gavel"></i> Evaluar Solicitud</h5>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    @using (Html.BeginForm("AprobarSolicitud", "Admin", FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="solicitudId" value="@Model.SolicitudId" />

                        <div class="form-group">
                            <label>Observaciones</label>
                            <textarea name="observaciones" class="form-control" rows="3"></textarea>
                        </div>

                        <button type="submit" class="btn btn-success btn-lg btn-block">
                            <i class="fas fa-check"></i> Aprobar Solicitud
                        </button>
                    }
                </div>

                <div class="col-md-6">
                    @using (Html.BeginForm("RechazarSolicitud", "Admin", FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="solicitudId" value="@Model.SolicitudId" />

                        <div class="form-group">
                            <label>Motivo de Rechazo *</label>
                            <textarea name="motivoRechazo" class="form-control" rows="3" required></textarea>
                        </div>

                        <button type="submit" class="btn btn-danger btn-lg btn-block">
                            <i class="fas fa-times"></i> Rechazar Solicitud
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
}
