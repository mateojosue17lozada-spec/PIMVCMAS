@model MVCMASCOTAS.Models.ViewModels.EditarRolViewModel
@{
    ViewBag.Title = "Editar Rol - ADOPTAMANÍA";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Hero Section -->
<section class="role-hero py-4">
    <div class="container text-center">
        <i class="fas fa-edit fa-3x text-green mb-3"></i>
        <h1 class="display-5 fw-bold mb-2 text-brown">Editar Rol</h1>
        <p class="lead mb-3 text-secondary">Modifique los datos del rol según sea necesario</p>
    </div>
</section>

<!-- Main Content -->
<section class="py-5 bg-beige">
    <div class="container">
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-beige border-green alert-dismissible fade show mb-4" role="alert">
                <i class="fas fa-exclamation-circle text-green me-2"></i>
                <strong class="text-brown">@TempData["ErrorMessage"]</strong>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-beige border-green alert-dismissible fade show mb-4" role="alert">
                <i class="fas fa-check-circle text-green me-2"></i>
                <strong class="text-brown">@TempData["SuccessMessage"]</strong>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                <!-- Tarjeta principal -->
                <div class="role-card mb-4">
                    <div class="role-card-header bg-green text-white">
                        <i class="fas fa-user-tag me-2"></i> Información del Rol
                    </div>
                    <div class="role-card-body">
                        @using (Html.BeginForm("EditarRol", "Admin", FormMethod.Post))
                        {
                            @Html.AntiForgeryToken()
                            @Html.HiddenFor(model => model.RolId)

                            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                            <!-- Nombre del Rol -->
                            <div class="form-group mb-4">
                                @Html.LabelFor(model => model.NombreRol, new { @class = "form-label text-brown fw-medium" })
                                <div class="input-group">
                                    <span class="input-group-text bg-white border-green">
                                        <i class="fas fa-tag text-green"></i>
                                    </span>
                                    @Html.TextBoxFor(model => model.NombreRol, new
                                    {
                                        @class = "form-control border-green",
                                        maxlength = "100",
                                        placeholder = "Ej: Administrador, Usuario, Moderador"
                                    })
                                </div>
                                @Html.ValidationMessageFor(model => model.NombreRol, "", new { @class = "text-danger small mt-1" })
                                <small class="form-text text-secondary">Nombre único del rol (no puede repetirse)</small>
                            </div>

                            <!-- Descripción -->
                            <div class="form-group mb-4">
                                @Html.LabelFor(model => model.Descripcion, new { @class = "form-label text-brown fw-medium" })
                                <div class="input-group">
                                    <span class="input-group-text bg-white border-green">
                                        <i class="fas fa-align-left text-green"></i>
                                    </span>
                                    @Html.TextAreaFor(model => model.Descripcion, new
                                    {
                                        @class = "form-control border-green",
                                        rows = 4,
                                        maxlength = "500",
                                        placeholder = "Describa las funciones y permisos de este rol..."
                                    })
                                </div>
                                @Html.ValidationMessageFor(model => model.Descripcion, "", new { @class = "text-danger small mt-1" })
                                <small class="form-text text-secondary">Máximo 500 caracteres</small>
                            </div>

                            <!-- Activo (switch) -->
                            <div class="form-group mb-4">
                                <div class="form-check form-switch">
                                    @Html.CheckBoxFor(model => model.Activo, new
                                    {
                                        @class = "form-check-input",
                                        id = "chkActivo",
                                        role = "switch"
                                    })
                                    <label class="form-check-label text-brown" for="chkActivo">
                                        <i class="fas fa-check-circle text-green me-1"></i> Activo
                                    </label>
                                </div>
                                <small class="form-text text-secondary">Los roles inactivos no pueden asignarse a nuevos usuarios</small>
                            </div>

                            <!-- Información adicional -->
                            <div class="alert alert-beige border-green mb-4">
                                <div class="d-flex align-items-start">
                                    <i class="fas fa-info-circle fa-2x text-green me-3"></i>
                                    <div>
                                        <strong class="text-brown">Información del Rol:</strong>
                                        <ul class="list-unstyled text-secondary mt-2">
                                            <li class="mb-1"><i class="fas fa-hashtag text-green me-2"></i> <strong>ID del Rol:</strong> <span class="badge bg-green">@Model.RolId</span></li>
                                            <li class="mb-1"><i class="fas fa-calendar-alt text-green me-2"></i> <strong>Fecha de creación:</strong> @(Model.FechaCreacion?.ToString("dd/MM/yyyy HH:mm") ?? "No registrada")</li>
                                            <li class="mb-1"><i class="fas fa-clock text-green me-2"></i> <strong>Última modificación:</strong> @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</li>
                                        </ul>
                                    </div>
                                </div>
                            </div>

                            <!-- Botones -->
                            <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-3 mt-4 pt-3 border-top border-green">
                                <a href="@Url.Action("Roles", "Admin")" class="btn btn-outline-green">
                                    <i class="fas fa-arrow-left me-2"></i> Volver a la lista
                                </a>
                                <div class="d-flex gap-2">
                                    <button type="button" class="btn btn-yellow" id="btnPreview">
                                        <i class="fas fa-eye me-2"></i> Vista previa
                                    </button>
                                    <button type="submit" class="btn btn-green" id="btnGuardar">
                                        <i class="fas fa-save me-2"></i> Guardar Cambios
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <!-- Panel de vista previa -->
                <div class="preview-card" id="previewPanel" style="display: none;">
                    <div class="preview-card-header bg-pink">
                        <i class="fas fa-eye me-2"></i> Vista Previa del Rol
                    </div>
                    <div class="preview-card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <h6 class="text-brown"><i class="fas fa-tag text-green me-2"></i> Nombre del Rol:</h6>
                                <p id="previewNombre" class="text-secondary preview-content">-</p>
                            </div>
                            <div class="col-md-6">
                                <h6 class="text-brown"><i class="fas fa-toggle-on text-green me-2"></i> Estado:</h6>
                                <p id="previewEstado" class="text-secondary preview-content">-</p>
                            </div>
                        </div>
                        <div class="row mt-3">
                            <div class="col-12">
                                <h6 class="text-brown"><i class="fas fa-align-left text-green me-2"></i> Descripción:</h6>
                                <p id="previewDescripcion" class="text-secondary preview-content">-</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Styles {
    <style>
        /* Hero */
        .role-hero {
            background-color: var(--fondo-beige);
            border-radius: 0 0 30px 30px;
            margin-bottom: 1rem;
        }

        /* Tarjeta principal */
        .role-card {
            background: white;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 15px 35px rgba(151,199,139,0.15);
            border: none;
        }

        .role-card-header {
            padding: 1.2rem 1.5rem;
            font-weight: 600;
            font-size: 1.2rem;
        }

        .role-card-body {
            padding: 2rem;
        }

        /* Input groups */
        .input-group-text {
            border-radius: 12px 0 0 12px;
            border-right: none;
            background-color: white;
        }

        .form-control {
            border-radius: 0 12px 12px 0;
            border-left: none;
            padding: 0.75rem 1rem;
            transition: border-color 0.2s, box-shadow 0.2s;
        }

            .form-control:focus {
                border-color: var(--verde-menta);
                box-shadow: 0 0 0 0.2rem rgba(151,199,139,0.25);
                outline: none;
            }

        .input-group:focus-within .input-group-text {
            border-color: var(--verde-menta);
            box-shadow: 0 0 0 0.2rem rgba(151,199,139,0.25);
        }

        /* Switch personalizado */
        .form-switch .form-check-input {
            width: 3em;
            height: 1.5em;
            margin-top: 0.25em;
            border: 2px solid var(--verde-menta);
            background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='-4 -4 8 8'%3e%3ccircle r='3' fill='%2397C78B'/%3e%3c/svg%3e");
            transition: background-position 0.2s;
            cursor: pointer;
        }

            .form-switch .form-check-input:checked {
                background-color: var(--verde-menta);
                border-color: var(--verde-menta);
                background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='-4 -4 8 8'%3e%3ccircle r='3' fill='%23fff'/%3e%3c/svg%3e");
            }

            .form-switch .form-check-input:focus {
                border-color: var(--verde-menta);
                box-shadow: 0 0 0 0.2rem rgba(151,199,139,0.25);
            }

        /* Alertas personalizadas */
        .alert-beige {
            background-color: var(--fondo-beige);
            border: 1px solid var(--verde-menta);
            color: var(--texto-oscuro);
            border-radius: 16px;
        }

        /* Panel de vista previa */
        .preview-card {
            background: white;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 15px 35px rgba(151,199,139,0.15);
            border: none;
            animation: slideDown 0.3s ease;
        }

        .preview-card-header {
            background-color: var(--rosado-claro);
            color: var(--texto-oscuro);
            padding: 1rem 1.5rem;
            font-weight: 600;
            font-size: 1.1rem;
        }

        .preview-card-body {
            padding: 1.5rem;
        }

        .preview-content {
            background-color: var(--fondo-beige);
            padding: 0.8rem 1rem;
            border-radius: 12px;
            border: 1px solid var(--plomo-calido);
        }

        @@keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Botones */
        .btn-green {
            background-color: var(--verde-menta);
            border: none;
            border-radius: 50px;
            padding: 0.6rem 2rem;
            font-weight: 600;
            transition: all 0.3s;
        }

            .btn-green:hover {
                background-color: #86b57a;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(151,199,139,0.4);
            }

        .btn-yellow {
            background-color: var(--amarillo-pastel);
            border: none;
            border-radius: 50px;
            padding: 0.6rem 2rem;
            font-weight: 600;
            transition: all 0.3s;
            color: var(--texto-oscuro);
        }

            .btn-yellow:hover {
                background-color: #e6b85c;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(242,198,109,0.4);
            }

        .btn-outline-green {
            border: 2px solid var(--verde-menta);
            background: transparent;
            color: var(--verde-menta);
            border-radius: 50px;
            padding: 0.6rem 2rem;
            font-weight: 600;
            transition: all 0.3s;
        }

            .btn-outline-green:hover {
                background-color: var(--verde-menta);
                color: white;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(151,199,139,0.3);
            }

        /* Badge */
        .badge.bg-green {
            background-color: var(--verde-menta);
            color: white;
            font-size: 0.9rem;
            padding: 0.4rem 0.8rem;
            border-radius: 30px;
        }

        /* Responsive */
        @@media (max-width: 768px) {
            .role-card-body {
                padding: 1.5rem;
            }

            .d-flex.flex-md-row {
                flex-direction: column;
            }

            .btn {
                width: 100%;
            }
        }
    </style>
}

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")

    <script>
        $(document).ready(function () {
            console.log('Vista Editar Rol cargada');

            // Auto cerrar alertas después de 5 segundos
            setTimeout(function () {
                $('.alert').alert('close');
            }, 5000);

            // Vista previa del rol
            $('#btnPreview').click(function () {
                var nombre = $('#NombreRol').val().trim();
                var descripcion = $('#Descripcion').val().trim();
                var activo = $('#chkActivo').is(':checked');

                $('#previewNombre').text(nombre || '[Sin nombre]');
                $('#previewDescripcion').text(descripcion || '[Sin descripción]');
                $('#previewEstado').html(activo ?
                    '<span class="badge bg-green">Activo</span>' :
                    '<span class="badge bg-pink">Inactivo</span>');

                $('#previewPanel').slideDown();
            });

            // Validación personalizada al guardar
            $('#btnGuardar').click(function (e) {
                e.preventDefault();
                var nombre = $('#NombreRol').val().trim();
                if (nombre === '') {
                    Swal.fire({
                        icon: 'warning',
                        title: 'Campo requerido',
                        text: 'Por favor, ingrese un nombre para el rol.',
                        confirmButtonColor: '#97C78B',
                        confirmButtonText: 'Entendido'
                    });
                    $('#NombreRol').focus();
                    return false;
                }

                Swal.fire({
                    title: '¿Guardar cambios?',
                    text: "Se actualizará la información del rol en el sistema.",
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonColor: '#97C78B',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Sí, guardar',
                    cancelButtonText: 'Cancelar'
                }).then((result) => {
                    if (result.isConfirmed) {
                        $('form').submit();
                    }
                });
            });
        });
    </script>
}