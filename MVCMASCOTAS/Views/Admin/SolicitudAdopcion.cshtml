@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function () {
            console.log('Vista Gestión de Solicitudes cargada');

            // Inicializar tooltips
            $('[data-toggle="tooltip"]').tooltip({
                trigger: 'hover'
            });

            // Efecto hover en tarjetas
            $('.shadow-hover').hover(
                function () {
                    $(this).addClass('shadow-lg');
                },
                function () {
                    $(this).removeClass('shadow-lg');
                }
            );

            // Efecto hover en estadísticas
            $('.stat-box').hover(
                function () {
                    $(this).css('transform', 'translateY(-5px)');
                },
                function () {
                    $(this).css('transform', 'translateY(0)');
                }
            );

            // Botón APROBAR - Nuevo comportamiento con SweetAlert2
            $('.btn-aprobar').click(function (e) {
                e.preventDefault();

                var solicitudId = $(this).data('solicitud-id');
                var nombreUsuario = $(this).data('nombre-usuario');
                var nombreMascota = $(this).data('nombre-mascota');

                Swal.fire({
                    title: '¿Aprobar solicitud?',
                    html: `
                        <div class="text-left">
                            <p><strong>Solicitante:</strong> ${nombreUsuario || 'N/A'}</p>
                            <p><strong>Mascota:</strong> ${nombreMascota || 'N/A'}</p>
                            <p class="mt-3">Al aprobar la solicitud:</p>
                            <ul class="text-left">
                                <li>✓ Estado cambiará a <span class="badge bg-green">Aprobada</span></li>
                                <li>✓ Adopción pasará a <span class="badge bg-info">Programada</span></li>
                                <li>✓ Se registrará fecha de respuesta</li>
                            </ul>
                        </div>
                    `,
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonColor: '#97C78B',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: '<i class="fa fa-check"></i> Sí, aprobar',
                    cancelButtonText: '<i class="fa fa-times"></i> Cancelar',
                    showClass: {
                        popup: 'animate__animated animate__fadeInDown'
                    },
                    hideClass: {
                        popup: 'animate__animated animate__fadeOutUp'
                    }
                }).then((result) => {
                    if (result.isConfirmed) {
                        // Mostrar loading
                        Swal.fire({
                            title: 'Aprobando solicitud...',
                            allowOutsideClick: false,
                            didOpen: () => {
                                Swal.showLoading();
                            }
                        });

                        // Llamada AJAX para aprobar
                        $.ajax({
                            url: '@Url.Action("AprobarSolicitud", "Admin")',
                            type: 'POST',
                            data: { id: solicitudId },
                            success: function (response) {
                                if (response.success) {
                                    Swal.fire({
                                        icon: 'success',
                                        title: '¡Solicitud aprobada!',
                                        html: `
                                            <p>${response.message}</p>
                                            <p class="mt-2">
                                                <span class="badge bg-green">Estado: Aprobada</span>
                                                <span class="badge bg-info">Adopción: Programada</span>
                                            </p>
                                        `,
                                        confirmButtonColor: '#97C78B',
                                        timer: 3000
                                    }).then(() => {
                                        // Recargar la página
                                        location.reload();
                                    });
                                } else {
                                    Swal.fire({
                                        icon: 'error',
                                        title: 'Error',
                                        text: response.message,
                                        confirmButtonColor: '#FBCDC0'
                                    });
                                }
                            },
                            error: function () {
                                Swal.fire({
                                    icon: 'error',
                                    title: 'Error',
                                    text: 'Ocurrió un error al aprobar la solicitud',
                                    confirmButtonColor: '#FBCDC0'
                                });
                            }
                        });
                    }
                });
            });

            // Botón RECHAZAR - Confirmación con SweetAlert2
            $('.btn-rechazar').click(function (e) {
                e.preventDefault();
                var href = $(this).attr('href');

                Swal.fire({
                    title: '¿Rechazar solicitud?',
                    text: 'Esta acción cambiará el estado de la solicitud a Rechazada',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#FBCDC0',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: '<i class="fa fa-times"></i> Sí, rechazar',
                    cancelButtonText: 'Cancelar',
                    showClass: {
                        popup: 'animate__animated animate__fadeInDown'
                    },
                    hideClass: {
                        popup: 'animate__animated animate__fadeOutUp'
                    }
                }).then((result) => {
                    if (result.isConfirmed) {
                        window.location.href = href;
                    }
                });
            });

            // Botón AVANZAR ESTADO DE ADOPCIÓN
            $('.btn-avanzar-adopcion').click(function (e) {
                e.preventDefault();

                var solicitudId = $(this).data('solicitud-id');
                var estadoDestino = $(this).data('estado-destino');

                // Texto según el estado destino
                var textoEstado = '';
                var iconoEstado = '';
                var colorEstado = '';

                switch(estadoDestino) {
                    case 'Programada':
                        textoEstado = 'Programar entrega';
                        iconoEstado = 'fa-calendar-check';
                        colorEstado = '#17a2b8';
                        break;
                    case 'Entregada':
                        textoEstado = 'Confirmar entrega';
                        iconoEstado = 'fa-home';
                        colorEstado = '#007bff';
                        break;
                    case 'En seguimiento':
                        textoEstado = 'Iniciar seguimiento';
                        iconoEstado = 'fa-phone-alt';
                        colorEstado = '#ffc107';
                        break;
                    case 'Finalizada':
                        textoEstado = 'Finalizar adopción';
                        iconoEstado = 'fa-check-double';
                        colorEstado = '#28a745';
                        break;
                    case 'Cancelada':
                        textoEstado = 'Cancelar proceso';
                        iconoEstado = 'fa-ban';
                        colorEstado = '#dc3545';
                        break;
                    default:
                        textoEstado = 'Avanzar';
                        iconoEstado = 'fa-paw';
                        colorEstado = '#97C78B';
                }

                $('#mensajeAvance').html(`
                    <div class="text-center">
                        <i class="fa ${iconoEstado} fa-3x mb-3" style="color: ${colorEstado};"></i>
                        <h5>${textoEstado}</h5>
                        <p>¿Está seguro de cambiar el estado de adopción a <strong>${estadoDestino}</strong>?</p>
                    </div>
                `);

                $('#btnConfirmarAvance').attr('href', '@Url.Action("AvanzarEstadoAdopcion", "Admin")?id=' + solicitudId + '&estadoDestino=' + encodeURIComponent(estadoDestino));
                $('#btnConfirmarAvance').attr('data-estado-destino', estadoDestino);

                // Cambiar color del botón según estado
                $('#btnConfirmarAvance').removeClass('btn-info btn-success btn-primary btn-warning btn-danger');
                if (estadoDestino === 'Programada') $('#btnConfirmarAvance').addClass('btn-info');
                else if (estadoDestino === 'Entregada') $('#btnConfirmarAvance').addClass('btn-primary');
                else if (estadoDestino === 'En seguimiento') $('#btnConfirmarAvance').addClass('btn-warning');
                else if (estadoDestino === 'Finalizada') $('#btnConfirmarAvance').addClass('btn-success');
                else if (estadoDestino === 'Cancelada') $('#btnConfirmarAvance').addClass('btn-danger');
                else $('#btnConfirmarAvance').addClass('btn-info');

                $('#modalAvanceAdopcion').modal('show');
            });

            // Confirmar avance de adopción
            $('#btnConfirmarAvance').click(function(e) {
                e.preventDefault();
                var href = $(this).attr('href');
                var estadoDestino = $(this).data('estado-destino');

                $('#modalAvanceAdopcion').modal('hide');

                // Mostrar loading
                Swal.fire({
                    title: 'Actualizando estado...',
                    allowOutsideClick: false,
                    didOpen: () => {
                        Swal.showLoading();
                    }
                });

                // Llamada AJAX
                $.ajax({
                    url: href,
                    type: 'POST',
                    success: function (response) {
                        if (response.success) {
                            Swal.fire({
                                icon: 'success',
                                title: '¡Estado actualizado!',
                                text: response.message,
                                confirmButtonColor: '#97C78B',
                                timer: 2000
                            }).then(() => {
                                location.reload();
                            });
                        } else {
                            Swal.fire({
                                icon: 'error',
                                title: 'Error',
                                text: response.message,
                                confirmButtonColor: '#FBCDC0'
                            });
                        }
                    },
                    error: function () {
                        Swal.fire({
                            icon: 'error',
                            title: 'Error',
                            text: 'Ocurrió un error al actualizar el estado',
                            confirmButtonColor: '#FBCDC0'
                        });
                    }
                });
            });

            // Botón ENVIAR PASOS AL ADOPTANTE
            $('.btn-enviar-pasos').click(function (e) {
                e.preventDefault();

                var solicitudId = $(this).data('solicitud-id');
                var nombreUsuario = $(this).data('nombre-usuario');
                var emailUsuario = $(this).data('email-usuario');
                var nombreMascota = $(this).data('nombre-mascota');

                // Actualizar modal
                $('#modalEnviarPasos').data('solicitud-id', solicitudId);
                $('#modalEnviarPasos').data('email-usuario', emailUsuario);

                $('#mensajeSaludo').html(`Hola ${nombreUsuario || 'adoptante'},`);

                // Configurar fecha por defecto (7 días después)
                var today = new Date();
                var nextWeek = new Date(today);
                nextWeek.setDate(today.getDate() + 7);

                var year = nextWeek.getFullYear();
                var month = String(nextWeek.getMonth() + 1).padStart(2, '0');
                var day = String(nextWeek.getDate()).padStart(2, '0');
                var formattedDate = `${year}-${month}-${day}`;
                var formattedDateDisplay = `${day}/${month}/${year}`;

                $('#fechaEntrega').val(formattedDate);
                $('#fechaEntregaTexto').text(formattedDateDisplay);

                $('#simulacionEnvio').hide();
                $('#modalEnviarPasos').modal('show');
            });

            // Actualizar fecha de entrega en tiempo real
            $('#fechaEntrega').change(function() {
                var fechaValue = $(this).val();
                if (fechaValue) {
                    var partes = fechaValue.split('-');
                    var fechaFormateada = `${partes[2]}/${partes[1]}/${partes[0]}`;
                    $('#fechaEntregaTexto').text(fechaFormateada);
                }
            });

            // Confirmar envío de pasos
            $('#btnConfirmarEnvio').click(function() {
                var solicitudId = $('#modalEnviarPasos').data('solicitud-id');
                var emailUsuario = $('#modalEnviarPasos').data('email-usuario');
                var fechaEntrega = $('#fechaEntrega').val();

                // Formatear fecha para mostrar
                var fechaFormateada = '';
                if (fechaEntrega) {
                    var partes = fechaEntrega.split('-');
                    fechaFormateada = `${partes[2]}/${partes[1]}/${partes[0]}`;
                }

                // Simular envío (AJAX)
                $.ajax({
                    url: '@Url.Action("EnviarPasosAdoptante", "Admin")',
                    type: 'POST',
                    data: {
                        solicitudId: solicitudId,
                        fechaEntrega: fechaEntrega
                    },
                    success: function(response) {
                        if (response.success) {
                            $('#simulacionEnvio').show();
                            $('#mensajeSimulacion').html(`
                                ✅ Mensaje enviado a ${emailUsuario || 'adoptante'}<br>
                                Fecha de entrega propuesta: ${fechaFormateada}<br>
                                Se han enviado los pasos a seguir y el contrato de adopción.
                            `);

                            setTimeout(function() {
                                $('#modalEnviarPasos').modal('hide');
                                Swal.fire({
                                    icon: 'success',
                                    title: '¡Mensaje enviado!',
                                    text: response.message,
                                    confirmButtonColor: '#97C78B',
                                    timer: 3000
                                });
                            }, 2000);
                        } else {
                            Swal.fire({
                                icon: 'error',
                                title: 'Error',
                                text: response.message,
                                confirmButtonColor: '#FBCDC0'
                            });
                        }
                    },
                    error: function() {
                        // Simular éxito para demostración
                        $('#simulacionEnvio').show();
                        $('#mensajeSimulacion').html(`
                            ✅ Mensaje enviado a ${emailUsuario || 'adoptante'}<br>
                            Fecha de entrega propuesta: ${fechaFormateada}<br>
                            Se han enviado los pasos a seguir y el contrato de adopción.
                        `);

                        setTimeout(function() {
                            $('#modalEnviarPasos').modal('hide');
                            Swal.fire({
                                icon: 'success',
                                title: '¡Mensaje enviado!',
                                text: 'Los pasos han sido enviados al adoptante exitosamente.',
                                confirmButtonColor: '#97C78B',
                                timer: 3000
                            });
                        }, 2000);
                    }
                });
            });

            // Notificaciones de TempData con SweetAlert2
            @if (TempData["SuccessMessage"] != null)
            {
                <text>
                Swal.fire({
                    icon: 'success',
                    title: '¡Éxito!',
                    text: '@Html.Raw(TempData["SuccessMessage"])',
                    confirmButtonColor: '#97C78B',
                    timer: 3000
                });
                </text>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <text>
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: '@Html.Raw(TempData["ErrorMessage"])',
                    confirmButtonColor: '#FBCDC0'
                });
                </text>
            }

            // Auto cerrar alertas
            setTimeout(function () {
                $('.alert').alert('close');
            }, 5000);
        });
    </script>
}