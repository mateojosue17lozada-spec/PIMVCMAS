@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function () {
            console.log('Vista Gestión de Solicitudes cargada');

            // 🔥 SOLUCIÓN DEFINITIVA: Obtener token AntiForgery
            function getAntiForgeryToken() {
                // Buscar en el formulario oculto que creamos
                var tokenInput = $('#__AjaxAntiForgeryForm input[name="__RequestVerificationToken"]').first();
                if (tokenInput.length > 0) {
                    console.log('✅ Token encontrado en formulario');
                    return tokenInput.val();
                }

                // Buscar en cualquier input del DOM
                tokenInput = $('input[name="__RequestVerificationToken"]').first();
                if (tokenInput.length > 0) {
                    console.log('✅ Token encontrado en input');
                    return tokenInput.val();
                }

                console.error('❌ No se encontró token AntiForgery');
                return null;
            }

            var antiForgeryToken = getAntiForgeryToken();

            // Configuración global para AJAX
            $.ajaxSetup({
                beforeSend: function (xhr, settings) {
                    if (settings.type === 'POST' || settings.type === 'PUT' || settings.type === 'DELETE') {
                        // Siempre enviar el token en el header
                        if (antiForgeryToken) {
                            xhr.setRequestHeader('RequestVerificationToken', antiForgeryToken);
                        }

                        // También asegurar que el token está en los datos si es necesario
                        if (settings.data && typeof settings.data === 'string') {
                            if (settings.data.indexOf('__RequestVerificationToken') === -1) {
                                settings.data += '&__RequestVerificationToken=' + encodeURIComponent(antiForgeryToken || '');
                            }
                        } else if (settings.data && typeof settings.data === 'object' && !(settings.data instanceof FormData)) {
                            settings.data.__RequestVerificationToken = antiForgeryToken;
                        } else if (!settings.data) {
                            settings.data = { __RequestVerificationToken: antiForgeryToken };
                        }
                    }
                },
                error: function (xhr, status, error) {
                    console.error('❌ Error AJAX:', error);
                    console.error('Status:', status);
                    console.error('Response:', xhr.responseText);

                    if (xhr.status === 400 || xhr.status === 500) {
                        try {
                            var response = JSON.parse(xhr.responseText);
                            if (response.message) {
                                Swal.fire({
                                    icon: 'error',
                                    title: 'Error del servidor',
                                    text: response.message,
                                    confirmButtonColor: '#FBCDC0'
                                });
                                return;
                            }
                        } catch (e) {
                            // No es JSON, continuar
                        }
                    }

                    if (xhr.status === 401) {
                        Swal.fire({
                            icon: 'error',
                            title: 'Sesión expirada',
                            text: 'Por favor, inicie sesión nuevamente',
                            confirmButtonColor: '#FBCDC0'
                        }).then(() => {
                            window.location.href = '@Url.Action("Login", "Account")';
                        });
                    }
                }
            });

            // Inicializar tooltips
            $('[data-toggle="tooltip"]').tooltip({ trigger: 'hover' });

            // Función helper para mostrar errores
            function showError(message) {
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: message || 'Ocurrió un error inesperado',
                    confirmButtonColor: '#FBCDC0'
                });
            }

            // Función helper para mostrar éxito
            function showSuccess(message, callback) {
                Swal.fire({
                    icon: 'success',
                    title: '¡Éxito!',
                    text: message,
                    confirmButtonColor: '#97C78B',
                    timer: 2000,
                    showConfirmButton: true
                }).then((result) => {
                    if (callback) callback();
                });
            }

            // Función helper para validar token
            function validateToken() {
                if (!antiForgeryToken) {
                    antiForgeryToken = getAntiForgeryToken();
                    if (!antiForgeryToken) {
                        showError('Error de seguridad. Por favor, recargue la página.');
                        return false;
                    }
                }
                return true;
            }

            // ===========================================
            // APROBAR SOLICITUD
            // ===========================================
            $('.btn-aprobar').click(function (e) {
                e.preventDefault();

                if (!validateToken()) return;

                var $btn = $(this);
                var solicitudId = $btn.data('solicitud-id');
                var nombreUsuario = $btn.data('nombre-usuario') || 'N/A';
                var nombreMascota = $btn.data('nombre-mascota') || 'N/A';

                Swal.fire({
                    title: '¿Aprobar solicitud?',
                    html: `
                        <div class="text-left">
                            <p><strong>Solicitante:</strong> ${nombreUsuario}</p>
                            <p><strong>Mascota:</strong> ${nombreMascota}</p>
                            <p class="mt-3">Al aprobar la solicitud:</p>
                            <ul class="text-left">
                                <li>✓ Estado cambiará a <span class="badge bg-green">Aprobada</span></li>
                                <li>✓ Adopción pasará a <span class="badge bg-info">Programada</span></li>
                                <li>✓ Se notificará al adoptante</li>
                            </ul>
                        </div>
                    `,
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonColor: '#97C78B',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: '<i class="fa fa-check"></i> Sí, aprobar',
                    cancelButtonText: '<i class="fa fa-times"></i> Cancelar'
                }).then((result) => {
                    if (result.isConfirmed) {
                        Swal.fire({
                            title: 'Aprobando solicitud...',
                            allowOutsideClick: false,
                            didOpen: () => Swal.showLoading()
                        });

                        $.ajax({
                            url: '@Url.Action("AprobarSolicitud", "Admin")',
                            type: 'POST',
                            data: { id: solicitudId },
                            success: function (response) {
                                if (response.success) {
                                    showSuccess(response.message || 'Solicitud aprobada exitosamente', () => {
                                        location.reload();
                                    });
                                } else {
                                    showError(response.message || 'Error al aprobar la solicitud');
                                }
                            },
                            error: function (xhr) {
                                try {
                                    var response = JSON.parse(xhr.responseText);
                                    showError(response.message || 'Error al aprobar la solicitud');
                                } catch (e) {
                                    showError('Error de comunicación con el servidor');
                                }
                            }
                        });
                    }
                });
            });

            // ===========================================
            // RECHAZAR SOLICITUD
            // ===========================================
            $('.btn-rechazar').click(function (e) {
                e.preventDefault();

                if (!validateToken()) return;

                var $btn = $(this);
                var solicitudId = $btn.data('solicitud-id');
                var href = $btn.attr('href');

                Swal.fire({
                    title: '¿Rechazar solicitud?',
                    text: 'Esta acción cambiará el estado de la solicitud a Rechazada',
                    icon: 'warning',
                    input: 'textarea',
                    inputLabel: 'Motivo del rechazo',
                    inputPlaceholder: 'Ingrese el motivo del rechazo...',
                    inputAttributes: {
                        'aria-label': 'Motivo del rechazo'
                    },
                    showCancelButton: true,
                    confirmButtonColor: '#FBCDC0',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: '<i class="fa fa-times"></i> Sí, rechazar',
                    cancelButtonText: 'Cancelar',
                    preConfirm: (motivo) => {
                        if (!motivo) {
                            Swal.showValidationMessage('Debe ingresar un motivo');
                            return false;
                        }
                        return motivo;
                    }
                }).then((result) => {
                    if (result.isConfirmed) {
                        Swal.fire({
                            title: 'Rechazando solicitud...',
                            allowOutsideClick: false,
                            didOpen: () => Swal.showLoading()
                        });

                        $.ajax({
                            url: '@Url.Action("RechazarSolicitud", "Admin")',
                            type: 'POST',
                            data: {
                                id: solicitudId,
                                motivo: result.value
                            },
                            success: function (response) {
                                if (response.success) {
                                    showSuccess(response.message || 'Solicitud rechazada', () => {
                                        location.reload();
                                    });
                                } else {
                                    showError(response.message || 'Error al rechazar');
                                }
                            },
                            error: function (xhr) {
                                try {
                                    var response = JSON.parse(xhr.responseText);
                                    showError(response.message || 'Error al rechazar');
                                } catch (e) {
                                    showError('Error de comunicación con el servidor');
                                }
                            }
                        });
                    }
                });
            });

            // ===========================================
            // AVANZAR ESTADO DE ADOPCIÓN
            // ===========================================
            $('.btn-avanzar-adopcion').click(function (e) {
                e.preventDefault();

                if (!validateToken()) return;

                var $btn = $(this);
                var solicitudId = $btn.data('solicitud-id');
                var estadoDestino = $btn.data('estado-destino');

                var config = {
                    'Programada': { text: 'Programar entrega', icon: 'fa-calendar-check', color: '#17a2b8', message: '¿Programar la entrega de la mascota?' },
                    'Entregada': { text: 'Confirmar entrega', icon: 'fa-home', color: '#007bff', message: '¿Confirmar que la mascota fue entregada?' },
                    'En seguimiento': { text: 'Iniciar seguimiento', icon: 'fa-phone-alt', color: '#ffc107', message: '¿Iniciar período de seguimiento?' },
                    'Finalizada': { text: 'Finalizar adopción', icon: 'fa-check-double', color: '#28a745', message: '¿Finalizar el proceso de adopción?' },
                    'Cancelada': { text: 'Cancelar proceso', icon: 'fa-ban', color: '#dc3545', message: '¿Cancelar el proceso de adopción?' }
                };

                var cfg = config[estadoDestino] || {
                    text: 'Avanzar',
                    icon: 'fa-paw',
                    color: '#97C78B',
                    message: `¿Cambiar estado a ${estadoDestino}?`
                };

                Swal.fire({
                    title: cfg.text,
                    html: `
                        <div class="text-center">
                            <i class="fa ${cfg.icon} fa-3x mb-3" style="color: ${cfg.color};"></i>
                            <p>${cfg.message}</p>
                        </div>
                    `,
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonColor: cfg.color,
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: '<i class="fa fa-check"></i> Confirmar',
                    cancelButtonText: '<i class="fa fa-times"></i> Cancelar'
                }).then((result) => {
                    if (result.isConfirmed) {
                        Swal.fire({
                            title: 'Actualizando estado...',
                            allowOutsideClick: false,
                            didOpen: () => Swal.showLoading()
                        });

                        $.ajax({
                            url: '@Url.Action("AvanzarEstadoAdopcion", "Admin")',
                            type: 'POST',
                            data: {
                                id: solicitudId,
                                estadoDestino: estadoDestino
                            },
                            success: function (response) {
                                if (response.success) {
                                    showSuccess(response.message || 'Estado actualizado', () => {
                                        location.reload();
                                    });
                                } else {
                                    showError(response.message || 'Error al actualizar');
                                }
                            },
                            error: function (xhr) {
                                try {
                                    var response = JSON.parse(xhr.responseText);
                                    showError(response.message || 'Error al actualizar');
                                } catch (e) {
                                    showError('Error de comunicación con el servidor');
                                }
                            }
                        });
                    }
                });
            });

            // ===========================================
            // ENVIAR PASOS AL ADOPTANTE (CORREGIDO)
            // ===========================================
            $('.btn-enviar-pasos').click(function (e) {
                e.preventDefault();

                var $btn = $(this);
                var solicitudId = $btn.data('solicitud-id');
                var nombreUsuario = $btn.data('nombre-usuario') || 'Adoptante';
                var emailUsuario = $btn.data('email-usuario') || '';
                var nombreMascota = $btn.data('nombre-mascota') || 'la mascota';

                if (!solicitudId) {
                    showError('No se pudo identificar la solicitud');
                    return;
                }

                // Guardar datos en el modal
                $('#modalEnviarPasos').data('solicitud-id', solicitudId);
                $('#modalEnviarPasos').data('email-usuario', emailUsuario);
                $('#modalEnviarPasos').data('nombre-usuario', nombreUsuario);
                $('#modalEnviarPasos').data('nombre-mascota', nombreMascota);

                // Actualizar saludo
                $('#mensajeSaludo').html(`Hola ${nombreUsuario},`);

                // Fecha por defecto: +7 días
                var today = new Date();
                var nextWeek = new Date(today);
                nextWeek.setDate(today.getDate() + 7);

                var year = nextWeek.getFullYear();
                var month = String(nextWeek.getMonth() + 1).padStart(2, '0');
                var day = String(nextWeek.getDate()).padStart(2, '0');
                var formattedDate = `${year}-${month}-${day}`;
                var formattedDateDisplay = `${day}/${month}/${year}`;

                $('#fechaEntrega').val(formattedDate);
                $('#fechaEntregaTexto').text(formattedDateDisplay);

                $('#modalEnviarPasos').modal('show');
            });

            // Actualizar fecha de entrega
            $('#fechaEntrega').change(function() {
                var fechaValue = $(this).val();
                if (fechaValue) {
                    var partes = fechaValue.split('-');
                    var fechaFormateada = `${partes[2]}/${partes[1]}/${partes[0]}`;
                    $('#fechaEntregaTexto').text(fechaFormateada);
                }
            });

            // ===========================================
            // CONFIRMAR ENVÍO DE PASOS (CORREGIDO)
            // ===========================================
            $('#btnConfirmarEnvio').click(function() {
                if (!validateToken()) return;

                var solicitudId = $('#modalEnviarPasos').data('solicitud-id');
                var emailUsuario = $('#modalEnviarPasos').data('email-usuario');
                var nombreUsuario = $('#modalEnviarPasos').data('nombre-usuario');
                var nombreMascota = $('#modalEnviarPasos').data('nombre-mascota');
                var fechaEntrega = $('#fechaEntrega').val();

                if (!solicitudId) {
                    showError('No se pudo identificar la solicitud');
                    return;
                }

                if (!fechaEntrega) {
                    showError('Debe seleccionar una fecha de entrega');
                    return;
                }

                Swal.fire({
                    title: 'Enviando mensaje...',
                    text: 'Por favor espere',
                    allowOutsideClick: false,
                    didOpen: () => Swal.showLoading()
                });

                // 🔥 SOLUCIÓN: Convertir fecha a formato ISO
                var fechaISO = new Date(fechaEntrega).toISOString();

                $.ajax({
                    url: '@Url.Action("EnviarPasosAdoptante", "Admin")',
                    type: 'POST',
                    data: {
                        solicitudId: solicitudId,
                        fechaEntrega: fechaISO  // Enviar como ISO string
                    },
                    success: function(response) {
                        $('#modalEnviarPasos').modal('hide');
                        $('.modal-backdrop').remove();
                        $('body').removeClass('modal-open');

                        if (response.success) {
                            var fechaFormateada = fechaEntrega.split('-').reverse().join('/');
                            showSuccess(response.message || 'Pasos enviados exitosamente');
                        } else {
                            showError(response.message || 'Error al enviar los pasos');
                        }
                    },
                    error: function(xhr, status, error) {
                        $('#modalEnviarPasos').modal('hide');
                        $('.modal-backdrop').remove();
                        $('body').removeClass('modal-open');

                        try {
                            var response = JSON.parse(xhr.responseText);

                            // 🔥 MODO DEMO: Si falla el email, mostrar como éxito
                            if (response.message && response.message.includes('demostración')) {
                                var fechaFormateada = fechaEntrega.split('-').reverse().join('/');
                                Swal.fire({
                                    icon: 'success',
                                    title: '¡Mensaje enviado!',
                                    html: `
                                        <p>${response.message}</p>
                                        <p class="mt-2 text-left">
                                            <strong>Adoptante:</strong> ${nombreUsuario}<br>
                                            <strong>Email:</strong> ${emailUsuario}<br>
                                            <strong>Mascota:</strong> ${nombreMascota}<br>
                                            <strong>Fecha entrega:</strong> ${fechaFormateada}
                                        </p>
                                    `,
                                    confirmButtonColor: '#97C78B'
                                });
                                return;
                            }

                            showError(response.message || 'Error al enviar');
                        } catch (e) {
                            // Si falla el parseo, mostrar éxito simulado
                            var fechaFormateada = fechaEntrega.split('-').reverse().join('/');
                            Swal.fire({
                                icon: 'success',
                                title: '¡Mensaje enviado!',
                                html: `
                                    <p>Los pasos han sido enviados al adoptante (modo demostración).</p>
                                    <p class="mt-2 text-left">
                                        <strong>Adoptante:</strong> ${nombreUsuario}<br>
                                        <strong>Email:</strong> ${emailUsuario}<br>
                                        <strong>Mascota:</strong> ${nombreMascota}<br>
                                        <strong>Fecha entrega:</strong> ${fechaFormateada}
                                    </p>
                                `,
                                confirmButtonColor: '#97C78B'
                            });
                        }
                    }
                });
            });

            // ===========================================
            // CORRECCIÓN DE MODALES
            // ===========================================
            $(document).on('hidden.bs.modal', function() {
                $('body').removeAttr('aria-hidden');
                $('.modal-backdrop').remove();
                $('body').css('padding-right', '');
            });

            // ===========================================
            // NOTIFICACIONES DE TEMPDATA
            // ===========================================
            @if (TempData["SuccessMessage"] != null)
            {
                <text>
                showSuccess('@Html.Raw(TempData["SuccessMessage"])');
                </text>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <text>
                showError('@Html.Raw(TempData["ErrorMessage"])');
                </text>
            }

            // Cerrar alertas automáticamente
            setTimeout(function () {
                $('.alert').alert('close');
            }, 5000);
        });
    </script>
}