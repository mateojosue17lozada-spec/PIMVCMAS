@model IEnumerable<MVCMASCOTAS.Models.SolicitudAdopcion>

@{
    ViewBag.Title = "Gestión de Solicitudes de Adopción";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <!-- Encabezado -->
    <div class="page-header mb-4 fade-in-up">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h1 class="h3 mb-0 text-brown">
                    <i class="fa fa-file-alt text-green"></i> Solicitudes de Adopción
                </h1>
                <p class="text-secondary mb-0">Gestiona todas las solicitudes de adopción del sistema</p>
            </div>
            <div>
                <a href="@Url.Action("Dashboard", "Admin")" class="btn btn-outline-green btn-sm">
                    <i class="fa fa-arrow-left"></i> Dashboard
                </a>
            </div>
        </div>
    </div>

    <!-- Estadísticas rápidas -->
    <div class="row mb-4">
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card stat-box border-green">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-green text-uppercase mb-1">
                                Pendientes
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-brown">
                                @ViewBag.SolicitudesPendientes
                            </div>
                        </div>
                        <div class="col-auto">
                            <i class="fa fa-clock fa-2x text-yellow"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card stat-box border-green">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-green text-uppercase mb-1">
                                En Evaluación
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-brown">
                                @ViewBag.SolicitudesEvaluacion
                            </div>
                        </div>
                        <div class="col-auto">
                            <i class="fa fa-search fa-2x text-pink"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card stat-box border-green">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-green text-uppercase mb-1">
                                Adopciones Activas
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-brown">
                                @ViewBag.AdopcionesActivas
                            </div>
                        </div>
                        <div class="col-auto">
                            <i class="fa fa-heart fa-2x text-green"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card stat-box border-green">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-green text-uppercase mb-1">
                                Finalizadas
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-brown">
                                @ViewBag.AdopcionesFinalizadas
                            </div>
                        </div>
                        <div class="col-auto">
                            <i class="fa fa-check-double fa-2x text-green"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Filtros -->
    <div class="card shadow-hover border-green mb-4">
        <div class="card-header py-3 d-flex justify-content-between align-items-center bg-green text-white">
            <h6 class="m-0 font-weight-bold">
                <i class="fa fa-filter"></i> Filtros de Búsqueda
            </h6>
            <div>
                <span class="badge bg-light-mint text-brown">Mostrando @ViewBag.TotalItems solicitudes</span>
            </div>
        </div>
        <div class="card-body bg-light-mint">
            @using (Html.BeginForm("SolicitudAdopcionFiltrada", "Admin", FormMethod.Get, new { @class = "form-inline" }))
            {
                <div class="form-group mr-2 mb-2">
                    <label class="mr-2 text-brown">Estado Solicitud:</label>
                    @{
                        var estados = new List<SelectListItem>
                                                {
                            new SelectListItem { Text = "Todos", Value = "Todos", Selected = ViewBag.EstadoSeleccionado == "Todos" || string.IsNullOrEmpty(ViewBag.EstadoSeleccionado) },
                            new SelectListItem { Text = "Pendiente", Value = "Pendiente", Selected = ViewBag.EstadoSeleccionado == "Pendiente" },
                            new SelectListItem { Text = "En evaluación", Value = "En evaluación", Selected = ViewBag.EstadoSeleccionado == "En evaluación" },
                            new SelectListItem { Text = "Aprobada", Value = "Aprobada", Selected = ViewBag.EstadoSeleccionado == "Aprobada" },
                            new SelectListItem { Text = "Rechazada", Value = "Rechazada", Selected = ViewBag.EstadoSeleccionado == "Rechazada" },
                            new SelectListItem { Text = "Cancelada", Value = "Cancelada", Selected = ViewBag.EstadoSeleccionado == "Cancelada" },
                            new SelectListItem { Text = "Completada", Value = "Completada", Selected = ViewBag.EstadoSeleccionado == "Completada" }
                        };
                    }
                    @Html.DropDownList("estado", estados, new { @class = "form-control border-green" })
                </div>

                <div class="form-group mr-2 mb-2">
                    <label class="mr-2 text-brown">Estado Adopción:</label>
                    @{
                        var estadosAdopcion = new List<SelectListItem>
                                                {
                            new SelectListItem { Text = "Todos", Value = "Todos", Selected = ViewBag.EstadoAdopcionSeleccionado == "Todos" || string.IsNullOrEmpty(ViewBag.EstadoAdopcionSeleccionado) },
                            new SelectListItem { Text = "No iniciada", Value = "No iniciada", Selected = ViewBag.EstadoAdopcionSeleccionado == "No iniciada" },
                            new SelectListItem { Text = "Programada", Value = "Programada", Selected = ViewBag.EstadoAdopcionSeleccionado == "Programada" },
                            new SelectListItem { Text = "Entregada", Value = "Entregada", Selected = ViewBag.EstadoAdopcionSeleccionado == "Entregada" },
                            new SelectListItem { Text = "En seguimiento", Value = "En seguimiento", Selected = ViewBag.EstadoAdopcionSeleccionado == "En seguimiento" },
                            new SelectListItem { Text = "Finalizada", Value = "Finalizada", Selected = ViewBag.EstadoAdopcionSeleccionado == "Finalizada" },
                            new SelectListItem { Text = "Cancelada", Value = "Cancelada", Selected = ViewBag.EstadoAdopcionSeleccionado == "Cancelada" }
                        };
                    }
                    @Html.DropDownList("estadoAdopcion", estadosAdopcion, new { @class = "form-control border-green" })
                </div>

                <button type="submit" class="btn btn-green mb-2 mr-2">
                    <i class="fa fa-search"></i> Buscar
                </button>
                <a href="@Url.Action("SolicitudAdopcion", "Admin")" class="btn btn-outline-green mb-2">
                    <i class="fa fa-redo"></i> Limpiar
                </a>
            }
        </div>
    </div>

    <!-- Tabla de Solicitudes -->
    <div class="card shadow-hover border-green mb-4">
        <div class="card-header py-3 d-flex justify-content-between align-items-center bg-green text-white">
            <h6 class="m-0 font-weight-bold">
                <i class="fa fa-table"></i> Listado de Solicitudes
            </h6>
            <div>
                <span class="badge bg-light-mint text-brown">Página @ViewBag.CurrentPage de @ViewBag.TotalPages</span>
            </div>
        </div>
        <div class="card-body">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-bordered table-hover" id="dataTable" width="100%" cellspacing="0">
                        <thead>
                            <tr class="bg-green text-white">
                                <th>ID</th>
                                <th>Solicitante</th>
                                <th>Mascota</th>
                                <th>Fecha Solicitud</th>
                                <th>Estado Solicitud</th>
                                <th>Estado Adopción</th>
                                <th>Puntaje</th>
                                <th class="text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var solicitud in Model)
                            {
                                <tr class="bg-light-mint">
                                    <td class="font-weight-bold text-brown">#@solicitud.SolicitudId</td>
                                    <td>
                                        @if (solicitud.Usuarios != null)
                                        {
                                            <div class="d-flex align-items-center">
                                                @if (solicitud.Usuarios.ImagenPerfil != null && solicitud.Usuarios.ImagenPerfil.Length > 0)
                                                {
                                                    <img src="data:image/jpeg;base64,@Convert.ToBase64String(solicitud.Usuarios.ImagenPerfil)"
                                                         alt="@solicitud.Usuarios.NombreCompleto"
                                                         class="rounded-circle mr-2 border-green"
                                                         style="width: 30px; height: 30px; object-fit: cover;" />
                                                }
                                                else
                                                {
                                                    <div class="rounded-circle bg-light-mint mr-2 d-flex align-items-center justify-content-center border-green"
                                                         style="width: 30px; height: 30px;">
                                                        <i class="fa fa-user text-secondary"></i>
                                                    </div>
                                                }
                                                <div>
                                                    <strong class="text-brown">@solicitud.Usuarios.NombreCompleto</strong><br />
                                                    <small class="text-secondary">@solicitud.Usuarios.Email</small>
                                                </div>
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="text-secondary">Usuario no disponible</span>
                                        }
                                    </td>
                                    <td>
                                        @if (solicitud.Mascotas != null)
                                        {
                                            <div class="d-flex align-items-center">
                                                @if (solicitud.Mascotas.ImagenPrincipal != null && solicitud.Mascotas.ImagenPrincipal.Length > 0)
                                                {
                                                    <img src="data:image/jpeg;base64,@Convert.ToBase64String(solicitud.Mascotas.ImagenPrincipal)"
                                                         alt="@solicitud.Mascotas.Nombre"
                                                         class="rounded mr-2 border-green"
                                                         style="width: 40px; height: 40px; object-fit: cover;" />
                                                }
                                                else
                                                {
                                                    <div class="rounded bg-light-mint mr-2 d-flex align-items-center justify-content-center border-green"
                                                         style="width: 40px; height: 40px;">
                                                        @if (solicitud.Mascotas.Especie == "Perro")
                                                        {
                                                            <i class="fa fa-dog text-secondary"></i>
                                                        }
                                                        else if (solicitud.Mascotas.Especie == "Gato")
                                                        {
                                                            <i class="fa fa-cat text-secondary"></i>
                                                        }
                                                        else
                                                        {
                                                            <i class="fa fa-paw text-secondary"></i>
                                                        }
                                                    </div>
                                                }
                                                <div>
                                                    <strong class="text-brown">@solicitud.Mascotas.Nombre</strong><br />
                                                    <small class="text-secondary">@solicitud.Mascotas.Especie • @solicitud.Mascotas.Raza</small>
                                                </div>
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="text-secondary">Mascota no disponible</span>
                                        }
                                    </td>
                                    <td>
                                        @if (solicitud.FechaSolicitud.HasValue)
                                        {
                                            <span class="text-brown">@solicitud.FechaSolicitud.Value.ToString("dd/MM/yyyy")</span><br />
                                            <small class="text-secondary">@solicitud.FechaSolicitud.Value.ToString("HH:mm")</small>
                                        }
                                        else
                                        {
                                            <span class="text-secondary">N/A</span>
                                        }
                                    </td>
                                    <td>
                                        @{
                                            string estadoBadge = "";
                                            string estadoIcono = "";
                                            switch (solicitud.Estado)
                                            {
                                                case "Pendiente":
                                                    estadoBadge = "bg-yellow";
                                                    estadoIcono = "fa-clock";
                                                    break;
                                                case "En evaluación":
                                                    estadoBadge = "bg-pink";
                                                    estadoIcono = "fa-search";
                                                    break;
                                                case "Aprobada":
                                                    estadoBadge = "bg-green";
                                                    estadoIcono = "fa-check-circle";
                                                    break;
                                                case "Rechazada":
                                                    estadoBadge = "bg-pink";
                                                    estadoIcono = "fa-times-circle";
                                                    break;
                                                case "Cancelada":
                                                    estadoBadge = "bg-secondary";
                                                    estadoIcono = "fa-ban";
                                                    break;
                                                case "Completada":
                                                    estadoBadge = "bg-success";
                                                    estadoIcono = "fa-check-double";
                                                    break;
                                                default:
                                                    estadoBadge = "bg-secondary";
                                                    estadoIcono = "fa-question-circle";
                                                    break;
                                            }
                                        }
                                        <span class="badge @estadoBadge">
                                            <i class="fa @estadoIcono mr-1"></i> @solicitud.Estado
                                        </span>
                                    </td>
                                    <td>
                                        @{
                                            string estadoAdopcionBadge = "";
                                            string estadoAdopcionIcono = "";
                                            string estadoAdopcion = solicitud.EstadoAdopcion ?? "No iniciada";

                                            switch (estadoAdopcion)
                                            {
                                                case "No iniciada":
                                                    estadoAdopcionBadge = "bg-secondary";
                                                    estadoAdopcionIcono = "fa-hourglass-start";
                                                    break;
                                                case "Programada":
                                                    estadoAdopcionBadge = "bg-info";
                                                    estadoAdopcionIcono = "fa-calendar-check";
                                                    break;
                                                case "Entregada":
                                                    estadoAdopcionBadge = "bg-primary";
                                                    estadoAdopcionIcono = "fa-home";
                                                    break;
                                                case "En seguimiento":
                                                    estadoAdopcionBadge = "bg-warning";
                                                    estadoAdopcionIcono = "fa-phone-alt";
                                                    break;
                                                case "Finalizada":
                                                    estadoAdopcionBadge = "bg-success";
                                                    estadoAdopcionIcono = "fa-check-double";
                                                    break;
                                                case "Cancelada":
                                                    estadoAdopcionBadge = "bg-danger";
                                                    estadoAdopcionIcono = "fa-ban";
                                                    break;
                                                default:
                                                    estadoAdopcionBadge = "bg-secondary";
                                                    estadoAdopcionIcono = "fa-question-circle";
                                                    break;
                                            }
                                        }
                                        <span class="badge @estadoAdopcionBadge">
                                            <i class="fa @estadoAdopcionIcono mr-1"></i> @estadoAdopcion
                                        </span>
                                    </td>
                                    <td>
                                        @if (solicitud.PuntajeEvaluacion.HasValue)
                                        {
                                            int puntaje = solicitud.PuntajeEvaluacion.Value;
                                            string barColor = puntaje >= 70 ? "bg-green" : puntaje >= 40 ? "bg-yellow" : "bg-pink";
                                            <div class="progress" style="height: 20px;">
                                                <div class="progress-bar @barColor"
                                                     role="progressbar"
                                                     style="width: @puntaje%;"
                                                     aria-valuenow="@puntaje"
                                                     aria-valuemin="0"
                                                     aria-valuemax="100">
                                                    @puntaje
                                                </div>
                                            </div>
                                            <small class="text-secondary">@puntaje/100</small>
                                        }
                                        else
                                        {
                                            <span class="badge bg-light-mint text-brown">Sin puntaje</span>
                                        }
                                    </td>
                                    
                                    <td class="text-center">
                                        <div class="btn-group-vertical" style="min-width: 120px;">
                                            <!-- Botón Ver Detalles -->
                                            <a href="@Url.Action("DetallesSolicitud", "Admin", new { id = solicitud.SolicitudId })"
                                               class="btn btn-outline-green btn-sm mb-1"
                                               title="Ver detalles completos"
                                               data-toggle="tooltip">
                                                <i class="fa fa-eye"></i> Ver detalles
                                            </a>

                                            <!-- Botones según estado de solicitud -->
                                            @if (solicitud.Estado == "Pendiente" || solicitud.Estado == "En evaluación")
                                            {
                                                <button type="button"
                                                        class="btn btn-green btn-sm mb-1 btn-aprobar"
                                                        data-solicitud-id="@solicitud.SolicitudId"
                                                        data-nombre-usuario="@(solicitud.Usuarios != null ? solicitud.Usuarios.NombreCompleto : "")"
                                                        data-nombre-mascota="@(solicitud.Mascotas != null ? solicitud.Mascotas.Nombre : "")"
                                                        title="Aprobar solicitud"
                                                        data-toggle="tooltip">
                                                    <i class="fa fa-check"></i> Aprobar
                                                </button>

                                                <a href="@Url.Action("RechazarSolicitud", "Admin", new { id = solicitud.SolicitudId })"
                                                   class="btn btn-pink btn-sm mb-1 btn-rechazar"
                                                   title="Rechazar solicitud"
                                                   data-toggle="tooltip">
                                                    <i class="fa fa-times"></i> Rechazar
                                                </a>
                                            }

                                            <!-- Botones de gestión de adopción (solo para solicitudes aprobadas) -->
                                            @if (solicitud.Estado == "Aprobada")
                                            {
                                                <div class="dropdown mb-1">
                                                    <button class="btn btn-info btn-sm dropdown-toggle w-100"
                                                            type="button"
                                                            id="dropdownAdopcion_@solicitud.SolicitudId"
                                                            data-toggle="dropdown"
                                                            aria-haspopup="true"
                                                            aria-expanded="false">
                                                        <i class="fa fa-paw"></i> Avanzar
                                                    </button>
                                                    <div class="dropdown-menu" aria-labelledby="dropdownAdopcion_@solicitud.SolicitudId">
                                                        @if (solicitud.EstadoAdopcion != "Programada")
                                                        {
                                                            <button class="dropdown-item btn-avanzar-adopcion"
                                                                    data-solicitud-id="@solicitud.SolicitudId"
                                                                    data-estado-destino="Programada">
                                                                <i class="fa fa-calendar-check text-info"></i> Programar entrega
                                                            </button>
                                                        }
                                                        @if (solicitud.EstadoAdopcion != "Entregada" && (solicitud.EstadoAdopcion == "Programada" || solicitud.EstadoAdopcion == "No iniciada"))
                                                        {
                                                            <button class="dropdown-item btn-avanzar-adopcion"
                                                                    data-solicitud-id="@solicitud.SolicitudId"
                                                                    data-estado-destino="Entregada">
                                                                <i class="fa fa-home text-primary"></i> Confirmar entrega
                                                            </button>
                                                        }
                                                        @if (solicitud.EstadoAdopcion != "En seguimiento" && solicitud.EstadoAdopcion == "Entregada")
                                                        {
                                                            <button class="dropdown-item btn-avanzar-adopcion"
                                                                    data-solicitud-id="@solicitud.SolicitudId"
                                                                    data-estado-destino="En seguimiento">
                                                                <i class="fa fa-phone-alt text-warning"></i> Iniciar seguimiento
                                                            </button>
                                                        }
                                                        @if (solicitud.EstadoAdopcion != "Finalizada" && (solicitud.EstadoAdopcion == "En seguimiento" || solicitud.EstadoAdopcion == "Entregada"))
                                                        {
                                                            <button class="dropdown-item btn-avanzar-adopcion"
                                                                    data-solicitud-id="@solicitud.SolicitudId"
                                                                    data-estado-destino="Finalizada">
                                                                <i class="fa fa-check-double text-success"></i> Finalizar adopción
                                                            </button>
                                                        }
                                                        <div class="dropdown-divider"></div>
                                                        <button class="dropdown-item btn-avanzar-adopcion"
                                                                data-solicitud-id="@solicitud.SolicitudId"
                                                                data-estado-destino="Cancelada">
                                                            <i class="fa fa-ban text-danger"></i> Cancelar proceso
                                                        </button>
                                                    </div>
                                                </div>

                                                <!-- Botón de contacto para enviar pasos -->
                                                <button type="button"
                                                        class="btn btn-yellow btn-sm mb-1 btn-enviar-pasos"
                                                        data-solicitud-id="@solicitud.SolicitudId"
                                                        data-nombre-usuario="@(solicitud.Usuarios != null ? solicitud.Usuarios.NombreCompleto : "")"
                                                        data-email-usuario="@(solicitud.Usuarios != null ? solicitud.Usuarios.Email : "")"
                                                        data-nombre-mascota="@(solicitud.Mascotas != null ? solicitud.Mascotas.Nombre : "")"
                                                        title="Enviar pasos siguientes al adoptante"
                                                        data-toggle="tooltip">
                                                    <i class="fa fa-envelope"></i> 📩 Enviar pasos
                                                </button>
                                            }

                                            @if (solicitud.Estado == "Completada" || solicitud.EstadoAdopcion == "Finalizada")
                                            {
                                                <span class="badge bg-success p-2">
                                                    <i class="fa fa-check-circle"></i> Adopción completada
                                                </span>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-green border-green">
                    <i class="fa fa-info-circle text-green"></i> <span class="text-brown">No se encontraron solicitudes con los filtros seleccionados.</span>
                </div>
            }
        </div>
    </div>

    <!-- Paginación -->
    @if (ViewBag.TotalPages != null && ViewBag.TotalPages > 1)
    {
        <div class="d-flex justify-content-center fade-in-up">
            <nav aria-label="Paginación de solicitudes">
                <ul class="pagination">
                    <!-- Primera página -->
                    @if (ViewBag.CurrentPage > 1)
                    {
                        <li class="page-item">
                            <a class="page-link text-green" href="@Url.Action("SolicitudAdopcionFiltrada", "Admin", new {
                                page = 1,
                                estado = ViewBag.EstadoSeleccionado,
                                estadoAdopcion = ViewBag.EstadoAdopcionSeleccionado
                            })" aria-label="Primera">
                                <i class="fa fa-angle-double-left"></i>
                            </a>
                        </li>
                        <li class="page-item">
                            <a class="page-link text-green" href="@Url.Action("SolicitudAdopcionFiltrada", "Admin", new {
                                page = ViewBag.CurrentPage - 1,
                                estado = ViewBag.EstadoSeleccionado,
                                estadoAdopcion = ViewBag.EstadoAdopcionSeleccionado
                            })" aria-label="Anterior">
                                <i class="fa fa-angle-left"></i>
                            </a>
                        </li>
                    }

                    <!-- Números de página -->
                    @{
                        int startPage = Math.Max(1, ViewBag.CurrentPage - 2);
                        int endPage = Math.Min(ViewBag.TotalPages, ViewBag.CurrentPage + 2);
                    }

                    @for (int i = startPage; i <= endPage; i++)
                    {
                        <li class="page-item @(i == ViewBag.CurrentPage ? "active bg-green" : "")">
                            <a class="page-link @(i == ViewBag.CurrentPage ? "text-white" : "text-green")" href="@Url.Action("SolicitudAdopcionFiltrada", "Admin", new {
                                page = i,
                                estado = ViewBag.EstadoSeleccionado,
                                estadoAdopcion = ViewBag.EstadoAdopcionSeleccionado
                            })">@i</a>
                        </li>
                    }

                    <!-- Última página -->
                    @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                    {
                        <li class="page-item">
                            <a class="page-link text-green" href="@Url.Action("SolicitudAdopcionFiltrada", "Admin", new {
                                page = ViewBag.CurrentPage + 1,
                                estado = ViewBag.EstadoSeleccionado,
                                estadoAdopcion = ViewBag.EstadoAdopcionSeleccionado
                            })" aria-label="Siguiente">
                                <i class="fa fa-angle-right"></i>
                            </a>
                        </li>
                        <li class="page-item">
                            <a class="page-link text-green" href="@Url.Action("SolicitudAdopcionFiltrada", "Admin", new {
                                page = ViewBag.TotalPages,
                                estado = ViewBag.EstadoSeleccionado,
                                estadoAdopcion = ViewBag.EstadoAdopcionSeleccionado
                            })" aria-label="Última">
                                <i class="fa fa-angle-double-right"></i>
                            </a>
                        </li>
                    }
                </ul>
            </nav>
        </div>
    }
</div>

