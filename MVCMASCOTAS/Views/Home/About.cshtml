@{
    ViewBag.Title = "Acerca de Nosotros - ADOPTAMANÍA";
}

<!-- Hero Section -->
<section class="about-hero py-5">
    <div class="container text-center">
        <h1 class="display-3 mb-4 text-white">Acerca de Nosotros</h1>
        <p class="lead mb-0 text-white">Desde 2015, trabajando por el bienestar animal en Ecuador</p>
    </div>
</section>

<!-- Misión y Visión (con imágenes de fondo) -->
<section class="mission-vision py-5">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-6">
                <div class="card h-100 border-0 shadow-hover tarjeta-con-fondo" style="background-image: url('https://images.unsplash.com/photo-1548199973-03cce0bbc87b?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80');">
                    <div class="card-body text-center p-5">
                        
                        <h3 class="card-title mb-3 text-white">Nuestra Misión</h3>
                        <p class="card-text text-white">
                            Rescatar, rehabilitar y encontrar hogares responsables para animales en situación
                            de abandono y maltrato en Quito y sus alrededores, promoviendo la tenencia
                            responsable y el respeto hacia todos los seres vivos.
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card h-100 border-0 shadow-hover tarjeta-con-fondo" style="background-image: url('https://images.unsplash.com/photo-1450778869180-41d0601e046e?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80');">
                    <div class="card-body text-center p-5">
                        
                        <h3 class="card-title mb-3 text-white">Nuestra Visión</h3>
                        <p class="card-text text-white">
                            Ser la organización líder en bienestar animal en Ecuador, creando una sociedad
                            consciente y comprometida donde ningún animal sufra por abandono, maltrato
                            o falta de cuidado médico.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Estadísticas (rediseñadas sin bordes) -->
<section class="py-5">
    <div class="container">
        <h2 class="text-center mb-5 text-brown">Nuestro Impacto en Números</h2>
        <div class="row g-4">
            <div class="col-md-3 col-sm-6">
                <div class="stat-box">
                    <div class="stat-icon">
                        <i class="fas fa-hands-helping fa-3x"></i>
                    </div>
                    <div class="counter">@(ViewBag.TotalMascotas ?? "1500")</div>
                    <p>Mascotas Rescatadas</p>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="stat-box">
                    <div class="stat-icon">
                        <i class="fas fa-hands-helping fa-3x"></i>
                    </div>
                    <div class="counter">@(ViewBag.MascotasAdoptadas ?? "1200")</div>
                    <p>Adopciones Exitosas</p>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="stat-box">
                    <div class="stat-icon">
                        <i class="fas fa-hands-helping fa-3x"></i>
                    </div>
                    <div class="counter">@(ViewBag.VoluntariosActivos ?? "250")</div>
                    <p>Voluntarios Activos</p>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="stat-box">
                    <div class="stat-icon">
                        <i class="fas fa-hand-holding-heart fa-3x"></i>
                    </div>
                    <div class="counter">@(ViewBag.TotalDonaciones ?? "5000")</div>
                    <p>Donaciones Recibidas</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Nuestra Historia (timeline con imágenes) -->
<section class="py-5 bg-beige">
    <div class="container">
        <h2 class="text-center mb-5 text-brown">Nuestra Historia</h2>
        <div class="timeline">
            <!-- 2015 -->
            <div class="timeline-item row align-items-center">
                <div class="col-md-6 order-md-2">
                    <img src="https://images.unsplash.com/photo-1548199973-03cce0bbc87b?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" alt="Fundación" class="img-fluid rounded shadow-hover">
                </div>
                <div class="col-md-6 order-md-1">
                    <h4 class="text-brown">2015 - Fundación</h4>
                    <p class="text-secondary">Un grupo de 5 amigos amantes de los animales funda el refugio con 10 mascotas rescatadas.</p>
                </div>
            </div>
            <!-- 2017 -->
            <div class="timeline-item row align-items-center">
                <div class="col-md-6">
                    <img src="https://images.unsplash.com/photo-1629909613654-28e377c37b09?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" alt="Centro Veterinario" class="img-fluid rounded shadow-hover">
                </div>
                <div class="col-md-6">
                    <h4 class="text-brown">2017 - Primer Centro Veterinario</h4>
                    <p class="text-secondary">Inauguramos nuestra primera clínica veterinaria para atender a las mascotas del refugio.</p>
                </div>
            </div>
            <!-- 2019 -->
            <div class="timeline-item row align-items-center">
                <div class="col-md-6 order-md-2">
                    <img src="https://images.unsplash.com/photo-1551288049-bebda4e38f71?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" alt="Sistema Web" class="img-fluid rounded shadow-hover">
                </div>
                <div class="col-md-6 order-md-1">
                    <h4 class="text-brown">2019 - Sistema Web</h4>
                    <p class="text-secondary">Implementamos el sistema web para digitalizar adopciones y donaciones.</p>
                </div>
            </div>
            <!-- 2021 -->
            <div class="timeline-item row align-items-center">
                <div class="col-md-6">
                    <img src="https://images.unsplash.com/photo-1552664730-d307ca884978?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" alt="Alianzas" class="img-fluid rounded shadow-hover">
                </div>
                <div class="col-md-6">
                    <h4 class="text-brown">2021 - Alianzas Estratégicas</h4>
                    <p class="text-secondary">Formamos alianzas con 15 empresas ecuatorianas comprometidas con el bienestar animal.</p>
                </div>
            </div>
            <!-- 2023 -->
            <div class="timeline-item row align-items-center">
                <div class="col-md-6 order-md-2">
                    <img src="https://images.unsplash.com/photo-1526778548025-fa2f459cd5c1?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" alt="Expansión" class="img-fluid rounded shadow-hover">
                </div>
                <div class="col-md-6 order-md-1">
                    <h4 class="text-brown">2023 - Expansión Nacional</h4>
                    <p class="text-secondary">Extendemos nuestras operaciones a Guayaquil y Cuenca con nuevos centros de rescate.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Nuestro Equipo (con fotos) -->
<section class="py-5">
    <div class="container">
        <h2 class="text-center mb-5 text-brown">Nuestro Equipo</h2>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="team-member text-center">
                    <div class="team-img-wrapper mx-auto mb-3">
                        <img src="https://images.unsplash.com/photo-1573497019940-1c28c88b4f3e?ixlib=rb-4.0.3&auto=format&fit=crop&w=300&q=80" alt="María González" class="team-img">
                    </div>
                    <h4 class="text-brown">María González</h4>
                    <p class="text-secondary">Directora Ejecutiva</p>
                    <p class="text-secondary small">Veterinaria con 15 años de experiencia en rescate animal.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="team-member text-center">
                    <div class="team-img-wrapper mx-auto mb-3">
                        <img src="https://images.unsplash.com/photo-1560250097-0b93528c311a?ixlib=rb-4.0.3&auto=format&fit=crop&w=300&q=80" alt="Carlos Mendoza" class="team-img">
                    </div>
                    <h4 class="text-brown">Carlos Mendoza</h4>
                    <p class="text-secondary">Coordinador de Rescates</p>
                    <p class="text-secondary small">Especialista en comportamiento animal y rescates de emergencia.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="team-member text-center">
                    <div class="team-img-wrapper mx-auto mb-3">
                        <img src="https://images.unsplash.com/photo-1580489944761-15a19d654956?ixlib=rb-4.0.3&auto=format&fit=crop&w=300&q=80" alt="Ana López" class="team-img">
                    </div>
                    <h4 class="text-brown">Ana López</h4>
                    <p class="text-secondary">Jefa de Veterinarios</p>
                    <p class="text-secondary small">Cirujana veterinaria especializada en animales de rescate.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Nuestros Valores (con imágenes) -->
<section class="py-5 bg-beige">
    <div class="container">
        <h2 class="text-center mb-5 text-brown">Nuestros Valores</h2>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-hover tarjeta-con-fondo" style="background-image: url('https://images.unsplash.com/photo-1543852786-1cf6624b9987?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80');">
                    <div class="card-body text-center p-4">
                        <i class="fas fa-shield-alt text-white fa-3x mb-3"></i>
                        <h4 class="card-title text-white">Compasión</h4>
                        <p class="card-text text-white">Actuamos con empatía y respeto hacia todos los seres vivos.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-hover tarjeta-con-fondo" style="background-image: url('https://images.unsplash.com/photo-1583511655857-d19b40a7a54e?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80');">
                    <div class="card-body text-center p-4">
                        <i class="fas fa-shield-alt text-white fa-3x mb-3"></i>
                        <h4 class="card-title text-white">Responsabilidad</h4>
                        <p class="card-text text-white">Nos comprometemos con el cuidado integral de cada animal.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-hover tarjeta-con-fondo" style="background-image: url('https://images.unsplash.com/photo-1511632765486-a01980e01a18?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80');">
                    <div class="card-body text-center p-4">
                        <i class="fas fa-shield-alt text-white fa-3x mb-3"></i>
                        <h4 class="card-title text-white">Comunidad</h4>
                        <p class="card-text text-white">Trabajamos en conjunto con la sociedad para crear cambio.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Call to Action -->
<section class="py-5 bg-green text-white">
    <div class="container text-center">
        <h2 class="mb-4">¿Quieres ser parte del cambio?</h2>
        <p class="lead mb-5">Únete a nuestra misión de crear un mundo mejor para los animales.</p>
        <div class="row justify-content-center g-3">
            <div class="col-md-3">
                <a href="@Url.Action("Register", "Account")" class="btn btn-pink btn-lg w-100">
                    <i class="fas fa-user-plus"></i> Ser Voluntario
                </a>
            </div>
            <div class="col-md-3">
                <a href="@Url.Action("Index", "Donaciones")" class="btn btn-yellow btn-lg w-100">
                    <i class="fas fa-donate"></i> Donar
                </a>
            </div>
            <div class="col-md-3">
                <a href="@Url.Action("Index", "Mascotas")" class="btn btn-light btn-lg w-100 text-brown">
                    <i class="fas fa-paw"></i> Adoptar
                </a>
            </div>
        </div>
    </div>
</section>

@section Styles {
    <style>
        /* Estilos específicos de About (se mantienen) */
        .about-hero {
            background: linear-gradient(135deg, rgba(151,199,139,0.9), rgba(242,198,109,0.8)), url('https://images.unsplash.com/photo-1548199973-03cce0bbc87b?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80');
            background-size: cover;
            background-position: center;
            border-radius: 0 0 30px 30px;
            margin-bottom: 2rem;
        }

        .tarjeta-con-fondo {
            position: relative;
            background-size: cover;
            background-position: center;
            border-radius: 20px;
            overflow: hidden;
            z-index: 0;
        }

            .tarjeta-con-fondo::after {
                content: "";
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                background: linear-gradient(135deg, rgba(151,199,139,0.7), rgba(242,198,109,0.7));
                z-index: 1;
                pointer-events: none;
            }

            .tarjeta-con-fondo .card-body {
                position: relative;
                z-index: 2;
            }

        .timeline-item img {
            border-radius: 20px;
            border: 4px solid var(--verde-menta);
            transition: transform 0.3s ease;
        }

            .timeline-item img:hover {
                transform: scale(1.02);
            }

        .team-img-wrapper {
            width: 150px;
            height: 150px;
            border-radius: 50%;
            overflow: hidden;
            border: 4px solid var(--verde-menta);
            box-shadow: 0 8px 20px rgba(151,199,139,0.3);
            transition: transform 0.3s ease;
        }

            .team-img-wrapper:hover {
                transform: scale(1.05);
            }

        .team-img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        /* Línea de tiempo decorativa */
        .timeline-item {
            position: relative;
        }

            .timeline-item::before {
                content: '';
                position: absolute;
                left: 50%;
                top: 0;
                bottom: 0;
                width: 4px;
                background: linear-gradient(to bottom, var(--verde-menta), var(--amarillo-pastel));
                transform: translateX(-50%);
                z-index: -1;
            }

            .timeline-item:first-child::before {
                top: 50%;
            }

            .timeline-item:last-child::before {
                bottom: 50%;
            }

        @@media (max-width: 768px) {
            .about-hero {
                border-radius: 0 0 20px 20px;
            }

            .timeline-item::before {
                left: 20px;
            }

            .timeline-item .row {
                text-align: center;
            }
        }
    </style>
}