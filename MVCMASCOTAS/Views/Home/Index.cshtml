@using MVCMASCOTAS.Models
@using MVCMASCOTAS.Helpers
@{
    ViewBag.Title = "Inicio - Refugio de Mascotas";
    var db = new RefugioMascotasDBEntities();
}

<div class="jumbotron bg-light p-5 rounded">
    <h1 class="display-4">🐾 Refugio de Mascotas</h1>
    <p class="lead">Damos amor, cuidado y un hogar a mascotas que lo necesitan.</p>
    <hr class="my-4">
    <p>Un refugio comprometido con el bienestar animal y la adopción responsable.</p>
    <a class="btn btn-primary btn-lg" href="@Url.Action("Index", "Mascotas")" role="button">Ver Mascotas Disponibles</a>
    <a class="btn btn-outline-secondary btn-lg" href="@Url.Action("Index", "Donaciones")" role="button">Hacer una Donación</a>
</div>

<!-- Estadísticas -->
<div class="row text-center mb-5">
    <div class="col-md-3">
        <div class="card text-white bg-primary mb-3">
            <div class="card-body">
                <h5 class="card-title">Total Mascotas</h5>
                <p class="card-text display-4">@ViewBag.TotalMascotas</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-success mb-3">
            <div class="card-body">
                <h5 class="card-title">Mascotas Adoptadas</h5>
                <p class="card-text display-4">@ViewBag.MascotasAdoptadas</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-warning mb-3">
            <div class="card-body">
                <h5 class="card-title">Voluntarios Activos</h5>
                <p class="card-text display-4">@ViewBag.VoluntariosActivos</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-info mb-3">
            <div class="card-body">
                <h5 class="card-title">Donaciones Activas</h5>
                <p class="card-text display-4">@db.Donaciones.Count(d => d.Estado == "Completada")</p>
            </div>
        </div>
    </div>
</div>

<!-- Mascotas Disponibles -->
@if (ViewBag.MascotasDisponibles != null)
{
    var mascotasList = ViewBag.MascotasDisponibles as System.Collections.IList;
    if (mascotasList != null && mascotasList.Count > 0)
    {
        <div class="row mt-4">
            <div class="col-12">
                <h2 class="mb-4">Mascotas Disponibles para Adopción</h2>
                <div class="row">
                    @foreach (var mascota in ViewBag.MascotasDisponibles)
                    {
                        <div class="col-md-4 mb-3">
                            <div class="card h-100">
                                @if (mascota.ImagenPrincipal != null)
                                {
                                    try
                                    {
                                        var imagenDataUri = ImageHelper.GetImageDataUri(mascota.ImagenPrincipal);
                                        if (!string.IsNullOrEmpty(imagenDataUri))
                                        {
                                            <img src="@imagenDataUri"
                                                 class="card-img-top"
                                                 alt="@mascota.Nombre"
                                                 style="height: 200px; object-fit: cover;">
                                        }
                                        else
                                        {
                                            <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
                                                <span class="text-muted">Imagen no disponible</span>
                                            </div>
                                        }
                                    }
                                    catch
                                    {
                                        <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
                                            <span class="text-muted">Error cargando imagen</span>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
                                        <span class="text-muted">Sin imagen</span>
                                    </div>
                                }
                                <div class="card-body d-flex flex-column">
                                    <h5 class="card-title">@mascota.Nombre</h5>
                                    <p class="card-text">
                                        <strong>Especie:</strong> @mascota.Especie<br>
                                        <strong>Edad:</strong> @mascota.EdadAproximada<br>
                                        <strong>Tamaño:</strong> @mascota.Tamanio
                                    </p>
                                    <div class="mt-auto">
                                        <a href="@Url.Action("Details", "Mascotas", new { id = mascota.MascotaId })"
                                           class="btn btn-primary btn-block">Ver Detalles</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <i class="fas fa-info-circle"></i> No hay mascotas disponibles para adopción en este momento.
        </div>
    }
}

<!-- Últimas Donaciones -->
@if (ViewBag.UltimasDonaciones != null)
{
    var donacionesList = ViewBag.UltimasDonaciones as System.Collections.IList;
    if (donacionesList != null && donacionesList.Count > 0)
    {
        <div class="container my-5">
            <h2 class="text-center mb-4"><i class="fas fa-users"></i> Nuestros Donantes Recientes</h2>
            <div class="card shadow-custom">
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Donante</th>
                                    <th>Tipo</th>
                                    <th>Monto</th>
                                    <th>Fecha</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var donante in ViewBag.UltimasDonaciones)
                                {
                                    <tr>
                                        <td>@donante.Nombre</td>
                                        <td>
                                            @if (donante.Tipo == "Única")
                                            {
                                                <span class="badge badge-primary">Única</span>
                                            }
                                            else
                                            {
                                                <span class="badge badge-success">Recurrente</span>
                                            }
                                        </td>
                                        <td>@string.Format("${0:N2}", donante.Monto)</td>
                                        <td>@donante.Fecha.ToString("dd/MM/yyyy")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }
}

<!-- Sección de información -->
<div class="row mt-5">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title"><i class="fas fa-clinic-medical"></i> Servicios Veterinarios</h5>
                <p class="card-text">
                    Ofrecemos atención veterinaria completa para todas nuestras mascotas,
                    incluyendo esterilización, vacunación y tratamientos especializados.
                </p>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title"><i class="fas fa-hands-helping"></i> Voluntariado</h5>
                <p class="card-text">
                    Únete a nuestro equipo de voluntarios y ayuda a cambiar la vida
                    de estas mascotas. Hay muchas formas de colaborar.
                </p>
                <a href="@Url.Action("Contact", "Home")" class="btn btn-outline-success">Quiero ser Voluntario</a>
            </div>
        </div>
    </div>
</div>

@{
    db.Dispose();
}