@{
    ViewBag.Title = "Inicio - Refugio de Mascotas";

    // Convertir ViewBag a variables tipadas
    var mascotasDisponibles = ViewBag.MascotasDisponibles as List<MVCMASCOTAS.Models.Mascotas>;
    var mascotasPerdidasRecientes = ViewBag.MascotasPerdidasRecientes as List<MVCMASCOTAS.Models.MascotasPerdidas>;
    var campanasActivas = ViewBag.CampanasActivas as List<MVCMASCOTAS.Models.CampaniaAdopcion>;

    // Valores por defecto para estadísticas
    var totalMascotasDisponibles = ViewBag.TotalMascotasDisponibles != null ? (int)ViewBag.TotalMascotasDisponibles : 0;
    var mascotasAdoptadas = ViewBag.MascotasAdoptadas != null ? (int)ViewBag.MascotasAdoptadas : 0;
    var totalMascotasPerdidasActivas = ViewBag.TotalMascotasPerdidasActivas != null ? (int)ViewBag.TotalMascotasPerdidasActivas : 0;
    var voluntariosActivos = ViewBag.VoluntariosActivos != null ? (int)ViewBag.VoluntariosActivos : 0;
}

<!-- Hero Section -->
<section class="hero-section py-5">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <h1 class="display-4 fw-bold mb-3 text-brown">Bienvenido al Refugio de Mascotas</h1>
                <p class="lead mb-4 text-secondary">Un hogar temporal para mascotas que buscan una segunda oportunidad. Juntos podemos hacer la diferencia.</p>
                <div class="d-flex flex-wrap gap-3">
                    @Html.ActionLink("🐕 Reportar Mascota Perdida", "ReportarMascotaPerdida", "Rescate", null, new { @class = "btn btn-green btn-lg text-white" })
                    @Html.ActionLink("🏠 Adoptar una Mascota", "Index", "Mascotas", null, new { @class = "btn btn-yellow btn-lg" })
                </div>
            </div>
            <div class="col-lg-6 mt-4 mt-lg-0">
                <div class="text-center">
                    <img src="https://images.unsplash.com/photo-1543466835-00a7907e9de1?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80"
                         alt="Mascotas felices"
                         class="img-fluid rounded shadow-lg hero-img">
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Quick Navigation -->
<section class="py-5 bg-light-mint">
    <div class="container">
        <h2 class="text-center mb-5 text-brown">Acceso Rápido</h2>
        <div class="row g-4">
            <div class="col-md-3 col-sm-6">
                <div class="card h-100 text-center border-green shadow-hover">
                    <div class="card-body">
                        <i class="fa fa-search fa-3x text-green mb-3"></i>
                        <h5 class="card-title text-brown">Mascotas Perdidas</h5>
                        <p class="card-text text-secondary">Reporta o busca mascotas extraviadas en nuestra comunidad.</p>
                        @Html.ActionLink("Ver Mascotas Perdidas", "MascotasPerdidas", "Rescate", null, new { @class = "btn btn-green text-white mt-2" })
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="card h-100 text-center border-green shadow-hover">
                    <div class="card-body">
                        <i class="fa fa-paw fa-3x text-green mb-3"></i>
                        <h5 class="card-title text-brown">Mascotas en Adopción</h5>
                        <p class="card-text text-secondary">Conoce a nuestros amigos que buscan un hogar para siempre.</p>
                        @Html.ActionLink("Ver Mascotas", "Index", "Mascotas", null, new { @class = "btn btn-green text-white mt-2" })
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="card h-100 text-center border-green shadow-hover">
                    <div class="card-body">
                        <i class="fa fa-hand-holding-heart fa-3x text-green mb-3"></i>
                        <h5 class="card-title text-brown">Donaciones</h5>
                        <p class="card-text text-secondary">Ayuda a mantener nuestro refugio y salvar más vidas.</p>
                        @Html.ActionLink("Hacer Donación", "Create", "Donaciones", null, new { @class = "btn btn-green text-white mt-2" })
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="card h-100 text-center border-green shadow-hover">
                    <div class="card-body">
                        <i class="fa fa-calendar-alt fa-3x text-green mb-3"></i>
                        <h5 class="card-title text-brown">Eventos</h5>
                        <p class="card-text text-secondary">Participa en nuestras actividades y campañas de adopción.</p>
                        @Html.ActionLink("Ver Eventos", "Index", "Actividades", null, new { @class = "btn btn-green text-white mt-2" })
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Statistics -->
<section class="py-5">
    <div class="container">
        <div class="row text-center">
            <div class="col-md-3 col-6 mb-4">
                <div class="stat-box border-green">
                    <h3 class="display-4 fw-bold text-green counter">@totalMascotasDisponibles</h3>
                    <p class="text-brown fw-medium">Mascotas para Adoptar</p>
                </div>
            </div>
            <div class="col-md-3 col-6 mb-4">
                <div class="stat-box border-green">
                    <h3 class="display-4 fw-bold text-green counter">@mascotasAdoptadas</h3>
                    <p class="text-brown fw-medium">Adopciones Exitosas</p>
                </div>
            </div>
            <div class="col-md-3 col-6 mb-4">
                <div class="stat-box border-green">
                    <h3 class="display-4 fw-bold text-green counter">@totalMascotasPerdidasActivas</h3>
                    <p class="text-brown fw-medium">Mascotas Perdidas</p>
                </div>
            </div>
            <div class="col-md-3 col-6 mb-4">
                <div class="stat-box border-green">
                    <h3 class="display-4 fw-bold text-green counter">@voluntariosActivos</h3>
                    <p class="text-brown fw-medium">Voluntarios Activos</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- 🆕 SECCIÓN: Campañas de Adopción - DINÁMICAS DESDE LA BD - ✅ CORREGIDO -->
@if (campanasActivas != null && campanasActivas.Count > 0)
{
    <section class="py-5 bg-light-mint">
        <div class="container">
            <div class="text-center mb-5">
                <h2 class="text-brown mb-3">
                    <i class="fa fa-calendar-alt text-green"></i> Campañas de Adopción Activas
                </h2>
                <p class="lead text-secondary">Únete a nuestros eventos especiales para encontrar hogar a nuestros amigos peludos</p>
            </div>

            <div class="row g-4">
                @foreach (var campana in campanasActivas)
                {
                    <div class="col-lg-4 col-md-6">
                        <div class="card h-100 border-green shadow-hover">
                            <!-- Imagen de la campaña -->
                            <div class="campaign-img" style="background-image: url('@(campana.Foto != null && campana.Foto.Length > 0 ? "data:image/jpeg;base64," + Convert.ToBase64String(campana.Foto) : "https://images.unsplash.com/photo-1552053831-71594a27632d?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80")');">
                                @{
                                    // Determinar badge según fecha
                                    var diasParaCampana = (campana.Fecha - DateTime.Now).TotalDays;
                                    string badgeClass = "bg-green";
                                    string badgeText = "Activo";

                                    if (diasParaCampana <= 3)
                                    {
                                        badgeClass = "bg-pink";
                                        badgeText = "¡Próximamente!";
                                    }
                                    else if (diasParaCampana <= 7)
                                    {
                                        badgeClass = "bg-yellow text-dark";
                                        badgeText = "Esta Semana";
                                    }
                                }
                                <span class="badge @badgeClass">@badgeText</span>
                            </div>

                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <h5 class="card-title text-brown mb-0">@campana.NombreCampania</h5>
                                    <span class="badge bg-green">
                                        @(campana.Estado ? "Activa" : "Finalizada")
                                    </span>
                                </div>

                                <p class="card-text text-secondary mb-2">
                                    <i class="fa fa-calendar-alt text-green me-2"></i>
                                    <strong>Fecha:</strong> @campana.Fecha.ToString("dddd, dd 'de' MMMM 'de' yyyy")
                                </p>

                                <p class="card-text text-secondary mb-2">
                                    <i class="fa fa-clock text-green me-2"></i>
                                    <strong>Hora:</strong> @campana.Hora.ToString(@"hh\:mm") hrs
                                </p>

                                @if (!string.IsNullOrEmpty(campana.Lugar))
                                {
                                    <p class="card-text text-secondary mb-2">
                                        <i class="fa fa-map-marker-alt text-green me-2"></i>
                                        <strong>Lugar:</strong> @campana.Lugar
                                    </p>
                                }

                                @if (!string.IsNullOrEmpty(campana.Actividades))
                                {
                                    <p class="card-text text-secondary mb-3">
                                        <i class="fa fa-info-circle text-green me-2"></i>
                                        @(campana.Actividades.Length > 120 ? campana.Actividades.Substring(0, 120) + "..." : campana.Actividades)
                                    </p>
                                }

                                <div class="d-flex justify-content-between align-items-center mt-3">
                                    <small class="text-muted">
                                        <i class="far fa-calendar me-1"></i>
                                        Creado: @campana.FechaCreacion.ToString("dd/MM/yyyy")
                                    </small>
                                    @Html.ActionLink("Ver Detalles", "Details", "CampaniaAdopciones", new { id = campana.IdCampania }, new { @class = "btn btn-green btn-sm text-white" })
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="text-center mt-5">
                @if (Request.IsAuthenticated && User.IsInRole("Administrador"))
                {
                    @Html.ActionLink("Gestionar Campañas", "Index", "CampaniaAdopciones", null, new { @class = "btn btn-green text-white me-2" })
                    @Html.ActionLink("Nueva Campaña", "Create", "CampaniaAdopciones", null, new { @class = "btn btn-pink" })
                }
                else
                {
                    @Html.ActionLink("Ver Todas las Campañas", "Index", "CampaniaAdopciones", null, new { @class = "btn btn-green text-white" })
                }
            </div>
        </div>
    </section>
}

<!-- Available Pets -->
<section class="py-5">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="text-brown">Mascotas Disponibles para Adopción</h2>
            @Html.ActionLink("Ver Todas", "Index", "Mascotas", null, new { @class = "btn btn-outline-green" })
        </div>

        @if (mascotasDisponibles != null && mascotasDisponibles.Count > 0)
        {
            <div class="row g-4">
                @{
                    int mascotasCount = Math.Min(mascotasDisponibles.Count, 3);
                }

                @for (int i = 0; i < mascotasCount; i++)
                {
                    var mascota = mascotasDisponibles[i];
                    <div class="col-lg-4 col-md-6">
                        <div class="card h-100 border-green shadow-hover">
                            <div class="card-img-top" style="height: 250px; background-color: var(--fondo-claro); display: flex; align-items: center; justify-content: center;">
                                @if (mascota.ImagenPrincipal != null && mascota.ImagenPrincipal.Length > 0)
                                {
                                    <img src="data:image/jpeg;base64,@Convert.ToBase64String(mascota.ImagenPrincipal)"
                                         alt="@mascota.Nombre"
                                         class="img-fluid rounded"
                                         style="max-height: 100%; max-width: 100%; object-fit: cover;">
                                }
                                else
                                {
                                    <i class="fa fa-paw fa-5x text-green"></i>
                                }
                            </div>
                            <div class="card-body">
                                <h5 class="card-title text-brown">@mascota.Nombre</h5>
                                <p class="card-text text-secondary">
                                    <strong>Especie:</strong> @mascota.Especie<br>
                                    <strong>Raza:</strong> @mascota.Raza<br>
                                    <strong>Edad:</strong> @mascota.EdadAproximada
                                </p>
                            </div>
                            <div class="card-footer bg-transparent border-top border-green">
                                @Html.ActionLink("Ver Detalles", "Detalle", "Mascotas", new { id = mascota.MascotaId }, new { @class = "btn btn-green btn-sm text-white" })
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="alert alert-green text-center border-green">
                <p class="text-brown">No hay mascotas disponibles para adopción en este momento.</p>
            </div>
        }
    </div>
</section>

<!-- Lost Pets -->
<section class="py-5 bg-light-mint">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="text-brown">Mascotas Perdidas Recientes</h2>
            @Html.ActionLink("Ver Todas", "MascotasPerdidas", "Rescate", null, new { @class = "btn btn-outline-green" })
        </div>

        @if (mascotasPerdidasRecientes != null && mascotasPerdidasRecientes.Count > 0)
        {
            <div class="row g-4">
                @{
                    int perdidasCount = Math.Min(mascotasPerdidasRecientes.Count, 3);
                }

                @for (int i = 0; i < perdidasCount; i++)
                {
                    var mascota = mascotasPerdidasRecientes[i];
                    <div class="col-lg-4 col-md-6">
                        <div class="card h-100 border-green shadow-hover">
                            <div class="card-img-top" style="height: 250px; background-color: var(--fondo-claro); display: flex; align-items: center; justify-content: center;">
                                @if (mascota.ImagenMascota != null && mascota.ImagenMascota.Length > 0)
                                {
                                    <img src="data:image/jpeg;base64,@Convert.ToBase64String(mascota.ImagenMascota)"
                                         alt="@mascota.NombreMascota"
                                         class="img-fluid rounded"
                                         style="max-height: 100%; max-width: 100%; object-fit: cover;">
                                }
                                else
                                {
                                    <i class="fa fa-search fa-5x text-green"></i>
                                }
                            </div>
                            <div class="card-body">
                                <h5 class="card-title text-brown">@mascota.NombreMascota</h5>
                                <p class="card-text text-secondary">
                                    <strong>Perdido en:</strong> @mascota.UbicacionPerdida<br>
                                    <strong>Fecha:</strong> @mascota.FechaPerdida.ToString("dd/MM/yyyy")<br>
                                    @if (mascota.Recompensa.HasValue && mascota.Recompensa.Value > 0)
                                    {
                                        <strong>Recompensa:</strong> <span class="badge bg-yellow text-dark">$@mascota.Recompensa.Value.ToString("N0")</span>
                                    }
                                </p>
                            </div>
                            <div class="card-footer bg-transparent border-top border-green">
                                @Html.ActionLink("Ver Detalles", "DetalleMascotaPerdida", "Rescate", new { id = mascota.MascotaPerdidaId }, new { @class = "btn btn-green btn-sm text-white" })
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="alert alert-green text-center border-green">
                <p class="text-brown">No hay reportes de mascotas perdidas recientes.</p>
            </div>
        }
    </div>
</section>

<!-- CTA Section -->
<section class="py-5 bg-green text-white">
    <div class="container text-center">
        <h2 class="mb-4">¿Quieres Ayudar?</h2>
        <p class="lead mb-4">Hay muchas formas de apoyar nuestro trabajo. ¡Únete a nuestra causa!</p>
        <div class="d-flex flex-wrap justify-content-center gap-3">
            @Html.ActionLink("💝 Hacer una Donación", "Create", "Donaciones", null, new { @class = "btn btn-pink btn-lg" })
            @Html.ActionLink("🤝 Ser Voluntario", "Register", "Account", null, new { @class = "btn btn-yellow btn-lg" })
            @Html.ActionLink("📋 Ver Actividades", "Index", "Actividades", null, new { @class = "btn btn-light btn-lg text-brown" })
        </div>
    </div>
</section>

@section Styles {
    <style>
        /* SOLO estilos únicos que NO están en el Layout */

        /* Animación para badges en hover */
        .pulse {
            animation: pulse 1.5s infinite;
        }

        @@keyframes pulse {
            0% {
                transform: scale(1);
            }

            50% {
                transform: scale(1.05);
            }

            100% {
                transform: scale(1);
            }
        }

        /* Ajuste específico para imágenes de campañas */
        .campaign-img {
            border-radius: 8px 8px 0 0 !important;
        }

        /* Clase única para animación scroll */
        .fade-in-up {
            opacity: 0;
            transform: translateY(30px);
            transition: opacity 0.6s ease, transform 0.6s ease;
        }

            .fade-in-up.visible {
                opacity: 1;
                transform: translateY(0);
            }

        /* Ajustes específicos para imágenes hero */
        .hero-img {
            max-width: 100%;
            height: auto;
            border-radius: 15px;
        }

        /* Ajuste específico para stat boxes */
        .stat-box:hover {
            transform: scale(1.05);
            box-shadow: 0 5px 15px rgba(151, 199, 139, 0.2);
        }
    </style>
}

@section Scripts {
    <script>
        // Script específico para la página de inicio
        $(document).ready(function () {
            // Evitar duplicación de contadores animados
            if (!$('.counter').hasClass('home-animated')) {
                $('.counter').each(function () {
                    var $this = $(this);
                    var currentValue = parseInt($this.text());
                    if (!isNaN(currentValue) && currentValue > 0) {
                        $({ countNum: 0 }).animate({
                            countNum: currentValue
                        }, {
                            duration: 2000,
                            easing: 'swing',
                            step: function () {
                                $this.text(Math.floor(this.countNum));
                            },
                            complete: function () {
                                $this.text(this.countNum);
                            }
                        });
                    }
                });
                $('.counter').addClass('home-animated');
            }

            // Animación de aparición para secciones (única para esta página)
            function checkScroll() {
                $('.fade-in-up').each(function () {
                    var elementTop = $(this).offset().top;
                    var windowHeight = $(window).height();
                    var scrollTop = $(window).scrollTop();

                    if (elementTop < scrollTop + windowHeight - 100) {
                        $(this).addClass('visible');
                    }
                });
            }

            // Verificar scroll al cargar y al hacer scroll
            checkScroll();
            $(window).scroll(checkScroll);

            // Animación hover específica para badges de campañas
            $('.campaign-img').hover(
                function () {
                    $(this).find('.badge').addClass('pulse');
                },
                function () {
                    $(this).find('.badge').removeClass('pulse');
                }
            );

            // Tooltips para elementos específicos de esta página
            $('[title]').tooltip();

            console.log('Home page loaded successfully with campaigns');
        });
    </script>
}