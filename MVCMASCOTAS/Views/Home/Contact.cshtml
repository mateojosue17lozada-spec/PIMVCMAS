@{
    ViewBag.Title = "Contacto";
}

<!-- Hero Section -->
<section class="contact-hero">
    <div class="container">
        <h1 class="display-3 mb-4 text-white">Contáctanos</h1>
        <p class="lead mb-0 text-white">Estamos aquí para ayudarte y responder todas tus preguntas</p>
    </div>
</section>

<div class="container">
    <div class="row mb-5">
        <!-- Información de Contacto -->
        <div class="col-md-4 mb-4">
            <div class="contact-info-card text-center">
                <div class="contact-icon bg-green">
                    <i class="fas fa-map-marker-alt text-white"></i>
                </div>
                <h4 class="text-brown">Dirección</h4>
                <p class="text-brown">@(ViewBag.Direccion ?? "Av. Amazonas N23-45 y Roca")</p>
                <p class="text-secondary">Quito, Ecuador</p>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="contact-info-card text-center">
                <div class="contact-icon bg-green">
                    <i class="fas fa-phone text-white"></i>
                </div>
                <h4 class="text-brown">Teléfono</h4>
                <p class="text-brown">@(ViewBag.Telefono ?? "(02) 245-6789")</p>
                <p class="text-secondary">@(ViewBag.Horario ?? "Lun-Vie: 8:00 AM - 6:00 PM")</p>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="contact-info-card text-center">
                <div class="contact-icon bg-green">
                    <i class="fas fa-envelope text-white"></i>
                </div>
                <h4 class="text-brown">Email</h4>
                <p class="text-brown">@(ViewBag.Email ?? "contacto@refugiomascotas.ec")</p>
                <p class="text-secondary">Respuesta en 24-48 horas</p>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Formulario de Contacto -->
        <div class="col-lg-8 mb-5">
            <div class="contact-form">
                <h3 class="mb-4 text-brown">Envíanos un Mensaje</h3>
                <p class="text-secondary mb-4">Completa el formulario y nos pondremos en contacto contigo lo antes posible.</p>

                <form id="contactForm">
                    @Html.AntiForgeryToken()

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="nombre" class="text-brown">Nombre Completo *</label>
                                <input type="text" class="form-control border-green" id="nombre" name="nombre" required>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="email" class="text-brown">Email *</label>
                                <input type="email" class="form-control border-green" id="email" name="email" required>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="telefono" class="text-brown">Teléfono</label>
                                <input type="tel" class="form-control border-green" id="telefono" name="telefono">
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="asunto" class="text-brown">Asunto *</label>
                                <select class="form-control border-green" id="asunto" name="asunto" required>
                                    <option value="">Seleccionar asunto</option>
                                    <option value="Adopción">Información sobre adopción</option>
                                    <option value="Donación">Consulta sobre donaciones</option>
                                    <option value="Voluntariado">Ser voluntario</option>
                                    <option value="Reporte">Reportar animal en peligro</option>
                                    <option value="Otro">Otro</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="mensaje" class="text-brown">Mensaje *</label>
                        <textarea class="form-control border-green" id="mensaje" name="mensaje" rows="5" required
                                  placeholder="Por favor, describe tu consulta o comentario en detalle..."></textarea>
                    </div>

                    <div class="form-group">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="newsletter" name="newsletter">
                            <label class="form-check-label text-secondary" for="newsletter">
                                Deseo recibir información sobre actividades y novedades del refugio
                            </label>
                        </div>
                    </div>

                    <div class="text-center">
                        <button type="submit" class="btn btn-green text-white btn-lg px-5">
                            <i class="fas fa-paper-plane"></i> Enviar Mensaje
                        </button>
                    </div>
                </form>
            </div>

            <!-- Contacto de Emergencia -->
            <div class="emergency-contact">
                <h3><i class="fas fa-exclamation-triangle"></i> Contacto de Emergencia</h3>
                <p>Para reportar animales en peligro inminente o situaciones de emergencia:</p>
                <div class="row">
                    <div class="col-md-6">
                        <h5><i class="fas fa-phone"></i> Rescates 24/7</h5>
                        <p class="mb-0">099-EMERGENCIA (363-734)</p>
                    </div>
                    <div class="col-md-6">
                        <h5><i class="fas fa-ambulance"></i> Veterinaria de Emergencia</h5>
                        <p class="mb-0">02-245-6789</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Mapa y Horarios -->
        <div class="col-lg-4">
            <!-- Mapa -->
            <div class="mb-5">
                <h4 class="mb-3 text-brown">Nuestra Ubicación</h4>
                <div class="map-container">
                    <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3989.785150196058!2d-78.470588!3d-0.1807!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x91d59a75a6d2e8a7%3A0x2a1c6b5e6c5b5e6c!2sQuito%2C%20Ecuador!5e0!3m2!1ses!2ses!4v1623456789012!5m2!1ses!2ses"
                            width="100%"
                            height="400"
                            style="border:0;"
                            allowfullscreen=""
                            loading="lazy">
                    </iframe>
                </div>
            </div>

            <!-- Horarios de Atención -->
            <div class="card border-green shadow-hover mb-4">
                <div class="card-body">
                    <h4 class="card-title mb-4 text-brown"><i class="fas fa-clock text-green"></i> Horarios de Atención</h4>
                    <ul class="business-hours">
                        <li class="text-brown">
                            <strong>Lunes - Viernes</strong>
                            <span class="float-right text-secondary">8:00 AM - 6:00 PM</span>
                        </li>
                        <li class="text-brown">
                            <strong>Sábados</strong>
                            <span class="float-right text-secondary">9:00 AM - 2:00 PM</span>
                        </li>
                        <li class="text-brown">
                            <strong>Domingos</strong>
                            <span class="float-right text-secondary">Emergencias solo</span>
                        </li>
                        <li class="text-brown">
                            <strong>Adopciones</strong>
                            <span class="float-right text-secondary">Con cita previa</span>
                        </li>
                        <li class="text-brown">
                            <strong>Visitas al Refugio</strong>
                            <span class="float-right text-secondary">10:00 AM - 4:00 PM</span>
                        </li>
                    </ul>
                </div>
            </div>

            <!-- Redes Sociales -->
            <div class="card border-green shadow-hover">
                <div class="card-body text-center">
                    <h4 class="card-title mb-4 text-brown"><i class="fas fa-share-alt text-green"></i> Síguenos</h4>
                    <div class="social-links">
                        <a href="#" class="btn btn-circle btn-lg mx-1 bg-green text-white">
                            <i class="fab fa-facebook-f"></i>
                        </a>
                        <a href="#" class="btn btn-circle btn-lg mx-1 bg-green text-white">
                            <i class="fab fa-twitter"></i>
                        </a>
                        <a href="#" class="btn btn-circle btn-lg mx-1 bg-green text-white">
                            <i class="fab fa-instagram"></i>
                        </a>
                        <a href="#" class="btn btn-circle btn-lg mx-1 bg-green text-white">
                            <i class="fab fa-whatsapp"></i>
                        </a>
                    </div>
                    <p class="text-secondary mt-3 mb-0">@("@")RefugioMascotasEC</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Preguntas Frecuentes -->
<section class="py-5 bg-light-mint">
    <div class="container">
        <h2 class="text-center mb-5 text-brown">Preguntas Frecuentes</h2>
        <div class="row">
            <div class="col-md-6">
                <div class="accordion" id="faqAccordion">
                    <div class="card border-green mb-2">
                        <div class="card-header bg-green" id="headingOne">
                            <h5 class="mb-0">
                                <button class="btn btn-link text-white" type="button" data-toggle="collapse" data-target="#collapseOne">
                                    ¿Cómo puedo adoptar una mascota?
                                </button>
                            </h5>
                        </div>
                        <div id="collapseOne" class="collapse show" data-parent="#faqAccordion">
                            <div class="card-body text-secondary">
                                Visita nuestra sección de mascotas disponibles, llena el formulario de adopción
                                y nuestro equipo se pondrá en contacto para coordinar una entrevista y visita.
                            </div>
                        </div>
                    </div>

                    <div class="card border-green mb-2">
                        <div class="card-header bg-green" id="headingTwo">
                            <h5 class="mb-0">
                                <button class="btn btn-link text-white collapsed" type="button" data-toggle="collapse" data-target="#collapseTwo">
                                    ¿Qué incluye el proceso de adopción?
                                </button>
                            </h5>
                        </div>
                        <div id="collapseTwo" class="collapse" data-parent="#faqAccordion">
                            <div class="card-body text-secondary">
                                Incluye entrevista, verificación de condiciones del hogar, firma de contrato,
                                esterilización, vacunación y seguimiento post-adopción.
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="accordion" id="faqAccordion2">
                    <div class="card border-green mb-2">
                        <div class="card-header bg-green" id="headingThree">
                            <h5 class="mb-0">
                                <button class="btn btn-link text-white" type="button" data-toggle="collapse" data-target="#collapseThree">
                                    ¿Puedo visitar el refugio?
                                </button>
                            </h5>
                        </div>
                        <div id="collapseThree" class="collapse show" data-parent="#faqAccordion2">
                            <div class="card-body text-secondary">
                                Sí, puedes visitarnos de lunes a viernes de 10:00 AM a 4:00 PM.
                                Recomendamos agendar cita previa.
                            </div>
                        </div>
                    </div>

                    <div class="card border-green mb-2">
                        <div class="card-header bg-green" id="headingFour">
                            <h5 class="mb-0">
                                <button class="btn btn-link text-white collapsed" type="button" data-toggle="collapse" data-target="#collapseFour">
                                    ¿Cómo puedo ayudar como voluntario?
                                </button>
                            </h5>
                        </div>
                        <div id="collapseFour" class="collapse" data-parent="#faqAccordion2">
                            <div class="card-body text-secondary">
                                Regístrate en nuestro sistema, asiste a la inducción y elige entre
                                diversas actividades: paseos, limpieza, socialización, eventos, etc.
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Styles {
    <style>
        .contact-hero {
            background: linear-gradient(rgba(151, 199, 139, 0.8), rgba(242, 201, 109, 0.8)), url('/Content/images/contact-hero.jpg');
            background-size: cover;
            background-position: center;
            padding: 100px 0;
            margin-bottom: 60px;
            border-radius: 10px;
        }

        .contact-info-card {
            background: white;
            border-radius: 10px;
            padding: 30px;
            box-shadow: 0 5px 15px rgba(151, 199, 139, 0.1);
            margin-bottom: 30px;
            height: 100%;
            transition: transform 0.3s;
            border: 2px solid #97C78B;
        }

            .contact-info-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 10px 25px rgba(151, 199, 139, 0.2);
                border-color: #86b57a;
            }

        .contact-icon {
            font-size: 2.5em;
            width: 70px;
            height: 70px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
        }

        .contact-form {
            background: white;
            border-radius: 15px;
            padding: 40px;
            box-shadow: 0 10px 30px rgba(151, 199, 139, 0.1);
            border: 2px solid #97C78B;
        }

        .map-container {
            border-radius: 10px;
            overflow: hidden;
            box-shadow: 0 5px 15px rgba(151, 199, 139, 0.1);
            height: 400px;
            border: 2px solid #97C78B;
        }

        iframe {
            width: 100%;
            height: 100%;
            border: none;
        }

        .business-hours {
            list-style: none;
            padding: 0;
        }

            .business-hours li {
                padding: 10px 0;
                border-bottom: 1px solid #F2E9D8;
            }

                .business-hours li:last-child {
                    border-bottom: none;
                }

        .emergency-contact {
            background: linear-gradient(135deg, #FBCDC0 0%, #F2C66D 100%);
            color: #5C4B43;
            border-radius: 15px;
            padding: 30px;
            margin-top: 30px;
            border: 2px solid #97C78B;
        }

        .btn-circle {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        /* Responsive */
        @@media (max-width: 768px) {
            .contact-hero {
                padding: 60px 0;
            }

            .contact-form {
                padding: 25px;
            }

            .contact-info-card {
                padding: 20px;
            }

            .map-container {
                height: 300px;
            }

            .emergency-contact {
                padding: 20px;
            }

            .btn-circle {
                width: 40px;
                height: 40px;
                margin: 5px;
            }

                .btn-circle i {
                    font-size: 1rem;
                }
        }

        /* Placeholder para imagen de contacto si no existe */
        .contact-hero {
            position: relative;
        }

            .contact-hero:before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                background: linear-gradient(135deg, #97C78B 0%, #F2C66D 100%);
                z-index: 0;
                border-radius: 10px;
            }

            .contact-hero .container {
                position: relative;
                z-index: 1;
            }

        /* Mejoras de formulario */
        .form-control.border-green:focus {
            border-color: #86b57a;
            box-shadow: 0 0 0 0.2rem rgba(151, 199, 139, 0.25);
        }
    </style>
}

@section Scripts {
    <script>
        $(document).ready(function () {
            // Inicializar acordeón
            $('.collapse').collapse();
        });
    </script>
}