@{
    ViewBag.Title = "Contacto - ADOPTAMANÍA";
}

<!-- Hero Section con imagen de fondo -->
<section class="contact-hero py-5">
    <div class="container text-center">
        <h1 class="display-3 mb-4 text-white">Contáctanos</h1>
        <p class="lead mb-0 text-white">Estamos aquí para ayudarte y responder todas tus preguntas</p>
    </div>
</section>

<div class="container">
    <!-- Tarjetas de Información de Contacto (con imágenes de fondo) -->
    <div class="row mb-5">
        <div class="col-md-4 mb-4">
            <div class="contact-info-card tarjeta-con-fondo" style="background-image: url('https://images.unsplash.com/photo-1509356843152-3e7d96241e11?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80');">
                <div class="contact-icon bg-green">
                    <i class="fas fa-map-marker-alt text-white"></i>
                </div>
                <h4 class="text-white">Dirección</h4>
                <p class="text-white">@(ViewBag.Direccion ?? "Av. Amazonas N23-45 y Roca")</p>
                <p class="text-white">Quito, Ecuador</p>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="contact-info-card tarjeta-con-fondo" style="background-image: url('https://images.unsplash.com/photo-1573497019940-1c28c88b4f3e?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80');">
                <div class="contact-icon bg-green">
                    <i class="fas fa-phone text-white"></i>
                </div>
                <h4 class="text-white">Teléfono</h4>
                <p class="text-white">@(ViewBag.Telefono ?? "(02) 245-6789")</p>
                <p class="text-white">@(ViewBag.Horario ?? "Lun-Vie: 8:00 AM - 6:00 PM")</p>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="contact-info-card tarjeta-con-fondo" style="background-image: url('https://images.unsplash.com/photo-1516387938699-a93567ec168e?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80');">
                <div class="contact-icon bg-green">
                    <i class="fas fa-envelope text-white"></i>
                </div>
                <h4 class="text-white">Email</h4>
                <p class="text-white">@(ViewBag.Email ?? "contacto@adoptamania.ec")</p>
                <p class="text-white">Respuesta en 24-48 horas</p>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Formulario de Contacto (sin cambios, solo estilos) -->
        <div class="col-lg-8 mb-5">
            <div class="contact-form">
                <h3 class="mb-4 text-brown">Envíanos un Mensaje</h3>
                <p class="text-secondary mb-4">Completa el formulario y nos pondremos en contacto contigo lo antes posible.</p>

                <form id="contactForm">
                    @Html.AntiForgeryToken()

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="nombre" class="text-brown">Nombre Completo *</label>
                                <input type="text" class="form-control border-green" id="nombre" name="nombre" required>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="email" class="text-brown">Email *</label>
                                <input type="email" class="form-control border-green" id="email" name="email" required>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="telefono" class="text-brown">Teléfono</label>
                                <input type="tel" class="form-control border-green" id="telefono" name="telefono">
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="asunto" class="text-brown">Asunto *</label>
                                <select class="form-control border-green" id="asunto" name="asunto" required>
                                    <option value="">Seleccionar asunto</option>
                                    <option value="Adopción">Información sobre adopción</option>
                                    <option value="Donación">Consulta sobre donaciones</option>
                                    <option value="Voluntariado">Ser voluntario</option>
                                    <option value="Reporte">Reportar animal en peligro</option>
                                    <option value="Otro">Otro</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="mensaje" class="text-brown">Mensaje *</label>
                        <textarea class="form-control border-green" id="mensaje" name="mensaje" rows="5" required
                                  placeholder="Por favor, describe tu consulta o comentario en detalle..."></textarea>
                    </div>

                    <div class="form-group">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="newsletter" name="newsletter">
                            <label class="form-check-label text-secondary" for="newsletter">
                                Deseo recibir información sobre actividades y novedades del refugio
                            </label>
                        </div>
                    </div>

                    <div class="text-center">
                        <button type="submit" class="btn btn-green text-white btn-lg px-5">
                            <i class="fas fa-paper-plane"></i> Enviar Mensaje
                        </button>
                    </div>
                </form>
            </div>

            <!-- Contacto de Emergencia (rediseñado) -->
            <div class="emergency-contact">
                <h3 class="text-white"><i class="fas fa-exclamation-triangle"></i> Contacto de Emergencia</h3>
                <p class="text-white">Para reportar animales en peligro inminente o situaciones de emergencia:</p>
                <div class="row">
                    <div class="col-md-6">
                        <h5 class="text-white"><i class="fas fa-phone"></i> Rescates 24/7</h5>
                        <p class="mb-0 text-white">099-EMERGENCIA (363-734)</p>
                    </div>
                    <div class="col-md-6">
                        <h5 class="text-white"><i class="fas fa-ambulance"></i> Veterinaria de Emergencia</h5>
                        <p class="mb-0 text-white">02-245-6789</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Mapa y Horarios (con mejoras visuales) -->
        <div class="col-lg-4">
            <!-- Mapa con estilo -->
            <div class="mb-5">
                <h4 class="mb-3 text-brown">Nuestra Ubicación</h4>
                <div class="map-container">
                    <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3989.785150196058!2d-78.470588!3d-0.1807!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x91d59a75a6d2e8a7%3A0x2a1c6b5e6c5b5e6c!2sQuito%2C%20Ecuador!5e0!3m2!1ses!2ses!4v1623456789012!5m2!1ses!2ses"
                            width="100%"
                            height="400"
                            style="border:0;"
                            allowfullscreen=""
                            loading="lazy">
                    </iframe>
                </div>
            </div>

            <!-- Horarios de Atención (con imagen de fondo) -->
            <div class="card border-0 shadow-hover tarjeta-con-fondo mb-4" style="background-image: url('https://images.unsplash.com/photo-1516738901171-8eb4fc13bd20?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80');">
                <div class="card-body">
                    <h4 class="card-title mb-4 text-white"><i class="fas fa-clock text-white"></i> Horarios de Atención</h4>
                    <ul class="business-hours">
                        <li class="text-white">
                            <strong>Lunes - Viernes</strong>
                            <span class="float-right">8:00 AM - 6:00 PM</span>
                        </li>
                        <li class="text-white">
                            <strong>Sábados</strong>
                            <span class="float-right">9:00 AM - 2:00 PM</span>
                        </li>
                        <li class="text-white">
                            <strong>Domingos</strong>
                            <span class="float-right">Emergencias solo</span>
                        </li>
                        <li class="text-white">
                            <strong>Adopciones</strong>
                            <span class="float-right">Con cita previa</span>
                        </li>
                        <li class="text-white">
                            <strong>Visitas al Refugio</strong>
                            <span class="float-right">10:00 AM - 4:00 PM</span>
                        </li>
                    </ul>
                </div>
            </div>

            <!-- Redes Sociales (con imagen de fondo) -->
            <div class="card border-0 shadow-hover tarjeta-con-fondo" style="background-image: url('https://images.unsplash.com/photo-1611162617213-7d7a39e9b1d7?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80');">
                <div class="card-body text-center">
                    <h4 class="card-title mb-4 text-white"><i class="fas fa-share-alt text-white"></i> Síguenos</h4>
                    <div class="social-links">
                        <a href="#" class="btn btn-circle btn-lg mx-1" style="background-color: var(--verde-menta); color: white;">
                            <i class="fab fa-facebook-f"></i>
                        </a>
                        <a href="#" class="btn btn-circle btn-lg mx-1" style="background-color: var(--verde-menta); color: white;">
                            <i class="fab fa-twitter"></i>
                        </a>
                        <a href="#" class="btn btn-circle btn-lg mx-1" style="background-color: var(--verde-menta); color: white;">
                            <i class="fab fa-instagram"></i>
                        </a>
                        <a href="#" class="btn btn-circle btn-lg mx-1" style="background-color: var(--verde-menta); color: white;">
                            <i class="fab fa-whatsapp"></i>
                        </a>
                    </div>
                    <p class="text-white mt-3 mb-0">@("@")ADOPTAMANÍA</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Preguntas Frecuentes (rediseñadas) -->
<section class="py-5 bg-beige">
    <div class="container">
        <h2 class="text-center mb-5 text-brown">Preguntas Frecuentes</h2>
        <div class="row">
            <div class="col-md-6">
                <div class="accordion" id="faqAccordion">
                    <div class="card border-0 shadow-hover mb-3 tarjeta-con-fondo" style="background-image: url('https://images.unsplash.com/photo-1548199973-03cce0bbc87b?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80');">
                        <div class="card-header bg-transparent border-0" id="headingOne">
                            <h5 class="mb-0">
                                <button class="btn btn-link text-white" type="button" data-toggle="collapse" data-target="#collapseOne">
                                    ¿Cómo puedo adoptar una mascota?
                                </button>
                            </h5>
                        </div>
                        <div id="collapseOne" class="collapse show" data-parent="#faqAccordion">
                            <div class="card-body text-white">
                                Visita nuestra sección de mascotas disponibles, llena el formulario de adopción
                                y nuestro equipo se pondrá en contacto para coordinar una entrevista y visita.
                            </div>
                        </div>
                    </div>

                    <div class="card border-0 shadow-hover mb-3 tarjeta-con-fondo" style="background-image: url('https://images.unsplash.com/photo-1543852786-1cf6624b9987?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80');">
                        <div class="card-header bg-transparent border-0" id="headingTwo">
                            <h5 class="mb-0">
                                <button class="btn btn-link text-white collapsed" type="button" data-toggle="collapse" data-target="#collapseTwo">
                                    ¿Qué incluye el proceso de adopción?
                                </button>
                            </h5>
                        </div>
                        <div id="collapseTwo" class="collapse" data-parent="#faqAccordion">
                            <div class="card-body text-white">
                                Incluye entrevista, verificación de condiciones del hogar, firma de contrato,
                                esterilización, vacunación y seguimiento post-adopción.
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="accordion" id="faqAccordion2">
                    <div class="card border-0 shadow-hover mb-3 tarjeta-con-fondo" style="background-image: url('https://images.unsplash.com/photo-1511632765486-a01980e01a18?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80');">
                        <div class="card-header bg-transparent border-0" id="headingThree">
                            <h5 class="mb-0">
                                <button class="btn btn-link text-white" type="button" data-toggle="collapse" data-target="#collapseThree">
                                    ¿Puedo visitar el refugio?
                                </button>
                            </h5>
                        </div>
                        <div id="collapseThree" class="collapse show" data-parent="#faqAccordion2">
                            <div class="card-body text-white">
                                Sí, puedes visitarnos de lunes a viernes de 10:00 AM a 4:00 PM.
                                Recomendamos agendar cita previa.
                            </div>
                        </div>
                    </div>

                    <div class="card border-0 shadow-hover mb-3 tarjeta-con-fondo" style="background-image: url('https://images.unsplash.com/photo-1548199973-03cce0bbc87b?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80');">
                        <div class="card-header bg-transparent border-0" id="headingFour">
                            <h5 class="mb-0">
                                <button class="btn btn-link text-white collapsed" type="button" data-toggle="collapse" data-target="#collapseFour">
                                    ¿Cómo puedo ayudar como voluntario?
                                </button>
                            </h5>
                        </div>
                        <div id="collapseFour" class="collapse" data-parent="#faqAccordion2">
                            <div class="card-body text-white">
                                Regístrate en nuestro sistema, asiste a la inducción y elige entre
                                diversas actividades: paseos, limpieza, socialización, eventos, etc.
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Styles {
    <style>
        /* Hero */
        .contact-hero {
            background: linear-gradient(135deg, rgba(151,199,139,0.9), rgba(242,198,109,0.8)), url('https://images.unsplash.com/photo-1511632765486-a01980e01a18?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80');
            background-size: cover;
            background-position: center;
            border-radius: 0 0 30px 30px;
            margin-bottom: 2rem;
        }

        /* Tarjetas de información de contacto */
        .contact-info-card {
            background-size: cover;
            background-position: center;
            border-radius: 20px;
            padding: 30px;
            height: 100%;
            transition: transform 0.3s ease;
            position: relative;
            z-index: 0;
            overflow: hidden;
        }

            .contact-info-card::after {
                content: "";
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                background: linear-gradient(135deg, rgba(151,199,139,0.7), rgba(242,198,109,0.7));
                z-index: 1;
                pointer-events: none;
            }

            .contact-info-card > * {
                position: relative;
                z-index: 2;
            }

            .contact-info-card .contact-icon {
                font-size: 2.5em;
                width: 70px;
                height: 70px;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                margin: 0 auto 20px;
                background-color: var(--verde-menta);
                border: 3px solid white;
            }

            .contact-info-card h4 {
                color: white !important;
                text-shadow: 0 2px 4px rgba(0,0,0,0.2);
            }

            .contact-info-card p {
                color: white !important;
                text-shadow: 0 1px 2px rgba(0,0,0,0.2);
            }

        /* Formulario */
        .contact-form {
            background: white;
            border-radius: 20px;
            padding: 40px;
            box-shadow: 0 10px 30px rgba(151,199,139,0.1);
            border: 2px solid var(--verde-menta);
        }

        .form-control.border-green {
            border: 2px solid var(--verde-menta);
            border-radius: 12px;
            padding: 12px;
        }

            .form-control.border-green:focus {
                border-color: #86b57a;
                box-shadow: 0 0 0 0.2rem rgba(151,199,139,0.25);
            }

        /* Contacto de Emergencia */
        .emergency-contact {
            background: linear-gradient(135deg, var(--rosado-claro), var(--amarillo-pastel));
            border-radius: 20px;
            padding: 30px;
            margin-top: 30px;
            border: 2px solid var(--verde-menta);
            color: white;
        }

            .emergency-contact h3, .emergency-contact p, .emergency-contact h5 {
                color: white !important;
            }

        /* Mapa */
        .map-container {
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(151,199,139,0.15);
            height: 400px;
            border: 4px solid var(--verde-menta);
        }

        /* Horarios y Redes (usando la misma clase de tarjeta con fondo) */
        .business-hours {
            list-style: none;
            padding: 0;
        }

            .business-hours li {
                padding: 10px 0;
                border-bottom: 1px solid rgba(255,255,255,0.3);
            }

                .business-hours li:last-child {
                    border-bottom: none;
                }

                .business-hours li strong {
                    font-weight: 600;
                }

        /* Redes sociales */
        .btn-circle {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            transition: transform 0.2s ease;
        }

            .btn-circle:hover {
                transform: scale(1.1);
            }

        /* Acordeón FAQ */
        .card.tarjeta-con-fondo {
            position: relative;
            z-index: 0;
            overflow: hidden;
        }

            .card.tarjeta-con-fondo::after {
                content: "";
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                background: linear-gradient(135deg, rgba(151,199,139,0.7), rgba(242,198,109,0.7));
                z-index: 1;
                pointer-events: none;
            }

            .card.tarjeta-con-fondo .card-header,
            .card.tarjeta-con-fondo .card-body {
                position: relative;
                z-index: 2;
            }

            .card.tarjeta-con-fondo .btn-link {
                color: white !important;
                text-decoration: none;
                font-weight: 600;
            }

                .card.tarjeta-con-fondo .btn-link:hover {
                    text-decoration: underline;
                }

        /* Responsive */
        @@media (max-width: 768px) {
            .contact-hero {
                border-radius: 0 0 20px 20px;
            }

            .contact-form {
                padding: 25px;
            }

            .contact-info-card {
                padding: 20px;
            }

            .map-container {
                height: 300px;
            }

            .btn-circle {
                width: 40px;
                height: 40px;
                margin: 5px;
            }
        }
    </style>
}