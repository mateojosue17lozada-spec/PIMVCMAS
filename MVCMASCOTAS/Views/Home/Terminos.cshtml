@{
    ViewBag.Title = "Términos y Condiciones - ADOPTAMANÍA";
}

<!-- Hero Section con imagen de fondo -->
<section class="terms-hero py-5">
    <div class="container text-center">
        <i class="fas fa-file-contract fa-4x text-white mb-4"></i>
        <h1 class="display-4 mb-3 text-white">Términos y Condiciones</h1>
        <p class="lead mb-0 text-white">Por favor, lee detenidamente antes de usar nuestros servicios</p>
    </div>
</section>

<div class="container">
    <div class="row">
        <!-- Navegación de Términos (índice con iconos) -->
        <div class="col-md-3 mb-4">
            <div class="terms-index-card">
                <h5 class="text-brown mb-3"><i class="fas fa-list-ul text-green me-2"></i> Índice</h5>
                <nav class="nav flex-column nav-terms">
                    <a class="nav-link" href="#aceptacion"><i class="fas fa-check-circle text-green me-2"></i> 1. Aceptación</a>
                    <a class="nav-link" href="#servicios"><i class="fas fa-paw text-green me-2"></i> 2. Servicios</a>
                    <a class="nav-link" href="#adopcion"><i class="fas fa-home text-green me-2"></i> 3. Adopción</a>
                    <a class="nav-link" href="#donaciones"><i class="fas fa-hand-holding-heart text-green me-2"></i> 4. Donaciones</a>
                    <a class="nav-link" href="#privacidad"><i class="fas fa-lock text-green me-2"></i> 5. Privacidad</a>
                    <a class="nav-link" href="#responsabilidades"><i class="fas fa-shield-alt text-green me-2"></i> 6. Responsabilidades</a>
                    <a class="nav-link" href="#propiedad"><i class="fas fa-copyright text-green me-2"></i> 7. Propiedad</a>
                    <a class="nav-link" href="#modificaciones"><i class="fas fa-edit text-green me-2"></i> 8. Modificaciones</a>
                    <a class="nav-link" href="#jurisdiccion"><i class="fas fa-gavel text-green me-2"></i> 9. Jurisdicción</a>
                </nav>
            </div>
        </div>

        <!-- Contenido de Términos -->
        <div class="col-md-9">
            <div class="terms-container">
                <!-- Fecha de actualización -->
                <div class="last-updated d-flex align-items-center mb-5">
                    <i class="fas fa-calendar-alt fa-2x text-green me-3"></i>
                    <div>
                        <p class="mb-0 text-brown"><strong>Última actualización:</strong> @DateTime.Now.ToString("dd 'de' MMMM 'de' yyyy")</p>
                        <p class="mb-0 text-secondary"><small>Versión 3.2 - Vigente desde el 1 de Enero de 2024</small></p>
                    </div>
                </div>

                <!-- Sección 1: Aceptación -->
                <div class="terms-section" id="aceptacion">
                    <h3 class="terms-title"><i class="fas fa-check-circle text-green me-2"></i> 1. Aceptación de los Términos</h3>
                    <p class="text-secondary">
                        Al acceder y utilizar el sistema web de ADOPTAMANÍA, usted acepta estar sujeto a estos Términos y Condiciones en su totalidad.
                        Si no está de acuerdo con alguna parte de estos términos, debe abstenerse de usar nuestros servicios.
                    </p>
                    <div class="acceptance-box">
                        <div class="d-flex">
                            <i class="fas fa-exclamation-triangle fa-2x text-yellow me-3"></i>
                            <div>
                                <h6 class="text-brown mb-2">Importante:</h6>
                                <p class="mb-0 text-secondary">
                                    El registro en el sistema implica la aceptación explícita de estos términos.
                                    Para usuarios menores de 18 años, se requiere autorización de padres o tutores.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Sección 2: Servicios -->
                <div class="terms-section" id="servicios">
                    <h3 class="terms-title"><i class="fas fa-paw text-green me-2"></i> 2. Servicios Ofrecidos</h3>
                    <p class="text-secondary">Nuestra plataforma proporciona los siguientes servicios:</p>
                    <div class="row g-3 mt-3">
                        <div class="col-md-6">
                            <div class="service-item d-flex align-items-start">
                                <i class="fas fa-check-circle text-green me-2 mt-1"></i>
                                <span class="text-secondary">Gestión de adopción responsable de mascotas</span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="service-item d-flex align-items-start">
                                <i class="fas fa-check-circle text-green me-2 mt-1"></i>
                                <span class="text-secondary">Sistema de donaciones y apadrinamiento</span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="service-item d-flex align-items-start">
                                <i class="fas fa-check-circle text-green me-2 mt-1"></i>
                                <span class="text-secondary">Reporte de mascotas perdidas y en riesgo</span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="service-item d-flex align-items-start">
                                <i class="fas fa-check-circle text-green me-2 mt-1"></i>
                                <span class="text-secondary">Programa de voluntariado</span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="service-item d-flex align-items-start">
                                <i class="fas fa-check-circle text-green me-2 mt-1"></i>
                                <span class="text-secondary">Tienda solidaria de productos para mascotas</span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="service-item d-flex align-items-start">
                                <i class="fas fa-check-circle text-green me-2 mt-1"></i>
                                <span class="text-secondary">Información sobre cuidado y bienestar animal</span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="service-item d-flex align-items-start">
                                <i class="fas fa-check-circle text-green me-2 mt-1"></i>
                                <span class="text-secondary">Seguimiento post-adopción y asesoría veterinaria</span>
                            </div>
                        </div>
                    </div>
                    <p class="mt-4 text-secondary">
                        Todos los servicios se ofrecen de acuerdo con la <strong class="text-brown">Ley Orgánica de Bienestar Animal (LOBA)</strong>
                        y regulaciones ecuatorianas vigentes.
                    </p>
                </div>

                <!-- Sección 3: Adopción -->
                <div class="terms-section" id="adopcion">
                    <h3 class="terms-title"><i class="fas fa-home text-green me-2"></i> 3. Proceso de Adopción</h3>
                    <p class="text-secondary">El proceso de adopción incluye las siguientes etapas y condiciones:</p>

                    <div class="sub-section">
                        <h6 class="text-brown"><i class="fas fa-user-check text-green me-2"></i> 3.1 Requisitos del Adoptante</h6>
                        <ul class="terms-list">
                            <li><i class="fas fa-check-circle text-green me-2"></i> Ser mayor de 21 años</li>
                            <li><i class="fas fa-check-circle text-green me-2"></i> Completar formulario de solicitud con información veraz</li>
                            <li><i class="fas fa-check-circle text-green me-2"></i> Contar con vivienda estable y adecuada para la mascota</li>
                            <li><i class="fas fa-check-circle text-green me-2"></i> Aceptar visita domiciliaria de evaluación</li>
                            <li><i class="fas fa-check-circle text-green me-2"></i> Proporcionar referencias personales verificables</li>
                        </ul>
                    </div>

                    <div class="sub-section mt-4">
                        <h6 class="text-brown"><i class="fas fa-handshake text-green me-2"></i> 3.2 Compromisos del Adoptante</h6>
                        <ul class="terms-list">
                            <li><i class="fas fa-check-circle text-green me-2"></i> Proporcionar alimentación adecuada y agua fresca</li>
                            <li><i class="fas fa-check-circle text-green me-2"></i> Ofrecer atención veterinaria regular y preventiva</li>
                            <li><i class="fas fa-check-circle text-green me-2"></i> Esterilizar a la mascota si aún no lo está</li>
                            <li><i class="fas fa-check-circle text-green me-2"></i> No utilizar a la mascota para reproducción</li>
                            <li><i class="fas fa-check-circle text-green me-2"></i> Permitir seguimiento post-adopción por 12 meses</li>
                            <li><i class="fas fa-check-circle text-green me-2"></i> Devolver la mascota al refugio si no puede continuar con su cuidado</li>
                        </ul>
                    </div>

                    <div class="sub-section mt-4">
                        <h6 class="text-brown"><i class="fas fa-shield-alt text-green me-2"></i> 3.3 Derechos del Refugio</h6>
                        <ul class="terms-list warning-list">
                            <li><i class="fas fa-exclamation-triangle text-yellow me-2"></i> Rechazar solicitudes sin obligación de justificación</li>
                            <li><i class="fas fa-exclamation-triangle text-yellow me-2"></i> Suspender el proceso si se detecta información falsa</li>
                            <li><i class="fas fa-exclamation-triangle text-yellow me-2"></i> Recuperar la mascota en caso de incumplimiento del contrato</li>
                            <li><i class="fas fa-exclamation-triangle text-yellow me-2"></i> Denegar adopción a personas con antecedentes de maltrato animal</li>
                        </ul>
                    </div>
                </div>

                <!-- Sección 4: Donaciones -->
                <div class="terms-section" id="donaciones">
                    <h3 class="terms-title"><i class="fas fa-hand-holding-heart text-green me-2"></i> 4. Donaciones y Apadrinamiento</h3>

                    <div class="sub-section">
                        <h6 class="text-brown"><i class="fas fa-tag text-green me-2"></i> 4.1 Tipos de Donación</h6>
                        <ul class="terms-list">
                            <li><i class="fas fa-check-circle text-green me-2"></i> <strong>Donación Única:</strong> Contribución puntual sin compromiso de continuidad</li>
                            <li><i class="fas fa-check-circle text-green me-2"></i> <strong>Donación Recurrente:</strong> Contribución automática mensual</li>
                            <li><i class="fas fa-check-circle text-green me-2"></i> <strong>Apadrinamiento:</strong> Donación mensual específica para una mascota</li>
                        </ul>
                    </div>

                    <div class="sub-section mt-4">
                        <h6 class="text-brown"><i class="fas fa-piggy-bank text-green me-2"></i> 4.2 Uso de Fondos</h6>
                        <p class="text-secondary">Los fondos donados se destinan exclusivamente a:</p>
                        <ul class="terms-list">
                            <li><i class="fas fa-check-circle text-green me-2"></i> Atención veterinaria y medicamentos</li>
                            <li><i class="fas fa-check-circle text-green me-2"></i> Alimentación de mascotas rescatadas</li>
                            <li><i class="fas fa-check-circle text-green me-2"></i> Mantenimiento de instalaciones del refugio</li>
                            <li><i class="fas fa-check-circle text-green me-2"></i> Programas de esterilización comunitaria</li>
                            <li><i class="fas fa-check-circle text-green me-2"></i> Campañas de educación y concienciación</li>
                        </ul>
                    </div>

                    <div class="sub-section mt-4">
                        <h6 class="text-brown"><i class="fas fa-times-circle text-green me-2"></i> 4.3 Cancelación</h6>
                        <p class="text-secondary">
                            Las donaciones recurrentes pueden cancelarse en cualquier momento
                            con 5 días de anticipación al siguiente cargo. Los donativos no
                            son reembolsables salvo error de procesamiento.
                        </p>
                    </div>
                </div>

                <!-- Sección 5: Privacidad -->
                <div class="terms-section" id="privacidad">
                    <h3 class="terms-title"><i class="fas fa-lock text-green me-2"></i> 5. Privacidad y Protección de Datos</h3>
                    <p class="text-secondary">
                        Nos comprometemos a proteger su información personal de acuerdo con
                        la <strong class="text-brown">Ley Orgánica de Protección de Datos Personales</strong> de Ecuador.
                    </p>

                    <div class="row mt-4">
                        <div class="col-md-6">
                            <div class="privacy-card p-3 mb-3">
                                <h6 class="text-brown"><i class="fas fa-database text-green me-2"></i> Datos Recopilados</h6>
                                <ul class="terms-list small">
                                    <li><i class="fas fa-check-circle text-green me-2"></i> Información de registro (nombre, email, teléfono)</li>
                                    <li><i class="fas fa-check-circle text-green me-2"></i> Datos de adopción y evaluación</li>
                                    <li><i class="fas fa-check-circle text-green me-2"></i> Historial de donaciones y transacciones</li>
                                    <li><i class="fas fa-check-circle text-green me-2"></i> Información de reportes y voluntariado</li>
                                    <li><i class="fas fa-check-circle text-green me-2"></i> Dirección IP y datos de navegación</li>
                                </ul>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="privacy-card p-3 mb-3">
                                <h6 class="text-brown"><i class="fas fa-chart-line text-green me-2"></i> Uso de Datos</h6>
                                <ul class="terms-list small">
                                    <li><i class="fas fa-check-circle text-green me-2"></i> Procesar solicitudes de adopción y donaciones</li>
                                    <li><i class="fas fa-check-circle text-green me-2"></i> Mantener comunicación sobre su participación</li>
                                    <li><i class="fas fa-check-circle text-green me-2"></i> Mejorar nuestros servicios y experiencia de usuario</li>
                                    <li><i class="fas fa-check-circle text-green me-2"></i> Cumplir con obligaciones legales y regulatorias</li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <div class="acceptance-box mt-3">
                        <div class="d-flex">
                            <i class="fas fa-user-secret fa-2x text-green me-3"></i>
                            <p class="mb-0 text-secondary">
                                <strong class="text-brown">Confidencialidad:</strong> No compartimos información personal con terceros sin su consentimiento,
                                excepto cuando sea requerido por ley o para procesar transacciones financieras con entidades autorizadas.
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Sección 6: Responsabilidades -->
                <div class="terms-section" id="responsabilidades">
                    <h3 class="terms-title"><i class="fas fa-shield-alt text-green me-2"></i> 6. Limitación de Responsabilidad</h3>

                    <div class="sub-section">
                        <h6 class="text-brown"><i class="fas fa-user text-green me-2"></i> 6.1 Responsabilidad del Usuario</h6>
                        <ul class="terms-list warning-list">
                            <li><i class="fas fa-exclamation-triangle text-yellow me-2"></i> Proporcionar información veraz y actualizada</li>
                            <li><i class="fas fa-exclamation-triangle text-yellow me-2"></i> Mantener la confidencialidad de su cuenta y contraseña</li>
                            <li><i class="fas fa-exclamation-triangle text-yellow me-2"></i> Reportar uso no autorizado de su cuenta inmediatamente</li>
                            <li><i class="fas fa-exclamation-triangle text-yellow me-2"></i> Utilizar el sistema conforme a la ley y moralidad</li>
                        </ul>
                    </div>

                    <div class="sub-section mt-4">
                        <h6 class="text-brown"><i class="fas fa-exclamation-circle text-green me-2"></i> 6.2 Exclusión de Garantías</h6>
                        <p class="text-secondary">
                            El sistema se proporciona "tal cual" sin garantías de ningún tipo.
                            No garantizamos disponibilidad continua, corrección de errores o
                            seguridad absoluta contra accesos no autorizados.
                        </p>
                    </div>

                    <div class="sub-section mt-4">
                        <h6 class="text-brown"><i class="fas fa-balance-scale text-green me-2"></i> 6.3 Daños y Perjuicios</h6>
                        <p class="text-secondary">
                            En ningún caso el refugio será responsable por daños directos,
                            indirectos, incidentales o consecuentes resultantes del uso o
                            imposibilidad de uso del sistema.
                        </p>
                    </div>
                </div>

                <!-- Sección 7: Propiedad -->
                <div class="terms-section" id="propiedad">
                    <h3 class="terms-title"><i class="fas fa-copyright text-green me-2"></i> 7. Propiedad Intelectual</h3>
                    <p class="text-secondary">
                        Todo el contenido del sistema (diseño, código, logos, imágenes,
                        textos) es propiedad exclusiva de ADOPTAMANÍA o de sus licenciantes
                        y está protegido por leyes de propiedad intelectual ecuatorianas e internacionales.
                    </p>
                    <div class="alert alert-green mt-3">
                        <i class="fas fa-ban me-2"></i> Queda prohibida la reproducción, distribución, modificación o
                        uso comercial sin autorización expresa por escrito.
                    </div>
                </div>

                <!-- Sección 8: Modificaciones -->
                <div class="terms-section" id="modificaciones">
                    <h3 class="terms-title"><i class="fas fa-edit text-green me-2"></i> 8. Modificaciones a los Términos</h3>
                    <p class="text-secondary">
                        Nos reservamos el derecho de modificar estos Términos y Condiciones
                        en cualquier momento. Los cambios entrarán en vigencia 15 días después
                        de su publicación en el sistema.
                    </p>
                    <p class="text-secondary mt-3">
                        Se notificarán los cambios importantes por email a los usuarios
                        registrados. El uso continuado del sistema después de los cambios
                        constituye aceptación de los nuevos términos.
                    </p>
                </div>

                <!-- Sección 9: Jurisdicción -->
                <div class="terms-section" id="jurisdiccion">
                    <h3 class="terms-title"><i class="fas fa-gavel text-green me-2"></i> 9. Jurisdicción y Ley Aplicable</h3>
                    <p class="text-secondary">
                        Estos Términos se rigen por las leyes de la República del Ecuador.
                        Cualquier disputa relacionada con estos términos será resuelta en
                        los tribunales competentes de Quito, Ecuador.
                    </p>
                    <p class="text-secondary mt-3">
                        Para controversias relacionadas con transacciones electrónicas,
                        se aplicarán las disposiciones de la Ley de Comercio Electrónico,
                        Firmas Electrónicas y Mensajes de Datos.
                    </p>
                </div>

                <!-- Aceptación Final -->
                <div class="acceptance-box mt-5">
                    <div class="d-flex align-items-center">
                        <i class="fas fa-check-circle fa-3x text-green me-3"></i>
                        <div>
                            <p class="mb-2 text-brown fw-bold">
                                Al usar este sistema, reconozco haber leído, entendido
                                y aceptado todos los Términos y Condiciones establecidos.
                            </p>
                            <p class="mb-0 text-secondary">
                                Para preguntas o aclaraciones sobre estos términos, contacta a:
                                <a href="mailto:legal@adoptamania.ec" class="text-green">legal@adoptamania.ec</a>
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Botones de acción -->
            <div class="text-center mb-5">
                <a href="@Url.Action("Index", "Home")" class="btn btn-green text-white btn-lg me-3">
                    <i class="fas fa-home me-2"></i> Volver al Inicio
                </a>
                <button onclick="window.print()" class="btn btn-outline-green btn-lg">
                    <i class="fas fa-print me-2"></i> Imprimir Términos
                </button>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        /* Hero */
        .terms-hero {
            background: linear-gradient(135deg, rgba(151,199,139,0.9), rgba(242,198,109,0.8)), url('https://images.unsplash.com/photo-1585829365295-ab7cd400c167?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80');
            background-size: cover;
            background-position: center;
            border-radius: 0 0 30px 30px;
            margin-bottom: 2rem;
        }

        /* Índice lateral */
        .terms-index-card {
            background: white;
            border-radius: 20px;
            padding: 1.5rem;
            box-shadow: 0 8px 20px rgba(151,199,139,0.15);
            position: sticky;
            top: 20px;
            border: none;
        }

        .nav-terms .nav-link {
            color: var(--texto-oscuro);
            padding: 0.6rem 1rem;
            border-radius: 12px;
            margin-bottom: 0.2rem;
            transition: background-color 0.2s, color 0.2s;
            font-weight: 500;
        }

            .nav-terms .nav-link:hover {
                background-color: var(--rosado-claro);
                color: var(--texto-oscuro);
            }

            .nav-terms .nav-link.active {
                background-color: var(--verde-menta);
                color: white !important;
            }

                .nav-terms .nav-link.active i {
                    color: white !important;
                }

        /* Contenedor principal */
        .terms-container {
            background: white;
            border-radius: 24px;
            padding: 2.5rem;
            box-shadow: 0 10px 30px rgba(151,199,139,0.1);
            border: none;
        }

        /* Última actualización */
        .last-updated {
            background: var(--fondo-beige);
            border-radius: 16px;
            padding: 1rem 1.5rem;
            border-left: 5px solid var(--verde-menta);
        }

        /* Secciones */
        .terms-section {
            margin-bottom: 3rem;
            padding-bottom: 2rem;
            border-bottom: 2px solid var(--plomo-calido);
        }

            .terms-section:last-child {
                border-bottom: none;
            }

        .terms-title {
            color: var(--texto-oscuro);
            margin-bottom: 1.5rem;
            font-size: 1.8rem;
        }

        /* Subsecciones */
        .sub-section {
            margin-top: 2rem;
        }

            .sub-section h6 {
                font-size: 1.2rem;
                margin-bottom: 1rem;
            }

        /* Listas */
        .terms-list {
            list-style: none;
            padding-left: 0;
        }

            .terms-list li {
                margin-bottom: 0.8rem;
                display: flex;
                align-items: flex-start;
            }

                .terms-list li i {
                    margin-right: 0.8rem;
                    margin-top: 0.2rem;
                    flex-shrink: 0;
                }

        /* Servicios en dos columnas */
        .service-item {
            background: #f9f9f9;
            padding: 0.8rem 1rem;
            border-radius: 12px;
            transition: background-color 0.2s;
        }

            .service-item:hover {
                background: var(--fondo-beige);
            }

        /* Caja de aceptación */
        .acceptance-box {
            background: var(--fondo-beige);
            border-radius: 16px;
            padding: 1.5rem;
            border-left: 5px solid var(--verde-menta);
        }

        /* Tarjetas de privacidad */
        .privacy-card {
            background: #f9f9f9;
            border-radius: 16px;
            border: 1px solid var(--plomo-calido);
        }

        /* Alertas */
        .alert-green {
            background-color: rgba(151,199,139,0.1);
            border: 1px solid var(--verde-menta);
            color: var(--texto-oscuro);
            border-radius: 12px;
        }

        /* Responsive */
        @@media (max-width: 768px) {
            .terms-hero {
                border-radius: 0 0 20px 20px;
            }

            .terms-index-card {
                position: static;
                margin-bottom: 1.5rem;
            }

            .terms-container {
                padding: 1.5rem;
            }
        }

        /* Estilos para impresión */
        @@media print {
            .terms-hero {
                background: white !important;
                color: black !important;
                padding: 20px 0;
            }

                .terms-hero i, .terms-hero h1, .terms-hero p {
                    color: black !important;
                }

            .terms-index-card, .btn, footer {
                display: none !important;
            }

            .terms-container {
                box-shadow: none;
                padding: 0;
            }
        }
    </style>
}

@section Scripts {
    <script>
        $(document).ready(function () {
            // Scroll suave a secciones
            $('.nav-terms a').on('click', function (e) {
                e.preventDefault();
                var target = $(this).attr('href');
                $('html, body').animate({
                    scrollTop: $(target).offset().top - 100
                }, 500);
            });

            // Resaltar sección activa al hacer scroll
            $(window).on('scroll', function () {
                var scrollPos = $(document).scrollTop() + 120;
                $('.terms-section').each(function () {
                    var section = $(this);
                    var sectionId = section.attr('id');
                    var sectionTop = section.offset().top;
                    var sectionBottom = sectionTop + section.outerHeight();

                    if (scrollPos >= sectionTop && scrollPos < sectionBottom) {
                        $('.nav-terms a').removeClass('active');
                        $('.nav-terms a[href="#' + sectionId + '"]').addClass('active');
                    }
                });
            });

            // Activar primera sección por defecto
            if ($('.nav-terms a.active').length === 0) {
                $('.nav-terms a:first').addClass('active');
            }
        });
    </script>
}