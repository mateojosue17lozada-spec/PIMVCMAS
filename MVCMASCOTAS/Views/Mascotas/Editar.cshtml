@model MVCMASCOTAS.Models.ViewModels.MascotaViewModel

@{
    ViewBag.Title = $"Editar {Model.Nombre}";
    Layout = "~/Views/Shared/_Layout.cshtml";

    // ✅ Definir imagen actual AQUÍ para que sea accesible en todo el archivo
    string urlImagenActual = "/Content/images/no-image.png";
    if (!string.IsNullOrEmpty(Model.ImagenBase64))
    {
        urlImagenActual = Model.ImagenBase64;
    }
    else if (Model.ImagenPrincipal != null && Model.ImagenPrincipal.Length > 0)
    {
        urlImagenActual = MVCMASCOTAS.Helpers.ImageHelper.GetImageDataUri(Model.ImagenPrincipal);
    }
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2>
                    <i class="fas fa-edit text-warning"></i> Editar Mascota: <strong>@Model.Nombre</strong>
                </h2>
                <div>
                    <a href="@Url.Action("Detalle", "Mascotas", new { id = Model.MascotaId })" class="btn btn-info me-2">
                        <i class="fas fa-eye"></i> Ver Detalle
                    </a>
                    <a href="@Url.Action("Gestionar", "Mascotas")" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Volver
                    </a>
                </div>
            </div>
        </div>
    </div>

    @using (Html.BeginForm("Editar", "Mascotas", FormMethod.Post, new { enctype = "multipart/form-data", id = "formEditarMascota" }))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.MascotaId)
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

        <div class="row">
            <!-- COLUMNA IZQUIERDA -->
            <div class="col-lg-8">

                <!-- INFORMACIÓN BÁSICA -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">
                            <i class="fas fa-info-circle me-2"></i>Información Básica
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <!-- Nombre -->
                            <div class="col-md-6 mb-3">
                                <label class="form-label">
                                    <i class="fas fa-tag me-1 text-primary"></i>
                                    Nombre <span class="text-danger">*</span>
                                </label>
                                @Html.TextBoxFor(m => m.Nombre, new
                                {
                                    @class = "form-control",
                                    placeholder = "Ej: Max, Luna, Rocky...",
                                    required = "required"
                                })
                                @Html.ValidationMessageFor(m => m.Nombre, "", new { @class = "text-danger small" })
                            </div>

                            <!-- Especie -->
                            <div class="col-md-6 mb-3">
                                <label class="form-label">
                                    <i class="fas fa-paw me-1 text-primary"></i>
                                    Especie <span class="text-danger">*</span>
                                </label>
                                @Html.DropDownListFor(m => m.Especie,
                                    Model.EspeciesList ?? new SelectList(new List<string> { "Perro", "Gato" }, Model.Especie),
                                    "-- Seleccione --",
                                    new { @class = "form-select", required = "required" })
                                @Html.ValidationMessageFor(m => m.Especie, "", new { @class = "text-danger small" })
                            </div>

                            <!-- Raza -->
                            <div class="col-md-6 mb-3">
                                <label class="form-label">
                                    <i class="fas fa-dna me-1 text-primary"></i>
                                    Raza
                                </label>
                                @Html.TextBoxFor(m => m.Raza, new
                                {
                                    @class = "form-control",
                                    placeholder = "Ej: Labrador, Mestizo..."
                                })
                            </div>

                            <!-- Sexo -->
                            <div class="col-md-6 mb-3">
                                <label class="form-label">
                                    <i class="fas fa-venus-mars me-1 text-primary"></i>
                                    Sexo <span class="text-danger">*</span>
                                </label>
                                <select name="Sexo" id="Sexo" class="form-select" required>
                                    <option value="">-- Seleccione --</option>
                                    <option value="Macho" @(Model.Sexo == "Macho" ? "selected" : "")>Macho</option>
                                    <option value="Hembra" @(Model.Sexo == "Hembra" ? "selected" : "")>Hembra</option>
                                </select>
                            </div>

                            <!-- Edad -->
                            <div class="col-md-4 mb-3">
                                <label class="form-label">
                                    <i class="fas fa-birthday-cake me-1 text-primary"></i>
                                    Edad Aproximada <span class="text-danger">*</span>
                                </label>
                                @Html.TextBoxFor(m => m.EdadAproximada, new
                                {
                                    @class = "form-control",
                                    placeholder = "Ej: 2 años",
                                    required = "required"
                                })
                            </div>

                            <!-- Tamaño -->
                            <div class="col-md-4 mb-3">
                                <label class="form-label">
                                    <i class="fas fa-ruler-combined me-1 text-primary"></i>
                                    Tamaño <span class="text-danger">*</span>
                                </label>
                                @Html.DropDownListFor(m => m.Tamanio,
                                    Model.TamaniosList ?? new SelectList(new List<string> { "Pequeño", "Mediano", "Grande" }, Model.Tamanio),
                                    "-- Seleccione --",
                                    new { @class = "form-select", required = "required" })
                            </div>

                            <!-- Color -->
                            <div class="col-md-4 mb-3">
                                <label class="form-label">
                                    <i class="fas fa-palette me-1 text-primary"></i>
                                    Color
                                </label>
                                @Html.TextBoxFor(m => m.Color, new
                                {
                                    @class = "form-control",
                                    placeholder = "Ej: Negro, Blanco..."
                                })
                            </div>

                            <!-- Esterilizado -->
                            <div class="col-md-6 mb-3">
                                <label class="form-label d-block">
                                    <i class="fas fa-check-circle me-1 text-primary"></i>
                                    ¿Esterilizado?
                                </label>
                                <div class="form-check form-check-inline">
                                    @Html.RadioButtonFor(m => m.Esterilizado, true, new { @class = "form-check-input", id = "esterilizadoSi" })
                                    <label class="form-check-label" for="esterilizadoSi">Sí</label>
                                </div>
                                <div class="form-check form-check-inline">
                                    @Html.RadioButtonFor(m => m.Esterilizado, false, new { @class = "form-check-input", id = "esterilizadoNo" })
                                    <label class="form-check-label" for="esterilizadoNo">No</label>
                                </div>
                            </div>

                            <!-- Microchip -->
                            <div class="col-md-6 mb-3">
                                <label class="form-label">
                                    <i class="fas fa-microchip me-1 text-primary"></i>
                                    Microchip
                                </label>
                                @Html.TextBoxFor(m => m.Microchip, new
                                {
                                    @class = "form-control",
                                    placeholder = "Número de microchip"
                                })
                            </div>
                        </div>
                    </div>
                </div>

                <!-- CATEGORÍA Y ESTADO -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0">
                            <i class="fas fa-flag me-2"></i>Categoría y Estado
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <!-- Categoría -->
                            <div class="col-md-4 mb-3">
                                <label class="form-label">
                                    <i class="fas fa-star me-1 text-info"></i>
                                    Categoría
                                </label>
                                @Html.DropDownListFor(m => m.Categoria,
                                    Model.CategoriasList ?? new SelectList(new List<string> { "Normal", "Especial" }, Model.Categoria),
                                    "-- Seleccione --",
                                    new { @class = "form-select", id = "selectCategoria" })
                            </div>

                            <!-- Tipo Especial -->
                            <div class="col-md-8 mb-3" id="divTipoEspecial" style="display: @(Model.Categoria == "Especial" ? "block" : "none");">
                                <label class="form-label">
                                    <i class="fas fa-info-circle me-1 text-warning"></i>
                                    Tipo de Necesidad Especial
                                </label>
                                @Html.TextBoxFor(m => m.TipoEspecial, new
                                {
                                    @class = "form-control",
                                    placeholder = "Ej: Discapacidad motora, ceguera...",
                                    id = "TipoEspecial"
                                })
                                <small class="text-muted">Especifique el tipo de necesidad especial</small>
                            </div>

                            <!-- Estado -->
                            <div class="col-md-6 mb-3">
                                <label class="form-label">
                                    <i class="fas fa-heartbeat me-1 text-info"></i>
                                    Estado <span class="text-danger">*</span>
                                </label>
                                @Html.DropDownListFor(m => m.Estado,
                                    Model.EstadosList ?? new SelectList(new List<string>
                                    {
                                        "Rescatada",
                                        "En revisión veterinaria",
                                        "En tratamiento",
                                        "En cuarentena",
                                        "Disponible para adopción",
                                        "Adoptada",
                                        "Archivada"
                                    }, Model.Estado),
                                    new { @class = "form-select", required = "required" })
                            </div>

                            <!-- Fecha Ingreso -->
                            <div class="col-md-6 mb-3">
                                <label class="form-label">
                                    <i class="fas fa-calendar-alt me-1 text-info"></i>
                                    Fecha de Ingreso <span class="text-danger">*</span>
                                </label>
                                @Html.TextBoxFor(m => m.FechaIngreso, "{0:yyyy-MM-dd}", new
                                {
                                    @class = "form-control",
                                    type = "date",
                                    required = "required",
                                    max = DateTime.Now.ToString("yyyy-MM-dd")
                                })
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ASIGNACIONES -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0">
                            <i class="fas fa-users me-2"></i>Asignaciones
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <!-- Veterinario -->
                            <div class="col-md-6 mb-3">
                                <label class="form-label">
                                    <i class="fas fa-user-md me-1 text-success"></i>
                                    Veterinario Asignado
                                </label>
                                @Html.DropDownListFor(m => m.VeterinarioAsignado,
                                    Model.VeterinariosList ?? new SelectList(new List<object>()),
                                    "-- Sin asignar --",
                                    new { @class = "form-select" })
                            </div>

                            <!-- Rescatista -->
                            <div class="col-md-6 mb-3">
                                <label class="form-label">
                                    <i class="fas fa-hands-helping me-1 text-success"></i>
                                    Rescatista
                                </label>
                                @Html.DropDownListFor(m => m.RescatistaId,
                                    Model.RescatistasList ?? new SelectList(new List<object>()),
                                    "-- Sin asignar --",
                                    new { @class = "form-select" })
                            </div>
                        </div>
                    </div>
                </div>

                <!-- DESCRIPCIONES -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-warning text-dark">
                        <h5 class="mb-0">
                            <i class="fas fa-align-left me-2"></i>Descripciones
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label">
                                <i class="fas fa-file-alt me-1 text-warning"></i>
                                Descripción General
                            </label>
                            @Html.TextAreaFor(m => m.DescripcionGeneral, new
                            {
                                @class = "form-control",
                                rows = "4",
                                placeholder = "Describe las características físicas..."
                            })
                            <small class="text-muted">Visible en la página pública</small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">
                                <i class="fas fa-heart me-1 text-warning"></i>
                                Características de Comportamiento
                            </label>
                            @Html.TextAreaFor(m => m.CaracteristicasComportamiento, new
                            {
                                @class = "form-control",
                                rows = "4",
                                placeholder = "Describe el comportamiento..."
                            })
                        </div>

                        <div class="mb-3">
                            <label class="form-label">
                                <i class="fas fa-book me-1 text-warning"></i>
                                Historia de Rescate
                            </label>
                            @Html.TextAreaFor(m => m.HistoriaRescate, new
                            {
                                @class = "form-control",
                                rows = "4",
                                placeholder = "Cuenta la historia..."
                            })
                        </div>
                    </div>
                </div>
            </div>

            <!-- COLUMNA DERECHA: IMAGEN -->
            <div class="col-lg-4">
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-secondary text-white">
                        <h5 class="mb-0">
                            <i class="fas fa-image me-2"></i>Imagen Principal
                        </h5>
                    </div>
                    <div class="card-body text-center">
                        <!-- ✅ Preview de Imagen con data-attribute -->
                        <div class="mb-3">
                            <img id="imgPreview"
                                 src="@urlImagenActual"
                                 data-imagen-original="@urlImagenActual"
                                 class="img-fluid rounded shadow-sm"
                                 style="max-height: 400px; width: 100%; object-fit: cover;"
                                 alt="Imagen actual">
                        </div>

                        <!-- Opciones de Imagen -->
                        <div class="mb-3">
                            <div class="form-check mb-2">
                                <input type="radio"
                                       name="opcionImagen"
                                       id="mantenerImagen"
                                       value="mantener"
                                       class="form-check-input"
                                       checked>
                                <label class="form-check-label" for="mantenerImagen">
                                    <i class="fas fa-check-circle text-success"></i> Mantener imagen actual
                                </label>
                            </div>
                            <div class="form-check">
                                <input type="radio"
                                       name="opcionImagen"
                                       id="cambiarImagen"
                                       value="cambiar"
                                       class="form-check-input">
                                <label class="form-check-label" for="cambiarImagen">
                                    <i class="fas fa-exchange-alt text-primary"></i> Cambiar imagen
                                </label>
                            </div>
                        </div>

                        <!-- Input de Archivo (oculto por defecto) -->
                        <div id="divCambiarImagen" style="display: none;">
                            <div class="mb-3">
                                <label class="btn btn-primary w-100">
                                    <i class="fas fa-upload me-2"></i>Seleccionar Nueva Imagen
                                    <input type="file"
                                           name="ImagenPrincipalFile"
                                           id="imagenFile"
                                           accept="image/jpeg,image/png,image/gif"
                                           style="display: none;"
                                           onchange="previewImage(this)">
                                </label>
                            </div>

                            <div class="alert alert-info mb-0">
                                <small>
                                    <i class="fas fa-info-circle me-1"></i>
                                    <strong>Formatos:</strong> JPG, PNG, GIF<br>
                                    <strong>Tamaño máximo:</strong> 5 MB
                                </small>
                            </div>

                            <div id="imagenError" class="alert alert-danger mt-3" style="display: none;"></div>
                        </div>
                    </div>
                </div>

                <!-- Información Adicional -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-dark text-white">
                        <h5 class="mb-0">
                            <i class="fas fa-info-circle me-2"></i>Información
                        </h5>
                    </div>
                    <div class="card-body">
                        <p class="mb-2">
                            <strong>ID:</strong> #@Model.MascotaId
                        </p>
                        <p class="mb-2">
                            <strong>Estado Actual:</strong>
                            <span class="badge @(
                                Model.Estado == "Disponible para adopción" ? "bg-success" :
                                Model.Estado == "Adoptada" ? "bg-info" :
                                Model.Estado == "En tratamiento" ? "bg-warning" : "bg-secondary"
                            )">
                                @Model.Estado
                            </span>
                        </p>
                        @if (Model.FechaIngreso != null)
                        {
                            <p class="mb-0">
                                <strong>Ingreso:</strong> @Model.FechaIngreso.ToString("dd/MM/yyyy")
                            </p>
                        }
                    </div>
                </div>

                <!-- Botones de Acción -->
                <div class="card shadow-sm">
                    <div class="card-body">
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-warning btn-lg" id="btnGuardar">
                                <i class="fas fa-save me-2"></i>Guardar Cambios
                            </button>
                            <a href="@Url.Action("Detalle", "Mascotas", new { id = Model.MascotaId })" class="btn btn-info">
                                <i class="fas fa-eye me-2"></i>Ver Detalle
                            </a>
                            <a href="@Url.Action("Gestionar", "Mascotas")" class="btn btn-secondary">
                                <i class="fas fa-times me-2"></i>Cancelar
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script src="~/Scripts/jquery.validate.min.js"></script>
    <script src="~/Scripts/jquery.validate.unobtrusive.min.js"></script>

    <script>
        // ✅ Obtener imagen original desde el atributo data
        var imagenOriginal = $('#imgPreview').attr('data-imagen-original');

        $(document).ready(function () {
            // Toggle TipoEspecial
            $('#selectCategoria').change(function () {
                if ($(this).val() === 'Especial') {
                    $('#divTipoEspecial').slideDown();
                } else {
                    $('#divTipoEspecial').slideUp();
                    $('#TipoEspecial').val('');
                }
            });

            // Toggle cambio de imagen
            $('input[name="opcionImagen"]').change(function () {
                if ($('#cambiarImagen').is(':checked')) {
                    $('#divCambiarImagen').slideDown();
                } else {
                    $('#divCambiarImagen').slideUp();
                    $('#imagenFile').val('');
                    // ✅ Restaurar imagen original
                    $('#imgPreview').attr('src', imagenOriginal);
                }
            });

            // Validación antes de enviar
            $('#formEditarMascota').submit(function (e) {
                var imagenFile = $('#imagenFile')[0];

                if ($('#cambiarImagen').is(':checked') && imagenFile.files.length > 0) {
                    var file = imagenFile.files[0];
                    var fileSize = file.size / 1024 / 1024;

                    if (fileSize > 5) {
                        e.preventDefault();
                        alert('La imagen no debe superar los 5 MB');
                        return false;
                    }

                    if (!['image/jpeg', 'image/png', 'image/gif'].includes(file.type)) {
                        e.preventDefault();
                        alert('Solo se aceptan imágenes JPG, PNG o GIF');
                        return false;
                    }
                }

                $('#btnGuardar').html('<i class="fas fa-spinner fa-spin me-2"></i>Guardando...').prop('disabled', true);
            });
        });

        function previewImage(input) {
            if (input.files && input.files[0]) {
                var file = input.files[0];
                var fileSize = file.size / 1024 / 1024;

                $('#imagenError').hide();

                if (fileSize > 5) {
                    $('#imagenError').text('La imagen no debe superar los 5 MB').show();
                    input.value = '';
                    return;
                }

                if (!['image/jpeg', 'image/png', 'image/gif'].includes(file.type)) {
                    $('#imagenError').text('Solo se aceptan imágenes JPG, PNG o GIF').show();
                    input.value = '';
                    return;
                }

                var reader = new FileReader();
                reader.onload = function (e) {
                    $('#imgPreview').attr('src', e.target.result);
                };
                reader.readAsDataURL(file);
            }
        }
    </script>
}

<style>
    .form-label {
        font-weight: 500;
    }

    .card {
        border: none;
        border-radius: 10px;
    }

    .card-header {
        border-radius: 10px 10px 0 0 !important;
        padding: 1rem 1.5rem;
    }

    #imgPreview {
        border: 3px solid #dee2e6;
        transition: all 0.3s;
    }

        #imgPreview:hover {
            border-color: #0d6efd;
        }
</style>