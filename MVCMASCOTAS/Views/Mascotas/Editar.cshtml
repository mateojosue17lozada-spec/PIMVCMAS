@model MVCMASCOTAS.Models.ViewModels.MascotaViewModel

@{
    ViewBag.Title = "Editar Mascota";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card shadow-custom">
                <div class="card-header bg-primary text-white">
                    <h3 class="mb-0"><i class="fas fa-edit me-2"></i> Editar Mascota: @Model.Nombre</h3>
                </div>
                <div class="card-body">
                    @using (Html.BeginForm("Editar", "Mascotas", FormMethod.Post, new { enctype = "multipart/form-data", @class = "needs-validation", novalidate = "novalidate" }))
                    {
                        @Html.AntiForgeryToken()
                        @Html.HiddenFor(m => m.MascotaId)
                        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                        <h5 class="border-bottom pb-2 mb-3">
                            <i class="fas fa-info-circle text-primary me-2"></i> Información Básica
                        </h5>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">
                                        <i class="fas fa-signature me-1"></i> Nombre *
                                    </label>
                                    @Html.TextBoxFor(m => m.Nombre, new { @class = "form-control", required = "required" })
                                    @Html.ValidationMessageFor(m => m.Nombre, "", new { @class = "text-danger small" })
                                </div>
                            </div>

                            <div class="col-md-3">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">
                                        <i class="fas fa-paw me-1"></i> Especie *
                                    </label>
                                    @Html.DropDownListFor(m => m.Especie, new SelectList(new[] { "Perro", "Gato", "Otro" }), "Seleccionar...", new { @class = "form-control", required = "required" })
                                    @Html.ValidationMessageFor(m => m.Especie, "", new { @class = "text-danger small" })
                                </div>
                            </div>

                            <div class="col-md-3">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">
                                        <i class="fas fa-venus-mars me-1"></i> Sexo *
                                    </label>
                                    @Html.DropDownListFor(m => m.Sexo, new SelectList(new[] { "Macho", "Hembra" }), "Seleccionar...", new { @class = "form-control", required = "required" })
                                    @Html.ValidationMessageFor(m => m.Sexo, "", new { @class = "text-danger small" })
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">
                                        <i class="fas fa-dog me-1"></i> Raza
                                    </label>
                                    @Html.TextBoxFor(m => m.Raza, new { @class = "form-control", placeholder = "Ej: Mestizo, Labrador, Siames, etc." })
                                    @Html.ValidationMessageFor(m => m.Raza, "", new { @class = "text-danger small" })
                                </div>
                            </div>

                            <div class="col-md-3">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">
                                        <i class="fas fa-ruler me-1"></i> Tamaño
                                    </label>
                                    @Html.DropDownListFor(m => m.Tamanio, new SelectList(new[] { "Pequeño", "Mediano", "Grande" }), "Seleccionar...", new { @class = "form-control" })
                                    @Html.ValidationMessageFor(m => m.Tamanio, "", new { @class = "text-danger small" })
                                </div>
                            </div>

                            <div class="col-md-3">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">
                                        <i class="fas fa-palette me-1"></i> Color
                                    </label>
                                    @Html.TextBoxFor(m => m.Color, new { @class = "form-control", placeholder = "Ej: Negro, Blanco, Marrón, etc." })
                                    @Html.ValidationMessageFor(m => m.Color, "", new { @class = "text-danger small" })
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">
                                        <i class="fas fa-calendar me-1"></i> Edad Aproximada
                                    </label>
                                    @Html.DropDownListFor(m => m.EdadAproximada, new SelectList(new[] {
                                        "Cachorro (0-1 año)",
                                        "Joven (1-3 años)",
                                        "Adulto (3-7 años)",
                                        "Senior (7+ años)"
                                    }), "Seleccionar...", new { @class = "form-control" })
                                    @Html.ValidationMessageFor(m => m.EdadAproximada, "", new { @class = "text-danger small" })
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">
                                        <i class="fas fa-tag me-1"></i> Categoría
                                    </label>
                                    @Html.DropDownListFor(m => m.Categoria, new SelectList(new[] { "Normal", "Especial" }), "Seleccionar...", new { @class = "form-control" })
                                    @Html.ValidationMessageFor(m => m.Categoria, "", new { @class = "text-danger small" })
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">
                                        <i class="fas fa-star me-1"></i> Tipo Especial
                                    </label>
                                    @Html.TextBoxFor(m => m.TipoEspecial, new { @class = "form-control", placeholder = "Ej: Discapacitado, Senior, etc." })
                                    @Html.ValidationMessageFor(m => m.TipoEspecial, "", new { @class = "text-danger small" })
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-check mb-3">
                                    @Html.CheckBoxFor(m => m.Esterilizado, new { @class = "form-check-input" })
                                    <label class="form-check-label fw-bold">
                                        <i class="fas fa-check-circle me-1"></i> Esterilizado/Castrado
                                    </label>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">
                                        <i class="fas fa-microchip me-1"></i> Microchip
                                    </label>
                                    @Html.TextBoxFor(m => m.Microchip, new { @class = "form-control", placeholder = "Número de microchip" })
                                    @Html.ValidationMessageFor(m => m.Microchip, "", new { @class = "text-danger small" })
                                </div>
                            </div>
                        </div>

                        <h5 class="border-bottom pb-2 mb-3 mt-4">
                            <i class="fas fa-align-left text-primary me-2"></i> Descripciones
                        </h5>

                        <div class="mb-3">
                            <label class="form-label fw-bold">
                                <i class="fas fa-align-left me-1"></i> Descripción General
                            </label>
                            @Html.TextAreaFor(m => m.DescripcionGeneral, new { @class = "form-control", rows = "3", maxlength = "500", placeholder = "Describe a la mascota" })
                            @Html.ValidationMessageFor(m => m.DescripcionGeneral, "", new { @class = "text-danger small" })
                            <div class="form-text text-end">
                                <span id="descripcion-counter">0</span>/500 caracteres
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">
                                <i class="fas fa-heart me-1"></i> Características de Comportamiento
                            </label>
                            @Html.TextAreaFor(m => m.CaracteristicasComportamiento, new { @class = "form-control", rows = "3", maxlength = "500", placeholder = "Cómo es su personalidad" })
                            @Html.ValidationMessageFor(m => m.CaracteristicasComportamiento, "", new { @class = "text-danger small" })
                            <div class="form-text text-end">
                                <span id="comportamiento-counter">0</span>/500 caracteres
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">
                                <i class="fas fa-book me-1"></i> Historia de Rescate
                            </label>
                            @Html.TextAreaFor(m => m.HistoriaRescate, new { @class = "form-control", rows = "3", maxlength = "1000", placeholder = "Cómo fue rescatada/o" })
                            @Html.ValidationMessageFor(m => m.HistoriaRescate, "", new { @class = "text-danger small" })
                            <div class="form-text text-end">
                                <span id="historia-counter">0</span>/1000 caracteres
                            </div>
                        </div>

                        <h5 class="border-bottom pb-2 mb-3 mt-4">
                            <i class="fas fa-image text-primary me-2"></i> Imagen
                        </h5>

                        <!-- Imagen actual si existe -->
                        if (!string.IsNullOrEmpty(Model.ImagenBase64))
                        {
                            <div class="mb-3">
                                <label class="form-label fw-bold">Imagen Actual:</label><br />
                                <img src="data:image/jpeg;base64,@Model.ImagenBase64"
                                     alt="Imagen actual de @Model.Nombre"
                                     style="max-width: 300px; max-height: 200px; object-fit: cover;"
                                     class="img-thumbnail border-primary" />
                            </div>
                        }

                        <div class="mb-3">
                            <label class="form-label fw-bold">
                                <i class="fas fa-camera me-1"></i> Cambiar Imagen (opcional)
                            </label>
                            @Html.TextBoxFor(m => m.ImagenPrincipalFile, new { type = "file", @class = "form-control", accept = "image/*", onchange = "previewImage(this)" })
                            <div class="form-text text-muted">
                                Tamaño máximo: 5 MB. Formatos: JPG, PNG, GIF
                            </div>
                            <img id="preview-mascota" src="#" alt="Vista previa de imagen"
                                 class="img-thumbnail mt-2 d-none" style="max-width: 300px; max-height: 200px;" />
                        </div>

                        <!-- Información del sistema -->
                        <h5 class="border-bottom pb-2 mb-3 mt-4">
                            <i class="fas fa-cogs text-primary me-2"></i> Información del Sistema
                        </h5>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label fw-bold text-muted">
                                        <i class="fas fa-calendar-plus me-1"></i> Fecha de Ingreso
                                    </label>
                                    <input type="text" class="form-control-plaintext bg-light p-2 rounded"
                                           value="@Model.FechaIngreso.ToString("dd/MM/yyyy")" readonly />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">
                                        <i class="fas fa-heart me-1"></i> Estado
                                    </label>
                                    @Html.DropDownListFor(m => m.Estado, new SelectList(new[] {
                                        "Rescatada",
                                        "En revisión veterinaria",
                                        "Pendiente de exámenes",
                                        "En cuarentena",
                                        "En tratamiento",
                                        "Disponible para adopción",
                                        "Adoptada",
                                        "Fallecida"
                                    }), new { @class = "form-control" })
                                    @Html.ValidationMessageFor(m => m.Estado, "", new { @class = "text-danger small" })
                                </div>
                            </div>
                        </div>

                        <!-- Información del personal -->
                        <div class="row">
                            @if (!string.IsNullOrEmpty(Model.VeterinarioNombre))
                            {
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label class="form-label fw-bold text-muted">
                                            <i class="fas fa-user-md me-1"></i> Veterinario Asignado
                                        </label>
                                        <input type="text" class="form-control-plaintext bg-light p-2 rounded"
                                               value="@Model.VeterinarioNombre" readonly />
                                    </div>
                                </div>
                            }

                            @if (!string.IsNullOrEmpty(Model.RescatistaNombre))
                            {
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label class="form-label fw-bold text-muted">
                                            <i class="fas fa-user me-1"></i> Rescatista
                                        </label>
                                        <input type="text" class="form-control-plaintext bg-light p-2 rounded"
                                               value="@Model.RescatistaNombre" readonly />
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="d-flex justify-content-between mt-4 pt-3 border-top">
                            <a href="@Url.Action("Detalle", "Mascotas", new { id = Model.MascotaId })"
                               class="btn btn-outline-secondary">
                                <i class="fas fa-arrow-left me-1"></i> Volver a Detalles
                            </a>
                            <div>
                                <a href="@Url.Action("Gestionar", "Mascotas")"
                                   class="btn btn-outline-danger me-2">
                                    <i class="fas fa-times me-1"></i> Cancelar
                                </a>
                                <button type="submit" class="btn btn-primary">
                                    <i class="fas fa-save me-1"></i> Guardar Cambios
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")

    <script>
        // Función para previsualizar imagen
        function previewImage(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();

                reader.onload = function (e) {
                    $('#preview-mascota')
                        .attr('src', e.target.result)
                        .removeClass('d-none')
                        .addClass('border-success');
                }

                reader.readAsDataURL(input.files[0]);
            }
        }

        // Contadores de caracteres
        $(document).ready(function () {
            // Configurar contadores
            function setupCounter(textareaId, counterId) {
                var textarea = $('#' + textareaId);
                var counter = $('#' + counterId);

                // Contar caracteres iniciales
                counter.text(textarea.val().length);

                // Actualizar al escribir
                textarea.on('input', function () {
                    counter.text($(this).val().length);
                });
            }

            // Configurar contadores para cada textarea
            setupCounter('DescripcionGeneral', 'descripcion-counter');
            setupCounter('CaracteristicasComportamiento', 'comportamiento-counter');
            setupCounter('HistoriaRescate', 'historia-counter');

            // Validación de tamaño de archivo
            $('input[type="file"]').change(function () {
                var file = this.files[0];
                if (file) {
                    var fileSize = file.size / 1024 / 1024; // en MB
                    if (fileSize > 5) {
                        alert('La imagen es demasiado grande. El tamaño máximo permitido es 5 MB.');
                        $(this).val('');
                        $('#preview-mascota').addClass('d-none');
                    }
                }
            });

            // Validación de Bootstrap
            (function () {
                'use strict'
                var forms = document.querySelectorAll('.needs-validation')
                Array.prototype.slice.call(forms)
                    .forEach(function (form) {
                        form.addEventListener('submit', function (event) {
                            if (!form.checkValidity()) {
                                event.preventDefault()
                                event.stopPropagation()
                            }
                            form.classList.add('was-validated')
                        }, false)
                    })
            })();
        });
    </script>

    <style>
        .shadow-custom {
            box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
            border: 1px solid rgba(0, 0, 0, 0.125);
        }

        .form-control-plaintext.bg-light {
            background-color: #f8f9fa !important;
            cursor: not-allowed;
        }

        .form-check-input:checked {
            background-color: #198754;
            border-color: #198754;
        }

        .border-primary {
            border-color: #0d6efd !important;
        }

        .border-success {
            border-color: #198754 !important;
        }

        .d-none {
            display: none !important;
        }
    </style>
}