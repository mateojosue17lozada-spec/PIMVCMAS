@model MVCMASCOTAS.Models.SeguimientoAdopcion

@{
    ViewBag.Title = "Editar Seguimiento";
    var mascota = ViewBag.Mascota as MVCMASCOTAS.Models.Mascotas;
    var contrato = ViewBag.Contrato as MVCMASCOTAS.Models.ContratoAdopcion;
}

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card shadow-lg">
                <div class="card-header bg-warning text-white">
                    <h3 class="mb-0">
                        <i class="fas fa-edit"></i> Editar Seguimiento #@Model.SeguimientoId
                    </h3>
                </div>
                <div class="card-body">
                    <!-- Información de contexto -->
                    <div class="alert alert-info mb-4">
                        <div class="row">
                            <div class="col-md-4">
                                <h6><i class="fas fa-dog"></i> Mascota</h6>
                                <p class="mb-0"><strong>@Html.Encode(mascota.Nombre)</strong></p>
                                <small>@Html.Encode(mascota.Especie) - @Html.Encode(mascota.Raza ?? "Mestizo")</small>
                            </div>
                            <div class="col-md-4">
                                <h6><i class="fas fa-user"></i> Adoptante</h6>
                                <p class="mb-0"><strong>@Html.Encode(contrato?.AdoptanteNombre)</strong></p>
                                <small>Contrato: @Html.Encode(contrato?.NumeroContrato)</small>
                            </div>
                            <div class="col-md-4">
                                <h6><i class="fas fa-calendar"></i> Fechas</h6>
                                <p class="mb-0">
                                    <strong>Original:</strong>
                                    @(Model.FechaSeguimiento?.ToString("dd/MM/yyyy") ?? "No realizada")
                                </p>
                                @if (Model.ProximoSeguimiento.HasValue)
                                {
                                    <small>
                                        <strong>Próximo:</strong>
                                        @Model.ProximoSeguimiento.Value.ToString("dd/MM/yyyy")
                                    </small>
                                }
                            </div>
                        </div>
                    </div>

                    @using (Html.BeginForm("EditarSeguimiento", "Mascotas", FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()
                        @Html.HiddenFor(model => model.SeguimientoId)
                        @Html.HiddenFor(model => model.ContratoId)
                        @Html.HiddenFor(model => model.ResponsableSeguimiento)

                        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                        <div class="row">
                            <div class="col-md-6">
                                <h5 class="border-bottom pb-2 mb-3">
                                    <i class="fas fa-calendar-alt text-primary"></i> Información Básica
                                </h5>

                                <div class="mb-3">
                                    <label class="form-label fw-bold">Fecha del Seguimiento *</label>
                                    @Html.TextBoxFor(model => model.FechaSeguimiento, "{0:yyyy-MM-dd}",
                                    new
                                         {
                                        @class = "form-control",
                                        type = "date",
                                        required = "required"
                                    })
                                    @Html.ValidationMessageFor(model => model.FechaSeguimiento, "", new { @class = "text-danger" })
                                </div>

                                <div class="mb-3">
                                    <label class="form-label fw-bold">Tipo de Seguimiento *</label>
                                    @Html.DropDownListFor(model => model.TipoSeguimiento,
                                        new SelectList(ViewBag.TiposSeguimiento ?? new string[] { }, Model.TipoSeguimiento),
                                        new { @class = "form-control", required = "required" })
                                    @Html.ValidationMessageFor(model => model.TipoSeguimiento, "", new { @class = "text-danger" })
                                </div>

                                <div class="mb-3">
                                    <label class="form-label fw-bold">Próximo Seguimiento</label>
                                    @Html.TextBoxFor(model => model.ProximoSeguimiento, "{0:yyyy-MM-dd}",
                                    new { @class = "form-control", type = "date" })
                                    @Html.ValidationMessageFor(model => model.ProximoSeguimiento, "", new { @class = "text-danger" })
                                </div>
                            </div>

                            <div class="col-md-6">
                                <h5 class="border-bottom pb-2 mb-3">
                                    <i class="fas fa-clipboard-check text-primary"></i> Evaluaciones
                                </h5>

                                <div class="mb-3">
                                    <label class="form-label fw-bold">Estado de la Mascota *</label>
                                    @Html.DropDownListFor(model => model.EstadoMascota,
                                        new SelectList(ViewBag.EstadosMascota ?? new string[] { }, Model.EstadoMascota),
                                        new { @class = "form-control", required = "required" })
                                    @Html.ValidationMessageFor(model => model.EstadoMascota, "", new { @class = "text-danger" })
                                </div>

                                <div class="mb-3">
                                    <label class="form-label fw-bold">Condiciones de Vivienda *</label>
                                    @Html.DropDownListFor(model => model.CondicionesVivienda,
                                        new SelectList(ViewBag.CondicionesVivienda ?? new string[] { }, Model.CondicionesVivienda),
                                        new { @class = "form-control", required = "required" })
                                    @Html.ValidationMessageFor(model => model.CondicionesVivienda, "", new { @class = "text-danger" })
                                </div>

                                <div class="mb-3">
                                    <label class="form-label fw-bold">Relación con Adoptante *</label>
                                    @Html.DropDownListFor(model => model.RelacionConAdoptante,
                                        new SelectList(ViewBag.Relaciones ?? new string[] { }, Model.RelacionConAdoptante),
                                        new { @class = "form-control", required = "required" })
                                    @Html.ValidationMessageFor(model => model.RelacionConAdoptante, "", new { @class = "text-danger" })
                                </div>

                                <div class="form-check mb-3">
                                    @Html.CheckBoxFor(model => model.RequiereIntervencion, new { @class = "form-check-input" })
                                    <label class="form-check-label fw-bold text-danger">
                                        Requiere intervención del refugio
                                    </label>
                                </div>
                            </div>
                        </div>

                        <h5 class="border-bottom pb-2 mb-3 mt-4">
                            <i class="fas fa-align-left text-primary"></i> Observaciones y Recomendaciones
                        </h5>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Observaciones</label>
                                    @Html.TextAreaFor(model => model.Observaciones,
                                    new { @class = "form-control", rows = "5" })
                                    <div class="form-text text-end">
                                        <span id="obsCounter">@(Model.Observaciones?.Length ?? 0)</span>/2000 caracteres
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Recomendaciones</label>
                                    @Html.TextAreaFor(model => model.Recomendaciones,
                                    new { @class = "form-control", rows = "5" })
                                    <div class="form-text text-end">
                                        <span id="recCounter">@(Model.Recomendaciones?.Length ?? 0)</span>/2000 caracteres
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-12">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Fotos de Evidencia</label>
                                    @Html.TextBoxFor(model => model.FotosEvidencia, new { @class = "form-control" })
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between mt-4 pt-3 border-top">
                            <a href="@Url.Action("SeguimientoMascota", "Mascotas", new { id = mascota.MascotaId })"
                               class="btn btn-outline-secondary">
                                <i class="fas fa-arrow-left"></i> Cancelar
                            </a>
                            <div>
                                @if (User.IsInRole("Administrador"))
                                {
                                    <a href="@Url.Action("EliminarSeguimiento", "Mascotas", new { id = Model.SeguimientoId })"
                                       class="btn btn-danger me-2"
                                       onclick="return confirm('¿Está seguro de eliminar este seguimiento?')">
                                        <i class="fas fa-trash"></i> Eliminar
                                    </a>
                                }
                                <button type="submit" class="btn btn-warning btn-lg">
                                    <i class="fas fa-save"></i> Guardar Cambios
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Contadores de caracteres
            function actualizarContador(textareaId, counterId) {
                var textarea = document.getElementById(textareaId);
                var counter = document.getElementById(counterId);
                if (textarea && counter) {
                    textarea.addEventListener('input', function() {
                        var length = this.value.length;
                        counter.textContent = length;

                        if (length > 1800) {
                            counter.className = 'text-danger';
                        } else if (length > 1500) {
                            counter.className = 'text-warning';
                        } else {
                            counter.className = '';
                        }
                    });
                }
            }

            actualizarContador('Observaciones', 'obsCounter');
            actualizarContador('Recomendaciones', 'recCounter');

            // Validación de fechas
            $('form').submit(function(e) {
                var fechaSeguimiento = new Date($('#FechaSeguimiento').val());
                var hoy = new Date();
                hoy.setHours(0, 0, 0, 0);

                if (fechaSeguimiento > hoy) {
                    e.preventDefault();
                    alert('La fecha del seguimiento no puede ser futura.');
                    return false;
                }

                var fechaProximo = $('#ProximoSeguimiento').val();
                if (fechaProximo) {
                    var fechaProximoDate = new Date(fechaProximo);
                    if (fechaProximoDate <= fechaSeguimiento) {
                        e.preventDefault();
                        alert('La fecha del próximo seguimiento debe ser posterior a la fecha del seguimiento actual.');
                        return false;
                    }
                }

                return true;
            });
        });
    </script>
}