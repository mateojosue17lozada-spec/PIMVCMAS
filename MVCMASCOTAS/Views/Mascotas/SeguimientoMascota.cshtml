@model IEnumerable<MVCMASCOTAS.Models.SeguimientoAdopcion>

@{
    ViewBag.Title = "Seguimiento de Mascota - ADOPTAMANIA";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var mascota = ViewBag.Mascota as MVCMASCOTAS.Models.Mascotas;
    var contrato = ViewBag.Contrato as MVCMASCOTAS.Models.ContratoAdopcion;
}

<section class="seguimiento-mascota-hero py-4">
    <div class="container">
        <div class="d-flex flex-wrap justify-content-between align-items-center">
            <div>
                <h1 class="h2 text-brown mb-1">
                    <i class="fas fa-clipboard-list text-green me-2"></i>Seguimiento de Mascota
                </h1>
                <p class="text-secondary mb-0">
                    @Html.Encode(mascota?.Nombre) - @Html.Encode(mascota?.Especie) @(!string.IsNullOrEmpty(mascota?.Raza) ? "(" + mascota.Raza + ")" : "")
                </p>
            </div>
            <div class="mt-2 mt-sm-0">
                <a href="@Url.Action("SeguimientoAdopciones", "Mascotas")" class="btn btn-outline-green me-2">
                    <i class="fas fa-arrow-left me-2"></i>Volver
                </a>
                @if (mascota != null)
                {
                    <a href="@Url.Action("CrearSeguimientoManual", "Mascotas", new { mascotaId = mascota.MascotaId })"
                       class="btn btn-green">
                        <i class="fas fa-plus me-2"></i>Nuevo Seguimiento
                    </a>
                }
            </div>
        </div>
    </div>
</section>

@if (TempData["SuccessMessage"] != null)
{
    <div class="container mt-3">
        <div class="alert alert-success alert-dismissible fade show border-0 rounded-4" role="alert">
            <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="container mt-3">
        <div class="alert alert-danger alert-dismissible fade show border-0 rounded-4" role="alert">
            <i class="fas fa-exclamation-circle me-2"></i>@TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    </div>
}

<section class="py-4 bg-beige">
    <div class="container">
        <div class="row g-4 mb-4">
            <div class="col-md-8">
                <div class="info-card h-100">
                    <div class="info-card-body">
                        <div class="d-flex flex-wrap align-items-start gap-3">
                            <div class="flex-shrink-0">
                                @if (ViewBag.ImagenBase64 != null)
                                {
                                    <img src="@ViewBag.ImagenBase64"
                                         class="rounded-3 shadow-sm"
                                         style="width: 150px; height: 150px; object-fit: cover; border: 2px solid var(--verde-menta);"
                                         alt="@mascota?.Nombre">
                                }
                                else
                                {
                                    <div class="rounded-3 d-flex align-items-center justify-content-center"
                                         style="width: 150px; height: 150px; background-color: #F2E9D8; border: 2px solid var(--verde-menta);">
                                        <i class="fas fa-paw fa-3x text-green"></i>
                                    </div>
                                }
                            </div>
                            <div class="flex-grow-1">
                                <h4 class="text-brown mb-2">@Html.Encode(mascota?.Nombre)</h4>
                                <div class="row g-2">
                                    <div class="col-md-6">
                                        <span class="text-secondary">Especie:</span> <span class="text-brown">@Html.Encode(mascota?.Especie)</span>
                                    </div>
                                    <div class="col-md-6">
                                        <span class="text-secondary">Raza:</span> <span class="text-brown">@Html.Encode(mascota?.Raza ?? "Mestizo")</span>
                                    </div>
                                    <div class="col-md-6">
                                        <span class="text-secondary">Sexo:</span> <span class="text-brown">@Html.Encode(ViewBag.SexoTexto as string)</span>
                                    </div>
                                    <div class="col-md-6">
                                        <span class="text-secondary">Fecha Adopcion:</span>
                                        <span class="text-brown">@(mascota?.FechaAdopcion?.ToString("dd/MM/yyyy") ?? "No especificada")</span>
                                    </div>
                                    <div class="col-md-6">
                                        <span class="text-secondary">Contrato:</span>
                                        <span class="text-brown">
                                            @Html.Encode(contrato?.NumeroContrato ?? "N/A")
                                            @if (contrato != null && contrato.NumeroContrato != null && contrato.NumeroContrato.StartsWith("CTR-AUTO"))
                                            {
                                                <span class="badge bg-yellow text-brown ms-1" title="Contrato generado automaticamente">
                                                    <i class="fas fa-magic"></i> Auto
                                                </span>
                                            }
                                        </span>
                                    </div>
                                    <div class="col-md-6">
                                        <span class="text-secondary">Adoptante:</span>
                                        <span class="text-brown">@Html.Encode(contrato?.AdoptanteNombre ?? "N/A")</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stats-card h-100">
                    <div class="stats-card-header bg-green text-white">
                        <i class="fas fa-chart-bar me-2"></i>Resumen
                    </div>
                    <div class="stats-card-body">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-secondary">Total seguimientos:</span>
                            <span class="fw-bold text-brown">@ViewBag.TotalSeguimientos</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-secondary">Completados:</span>
                            <span class="fw-bold text-green">@ViewBag.SeguimientosCompletados</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-secondary">Pendientes:</span>
                            <span class="fw-bold text-yellow">@ViewBag.SeguimientosPendientes</span>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span class="text-secondary">Con intervencion:</span>
                            <span class="fw-bold text-pink">@Model.Count(s => s.RequiereIntervencion)</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="table-card">
            <div class="table-card-header bg-green text-white d-flex justify-content-between align-items-center">
                <span><i class="fas fa-list me-2"></i>Historial de Seguimientos</span>
                <span class="badge bg-light-mint text-brown px-3 py-2">@Model.Count() registros</span>
            </div>
            <div class="table-card-body p-0">
                @if (Model.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0" id="seguimientosTable">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Fecha</th>
                                    <th>Tipo</th>
                                    <th>Estado Mascota</th>
                                    <th>Condiciones</th>
                                    <th>Relacion</th>
                                    <th>Intervencion</th>
                                    <th>Proximo</th>
                                    <th class="text-center">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var seguimiento in Model.OrderByDescending(s => s.FechaSeguimiento))
                                {
                                    <tr class="@(seguimiento.RequiereIntervencion ? "table-danger-row" : "")">
                                        <td><span class="badge bg-light-mint text-brown px-3 py-2">@seguimiento.SeguimientoId</span></td>
                                        <td class="text-secondary">
                                            @if (seguimiento.FechaSeguimiento.HasValue)
                                            {
                                                @seguimiento.FechaSeguimiento.Value.ToString("dd/MM/yyyy HH:mm")
                                            }
                                            else
                                            {
                                                <span class="text-secondary">No realizado</span>
                                            }
                                        </td>
                                        <td>
                                            <span class="badge @(seguimiento.TipoSeguimiento == "Inicial" ? "bg-green text-white" :
                                                               seguimiento.TipoSeguimiento == "Final" ? "bg-info text-white" :
                                                               seguimiento.TipoSeguimiento == "Extraordinario" ? "bg-yellow text-brown" : "bg-secondary text-white") px-3 py-2">
                                                @seguimiento.TipoSeguimiento
                                            </span>
                                        </td>
                                        <td>
                                            @{
                                                string estadoColor = seguimiento.EstadoMascota?.Contains("Excelente") == true ? "bg-green text-white" :
                                                                    seguimiento.EstadoMascota?.Contains("Bueno") == true ? "bg-info text-white" :
                                                                    seguimiento.EstadoMascota?.Contains("Regular") == true ? "bg-yellow text-brown" :
                                                                    seguimiento.EstadoMascota?.Contains("Malo") == true ? "bg-pink text-brown" : "bg-secondary text-white";
                                            }
                                            <span class="badge @estadoColor px-3 py-2">@seguimiento.EstadoMascota</span>
                                        </td>
                                        <td class="text-secondary">@seguimiento.CondicionesVivienda</td>
                                        <td class="text-secondary">@seguimiento.RelacionConAdoptante</td>
                                        <td class="text-center">
                                            @if (seguimiento.RequiereIntervencion)
                                            {
                                                <span class="badge bg-pink text-brown px-3 py-2">
                                                    <i class="fas fa-exclamation-triangle me-1"></i> Si
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-green text-white px-3 py-2">
                                                    <i class="fas fa-check me-1"></i> No
                                                </span>
                                            }
                                        </td>
                                        <td>
                                            @if (seguimiento.ProximoSeguimiento.HasValue)
                                            {
                                                var hoy = DateTime.Today;
                                                var dias = (seguimiento.ProximoSeguimiento.Value - hoy).Days;
                                                string clase = dias <= 0 ? "text-pink fw-bold" :
                                                               dias <= 7 ? "text-yellow fw-bold" : "text-green";
                                                <span class="@clase">
                                                    @seguimiento.ProximoSeguimiento.Value.ToString("dd/MM/yyyy")
                                                    @if (dias <= 0)
                                                    {
                                                        <br /><small class="text-secondary">(Vencido hace @(-dias) dias)</small>
                                                    }
                                                    else
                                                    {
                                                        <br /><small class="text-secondary">(En @dias dias)</small>
                                                    }
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="text-secondary">N/A</span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            
                                            <div class="d-flex justify-content-center gap-2">
                                                <button type="button"
                                                        class="btn btn-sm btn-outline-green btn-ver-detalle"
                                                        data-id="@seguimiento.SeguimientoId"
                                                        title="Ver detalles">
                                                    <i class="fas fa-eye"></i>
                                                </button>
                                                <a href="@Url.Action("EditarSeguimiento", "Mascotas", new { id = seguimiento.SeguimientoId })"
                                                   class="btn btn-sm btn-yellow" title="Editar">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                                @if (User.IsInRole("Administrador") || User.IsInRole("Veterinario"))
                                                {
                                                    <form action="@Url.Action("EliminarSeguimiento", "Mascotas")"
                                                          method="post" class="d-inline">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="id" value="@seguimiento.SeguimientoId" />
                                                        <button type="submit" class="btn btn-sm btn-pink btn-eliminar" title="Eliminar">
                                                            <i class="fas fa-trash"></i>
                                                        </button>
                                                    </form>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="empty-state text-center py-5">
                        <i class="fas fa-clipboard-list fa-4x text-green mb-3"></i>
                        <h4 class="text-brown">No hay seguimientos registrados</h4>
                        <p class="text-secondary mb-3">Comienza registrando el primer seguimiento de esta adopcion.</p>
                        @if (mascota != null)
                        {
                            <a href="@Url.Action("CrearSeguimientoManual", "Mascotas", new { mascotaId = mascota.MascotaId })"
                               class="btn btn-green mt-2">
                                <i class="fas fa-plus me-2"></i> Registrar Primer Seguimiento
                            </a>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</section>


@foreach (var seguimiento in Model)
{
    <div class="modal fade" id="modalDetalle@(seguimiento.SeguimientoId)" tabindex="-1"
         aria-labelledby="modalDetalleLabel@(seguimiento.SeguimientoId)" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-green text-white">
                    <h5 class="modal-title" id="modalDetalleLabel@(seguimiento.SeguimientoId)">
                        <i class="fas fa-clipboard-check me-2"></i>Seguimiento #@seguimiento.SeguimientoId
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <h6 class="text-brown border-bottom pb-2">Informacion General</h6>
                            <p><span class="text-secondary">Fecha:</span> <span class="text-brown">@(seguimiento.FechaSeguimiento?.ToString("dd/MM/yyyy HH:mm") ?? "No registrada")</span></p>
                            <p><span class="text-secondary">Tipo:</span> <span class="text-brown">@seguimiento.TipoSeguimiento</span></p>
                            <p><span class="text-secondary">Estado Mascota:</span> <span class="text-brown">@seguimiento.EstadoMascota</span></p>
                            <p><span class="text-secondary">Condiciones Vivienda:</span> <span class="text-brown">@seguimiento.CondicionesVivienda</span></p>
                            <p><span class="text-secondary">Relacion con Adoptante:</span> <span class="text-brown">@seguimiento.RelacionConAdoptante</span></p>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-brown border-bottom pb-2">Informacion Adicional</h6>
                            <p><span class="text-secondary">Proximo seguimiento:</span> <span class="text-brown">@(seguimiento.ProximoSeguimiento?.ToString("dd/MM/yyyy") ?? "No programado")</span></p>
                            <p><span class="text-secondary">Requiere intervencion:</span> <span class="text-brown">@(seguimiento.RequiereIntervencion ? "Si" : "No")</span></p>
                            <p><span class="text-secondary">Fotos de evidencia:</span><br /><span class="text-secondary">@(string.IsNullOrEmpty(seguimiento.FotosEvidencia) ? "No hay fotos" : seguimiento.FotosEvidencia)</span></p>
                        </div>
                    </div>
                    <hr />
                    <div class="row g-3">
                        <div class="col-md-6">
                            <h6 class="text-brown border-bottom pb-2">Observaciones</h6>
                            <div class="alert-beige p-3 rounded-3">
                                @if (!string.IsNullOrEmpty(seguimiento.Observaciones))
                                {
                                    @Html.Raw(seguimiento.Observaciones.Replace("\n", "<br />"))
                                }
                                else
                                {
                                    <span class="text-secondary">No hay observaciones</span>
                                }
                            </div>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-brown border-bottom pb-2">Recomendaciones</h6>
                            <div class="alert-beige p-3 rounded-3">
                                @if (!string.IsNullOrEmpty(seguimiento.Recomendaciones))
                                {
                                    @Html.Raw(seguimiento.Recomendaciones.Replace("\n", "<br />"))
                                }
                                else
                                {
                                    <span class="text-secondary">No hay recomendaciones</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-green" data-bs-dismiss="modal">
                        <i class="fas fa-times me-2"></i>Cerrar
                    </button>
                    <a href="@Url.Action("EditarSeguimiento", "Mascotas", new { id = seguimiento.SeguimientoId })"
                       class="btn btn-green">
                        <i class="fas fa-edit me-2"></i>Editar
                    </a>
                </div>
            </div>
        </div>
    </div>
}

