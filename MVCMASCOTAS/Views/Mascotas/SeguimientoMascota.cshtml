@section Scripts {
    <script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.4/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function () {

            // ✅ CLAVE: mover todos los modales al body para que DataTables no los rompa
            $('[id^="modalDetalle"]').appendTo('body');

            // Inicializar DataTables
            $('#seguimientosTable').DataTable({
                order: [[1, 'desc']],
                language: { url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json' },
                pageLength: 10,
                responsive: true
            });

            $('[data-bs-toggle="tooltip"]').tooltip();

            // ✅ Botón Ver Detalle — abre el modal por data-id
            var modalActivo = null;

            $(document).on('click', '.btn-ver-detalle', function () {
                var id = $(this).data('id');
                var el = document.getElementById('modalDetalle' + id);
                modalActivo = new bootstrap.Modal(el);
                modalActivo.show();
            });

            // ✅ Cerrar modal: btn-close (X) y botón Cerrar/Cancelar dentro del modal
            $(document).on('click', '[data-bs-dismiss="modal"], .btn-close-white', function () {
                if (modalActivo) {
                    modalActivo.hide();
                    modalActivo = null;
                }
            });

            // SweetAlert para eliminar
            $(document).on('click', '.btn-eliminar', function (e) {
                e.preventDefault();
                var form = $(this).closest('form');
                Swal.fire({
                    title: 'Eliminar seguimiento?',
                    text: 'Esta accion no se puede deshacer.',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#FBCDC0',
                    cancelButtonColor: '#97C78B',
                    confirmButtonText: '<i class="fas fa-trash me-2"></i>Si, eliminar',
                    cancelButtonText: '<i class="fas fa-times me-2"></i>Cancelar'
                }).then((result) => {
                    if (result.isConfirmed) { form.submit(); }
                });
            });
        });
    </script>
}
