@model MVCMASCOTAS.Models.Mascotas

@{
    ViewBag.Title = $"Detalles de {Model.Nombre}";
}

<div class="row">
    <div class="col-md-6">
        <!-- Imagen Principal -->
        <div class="card shadow-custom mb-4">
            @if (ViewBag.ImagenBase64 != null)
            {
                <img src="@ViewBag.ImagenBase64" class="card-img-top img-preview" alt="@Model.Nombre">
            }
            else
            {
                <img src="~/Content/images/no-image.png" class="card-img-top" alt="Sin imagen">
            }
        </div>

        <!-- Imágenes Adicionales -->
        @if (ViewBag.ImagenesAdicionales != null && ViewBag.ImagenesAdicionales.Count > 0)
        {
            <div class="card shadow-custom">
                <div class="card-header">
                    <h5><i class="fas fa-images"></i> Más Fotos</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        @foreach (var imagen in ViewBag.ImagenesAdicionales)
                        {
                            <div class="col-md-4 mb-2">
                                <img src="@MVCMASCOTAS.Helpers.ImageHelper.GetImageDataUri(imagen.Imagen)" class="img-fluid rounded" alt="Imagen adicional">
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="col-md-6">
        <div class="card shadow-custom">
            <div class="card-header bg-primary text-white">
                <h3><i class="fas fa-paw"></i> @Model.Nombre</h3>
            </div>
            <div class="card-body">
                <!-- Información Básica -->
                <h5 class="border-bottom pb-2 mb-3">
                    <i class="fas fa-info-circle text-primary"></i> Información Básica
                </h5>
                <table class="table table-borderless">
                    <tr>
                        <td><strong><i class="fas fa-paw"></i> Especie:</strong></td>
                        <td>@Model.Especie</td>
                    </tr>
                    <tr>
                        <td><strong><i class="fas fa-dog"></i> Raza:</strong></td>
                        <td>@(Model.Raza ?? "Mestizo")</td>
                    </tr>
                    <tr>
                        <td><strong><i class="fas fa-venus-mars"></i> Sexo:</strong></td>
                        <td>@Model.Sexo</td>
                    </tr>
                    <tr>
                        <td><strong><i class="fas fa-calendar"></i> Edad Aproximada:</strong></td>
                        <td>@Model.EdadAproximada</td>
                    </tr>
                    <tr>
                        <td><strong><i class="fas fa-ruler"></i> Tamaño:</strong></td>
                        <td>@Model.Tamanio</td>
                    </tr>
                    <tr>
                        <td><strong><i class="fas fa-palette"></i> Color:</strong></td>
                        <td>@Model.Color</td>
                    </tr>
                    <tr>
                        <td><strong><i class="fas fa-check-circle"></i> Esterilizado:</strong></td>
                        <td>
                            @if (Model.Esterilizado == true)
                            {
                                <span class="badge badge-success">Sí</span>
                            }
                            else
                            {
                                <span class="badge badge-warning">No</span>
                            }
                        </td>
                    </tr>
                    @if (!string.IsNullOrEmpty(Model.Microchip))
                    {
                        <tr>
                            <td><strong><i class="fas fa-microchip"></i> Microchip:</strong></td>
                            <td>@Model.Microchip</td>
                        </tr>
                    }
                    <tr>
                        <td><strong><i class="fas fa-calendar-plus"></i> Fecha de Ingreso:</strong></td>
                        <td>@Model.FechaIngreso.ToString("dd/MM/yyyy")</td>
                    </tr>
                </table>

                <!-- Descripción -->
                @if (!string.IsNullOrEmpty(Model.DescripcionGeneral))
                {
                    <h5 class="border-bottom pb-2 mb-3 mt-4">
                        <i class="fas fa-align-left text-primary"></i> Sobre Mí
                    </h5>
                    <p>@Model.DescripcionGeneral</p>
                }

                <!-- Características de Comportamiento -->
                @if (!string.IsNullOrEmpty(Model.CaracteristicasComportamiento))
                {
                    <h5 class="border-bottom pb-2 mb-3 mt-4">
                        <i class="fas fa-heart text-primary"></i> Mi Personalidad
                    </h5>
                    <p>@Model.CaracteristicasComportamiento</p>
                }

                <!-- Historia de Rescate -->
                @if (!string.IsNullOrEmpty(Model.HistoriaRescate))
                {
                    <h5 class="border-bottom pb-2 mb-3 mt-4">
                        <i class="fas fa-book text-primary"></i> Mi Historia
                    </h5>
                    <p>@Model.HistoriaRescate</p>
                }

                <!-- Información de Vacunas -->
                @if (ViewBag.Vacunas != null && ViewBag.Vacunas.Count > 0)
                {
                    <h5 class="border-bottom pb-2 mb-3 mt-4">
                        <i class="fas fa-syringe text-primary"></i> Vacunas Aplicadas
                    </h5>
                    <ul class="list-group">
                        @foreach (var vacuna in ViewBag.Vacunas)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                @vacuna.Vacunas.NombreVacuna
                                <span class="badge badge-primary badge-pill">@vacuna.FechaAplicacion.ToString("dd/MM/yyyy")</span>
                            </li>
                        }
                    </ul>
                }

                <!-- Botón de Adopción -->
                <div class="mt-4">
                    @if (Model.Estado == "Disponible para adopción")
                    {
                        if (Request.IsAuthenticated)
                        {
                            if (ViewBag.YaSolicito == true)
                            {
                                <div class="alert alert-info">
                                    <i class="fas fa-info-circle"></i> Ya has solicitado adoptar a @Model.Nombre
                                </div>
                            }
                            else
                            {
                                <a href="@Url.Action("Solicitar", "Adopcion", new { mascotaId = Model.MascotaId })" class="btn btn-success btn-lg btn-block">
                                    <i class="fas fa-hand-holding-heart"></i> ¡Quiero Adoptar a @Model.Nombre!
                                </a>
                            }
                        }
                        else
                        {
                            <div class="alert alert-warning">
                                <i class="fas fa-exclamation-triangle"></i> Debes <a href="@Url.Action("Login", "Account")">iniciar sesión</a> para adoptar
                            </div>
                        }
                    }
                    else
                    {
                        <div class="alert alert-secondary">
                            <i class="fas fa-info-circle"></i> @Model.Nombre no está disponible para adopción en este momento (Estado: @Model.Estado)
                        </div>
                    }
                </div>

                <!-- Opciones alternativas -->
                <div class="mt-3">
                    <a href="@Url.Action("Apadrinar", "Donaciones")" class="btn btn-outline-primary btn-block">
                        <i class="fas fa-heart"></i> Apadrinar a @Model.Nombre
                    </a>
                    <a href="@Url.Action("Index", "Mascotas")" class="btn btn-outline-secondary btn-block">
                        <i class="fas fa-arrow-left"></i> Ver Otras Mascotas
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
