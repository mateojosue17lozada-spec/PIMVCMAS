@model MVCMASCOTAS.Models.Mascotas

@{
    ViewBag.Title = "Detalles de " + Model.Nombre;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4 mb-5">
    <!-- ✅ BOTÓN VOLVER A GESTIONAR -->
    <div class="row mb-3">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <a href="@Url.Action("Gestionar", "Mascotas")" class="btn btn-secondary">
                    <i class="fas fa-arrow-left me-2"></i>Volver a Gestión
                </a>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-0">
                        <li class="breadcrumb-item">
                            <a href="@Url.Action("Index", "Home")">
                                <i class="fas fa-home"></i> Inicio
                            </a>
                        </li>
                        <li class="breadcrumb-item">
                            <a href="@Url.Action("Gestionar", "Mascotas")">Gestión de Mascotas</a>
                        </li>
                        <li class="breadcrumb-item active" aria-current="page">@Model.Nombre</li>
                    </ol>
                </nav>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-paw me-2"></i>@Model.Nombre
                        @if (Model.Categoria == "Especial")
                        {
                            <span class="badge bg-warning ms-2">
                                <i class="fas fa-star"></i> Especial
                            </span>
                        }
                    </h4>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            @{
                                string imagenUrl = "/Content/images/no-image.png";
                                if (Model.ImagenPrincipal != null && Model.ImagenPrincipal.Length > 0)
                                {
                                    imagenUrl = MVCMASCOTAS.Helpers.ImageHelper.GetImageDataUri(Model.ImagenPrincipal);
                                }
                            }
                            <img src="@imagenUrl"
                                 alt="@Model.Nombre"
                                 class="img-fluid rounded shadow-sm"
                                 style="width: 100%; height: auto; object-fit: cover;"
                                 onerror="this.src='/Content/images/no-image.png'">
                        </div>
                        <div class="col-md-6">
                            <h5 class="text-primary mb-3">Información General</h5>

                            <table class="table table-borderless">
                                <tr>
                                    <td><strong><i class="fas fa-id-card text-primary me-2"></i>ID:</strong></td>
                                    <td>#@Model.MascotaId</td>
                                </tr>
                                <tr>
                                    <td><strong><i class="fas fa-paw text-primary me-2"></i>Especie:</strong></td>
                                    <td>
                                        <span class="badge @(Model.Especie == "Perro" ? "bg-info" : "bg-pink")">
                                            @Model.Especie
                                        </span>
                                    </td>
                                </tr>
                                <tr>
                                    <td><strong><i class="fas fa-dna text-primary me-2"></i>Raza:</strong></td>
                                    <td>@(Model.Raza ?? "Mestizo")</td>
                                </tr>
                                <tr>
                                    <td><strong><i class="fas fa-venus-mars text-primary me-2"></i>Sexo:</strong></td>
                                    <td>
                                        @{
                                            string sexoTexto = Model.Sexo == "M" ? "Macho" : "Hembra";
                                            string sexoIcono = Model.Sexo == "M" ? "fa-mars" : "fa-venus";
                                            string sexoColor = Model.Sexo == "M" ? "text-info" : "text-danger";
                                        }
                                        <i class="fas @sexoIcono @sexoColor me-1"></i>@sexoTexto
                                    </td>
                                </tr>
                                <tr>
                                    <td><strong><i class="fas fa-birthday-cake text-primary me-2"></i>Edad:</strong></td>
                                    <td>@(Model.EdadAproximada ?? "No especificada")</td>
                                </tr>
                                <tr>
                                    <td><strong><i class="fas fa-ruler-combined text-primary me-2"></i>Tamaño:</strong></td>
                                    <td>
                                        <span class="badge @(
                                            Model.Tamanio == "Pequeño" ? "bg-success" :
                                            Model.Tamanio == "Mediano" ? "bg-warning" :
                                            Model.Tamanio == "Grande" ? "bg-secondary" : "bg-dark"
                                        )">
                                            @Model.Tamanio
                                        </span>
                                    </td>
                                </tr>
                                <tr>
                                    <td><strong><i class="fas fa-palette text-primary me-2"></i>Color:</strong></td>
                                    <td>@(Model.Color ?? "No especificado")</td>
                                </tr>
                                <tr>
                                    <td><strong><i class="fas fa-check-circle text-primary me-2"></i>Esterilizado:</strong></td>
                                    <td>
                                        @if (Model.Esterilizado == true)
                                        {
                                            <span class="badge bg-success">
                                                <i class="fas fa-check"></i> Sí
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">
                                                <i class="fas fa-times"></i> No
                                            </span>
                                        }
                                    </td>
                                </tr>
                                @if (!string.IsNullOrEmpty(Model.Microchip))
                                {
                                    <tr>
                                        <td><strong><i class="fas fa-microchip text-primary me-2"></i>Microchip:</strong></td>
                                        <td><code>@Model.Microchip</code></td>
                                    </tr>
                                }
                            </table>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.DescripcionGeneral))
                    {
                        <hr class="my-4">
                        <h5 class="text-primary mb-3">
                            <i class="fas fa-align-left me-2"></i>Descripción
                        </h5>
                        <p class="text-justify">@Model.DescripcionGeneral</p>
                    }

                    @if (!string.IsNullOrEmpty(Model.CaracteristicasComportamiento))
                    {
                        <hr class="my-4">
                        <h5 class="text-primary mb-3">
                            <i class="fas fa-heart me-2"></i>Comportamiento
                        </h5>
                        <p class="text-justify">@Model.CaracteristicasComportamiento</p>
                    }

                    @if (!string.IsNullOrEmpty(Model.HistoriaRescate))
                    {
                        <hr class="my-4">
                        <h5 class="text-primary mb-3">
                            <i class="fas fa-book me-2"></i>Historia de Rescate
                        </h5>
                        <p class="text-justify">@Model.HistoriaRescate</p>
                    }
                </div>
            </div>

            @* ✅ SECCIÓN DE VACUNAS - CORREGIDA *@
            @if (ViewBag.Vacunas != null && ((List<MVCMASCOTAS.Models.MascotaVacunas>)ViewBag.Vacunas).Count > 0)
            {
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0">
                            <i class="fas fa-syringe me-2"></i>Vacunas Aplicadas
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-sm table-hover">
                                <thead>
                                    <tr>
                                        <th>Vacuna</th>
                                        <th>Fecha Aplicación</th>
                                        <th>Próxima Dosis</th>
                                        <th>Lote</th>
                                        <th>Laboratorio</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var vacuna in (List<MVCMASCOTAS.Models.MascotaVacunas>)ViewBag.Vacunas)
                                    {
                                        <tr>
                                            @* ✅ CORRECCIÓN: Acceder a través de la relación Vacunas *@
                                            <td>
                                                <strong>
                                                    @if (vacuna.Vacunas != null && !string.IsNullOrEmpty(vacuna.Vacunas.NombreVacuna))
                                                    {
                                                        @vacuna.Vacunas.NombreVacuna
                                                    }
                                                    else
                                                    {
                                                        <text>Vacuna #@vacuna.VacunaId</text>
                                                    }
                                                </strong>
                                            </td>
                                            @* ✅ CORRECCIÓN: FechaAplicacion NO es nullable *@
                                            <td>@vacuna.FechaAplicacion.ToString("dd/MM/yyyy")</td>
                                            @* ✅ ProximaDosis SÍ es nullable *@
                                            <td>
                                                @if (vacuna.ProximaDosis.HasValue)
                                                {
                                                    @vacuna.ProximaDosis.Value.ToString("dd/MM/yyyy")
                                                }
                                                else
                                                {
                                                    <text>-</text>
                                                }
                                            </td>
                                            <td>@(vacuna.Lote ?? "-")</td>
                                            <td>@(vacuna.Laboratorio ?? "-")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }

            @* ✅ SECCIÓN DE HISTORIAL MÉDICO - NUEVA *@
            @if (ViewBag.HistorialMedico != null && ((List<MVCMASCOTAS.Models.HistorialMedico>)ViewBag.HistorialMedico).Count > 0)
            {
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-warning text-dark">
                        <h5 class="mb-0">
                            <i class="fas fa-stethoscope me-2"></i>Historial Médico Reciente
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="accordion" id="historialAccordion">
                            @{
                                int idx = 0;
                                foreach (var historial in (List<MVCMASCOTAS.Models.HistorialMedico>)ViewBag.HistorialMedico)
                                {
                                    <div class="accordion-item">
                                        <h2 class="accordion-header" id="heading@idx">
                                            <button class="accordion-button collapsed" type="button"
                                                    data-bs-toggle="collapse"
                                                    data-bs-target="#collapse@idx"
                                                    aria-expanded="false">
                                                <i class="fas fa-calendar-check me-2"></i>
                                                @* ✅ CORRECCIÓN: FechaConsulta es nullable *@
                                                @if (historial.FechaConsulta.HasValue)
                                                {
                                                    @historial.FechaConsulta.Value.ToString("dd/MM/yyyy")
                                                }
                                                else
                                                {
                                                    <text>Fecha no registrada</text>
                                                }
                                                - @(historial.TipoConsulta ?? "Consulta General")
                                            </button>
                                        </h2>
                                        <div id="collapse@idx" class="accordion-collapse collapse"
                                             data-bs-parent="#historialAccordion">
                                            <div class="accordion-body">
                                                @if (!string.IsNullOrEmpty(historial.Diagnostico))
                                                {
                                                    <p><strong>Diagnóstico:</strong> @historial.Diagnostico</p>
                                                }
                                                @if (!string.IsNullOrEmpty(historial.Tratamiento))
                                                {
                                                    <p><strong>Tratamiento:</strong> @historial.Tratamiento</p>
                                                }
                                                @if (historial.Peso.HasValue)
                                                {
                                                    <p><strong>Peso:</strong> @historial.Peso.Value kg</p>
                                                }
                                                @if (historial.Temperatura.HasValue)
                                                {
                                                    <p><strong>Temperatura:</strong> @historial.Temperatura.Value °C</p>
                                                }
                                                @if (!string.IsNullOrEmpty(historial.EstadoGeneral))
                                                {
                                                    <p><strong>Estado General:</strong> @historial.EstadoGeneral</p>
                                                }
                                                @if (!string.IsNullOrEmpty(historial.Observaciones))
                                                {
                                                    <p><strong>Observaciones:</strong> @historial.Observaciones</p>
                                                }
                                                @if (historial.ProximaConsulta.HasValue)
                                                {
                                                    <p>
                                                        <strong>Próxima Consulta:</strong>
                                                        <span class="badge bg-info">
                                                            @historial.ProximaConsulta.Value.ToString("dd/MM/yyyy")
                                                        </span>
                                                    </p>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                    idx++;
                                }
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-info-circle me-2"></i>Estado Actual
                    </h5>
                </div>
                <div class="card-body">
                    <div class="text-center mb-3">
                        <span class="badge @(
                            Model.Estado == "Disponible para adopción" ? "bg-success" :
                            Model.Estado == "Adoptada" ? "bg-info" :
                            Model.Estado == "En tratamiento" ? "bg-warning" :
                            Model.Estado == "Archivada" ? "bg-secondary" : "bg-primary"
                        ) fs-5 p-3">
                            @Model.Estado
                        </span>
                    </div>

                    <hr>

                    <p class="mb-2">
                        <strong><i class="fas fa-calendar-alt text-info me-2"></i>Fecha de Ingreso:</strong><br>
                        <span class="ms-4">@(Model.FechaIngreso.HasValue ? Model.FechaIngreso.Value.ToString("dd/MM/yyyy") : "No especificada")</span>
                    </p>

                    @* ✅ Tiempo en refugio *@
                    @if (Model.FechaIngreso.HasValue)
                    {
                        <p class="mb-2">
                            <strong><i class="fas fa-clock text-info me-2"></i>Tiempo en refugio:</strong><br>
                            <span class="ms-4">
                                @{
                                    var dias = (DateTime.Now - Model.FechaIngreso.Value).Days;
                                    if (dias < 30)
                                    {
                                        <text>@dias día@(dias != 1 ? "s" : "")</text>
                                    }
                                    else if (dias < 365)
                                    {
                                        var meses = dias / 30;
                                        <text>@meses @(meses == 1 ? "mes" : "meses")</text>
                                    }
                                    else
                                    {
                                        var anios = dias / 365;
                                        <text>@anios @(anios == 1 ? "año" : "años")</text>
                                    }
                                }
                            </span>
                        </p>
                    }

                    @if (!string.IsNullOrEmpty(ViewBag.VeterinarioNombre))
                    {
                        <p class="mb-2">
                            <strong><i class="fas fa-user-md text-info me-2"></i>Veterinario:</strong><br>
                            <span class="ms-4">@ViewBag.VeterinarioNombre</span>
                        </p>
                    }

                    @if (!string.IsNullOrEmpty(ViewBag.RescatistaNombre))
                    {
                        <p class="mb-2">
                            <strong><i class="fas fa-hands-helping text-info me-2"></i>Rescatista:</strong><br>
                            <span class="ms-4">@ViewBag.RescatistaNombre</span>
                        </p>
                    }

                    @if (Model.Estado == "Disponible para adopción")
                    {
                        <hr>
                        <div class="d-grid gap-2">
                            @if (User.Identity.IsAuthenticated)
                            {
                                if (ViewBag.YaSolicito == true)
                                {
                                    <button class="btn btn-secondary" disabled>
                                        <i class="fas fa-check me-2"></i>Ya Solicitaste Adoptar
                                    </button>
                                    <a href="@Url.Action("MisSolicitudes", "Adopcion")" class="btn btn-outline-info">
                                        <i class="fas fa-list me-1"></i> Ver Mis Solicitudes
                                    </a>
                                }
                                else
                                {
                                    <a href="@Url.Action("Solicitar", "Adopcion", new { mascotaId = Model.MascotaId })"
                                       class="btn btn-success btn-lg">
                                        <i class="fas fa-heart me-2"></i>Adoptar a @Model.Nombre
                                    </a>
                                }
                            }
                            else
                            {
                                <a href="@Url.Action("Login", "Account", new { returnUrl = Url.Action("Detalle", "Mascotas", new { id = Model.MascotaId }) })"
                                   class="btn btn-success btn-lg">
                                    <i class="fas fa-sign-in-alt me-2"></i>Inicia Sesión para Adoptar
                                </a>
                            }
                        </div>
                    }
                    else if (Model.Estado == "Adoptada")
                    {
                        <hr>
                        <div class="alert alert-success mb-0">
                            <i class="fas fa-heart me-2"></i>
                            ¡@Model.Nombre ya encontró un hogar lleno de amor!
                        </div>
                    }
                </div>
            </div>

            @if (User.IsInRole("Administrador") || User.IsInRole("Veterinario") || User.IsInRole("Rescatista"))
            {
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-warning text-dark">
                        <h5 class="mb-0">
                            <i class="fas fa-cog me-2"></i>Acciones Administrativas
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="d-grid gap-2">
                            <a href="@Url.Action("Editar", "Mascotas", new { id = Model.MascotaId })"
                               class="btn btn-warning">
                                <i class="fas fa-edit me-2"></i>Editar
                            </a>
                            <a href="@Url.Action("HistorialEstados", "Mascotas", new { id = Model.MascotaId })"
                               class="btn btn-info">
                                <i class="fas fa-history me-2"></i>Historial de Estados
                            </a>
                        </div>
                    </div>
                </div>
            }

            @if (ViewBag.MascotasSimilares != null && ((List<MVCMASCOTAS.Models.Mascotas>)ViewBag.MascotasSimilares).Count > 0)
            {
                <div class="card shadow-sm">
                    <div class="card-header bg-secondary text-white">
                        <h5 class="mb-0">
                            <i class="fas fa-paw me-2"></i>Mascotas Similares
                        </h5>
                    </div>
                    <div class="card-body">
                        @foreach (var similar in (List<MVCMASCOTAS.Models.Mascotas>)ViewBag.MascotasSimilares)
                        {
                            string imagenSimilarUrl = "/Content/images/no-image.png";
                            if (similar.ImagenPrincipal != null && similar.ImagenPrincipal.Length > 0)
                            {
                                imagenSimilarUrl = MVCMASCOTAS.Helpers.ImageHelper.GetImageDataUri(similar.ImagenPrincipal);
                            }

                            <div class="d-flex align-items-center mb-3 pb-3 border-bottom">
                                <img src="@imagenSimilarUrl"
                                     alt="@similar.Nombre"
                                     style="width: 60px; height: 60px; object-fit: cover; border-radius: 8px;"
                                     onerror="this.src='/Content/images/no-image.png'">
                                <div class="ms-3 flex-grow-1">
                                    <h6 class="mb-1">@similar.Nombre</h6>
                                    <small class="text-muted">@similar.Especie - @(similar.Raza ?? "Mestizo")</small>
                                </div>
                                <a href="@Url.Action("Detalle", "Mascotas", new { id = similar.MascotaId })"
                                   class="btn btn-sm btn-outline-primary">
                                    Ver
                                </a>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .badge.bg-pink {
        background-color: #FBCDC0 !important;
        color: #5C4B43 !important;
    }

    .text-justify {
        text-align: justify;
    }
</style>