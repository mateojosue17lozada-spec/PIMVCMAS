@model IEnumerable<MVCMASCOTAS.Models.HistorialEstadosMascota>

@{
    ViewBag.Title = "Historial de Estados";
    var mascota = ViewBag.Mascota as MVCMASCOTAS.Models.Mascotas;
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>
            <i class="fas fa-history text-primary"></i>
            Historial de Estados: @Html.Encode(mascota.Nombre)
        </h2>
        <div>
            <a href="@Url.Action("Gestionar", "Mascotas")" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left"></i> Volver
            </a>
            <a href="@Url.Action("Detalle", "Mascotas", new { id = mascota.MascotaId })" class="btn btn-info">
                <i class="fas fa-eye"></i> Ver Detalles
            </a>
        </div>
    </div>

    <!-- Información de la mascota -->
    <div class="row mb-4">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-3 text-center">
                            @if (ViewBag.ImagenBase64 != null)
                            {
                                <img src="@ViewBag.ImagenBase64"
                                     class="img-fluid rounded"
                                     style="max-height: 120px;"
                                     alt="@mascota.Nombre">
                            }
                            else
                            {
                                <div class="bg-light rounded d-flex align-items-center justify-content-center"
                                     style="height: 120px; width: 120px; margin: 0 auto;">
                                    <i class="fas fa-paw fa-2x text-secondary"></i>
                                </div>
                            }
                        </div>
                        <div class="col-md-9">
                            <h4 class="text-primary">@Html.Encode(mascota.Nombre)</h4>
                            <div class="row">
                                <div class="col-md-4">
                                    <p><strong>ID:</strong> #@mascota.MascotaId</p>
                                </div>
                                <div class="col-md-4">
                                    <p><strong>Especie:</strong> @Html.Encode(mascota.Especie)</p>
                                </div>
                                <div class="col-md-4">
                                    <p><strong>Sexo:</strong> @Html.Encode(ViewBag.SexoTexto)</p>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-12">
                                    <p>
                                        <strong>Estado Actual:</strong>
                                        <span class="badge @GetEstadoBadgeClass(mascota.Estado)">@mascota.Estado</span>
                                        @if (mascota.FechaIngreso.HasValue)
                                        {
                                            <span class="text-muted ms-3">
                                                <i class="fas fa-calendar"></i>
                                                Ingreso: @mascota.FechaIngreso.Value.ToString("dd/MM/yyyy")
                                            </span>
                                        }
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm border-info">
                <div class="card-header bg-info text-white">
                    <h6 class="mb-0"><i class="fas fa-chart-line"></i> Estadísticas</h6>
                </div>
                <div class="card-body">
                    <p class="mb-2">
                        <strong>Total cambios:</strong>
                        <span class="float-end text-primary">@Model.Count()</span>
                    </p>
                    <p class="mb-2">
                        <strong>Primer cambio:</strong>
                        <span class="float-end">
                            @(Model.OrderBy(h => h.FechaCambio).FirstOrDefault()?.FechaCambio?.ToString("dd/MM/yyyy") ?? "N/A")
                        </span>
                    </p>
                    <p class="mb-2">
                        <strong>Último cambio:</strong>
                        <span class="float-end">
                            @(Model.OrderByDescending(h => h.FechaCambio).FirstOrDefault()?.FechaCambio?.ToString("dd/MM/yyyy") ?? "N/A")
                        </span>
                    </p>
                    <p class="mb-0">
                        <strong>Promedio por mes:</strong>
                        <span class="float-end">
                            @{
                                var primerCambio = Model.OrderBy(h => h.FechaCambio).FirstOrDefault()?.FechaCambio;
                                var meses = primerCambio.HasValue ?
                                    Math.Max(1, (DateTime.Now - primerCambio.Value).TotalDays / 30) : 1;
                                var promedio = Math.Round(Model.Count() / meses, 1);
                            }
                            @promedio
                        </span>
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- Gráfico de línea (simulado) -->
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-light">
            <h5 class="mb-0"><i class="fas fa-chart-line"></i> Evolución de Estados</h5>
        </div>
        <div class="card-body">
            <div class="timeline">
                @{
                    var historialOrdenado = Model.OrderBy(h => h.FechaCambio).ToList();
                    for (int i = 0; i < historialOrdenado.Count; i++)
                    {
                        var item = historialOrdenado[i];
                        <div class="timeline-item @(i % 2 == 0 ? "left" : "right")">
                            <div class="timeline-content">
                                <div class="timeline-header">
                                    <span class="badge @GetEstadoBadgeClass(item.EstadoNuevo)">
                                        @item.EstadoNuevo
                                    </span>
                                    <span class="timeline-date">
                                        @item.FechaCambio?.ToString("dd/MM/yyyy HH:mm")
                                    </span>
                                </div>
                                <div class="timeline-body">
                                    <p class="mb-1">
                                        @if (!string.IsNullOrEmpty(item.EstadoAnterior))
                                        {
                                            <span class="text-muted">
                                                <i class="fas fa-arrow-right"></i>
                                                De: <strong>@item.EstadoAnterior</strong>
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-success">
                                                <i class="fas fa-plus-circle"></i>
                                                Estado inicial
                                            </span>
                                        }
                                    </p>
                                    <p class="mb-1"><strong>Motivo:</strong> @item.Motivo</p>
                                    @if (!string.IsNullOrEmpty(item.Observaciones))
                                    {
                                        <p class="mb-0"><strong>Observaciones:</strong> @item.Observaciones</p>
                                    }
                                </div>
                                <div class="timeline-footer">
                                    <small class="text-muted">
                                        <i class="fas fa-user"></i>
                                        @(item.Usuarios?.NombreCompleto ?? "Usuario desconocido")
                                    </small>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>

    <!-- Tabla detallada -->
    <div class="card shadow-sm">
        <div class="card-header bg-light d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><i class="fas fa-table"></i> Detalle de Cambios</h5>
            <span class="badge bg-primary">@Model.Count() registros</span>
        </div>
        <div class="card-body">
            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-primary">
                            <tr>
                                <th>#</th>
                                <th>Fecha</th>
                                <th>Estado Anterior</th>
                                <th>Estado Nuevo</th>
                                <th>Motivo</th>
                                <th>Usuario</th>
                                <th>Observaciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.OrderByDescending(h => h.FechaCambio))
                            {
                                <tr>
                                    <td><strong>@item.HistorialId</strong></td>
                                    <td>@item.FechaCambio?.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(item.EstadoAnterior))
                                        {
                                            <span class="badge @GetEstadoBadgeClass(item.EstadoAnterior)">
                                                @item.EstadoAnterior
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">N/A</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge @GetEstadoBadgeClass(item.EstadoNuevo)">
                                            @item.EstadoNuevo
                                        </span>
                                    </td>
                                    <td>@item.Motivo</td>
                                    <td>
                                        <small>@(item.Usuarios?.NombreCompleto ?? "N/A")</small>
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(item.Observaciones))
                                        {
                                            <span class="d-inline-block text-truncate" style="max-width: 200px;"
                                                  title="@item.Observaciones">
                                                @item.Observaciones
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Ninguna</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="fas fa-history fa-4x text-muted mb-3"></i>
                    <h4 class="text-muted">No hay historial de estados</h4>
                    <p class="text-muted">Esta mascota no ha tenido cambios de estado registrados.</p>
                </div>
            }
        </div>
    </div>
</div>

@functions {
    string GetEstadoBadgeClass(string estado)
    {
        switch (estado)
        {
            case "Disponible para adopción":
                return "bg-success";
            case "Adoptada":
                return "bg-info";
            case "En tratamiento":
            case "En revisión veterinaria":
            case "Pendiente de exámenes":
                return "bg-warning";
            case "Rescatada":
                return "bg-danger";
            case "Fallecida":
                return "bg-dark";
            case "Archivada":
                return "bg-secondary";
            default:
                return "bg-primary";
        }
    }
}

@section Scripts {
    <script>
        $(document).ready(function () {
            // Inicializar DataTables
            $('.table').DataTable({
                order: [[1, 'desc']],
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json'
                },
                pageLength: 10
            });

            // Tooltips para observaciones truncadas
            $('[title]').tooltip();
        });
    </script>

    <style>
        .timeline {
            position: relative;
            padding: 20px 0;
        }

            .timeline::before {
                content: '';
                position: absolute;
                left: 50%;
                top: 0;
                bottom: 0;
                width: 2px;
                background: #007bff;
                transform: translateX(-50%);
            }

        .timeline-item {
            position: relative;
            margin-bottom: 30px;
            width: 45%;
        }

            .timeline-item.left {
                float: left;
                text-align: right;
                padding-right: 30px;
            }

            .timeline-item.right {
                float: right;
                padding-left: 30px;
            }

            .timeline-item::before {
                content: '';
                position: absolute;
                top: 20px;
                width: 12px;
                height: 12px;
                border-radius: 50%;
                background: #007bff;
            }

            .timeline-item.left::before {
                right: -6px;
            }

            .timeline-item.right::before {
                left: -6px;
            }

        .timeline-content {
            padding: 15px;
            background: #f8f9fa;
            border-radius: 6px;
            border: 1px solid #dee2e6;
        }

        .timeline-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 10px;
        }

        .timeline-date {
            font-size: 0.85rem;
            color: #6c757d;
        }

        .timeline-footer {
            margin-top: 10px;
            font-size: 0.8rem;
        }

        /* Responsive */
        @@media (max-width: 768px) {
            .timeline::before {
                left: 30px;
            }

            .timeline-item {
                width: calc(100% - 60px);
                float: none;
                margin-left: 60px;
                text-align: left;
                padding-left: 30px;
                padding-right: 0;
            }

                .timeline-item.left::before,
                .timeline-item.right::before {
                    left: 24px;
                }
        }
    </style>
}