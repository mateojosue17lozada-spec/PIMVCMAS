@model MVCMASCOTAS.Models.SeguimientoAdopcion

@{
    ViewBag.Title = (Model.SeguimientoId == 0 ? "Registrar Seguimiento" : "Editar Seguimiento") + " - ADOPTAMANÍA";
    var mascota = ViewBag.Mascota as MVCMASCOTAS.Models.Mascotas;
    var contrato = ViewBag.Contrato as MVCMASCOTAS.Models.ContratoAdopcion;
}

<!-- Hero Section -->
<section class="seguimiento-hero py-4">
    <div class="container">
        <div class="d-flex flex-wrap justify-content-between align-items-center">
            <div>
                <h1 class="h2 text-brown mb-1">
                    <i class="fas fa-clipboard-check text-green me-2"></i>
                    @(Model.SeguimientoId == 0 ? "Registrar Nuevo Seguimiento" : "Editar Seguimiento")
                </h1>
                <p class="text-secondary mb-0">
                    @Html.Encode(mascota?.Nombre) – @Html.Encode(mascota?.Especie) @(!string.IsNullOrEmpty(mascota?.Raza) ? "(" + mascota.Raza + ")" : "")
                </p>
            </div>
            <div class="mt-2 mt-sm-0">
                <a href="@Url.Action("Seguimiento", "Mascotas", new { id = mascota?.MascotaId })" class="btn btn-outline-green">
                    <i class="fas fa-arrow-left me-2"></i>Volver a Seguimientos
                </a>
            </div>
        </div>
    </div>
</section>

<!-- Main Content -->
<section class="py-4 bg-beige">
    <div class="container">
        <div class="row g-4 mb-4">
            <!-- Tarjeta de la mascota -->
            <div class="col-md-6">
                <div class="info-card h-100">
                    <div class="info-card-header bg-info text-white">
                        <i class="fas fa-dog me-2"></i>Mascota
                    </div>
                    <div class="info-card-body">
                        <h5 class="text-brown mb-1">@Html.Encode(mascota?.Nombre)</h5>
                        <p class="text-secondary mb-2">@Html.Encode(mascota?.Especie) - @Html.Encode(mascota?.Raza ?? "Mestizo")</p>
                        <hr class="border-green">
                        <p class="mb-1"><strong class="text-brown">Adoptante:</strong> <span class="text-secondary">@Html.Encode(ViewBag.Adoptante ?? contrato?.AdoptanteNombre ?? "No especificado")</span></p>
                        <p class="mb-0"><strong class="text-brown">Contrato:</strong> <span class="text-secondary">@Html.Encode(contrato?.NumeroContrato ?? "N/A")</span></p>
                    </div>
                </div>
            </div>
            <!-- Tarjeta de información del seguimiento -->
            <div class="col-md-6">
                <div class="info-card h-100">
                    <div class="info-card-header bg-green text-white">
                        <i class="fas fa-info-circle me-2"></i>Información del Seguimiento
                    </div>
                    <div class="info-card-body">
                        @if (Model.SeguimientoId > 0)
                        {
                            <p class="mb-1"><strong class="text-brown">ID Seguimiento:</strong> <span class="text-brown">#@Model.SeguimientoId</span></p>
                        }
                        <p class="mb-1"><strong class="text-brown">Fecha Registro:</strong> <span class="text-secondary">@DateTime.Now.ToString("dd/MM/yyyy HH:mm")</span></p>
                        <p class="mb-0"><strong class="text-brown">Responsable:</strong> <span class="text-secondary">@Html.Encode(User.Identity.Name)</span></p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Formulario principal -->
        <div class="form-card">
            <div class="form-card-header bg-green text-white">
                <i class="fas fa-edit me-2"></i>Datos del Seguimiento
            </div>
            <div class="form-card-body">
                @using (Html.BeginForm("RegistrarSeguimiento", "Mascotas", new { MascotaId = mascota?.MascotaId }, FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(model => model.SeguimientoId)
                    @Html.HiddenFor(model => model.ContratoId)
                    @Html.HiddenFor(model => model.ResponsableSeguimiento)

                    @Html.ValidationSummary(true, "", new { @class = "alert alert-beige border-green" })

                    <div class="row g-3">
                        <!-- Fila 1: Fecha y Tipo -->
                        <div class="col-md-6">
                            <label class="form-label text-brown fw-medium">
                                <i class="fas fa-calendar-alt text-green me-2"></i>Fecha del Seguimiento *
                            </label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-green"><i class="fas fa-calendar-alt text-green"></i></span>
                                @Html.TextBoxFor(model => model.FechaSeguimiento, "{0:yyyy-MM-dd}", new
                                {
                                    @class = "form-control border-green",
                                    type = "date",
                                    id = "FechaSeguimiento",
                                    required = "required"
                                })
                            </div>
                            @Html.ValidationMessageFor(model => model.FechaSeguimiento, "", new { @class = "text-danger small mt-1" })
                            <small class="text-secondary">La fecha no puede ser futura</small>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label text-brown fw-medium">
                                <i class="fas fa-tag text-green me-2"></i>Tipo de Seguimiento *
                            </label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-green"><i class="fas fa-tag text-green"></i></span>
                                @Html.DropDownListFor(model => model.TipoSeguimiento,
                                    new SelectList(new[] {
                                        new { Text = "Inicial", Value = "Inicial" },
                                        new { Text = "Periódico", Value = "Periódico" },
                                        new { Text = "Extraordinario", Value = "Extraordinario" },
                                        new { Text = "Final", Value = "Final" }
                                    }, "Value", "Text", Model.TipoSeguimiento),
                                    "Seleccione tipo",
                                    new { @class = "form-select border-green", required = "required" })
                            </div>
                            @Html.ValidationMessageFor(model => model.TipoSeguimiento, "", new { @class = "text-danger small mt-1" })
                        </div>

                        <!-- Fila 2: Estado y Condiciones -->
                        <div class="col-md-6">
                            <label class="form-label text-brown fw-medium">
                                <i class="fas fa-heart text-green me-2"></i>Estado de la Mascota *
                            </label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-green"><i class="fas fa-heart text-green"></i></span>
                                @Html.DropDownListFor(model => model.EstadoMascota,
                                    new SelectList(ViewBag.EstadosMascota ?? new[] { "Excelente", "Bueno", "Regular", "Malo", "Por evaluar" }, Model.EstadoMascota),
                                    "Seleccione estado",
                                    new { @class = "form-select border-green", required = "required" })
                            </div>
                            @Html.ValidationMessageFor(model => model.EstadoMascota, "", new { @class = "text-danger small mt-1" })
                        </div>

                        <div class="col-md-6">
                            <label class="form-label text-brown fw-medium">
                                <i class="fas fa-home text-green me-2"></i>Condiciones de Vivienda *
                            </label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-green"><i class="fas fa-home text-green"></i></span>
                                @Html.DropDownListFor(model => model.CondicionesVivienda,
                                    new SelectList(ViewBag.CondicionesVivienda ?? new[] { "Excelentes", "Buenas", "Regulares", "Malas", "Por evaluar" }, Model.CondicionesVivienda),
                                    "Seleccione condición",
                                    new { @class = "form-select border-green", required = "required" })
                            </div>
                            @Html.ValidationMessageFor(model => model.CondicionesVivienda, "", new { @class = "text-danger small mt-1" })
                        </div>

                        <!-- Fila 3: Relación -->
                        <div class="col-md-12">
                            <label class="form-label text-brown fw-medium">
                                <i class="fas fa-users text-green me-2"></i>Relación con Adoptante *
                            </label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-green"><i class="fas fa-users text-green"></i></span>
                                @Html.DropDownListFor(model => model.RelacionConAdoptante,
                                    new SelectList(ViewBag.Relaciones ?? new[] { "Excelente", "Buena", "Regular", "Mala", "Por evaluar" }, Model.RelacionConAdoptante),
                                    "Seleccione relación",
                                    new { @class = "form-select border-green", required = "required" })
                            </div>
                            @Html.ValidationMessageFor(model => model.RelacionConAdoptante, "", new { @class = "text-danger small mt-1" })
                        </div>

                        <!-- Fila 4: Fotos de Evidencia -->
                        <div class="col-md-12">
                            <label class="form-label text-brown fw-medium">
                                <i class="fas fa-images text-green me-2"></i>Ruta de Fotos de Evidencia
                            </label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-green"><i class="fas fa-images text-green"></i></span>
                                @Html.TextBoxFor(model => model.FotosEvidencia, new
                                {
                                    @class = "form-control border-green",
                                    placeholder = "Ej: C:\\Fotos\\Seguimiento\\"
                                })
                            </div>
                            @Html.ValidationMessageFor(model => model.FotosEvidencia, "", new { @class = "text-danger small mt-1" })
                            <small class="text-secondary">Ingrese la ruta donde se encuentran las fotos de evidencia</small>
                        </div>

                        <!-- Fila 5: Observaciones -->
                        <div class="col-md-12">
                            <label class="form-label text-brown fw-medium">
                                <i class="fas fa-comment-alt text-green me-2"></i>Observaciones
                            </label>
                            @Html.TextAreaFor(model => model.Observaciones, new
                            {
                                @class = "form-control border-green",
                                rows = 5,
                                maxlength = "2000",
                                id = "Observaciones",
                                placeholder = "Describa en detalle las observaciones del seguimiento..."
                            })
                            @Html.ValidationMessageFor(model => model.Observaciones, "", new { @class = "text-danger small mt-1" })
                            <div class="text-end small mt-1">
                                <span id="contadorObservaciones">@(Model.Observaciones?.Length ?? 0)</span>/2000 caracteres
                            </div>
                            <small class="text-secondary">Describa el estado de la mascota, comportamiento, adaptación, etc.</small>
                        </div>

                        <!-- Fila 6: Recomendaciones -->
                        <div class="col-md-12">
                            <label class="form-label text-brown fw-medium">
                                <i class="fas fa-lightbulb text-green me-2"></i>Recomendaciones
                            </label>
                            @Html.TextAreaFor(model => model.Recomendaciones, new
                            {
                                @class = "form-control border-green",
                                rows = 5,
                                maxlength = "2000",
                                id = "Recomendaciones",
                                placeholder = "Ingrese recomendaciones para el adoptante..."
                            })
                            @Html.ValidationMessageFor(model => model.Recomendaciones, "", new { @class = "text-danger small mt-1" })
                            <div class="text-end small mt-1">
                                <span id="contadorRecomendaciones">@(Model.Recomendaciones?.Length ?? 0)</span>/2000 caracteres
                            </div>
                            <small class="text-secondary">Recomendaciones específicas para mejorar el bienestar de la mascota</small>
                        </div>

                        <!-- Fila 7: Checkbox y Próximo Seguimiento -->
                        <div class="col-md-6">
                            <div class="form-check mb-3">
                                @Html.CheckBoxFor(model => model.RequiereIntervencion, new { @class = "form-check-input" })
                                <label class="form-check-label text-brown fw-medium">
                                    <i class="fas fa-exclamation-triangle text-pink me-2"></i>¿Requiere intervención del refugio?
                                </label>
                            </div>
                            <small class="text-secondary">Marque si se requiere intervención urgente del refugio</small>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label text-brown fw-medium">
                                <i class="fas fa-calendar-plus text-green me-2"></i>Fecha Próximo Seguimiento
                            </label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-green"><i class="fas fa-calendar-plus text-green"></i></span>
                                @Html.TextBoxFor(model => model.ProximoSeguimiento, "{0:yyyy-MM-dd}", new
                                {
                                    @class = "form-control border-green",
                                    type = "date",
                                    id = "ProximoSeguimiento"
                                })
                            </div>
                            @Html.ValidationMessageFor(model => model.ProximoSeguimiento, "", new { @class = "text-danger small mt-1" })
                            <small class="text-secondary">La fecha debe ser posterior a hoy</small>
                        </div>
                    </div>

                    <!-- Botones de acción -->
                    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mt-5 pt-4 border-top border-green">
                        <a href="@Url.Action("Seguimiento", "Mascotas", new { id = mascota?.MascotaId })" class="btn btn-outline-green">
                            <i class="fas fa-arrow-left me-2"></i>Volver
                        </a>
                        <div class="d-flex gap-2">
                            <a href="@Url.Action("Seguimiento", "Mascotas", new { id = mascota?.MascotaId })" class="btn btn-outline-green">
                                <i class="fas fa-times me-2"></i>Cancelar
                            </a>
                            <button type="submit" class="btn btn-green btn-lg">
                                <i class="fas fa-save me-2"></i>@(Model.SeguimientoId == 0 ? "Registrar Seguimiento" : "Actualizar Seguimiento")
                            </button>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

@section Styles {
    <style>
        :root {
            --green: #97C78B;
            --yellow: #F2C66D;
            --pink: #FBCDC0;
            --brown: #2F2F2F;
            --bg-light: #F2E9D8;
            --beige: #F5E6D3;
            --text-secondary: #555555;
            --info: #17a2b8;
        }

        body {
            background-color: var(--beige);
        }

        /* Hero */
        .seguimiento-hero {
            background-color: var(--beige);
            border-radius: 0 0 30px 30px;
            margin-bottom: 1rem;
        }

        /* Tarjetas de información */
        .info-card, .form-card {
            background: white;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 15px 35px rgba(151,199,139,0.15);
            border: none;
        }

        .info-card-header, .form-card-header {
            padding: 1rem 1.5rem;
            font-weight: 600;
            font-size: 1.1rem;
        }

            .info-card-header.bg-info {
                background-color: var(--info);
            }

            .info-card-header.bg-green {
                background-color: var(--green);
            }

        .info-card-body, .form-card-body {
            padding: 1.5rem;
        }

        /* Input groups */
        .input-group-text {
            border: 2px solid var(--green);
            border-radius: 16px 0 0 16px;
            background-color: white;
        }

        .form-control, .form-select {
            border: 2px solid var(--green);
            border-left: none;
            border-radius: 0 16px 16px 0;
            padding: 0.6rem 1rem;
            transition: border-color 0.2s, box-shadow 0.2s;
        }

            .form-control:focus, .form-select:focus {
                border-color: var(--green);
                box-shadow: 0 0 0 0.2rem rgba(151,199,139,0.25);
                outline: none;
            }

        .input-group:focus-within .input-group-text {
            border-color: var(--green);
            box-shadow: 0 0 0 0.2rem rgba(151,199,139,0.25);
        }

        /* Botones */
        .btn-green {
            background-color: var(--green);
            border: none;
            border-radius: 50px;
            padding: 0.6rem 2rem;
            font-weight: 500;
            transition: all 0.3s;
            color: white;
        }

            .btn-green:hover {
                background-color: #86b57a;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(151,199,139,0.4);
            }

        .btn-outline-green {
            border: 2px solid var(--green);
            background: transparent;
            color: var(--green);
            border-radius: 50px;
            padding: 0.6rem 2rem;
            font-weight: 500;
            transition: all 0.3s;
        }

            .btn-outline-green:hover {
                background-color: var(--green);
                color: white;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(151,199,139,0.3);
            }

        /* Checkbox personalizado */
        .form-check-input {
            width: 1.2rem;
            height: 1.2rem;
            border: 2px solid var(--green);
            transition: background-color 0.2s;
        }

            .form-check-input:checked {
                background-color: var(--green);
                border-color: var(--green);
            }

            .form-check-input:focus {
                border-color: var(--green);
                box-shadow: 0 0 0 0.2rem rgba(151,199,139,0.25);
            }

        /* Alertas */
        .alert-beige {
            background-color: var(--bg-light);
            border: 1px solid var(--green);
            color: var(--brown);
            border-radius: 16px;
        }

        /* Contadores */
        .text-warning {
            color: #ffc107 !important;
        }

        .text-danger {
            color: #dc3545 !important;
        }

        /* Responsive */
        @@media (max-width: 768px) {
            .info-card-body, .form-card-body {
                padding: 1rem;
            }

            .btn-lg {
                width: 100%;
            }
        }
    </style>
}

@section Scripts {
    <script>
        $(document).ready(function () {
            // ✅ Validación de fechas
            var hoy = new Date().toISOString().split('T')[0];

            // Fecha de seguimiento no puede ser futura
            $('#FechaSeguimiento').attr('max', hoy);

            // Establecer hoy por defecto si está vacío
            if (!$('#FechaSeguimiento').val()) {
                $('#FechaSeguimiento').val(hoy);
            }

            // Fecha próximo seguimiento debe ser posterior a hoy
            var manana = new Date();
            manana.setDate(manana.getDate() + 1);
            var minDate = manana.toISOString().split('T')[0];
            $('#ProximoSeguimiento').attr('min', minDate);

            // Si es nuevo seguimiento, establecer fecha de mañana por defecto
            if ($('#SeguimientoId').val() == '0' && !$('#ProximoSeguimiento').val()) {
                $('#ProximoSeguimiento').val(minDate);
            }

            // ✅ Contadores de caracteres con feedback visual
            function actualizarContador(textareaId, contadorId) {
                var $textarea = $('#' + textareaId);
                var length = $textarea.val().length;
                var maxLength = parseInt($textarea.attr('maxlength'));
                var $contador = $('#' + contadorId);

                $contador.text(length);

                if (length > maxLength * 0.9) {
                    $contador.addClass('text-warning');
                } else {
                    $contador.removeClass('text-warning');
                }
            }

            $('#Observaciones').on('input', function () {
                actualizarContador('Observaciones', 'contadorObservaciones');
            });

            $('#Recomendaciones').on('input', function () {
                actualizarContador('Recomendaciones', 'contadorRecomendaciones');
            });

            // Inicializar contadores
            actualizarContador('Observaciones', 'contadorObservaciones');
            actualizarContador('Recomendaciones', 'contadorRecomendaciones');
        });
    </script>
}