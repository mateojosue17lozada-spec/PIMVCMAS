@model MVCMASCOTAS.Models.SeguimientoAdopcion

@{
    ViewBag.Title = Model.SeguimientoId == 0 ? "Registrar Seguimiento" : "Editar Seguimiento";
    var mascota = ViewBag.Mascota as MVCMASCOTAS.Models.Mascotas;
    var contrato = ViewBag.Contrato as MVCMASCOTAS.Models.ContratoAdopcion;
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>
            <i class="fas fa-clipboard-check"></i>
            @(Model.SeguimientoId == 0 ? "Registrar Nuevo Seguimiento" : "Editar Seguimiento")
        </h2>
        <a href="@Url.Action("Seguimiento", "Mascotas", new { id = mascota.MascotaId })" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> Volver a Seguimientos
        </a>
    </div>

    <!-- Información de la mascota y contrato -->
    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-info text-white">
                    <i class="fas fa-dog"></i> Mascota
                </div>
                <div class="card-body">
                    <h5><strong>@Html.Encode(mascota.Nombre)</strong></h5>
                    <p>@Html.Encode(mascota.Especie) - @Html.Encode(mascota.Raza ?? "Mestizo")</p>
                    <p><strong>Adoptante:</strong> @Html.Encode(ViewBag.Adoptante ?? contrato?.AdoptanteNombre ?? "No especificado")</p>
                    <p><strong>Contrato:</strong> @Html.Encode(contrato?.NumeroContrato ?? "N/A")</p>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <i class="fas fa-info-circle"></i> Información del Seguimiento
                </div>
                <div class="card-body">
                    @if (Model.SeguimientoId > 0)
                    {
                        <p><strong>ID Seguimiento:</strong> #@Model.SeguimientoId</p>
                    }
                    <p><strong>Fecha Registro:</strong> @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</p>
                    <p><strong>Responsable:</strong> @Html.Encode(User.Identity.Name)</p>
                </div>
            </div>
        </div>
    </div>

    @using (Html.BeginForm("RegistrarSeguimiento", "Mascotas", new { MascotaId = mascota.MascotaId }, FormMethod.Post))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(model => model.SeguimientoId)
        @Html.HiddenFor(model => model.ContratoId)
        @Html.HiddenFor(model => model.ResponsableSeguimiento)

        <div class="card shadow-custom">
            <div class="card-body">
                <h4 class="card-title mb-4">
                    <i class="fas fa-edit"></i> Datos del Seguimiento
                </h4>

                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label fw-bold">
                                <i class="fas fa-calendar"></i> Fecha del Seguimiento *
                            </label>
                            @Html.TextBoxFor(model => model.FechaSeguimiento, "{0:yyyy-MM-dd}", new
                            {
                                @class = "form-control",
                                type = "date",
                                id = "FechaSeguimiento",
                                required = "required"
                            })
                            @Html.ValidationMessageFor(model => model.FechaSeguimiento, "", new { @class = "text-danger" })
                            <small class="text-muted">La fecha no puede ser futura</small>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label fw-bold">
                                <i class="fas fa-tag"></i> Tipo de Seguimiento *
                            </label>
                            @Html.DropDownListFor(model => model.TipoSeguimiento,
                                     new SelectList(new[] {
                                    new { Text = "Inicial", Value = "Inicial" },
                                    new { Text = "Periódico", Value = "Periódico" },
                                    new { Text = "Extraordinario", Value = "Extraordinario" },
                                    new { Text = "Final", Value = "Final" }
                         }, "Value", "Text", Model.TipoSeguimiento),
                                     "Seleccione tipo",
                                     new { @class = "form-control", required = "required" })
                            @Html.ValidationMessageFor(model => model.TipoSeguimiento, "", new { @class = "text-danger" })
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label fw-bold">
                                <i class="fas fa-heart"></i> Estado de la Mascota *
                            </label>
                            @Html.DropDownListFor(model => model.EstadoMascota,
                                     new SelectList(ViewBag.EstadosMascota ?? new[] { "Excelente", "Bueno", "Regular", "Malo", "Por evaluar" }, Model.EstadoMascota),
                                     "Seleccione estado",
                                     new { @class = "form-control", required = "required" })
                            @Html.ValidationMessageFor(model => model.EstadoMascota, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label fw-bold">
                                <i class="fas fa-home"></i> Condiciones de Vivienda *
                            </label>
                            @Html.DropDownListFor(model => model.CondicionesVivienda,
                                     new SelectList(ViewBag.CondicionesVivienda ?? new[] { "Excelentes", "Buenas", "Regulares", "Malas", "Por evaluar" }, Model.CondicionesVivienda),
                                     "Seleccione condición",
                                     new { @class = "form-control", required = "required" })
                            @Html.ValidationMessageFor(model => model.CondicionesVivienda, "", new { @class = "text-danger" })
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-12">
                        <div class="mb-3">
                            <label class="form-label fw-bold">
                                <i class="fas fa-users"></i> Relación con Adoptante *
                            </label>
                            @Html.DropDownListFor(model => model.RelacionConAdoptante,
                                     new SelectList(ViewBag.Relaciones ?? new[] { "Excelente", "Buena", "Regular", "Mala", "Por evaluar" }, Model.RelacionConAdoptante),
                                     "Seleccione relación",
                                     new { @class = "form-control", required = "required" })
                            @Html.ValidationMessageFor(model => model.RelacionConAdoptante, "", new { @class = "text-danger" })
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-12">
                        <div class="mb-3">
                            <label class="form-label fw-bold">
                                <i class="fas fa-images"></i> Ruta de Fotos de Evidencia
                            </label>
                            @Html.TextBoxFor(model => model.FotosEvidencia, new
                            {
                                @class = "form-control",
                                placeholder = "Ej: C:\\Fotos\\Seguimiento\\"
                            })
                            @Html.ValidationMessageFor(model => model.FotosEvidencia, "", new { @class = "text-danger" })
                            <small class="text-muted">Ingrese la ruta donde se encuentran las fotos de evidencia</small>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-12">
                        <div class="mb-3">
                            <label class="form-label fw-bold">
                                <i class="fas fa-comment-alt"></i> Observaciones
                            </label>
                            @Html.TextAreaFor(model => model.Observaciones, new
                            {
                                @class = "form-control",
                                rows = 5,
                                maxlength = "2000",
                                id = "Observaciones",
                                placeholder = "Describa en detalle las observaciones del seguimiento..."
                            })
                            @Html.ValidationMessageFor(model => model.Observaciones, "", new { @class = "text-danger" })
                            <div class="form-text text-end">
                                <span id="contadorObservaciones">0</span>/2000 caracteres
                            </div>
                            <small class="text-muted">Describa el estado de la mascota, comportamiento, adaptación, etc.</small>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-12">
                        <div class="mb-3">
                            <label class="form-label fw-bold">
                                <i class="fas fa-lightbulb"></i> Recomendaciones
                            </label>
                            @Html.TextAreaFor(model => model.Recomendaciones, new
                            {
                                @class = "form-control",
                                rows = 5,
                                maxlength = "2000",
                                id = "Recomendaciones",
                                placeholder = "Ingrese recomendaciones para el adoptante..."
                            })
                            @Html.ValidationMessageFor(model => model.Recomendaciones, "", new { @class = "text-danger" })
                            <div class="form-text text-end">
                                <span id="contadorRecomendaciones">0</span>/2000 caracteres
                            </div>
                            <small class="text-muted">Recomendaciones específicas para mejorar el bienestar de la mascota</small>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <div class="form-check">
                                @Html.CheckBoxFor(model => model.RequiereIntervencion, new { @class = "form-check-input" })
                                @Html.LabelFor(model => model.RequiereIntervencion,
                                         "¿Requiere intervención del refugio?", new { @class = "form-check-label fw-bold" })
                            </div>
                            <small class="text-muted">Marque si se requiere intervención urgente del refugio</small>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label fw-bold">
                                <i class="fas fa-calendar-plus"></i> Fecha Próximo Seguimiento
                            </label>
                            @Html.TextBoxFor(model => model.ProximoSeguimiento, "{0:yyyy-MM-dd}", new
                            {
                                @class = "form-control",
                                type = "date",
                                id = "ProximoSeguimiento"
                            })
                            @Html.ValidationMessageFor(model => model.ProximoSeguimiento, "", new { @class = "text-danger" })
                            <small class="text-muted">La fecha debe ser posterior a hoy</small>
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-between mt-4 pt-3 border-top">
                    <a href="@Url.Action("Seguimiento", "Mascotas", new { id = mascota.MascotaId })" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Volver
                    </a>
                    <div>
                        <a href="@Url.Action("Seguimiento", "Mascotas", new { id = mascota.MascotaId })" class="btn btn-outline-danger me-2">
                            <i class="fas fa-times"></i> Cancelar
                        </a>
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="fas fa-save"></i> @(Model.SeguimientoId == 0 ? "Registrar Seguimiento" : "Actualizar Seguimiento")
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // ✅ Validación de fechas
            var hoy = new Date().toISOString().split('T')[0];

            // Fecha de seguimiento no puede ser futura
            $('#FechaSeguimiento').attr('max', hoy);

            // Establecer hoy por defecto si está vacío
            if (!$('#FechaSeguimiento').val()) {
                $('#FechaSeguimiento').val(hoy);
            }

            // Fecha próximo seguimiento debe ser posterior a hoy
            var manana = new Date();
            manana.setDate(manana.getDate() + 1);
            var minDate = manana.toISOString().split('T')[0];
            $('#ProximoSeguimiento').attr('min', minDate);

            // Si es nuevo seguimiento, establecer fecha de mañana por defecto
            if ($('#SeguimientoId').val() == '0' && !$('#ProximoSeguimiento').val()) {
                $('#ProximoSeguimiento').val(minDate);
            }

            // ✅ Contadores de caracteres
            function actualizarContador(textareaId, contadorId) {
                var $textarea = $('#' + textareaId);
                var length = $textarea.val().length;
                var maxLength = parseInt($textarea.attr('maxlength'));

                $('#' + contadorId).text(length);

                if (length > maxLength * 0.9) {
                    $('#' + contadorId).addClass('text-warning');
                } else {
                    $('#' + contadorId).removeClass('text-warning');
                }
            }

            $('#Observaciones').on('keyup', function () {
                actualizarContador('Observaciones', 'contadorObservaciones');
            });

            $('#Recomendaciones').on('keyup', function () {
                actualizarContador('Recomendaciones', 'contadorRecomendaciones');
            });

            // Inicializar contadores
            actualizarContador('Observaciones', 'contadorObservaciones');
            actualizarContador('Recomendaciones', 'contadorRecomendaciones');
        });
    </script>

    <style>
        .shadow-custom {
            box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
            border: 1px solid rgba(0, 0, 0, 0.125);
        }
    </style>
}
