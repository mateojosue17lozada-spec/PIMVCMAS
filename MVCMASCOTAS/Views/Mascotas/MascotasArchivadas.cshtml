@model IEnumerable<MVCMASCOTAS.Models.Mascotas>

@{
    ViewBag.Title = "Mascotas Archivadas - ADOPTAMANÍA";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Hero Section -->
<section class="archivadas-hero py-4">
    <div class="container">
        <div class="d-flex flex-wrap justify-content-between align-items-center">
            <div>
                <h1 class="h2 text-brown mb-1">
                    <i class="fas fa-archive text-green me-2"></i>Mascotas Archivadas
                </h1>
                <p class="text-secondary mb-0">Listado de mascotas que han sido archivadas</p>
            </div>
            <div class="mt-2 mt-sm-0">
                <a href="@Url.Action("Gestionar", "Mascotas")" class="btn btn-outline-green">
                    <i class="fas fa-arrow-left me-2"></i>Volver a Gestionar
                </a>
            </div>
        </div>
    </div>
</section>

<!-- Main Content -->
<section class="py-4 bg-beige">
    <div class="container">
        <!-- Alerta informativa -->
        <div class="alert alert-beige border-green d-flex align-items-start mb-4">
            <i class="fas fa-exclamation-triangle fa-2x text-yellow me-3"></i>
            <div>
                <strong class="text-brown">Importante:</strong> Las mascotas archivadas solo pueden ser eliminadas físicamente si:
                <ul class="mb-0 mt-2 text-secondary">
                    <li><i class="fas fa-check-circle text-green me-2"></i>Tienen estado "Fallecida"</li>
                    <li><i class="fas fa-check-circle text-green me-2"></i>Han pasado al menos 2 años desde su fallecimiento</li>
                    <li><i class="fas fa-check-circle text-green me-2"></i>No tienen registros relacionados (adopciones, tratamientos, etc.)</li>
                </ul>
            </div>
        </div>

        <!-- Tabla -->
        <div class="table-card">
            <div class="table-card-header bg-green text-white">
                <i class="fas fa-archive me-2"></i> Listado de Mascotas Archivadas
            </div>
            <div class="table-card-body p-0">
                <div class="table-responsive">
                    <table id="tablaArchivadas" class="table table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Foto</th>
                                <th>Nombre</th>
                                <th>Especie</th>
                                <th class="text-center">Sexo</th>
                                <th>Estado</th>
                                <th>F. Ingreso</th>
                                <th class="text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                foreach (var mascota in Model)
                                {
                                    string sexoTexto = mascota.Sexo == "M" ? "Macho" : "Hembra";
                                    string sexoSimbolo = mascota.Sexo == "M" ? "♂" : "♀";
                                    string imagenUrl = "/Content/images/no-image.png";

                                    if (mascota.ImagenPrincipal != null && mascota.ImagenPrincipal.Length > 0)
                                    {
                                        imagenUrl = MVCMASCOTAS.Helpers.ImageHelper.GetImageDataUri(mascota.ImagenPrincipal);
                                    }

                                    <tr>
                                        <td><span class="badge bg-light-mint text-brown px-3 py-2">#@mascota.MascotaId</span></td>
                                        <td>
                                            <div class="avatar-wrapper archived">
                                                <img src="@imagenUrl"
                                                     alt="@mascota.Nombre"
                                                     onerror="this.src='/Content/images/no-image.png'">
                                            </div>
                                        </td>
                                        <td>
                                            <span class="fw-medium text-brown">@mascota.Nombre</span>
                                            @if (!string.IsNullOrEmpty(mascota.Raza))
                                            {
                                                <br><small class="text-secondary">@mascota.Raza</small>
                                            }
                                        </td>
                                        <td class="text-secondary">@mascota.Especie</td>
                                        <td class="text-center">
                                            @if (mascota.Sexo == "M")
                                            {
                                                <span class="badge bg-green text-white px-3 py-2" title="@sexoTexto">
                                                    <i class="fas fa-mars me-1"></i>♂
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-pink text-brown px-3 py-2" title="@sexoTexto">
                                                    <i class="fas fa-venus me-1"></i>♀
                                                </span>
                                            }
                                        </td>
                                        <td>
                                            <span class="badge bg-secondary text-white px-3 py-2">
                                                @mascota.Estado
                                            </span>
                                        </td>
                                        <td class="text-secondary">@(mascota.FechaIngreso?.ToString("dd/MM/yyyy") ?? "N/A")</td>
                                        <td class="text-center">
                                            <div class="d-flex justify-content-center gap-2">
                                                <button type="button"
                                                        class="btn btn-sm btn-green btn-restaurar"
                                                        data-id="@mascota.MascotaId"
                                                        data-nombre="@mascota.Nombre"
                                                        title="Restaurar">
                                                    <i class="fas fa-undo me-1"></i>Restaurar
                                                </button>
                                                <button type="button"
                                                        class="btn btn-sm btn-pink btn-eliminar"
                                                        data-id="@mascota.MascotaId"
                                                        data-nombre="@mascota.Nombre"
                                                        title="Eliminar Físicamente">
                                                    <i class="fas fa-trash me-1"></i>Eliminar
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="8" class="text-center py-5">
                                        <div class="empty-state">
                                            <i class="fas fa-archive fa-3x text-green mb-3"></i>
                                            <h5 class="text-brown mb-2">No hay mascotas archivadas</h5>
                                            <p class="text-secondary mb-0">Las mascotas archivadas aparecerán aquí.</p>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Modal Restaurar -->
<div class="modal fade" id="modalRestaurar" tabindex="-1" aria-labelledby="modalRestaurarLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-green text-white">
                <h5 class="modal-title" id="modalRestaurarLabel">
                    <i class="fas fa-undo me-2"></i>Restaurar Mascota
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="formRestaurar" method="post" action="@Url.Action("RestaurarMascota", "Mascotas")">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="restaurarId">
                <div class="modal-body">
                    <p class="text-brown">¿Está seguro de restaurar a <strong id="restaurarNombre" class="text-green"></strong>?</p>
                    <div class="mb-3">
                        <label class="form-label text-brown fw-medium">Motivo de restauración *</label>
                        <textarea name="motivo"
                                  class="form-control border-green"
                                  rows="3"
                                  required
                                  placeholder="Explique por qué está restaurando esta mascota..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-green" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-green">
                        <i class="fas fa-undo me-2"></i>Restaurar
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Eliminar Físicamente -->
<div class="modal fade" id="modalEliminar" tabindex="-1" aria-labelledby="modalEliminarLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-pink text-brown">
                <h5 class="modal-title" id="modalEliminarLabel">
                    <i class="fas fa-exclamation-triangle me-2"></i>Eliminar Físicamente
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="formEliminar" method="post" action="@Url.Action("EliminarFisicamente", "Mascotas")">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="eliminarId">
                <div class="modal-body">
                    <div id="validacionMensaje" class="alert" style="display:none;"></div>

                    <div id="formEliminarContenido">
                        <div class="alert alert-beige border-green">
                            <i class="fas fa-exclamation-triangle text-yellow me-2"></i>
                            <strong class="text-brown">¡ADVERTENCIA!</strong> Esta acción es irreversible.
                        </div>

                        <p class="text-brown">
                            Está a punto de eliminar permanentemente a <strong id="eliminarNombre" class="text-pink"></strong> del sistema.
                        </p>

                        <div class="mb-3">
                            <label class="form-label text-brown fw-medium">Justificación detallada (mínimo 20 caracteres) *</label>
                            <textarea name="justificacion"
                                      class="form-control border-green"
                                      rows="4"
                                      required
                                      minlength="20"
                                      placeholder="Explique detalladamente por qué es necesario eliminar físicamente este registro..."></textarea>
                            <small class="text-secondary">
                                Esta justificación quedará registrada en auditoría.
                            </small>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-green" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-pink" id="btnConfirmarEliminar" style="display:none;">
                        <i class="fas fa-trash me-2"></i>Eliminar Permanentemente
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Styles {
    <style>
        :root {
            --green: #97C78B;
            --yellow: #F2C66D;
            --pink: #FBCDC0;
            --brown: #2F2F2F;
            --bg-light: #F2E9D8;
            --beige: #F5E6D3;
            --text-secondary: #555555;
            --secondary: #6c757d;
        }

        body {
            background-color: var(--beige);
        }

        /* Hero */
        .archivadas-hero {
            background-color: var(--beige);
            border-radius: 0 0 30px 30px;
            margin-bottom: 1rem;
        }

        /* Alertas */
        .alert-beige {
            background-color: var(--bg-light);
            border: 1px solid var(--green);
            color: var(--brown);
            border-radius: 16px;
        }

        /* Tabla */
        .table-card {
            background: white;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 15px 35px rgba(151,199,139,0.15);
            border: none;
        }

        .table-card-header {
            padding: 1rem 1.5rem;
            font-weight: 600;
            font-size: 1.1rem;
        }

        .table-card-body {
            padding: 0;
        }

        .table {
            margin-bottom: 0;
        }

            .table th {
                background-color: var(--bg-light);
                color: var(--brown);
                font-weight: 600;
                border-bottom: 2px solid var(--green);
                padding: 1rem 0.5rem;
            }

            .table td {
                padding: 1rem 0.5rem;
                border-bottom: 1px solid var(--bg-light);
            }

        .table-hover tbody tr:hover {
            background-color: rgba(151,199,139,0.05);
        }

        /* Avatar */
        .avatar-wrapper {
            width: 60px;
            height: 60px;
            border-radius: 12px;
            overflow: hidden;
            border: 2px solid var(--green);
            background-color: var(--bg-light);
        }

            .avatar-wrapper.archived img {
                filter: grayscale(50%);
            }

            .avatar-wrapper img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

        /* Badges */
        .badge.bg-green {
            background-color: var(--green) !important;
            color: white !important;
        }

        .badge.bg-yellow {
            background-color: var(--yellow) !important;
            color: var(--brown) !important;
        }

        .badge.bg-pink {
            background-color: var(--pink) !important;
            color: var(--brown) !important;
        }

        .badge.bg-secondary {
            background-color: var(--secondary) !important;
            color: white !important;
        }

        .badge.bg-light-mint {
            background-color: var(--bg-light) !important;
            color: var(--brown) !important;
            border: 1px solid var(--green);
        }

        /* Botones */
        .btn-green {
            background-color: var(--green);
            border: none;
            border-radius: 50px;
            padding: 0.6rem 1.8rem;
            font-weight: 500;
            transition: all 0.3s;
            color: white;
        }

            .btn-green:hover {
                background-color: #86b57a;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(151,199,139,0.4);
            }

        .btn-pink {
            background-color: var(--pink);
            border: none;
            border-radius: 50px;
            padding: 0.6rem 1.8rem;
            font-weight: 500;
            transition: all 0.3s;
            color: var(--brown);
        }

            .btn-pink:hover {
                background-color: #f9c2b0;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(249,194,176,0.4);
            }

        .btn-outline-green {
            border: 2px solid var(--green);
            background: transparent;
            color: var(--green);
            border-radius: 50px;
            padding: 0.6rem 1.8rem;
            font-weight: 500;
            transition: all 0.3s;
        }

            .btn-outline-green:hover {
                background-color: var(--green);
                color: white;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(151,199,139,0.3);
            }

        /* Botones pequeños */
        .btn-sm {
            padding: 0.4rem 1rem;
            font-size: 0.875rem;
        }

        /* Empty state */
        .empty-state {
            background: white;
            border-radius: 24px;
            padding: 2.5rem;
            border: 2px dashed var(--green);
            display: inline-block;
        }

        /* Modales */
        .modal-content {
            border-radius: 24px;
            overflow: hidden;
            border: none;
            box-shadow: 0 20px 40px rgba(0,0,0,0.2);
        }

        .modal-header {
            padding: 1.2rem 1.5rem;
            border-bottom: none;
        }

            .modal-header.bg-green {
                background-color: var(--green);
            }

            .modal-header.bg-pink {
                background-color: var(--pink);
            }

        .modal-footer {
            border-top: 1px solid var(--green);
            padding: 1rem 1.5rem;
        }

        /* Formularios en modales */
        .form-control {
            border: 2px solid var(--green);
            border-radius: 16px;
            padding: 0.6rem 1rem;
            transition: border-color 0.2s, box-shadow 0.2s;
        }

            .form-control:focus {
                border-color: var(--green);
                box-shadow: 0 0 0 0.2rem rgba(151,199,139,0.25);
                outline: none;
            }

        /* DataTables personalización (opcional) */
        .dataTables_wrapper .dataTables_paginate .paginate_button {
            border-radius: 30px !important;
        }

            .dataTables_wrapper .dataTables_paginate .paginate_button.current {
                background: var(--green) !important;
                color: white !important;
                border-color: var(--green) !important;
            }

            .dataTables_wrapper .dataTables_paginate .paginate_button:hover {
                background: var(--bg-light) !important;
                color: var(--brown) !important;
            }

        /* Responsive */
        @@media (max-width: 768px) {
            .table th, .table td {
                white-space: nowrap;
            }
        }
    </style>
}

@section Scripts {
    <!-- DataTables -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.4/css/dataTables.bootstrap5.min.css">
    <script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.4/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        $(document).ready(function () {
            // Inicializar DataTables
            $('#tablaArchivadas').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.4/i18n/es-ES.json'
                },
                order: [[0, 'desc']],
                pageLength: 25
            });

            // Restaurar mascota
            $('.btn-restaurar').click(function () {
                var id = $(this).data('id');
                var nombre = $(this).data('nombre');

                $('#restaurarId').val(id);
                $('#restaurarNombre').text(nombre);
                $('#modalRestaurar').modal('show');
            });

            // Eliminar físicamente
            $('.btn-eliminar').click(function () {
                var id = $(this).data('id');
                var nombre = $(this).data('nombre');

                $('#eliminarId').val(id);
                $('#eliminarNombre').text(nombre);
                $('#validacionMensaje').hide();
                $('#formEliminarContenido').hide();
                $('#btnConfirmarEliminar').hide();

                // Validar si se puede eliminar
                $.ajax({
                    url: '@Url.Action("ValidarEliminacionFisica", "Mascotas")',
                    type: 'GET',
                    data: { id: id },
                    success: function (response) {
                        if (response.success) {
                            $('#validacionMensaje')
                                .removeClass('alert-danger alert-beige')
                                .addClass('alert alert-beige border-green')
                                .html('<i class="fas fa-check-circle text-green me-2"></i>' + response.message)
                                .show();
                            $('#formEliminarContenido').show();
                            $('#btnConfirmarEliminar').show();
                        } else {
                            $('#validacionMensaje')
                                .removeClass('alert-beige border-green')
                                .addClass('alert alert-pink border-green')
                                .html('<i class="fas fa-times-circle text-pink me-2"></i><strong class="text-brown">No se puede eliminar:</strong> ' + response.message)
                                .show();
                        }
                    },
                    error: function () {
                        $('#validacionMensaje')
                            .removeClass('alert-beige border-green')
                            .addClass('alert alert-pink border-green')
                            .html('<i class="fas fa-times-circle text-pink me-2"></i>Error al validar')
                            .show();
                    }
                });

                $('#modalEliminar').modal('show');
            });

            // Validación de formulario de restauración
            $('#formRestaurar').submit(function (e) {
                var motivo = $(this).find('textarea[name="motivo"]').val();
                if (motivo.trim().length < 10) {
                    e.preventDefault();
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: 'El motivo debe tener al menos 10 caracteres',
                        confirmButtonColor: '#FBCDC0'
                    });
                    return false;
                }
            });

            // Validación y confirmación para eliminación
            $('#formEliminar').submit(function (e) {
                var justificacion = $(this).find('textarea[name="justificacion"]').val();
                if (justificacion.trim().length < 20) {
                    e.preventDefault();
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: 'La justificación debe tener al menos 20 caracteres',
                        confirmButtonColor: '#FBCDC0'
                    });
                    return false;
                }

                // Confirmación adicional
                e.preventDefault();
                var form = this;
                Swal.fire({
                    title: '¿Está completamente seguro?',
                    html: '<div class="text-center">' +
                          '<i class="fas fa-exclamation-triangle fa-3x text-pink mb-3"></i>' +
                          '<p class="text-brown">Esta acción <strong>NO se puede deshacer</strong>. El registro será eliminado permanentemente.</p>' +
                          '</div>',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#FBCDC0',
                    cancelButtonColor: '#97C78B',
                    confirmButtonText: '<i class="fas fa-trash me-2"></i> Sí, eliminar permanentemente',
                    cancelButtonText: '<i class="fas fa-times me-2"></i> Cancelar'
                }).then((result) => {
                    if (result.isConfirmed) {
                        form.submit();
                    }
                });
            });
        });
    </script>
}