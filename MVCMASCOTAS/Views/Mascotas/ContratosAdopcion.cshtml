@model IEnumerable<MVCMASCOTAS.Models.ContratoAdopcion>

@{
    ViewBag.Title = "Contratos de Adopción";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>
            <i class="fas fa-file-contract text-primary"></i>
            Contratos de Adopción
        </h2>
        <div>
            <a href="@Url.Action("SeguimientoAdopciones", "Mascotas")" class="btn btn-outline-primary">
                <i class="fas fa-clipboard-check"></i> Seguimientos
            </a>
            <a href="@Url.Action("Listado", "Mascotas", new { tipo = "Adoptadas" })" class="btn btn-info">
                <i class="fas fa-dog"></i> Mascotas Adoptadas
            </a>
        </div>
    </div>

    <!-- Estadísticas -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card border-primary">
                <div class="card-body text-center">
                    <h3 class="text-primary">@Model.Count()</h3>
                    <p class="text-muted mb-0">Total Contratos</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-success">
                <div class="card-body text-center">
                    <h3 class="text-success">@Model.Count(c => c.Estado == "Activo")</h3>
                    <p class="text-muted mb-0">Activos</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-warning">
                <div class="card-body text-center">
                    <h3 class="text-warning">@Model.Count(c => c.Estado == "Cumplido")</h3>
                    <p class="text-muted mb-0">Cumplidos</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-danger">
                <div class="card-body text-center">
                    <h3 class="text-danger">@Model.Count(c => c.Estado == "Incumplido" || c.Estado == "Anulado")</h3>
                    <p class="text-muted mb-0">Problemas</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Filtros -->
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-light">
            <h5 class="mb-0"><i class="fas fa-filter"></i> Filtros</h5>
        </div>
        <div class="card-body">
            <form method="get" action="@Url.Action("ContratosAdopcion")" class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Estado del Contrato:</label>
                    <select name="estado" class="form-select">
                        <option value="">Todos los estados</option>
                        <option value="Activo">Activo</option>
                        <option value="Cumplido">Cumplido</option>
                        <option value="Incumplido">Incumplido</option>
                        <option value="Anulado">Anulado</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Buscar:</label>
                    <input type="text" name="buscar" class="form-control"
                           placeholder="N° contrato, adoptante o mascota..." />
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="fas fa-search"></i> Buscar
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Tabla de contratos -->
    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead class="table-primary">
                        <tr>
                            <th>N° Contrato</th>
                            <th>Mascota</th>
                            <th>Adoptante</th>
                            <th>Fecha</th>
                            <th>Estado</th>
                            <th>Firmas</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var contrato in Model.OrderByDescending(c => c.FechaContrato))
                        {
                            <tr>
                                <td>
                                    <strong>@contrato.NumeroContrato</strong>
                                    @if (contrato.DocumentoPDF != null)
                                    {
                                        <br />
                                        <small class="text-success">
                                            <i class="fas fa-file-pdf"></i> PDF disponible
                                        </small>
                                    }
                                </td>
                                <td>
                                    <strong>@Html.Encode(contrato.MascotaNombre)</strong>
                                    <br />
                                    <small class="text-muted">@Html.Encode(contrato.MascotaEspecie)</small>
                                    @if (!string.IsNullOrEmpty(contrato.MascotaMicrochip))
                                    {
                                        <br />
                                        <small><i class="fas fa-microchip"></i> @contrato.MascotaMicrochip</small>
                                    }
                                </td>
                                <td>
                                    <strong>@Html.Encode(contrato.AdoptanteNombre)</strong>
                                    <br />
                                    <small class="text-muted">
                                        <i class="fas fa-id-card"></i> @contrato.AdoptanteCedula
                                    </small>
                                    <br />
                                    <small><i class="fas fa-phone"></i> @contrato.AdoptanteTelefono</small>
                                </td>
                                <td>
                                    @contrato.FechaContrato?.ToString("dd/MM/yyyy")
                                    <br />
                                    <small class="text-muted">
                                        @{
                                            var dias = contrato.FechaContrato.HasValue ?
                                                (DateTime.Now - contrato.FechaContrato.Value).Days : 0;
                                            if (dias > 0)
                                            {
                                                <text>Hace @dias días</text>
                                            }
                                        }
                                    </small>
                                </td>
                                <td>
                                    @{
                                        var estadoBadge = contrato.Estado == "Activo" ? "bg-success" :
                                                         contrato.Estado == "Cumplido" ? "bg-info" :
                                                         contrato.Estado == "Incumplido" ? "bg-danger" :
                                                         contrato.Estado == "Anulado" ? "bg-warning" : "bg-secondary";
                                    }
                                    <span class="badge @estadoBadge">
                                        @contrato.Estado
                                    </span>
                                </td>
                                <td>
                                    @if (contrato.FechaFirmaAdoptante.HasValue && contrato.FechaFirmaRefugio.HasValue)
                                    {
                                        <span class="text-success">
                                            <i class="fas fa-check-double"></i> Completas
                                        </span>
                                        <br />
                                        <small class="text-muted">
                                            @contrato.FechaFirmaAdoptante?.ToString("dd/MM/yyyy")
                                        </small>
                                    }
                                    else if (contrato.FechaFirmaAdoptante.HasValue || contrato.FechaFirmaRefugio.HasValue)
                                    {
                                        <span class="text-warning">
                                            <i class="fas fa-exclamation-triangle"></i> Parciales
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-danger">
                                            <i class="fas fa-times"></i> Pendientes
                                        </span>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm" role="group">
                                        <a href="@Url.Action("DetalleContrato", "Mascotas", new { id = contrato.ContratoId })"
                                           class="btn btn-info" title="Ver detalles">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a href="@Url.Action("SeguimientoMascota", "Mascotas",
                                                new { id = contrato.SolicitudAdopcion?.MascotaId })"
                                           class="btn btn-primary" title="Seguimientos">
                                            <i class="fas fa-clipboard-check"></i>
                                        </a>
                                        @if (User.IsInRole("Administrador"))
                                        {
                                            <button type="button" class="btn btn-warning"
                                                    onclick="descargarContrato('@contrato.ContratoId')"
                                                    title="Descargar PDF">
                                                <i class="fas fa-download"></i>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Mensaje si no hay contratos -->
    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="fas fa-file-contract fa-4x text-muted mb-3"></i>
            <h4 class="text-muted">No hay contratos de adopción registrados</h4>
            <p class="text-muted">
                Los contratos se generan automáticamente cuando se aprueba una solicitud de adopción.
            </p>
        </div>
    }
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Inicializar DataTables
            $('.table').DataTable({
                order: [[3, 'desc']],
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json'
                },
                pageLength: 10
            });

            // Función para descargar contrato
            window.descargarContrato = function(contratoId) {
                Swal.fire({
                    title: 'Descargar Contrato',
                    text: '¿Desea descargar el contrato en formato PDF?',
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonText: 'Sí, descargar',
                    cancelButtonText: 'Cancelar'
                }).then((result) => {
                    if (result.isConfirmed) {
                        window.location.href = '@Url.Action("DescargarContrato", "Mascotas")?id=' + contratoId;
                    }
                });
            };
        });
    </script>
}