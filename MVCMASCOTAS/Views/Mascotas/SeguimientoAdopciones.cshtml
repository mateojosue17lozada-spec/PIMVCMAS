@model IEnumerable<dynamic>

@{
    ViewBag.Title = "Seguimiento de Adopciones";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-clipboard-check text-primary"></i> Seguimiento de Adopciones</h2>
        <div>
            <a href="@Url.Action("Listado", "Mascotas", new { tipo = "Adoptadas" })" class="btn btn-outline-primary">
                <i class="fas fa-dog"></i> Ver Adoptadas
            </a>
            <a href="@Url.Action("ContratosAdopcion", "Mascotas")" class="btn btn-info">
                <i class="fas fa-file-contract"></i> Ver Contratos
            </a>
        </div>
    </div>

    <!-- Filtros de seguimiento -->
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-light">
            <h5 class="mb-0"><i class="fas fa-filter"></i> Filtros de Seguimiento</h5>
        </div>
        <div class="card-body">
            <form method="get" action="@Url.Action("SeguimientoAdopciones")" class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">Estado del Seguimiento:</label>
                    <select name="estadoSeguimiento" class="form-select">
                        <option value="">Todos los estados</option>
                        <option value="Vencido">Vencido</option>
                        <option value="Próximo">Próximo</option>
                        <option value="Programado">Programado</option>
                        <option value="Sin programar">Sin programar</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Intervención:</label>
                    <select name="intervencion" class="form-select">
                        <option value="">Todas</option>
                        <option value="true">Requiere Intervención</option>
                        <option value="false">Sin Intervención</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Buscar:</label>
                    <input type="text" name="buscar" class="form-control"
                           placeholder="Nombre mascota o adoptante..." />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="fas fa-search"></i> Buscar
                    </button>
                </div>
            </form>
        </div>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card shadow-sm h-100">
                        <div class="card-header @(item.EstadoSeguimiento == "Vencido" ? "bg-danger" :
                                                  item.EstadoSeguimiento == "Próximo" ? "bg-warning" :
                                                  item.EstadoSeguimiento == "Programado" ? "bg-info" : "bg-secondary") text-white">
                            <div class="d-flex justify-content-between align-items-center">
                                <h6 class="mb-0">
                                    @if (item.EstadoSeguimiento == "Vencido")
                                    {
                                        <i class="fas fa-exclamation-triangle"></i>
                                    }
                                    else if (item.EstadoSeguimiento == "Próximo")
                                    {
                                        <i class="fas fa-clock"></i>
                                    }
                                    else if (item.EstadoSeguimiento == "Programado")
                                    {
                                        <i class="fas fa-calendar-check"></i>
                                    }
                                    else
                                    {
                                        <i class="fas fa-question-circle"></i>
                                    }
                                    @item.EstadoSeguimiento
                                </h6>
                                @if (item.RequiereIntervencion)
                                {
                                    <span class="badge bg-danger">
                                        <i class="fas fa-exclamation-circle"></i> Intervención
                                    </span>
                                }
                            </div>
                        </div>
                        <div class="card-body">
                            <h5 class="card-title text-primary">@item.Nombre</h5>
                            <p class="card-text">
                                <strong>Especie:</strong> @item.Especie<br />
                                <strong>Adoptante:</strong> @item.AdoptanteNombre<br />
                                <strong>Contrato:</strong> @item.NumeroContrato
                            </p>

                            <div class="mb-3">
                                @if (item.UltimoSeguimiento != null)
                                {
                                    <p class="mb-1">
                                        <strong>Último seguimiento:</strong><br />
                                        @(((DateTime)item.UltimoSeguimiento).ToString("dd/MM/yyyy"))
                                    </p>
                                }

                                @if (item.ProximoSeguimiento != null)
                                {
                                    var proximoSeguimiento = (DateTime)item.ProximoSeguimiento;
                                    var hoy = DateTime.Today;
                                    var diasRestantes = (proximoSeguimiento - hoy).Days;

                                    <p class="mb-1">
                                        <strong>Próximo seguimiento:</strong><br />
                                        @proximoSeguimiento.ToString("dd/MM/yyyy")
                                    </p>
                                    <div class="progress mb-2">
                                        <div class="progress-bar @(diasRestantes <= 0 ? "bg-danger" : diasRestantes <= 7 ? "bg-warning" : "bg-success")"
                                             role="progressbar"
                                             style="width: @(Math.Min(100, Math.Max(0, (30 - diasRestantes) * 100 / 30)))%">
                                            @if (diasRestantes <= 0)
                                            {
                                                <span>Vencido hace @(-diasRestantes) días</span>
                                            }
                                            else
                                            {
                                                <span>@diasRestantes días restantes</span>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                        <div class="card-footer bg-transparent border-top-0">
                            <div class="d-grid gap-2">
                                <a href="@Url.Action("SeguimientoMascota", "Mascotas", new { id = item.MascotaId })"
                                   class="btn btn-primary btn-sm">
                                    <i class="fas fa-eye"></i> Ver Seguimientos
                                </a>
                                @if (item.ProximoSeguimiento != null && ((DateTime)item.ProximoSeguimiento) <= DateTime.Today)
                                {
                                    <a href="@Url.Action("CrearSeguimientoManual", "Mascotas", new { mascotaId = item.MascotaId })"
                                       class="btn btn-warning btn-sm">
                                        <i class="fas fa-plus"></i> Registrar Seguimiento
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="fas fa-clipboard-check fa-4x text-muted mb-3"></i>
            <h4 class="text-muted">No hay seguimientos pendientes</h4>
            <p class="text-muted">Todas las adopciones están al día con sus seguimientos.</p>
            <a href="@Url.Action("Listado", "Mascotas", new { tipo = "Adoptadas" })"
               class="btn btn-primary mt-3">
                <i class="fas fa-dog"></i> Ver Mascotas Adoptadas
            </a>
        </div>
    }

    <!-- Resumen estadístico -->
    @if (Model != null && Model.Any())
    {
        <div class="row mt-4">
            <div class="col-md-3">
                <div class="card border-primary">
                    <div class="card-body text-center">
                        <h3 class="text-primary">@Model.Count()</h3>
                        <p class="text-muted mb-0">Total adopciones</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-warning">
                    <div class="card-body text-center">
                        <h3 class="text-warning">@Model.Count(m => m.EstadoSeguimiento == "Próximo" || m.EstadoSeguimiento == "Vencido")</h3>
                        <p class="text-muted mb-0">Seguimientos pendientes</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-danger">
                    <div class="card-body text-center">
                        <h3 class="text-danger">@Model.Count(m => m.RequiereIntervencion)</h3>
                        <p class="text-muted mb-0">Requieren intervención</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-success">
                    <div class="card-body text-center">
                        <h3 class="text-success">@Model.Count(m => m.EstadoSeguimiento == "Programado")</h3>
                        <p class="text-muted mb-0">Programados</p>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Inicializar tooltips
            $('[data-bs-toggle="tooltip"]').tooltip();

            // Mostrar alerta si hay seguimientos vencidos
            var vencidos = @Model?.Count(m => m.EstadoSeguimiento == "Vencido") ?? 0;
            if (vencidos > 0) {
                Swal.fire({
                    icon: 'warning',
                    title: '¡Atención!',
                    html: `Tienes <strong>${vencidos}</strong> seguimiento(s) vencido(s) que requieren atención.`,
                    confirmButtonText: 'Entendido',
                    confirmButtonColor: '#ffc107'
                });
            }
        });
    </script>
}