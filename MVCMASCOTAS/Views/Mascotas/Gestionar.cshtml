@model IEnumerable<MVCMASCOTAS.Models.Mascotas>

@{
    ViewBag.Title = "Gestionar Mascotas";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-dog"></i> Gestionar Mascotas</h2>
    <a href="@Url.Action("Crear", "Mascotas")" class="btn btn-primary">
        <i class="fas fa-plus"></i> Nueva Mascota
    </a>
</div>

<!-- Filtros -->
<div class="card mb-4">
    <div class="card-body">
        <form method="get" action="@Url.Action("Gestionar")" class="form-inline">
            <div class="form-group mr-3 mb-2">
                <label class="mr-2">Estado:</label>
                <select name="estado" class="form-control">
                    <option value="Todos" @(ViewBag.FiltroEstado == "Todos" ? "selected" : "")>Todos</option>
                    <option value="Rescatada" @(ViewBag.FiltroEstado == "Rescatada" ? "selected" : "")>Rescatada</option>
                    <option value="En tratamiento" @(ViewBag.FiltroEstado == "En tratamiento" ? "selected" : "")>En tratamiento</option>
                    <option value="Disponible para adopción" @(ViewBag.FiltroEstado == "Disponible para adopción" ? "selected" : "")>Disponible</option>
                    <option value="Adoptada" @(ViewBag.FiltroEstado == "Adoptada" ? "selected" : "")>Adoptada</option>
                </select>
            </div>

            <button type="submit" class="btn btn-primary mb-2">
                <i class="fas fa-filter"></i> Filtrar
            </button>
        </form>
    </div>
</div>

<!-- Tabla de Mascotas -->
<div class="card shadow-custom">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead class="bg-primary text-white">
                    <tr>
                        <th>ID</th>
                        <th>Nombre</th>
                        <th>Especie</th>
                        <th>Sexo</th>
                        <th>Tamaño</th>
                        <th>Estado</th>
                        <th>Fecha Ingreso</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var mascota in Model)
                        {
                            <tr>
                                <td>@mascota.MascotaId</td>
                                <td><strong>@mascota.Nombre</strong></td>
                                <td>@mascota.Especie</td>
                                <td>@mascota.Sexo</td>
                                <td>@mascota.Tamanio</td>
                                <td>
                                    @switch (mascota.Estado)
                                    {
                                        case "Rescatada":
                                            <span class="badge badge-danger">@mascota.Estado</span>
                                            break;
                                        case "En tratamiento":
                                            <span class="badge badge-warning">@mascota.Estado</span>
                                            break;
                                        case "Disponible para adopción":
                                            <span class="badge badge-success">@mascota.Estado</span>
                                            break;
                                        case "Adoptada":
                                            <span class="badge badge-info">@mascota.Estado</span>
                                            break;
                                        default:
                                            <span class="badge badge-secondary">@mascota.Estado</span>
                                            break;
                                    }
                                </td>
                                <!-- LÍNEA CORREGIDA AQUÍ -->
                                <td>@(mascota.FechaIngreso?.ToString("dd/MM/yyyy") ?? "No especificada")</td>
                                <td>
                                    <a href="@Url.Action("Detalle", "Mascotas", new { id = mascota.MascotaId })" class="btn btn-sm btn-info" title="Ver">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    @if (User.IsInRole("Veterinario") || User.IsInRole("Administrador"))
                                    {
                                        <a href="@Url.Action("HistorialMedico", "Veterinario", new { mascotaId = mascota.MascotaId })" class="btn btn-sm btn-success" title="Historial">
                                            <i class="fas fa-stethoscope"></i>
                                        </a>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center">No hay mascotas registradas</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Paginación -->
@if (ViewBag.TotalPages > 1)
{
    <nav aria-label="Paginación" class="mt-4">
        <ul class="pagination justify-content-center">
            @if (ViewBag.CurrentPage > 1)
            {
                <li class="page-item">
                    <a class="page-link" href="@Url.Action("Gestionar", new { page = ViewBag.CurrentPage - 1, estado = ViewBag.FiltroEstado })">Anterior</a>
                </li>
            }

            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                    <a class="page-link" href="@Url.Action("Gestionar", new { page = i, estado = ViewBag.FiltroEstado })">@i</a>
                </li>
            }

            @if (ViewBag.CurrentPage < ViewBag.TotalPages)
            {
                <li class="page-item">
                    <a class="page-link" href="@Url.Action("Gestionar", new { page = ViewBag.CurrentPage + 1, estado = ViewBag.FiltroEstado })">Siguiente</a>
                </li>
            }
        </ul>
    </nav>
}
