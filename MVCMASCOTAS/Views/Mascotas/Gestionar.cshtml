@model IEnumerable<MVCMASCOTAS.Models.Mascotas>

@{
    ViewBag.Title = "Gestionar Mascotas - ADOPTAMANÍA";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Hero Section -->
<section class="gestionar-hero py-4">
    <div class="container">
        <div class="d-flex flex-wrap justify-content-between align-items-center">
            <div>
                <h1 class="h2 text-brown mb-1">
                    <i class="fas fa-paw text-green me-2"></i>Gestionar Mascotas
                </h1>
                <p class="text-secondary mb-0">Administración completa de las mascotas del refugio</p>
            </div>
            <div class="mt-2 mt-sm-0">
                <a href="@Url.Action("Crear", "Mascotas")" class="btn btn-green me-2">
                    <i class="fas fa-plus me-2"></i>Nueva Mascota
                </a>
                <a href="@Url.Action("MascotasArchivadas", "Mascotas")" class="btn btn-outline-green">
                    <i class="fas fa-archive me-2"></i>Archivadas
                </a>
            </div>
        </div>
    </div>
</section>

<!-- Main Content -->
<section class="py-4 bg-beige">
    <div class="container">
        <!-- Estadísticas -->
        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <div class="stat-card">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0 me-3">
                            <i class="fas fa-paw fa-3x text-green"></i>
                        </div>
                        <div>
                            <div class="text-xs text-uppercase fw-bold text-green">Total Activas</div>
                            <div class="h3 mb-0 fw-bold text-brown">@ViewBag.TotalMascotas</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat-card">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0 me-3">
                            <i class="fas fa-check-circle fa-3x text-green"></i>
                        </div>
                        <div>
                            <div class="text-xs text-uppercase fw-bold text-green">Disponibles</div>
                            <div class="h3 mb-0 fw-bold text-brown">@ViewBag.MascotasDisponibles</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat-card">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0 me-3">
                            <i class="fas fa-medkit fa-3x text-yellow"></i>
                        </div>
                        <div>
                            <div class="text-xs text-uppercase fw-bold text-green">En Tratamiento</div>
                            <div class="h3 mb-0 fw-bold text-brown">@ViewBag.MascotasEnTratamiento</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat-card">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0 me-3">
                            <i class="fas fa-heart fa-3x text-pink"></i>
                        </div>
                        <div>
                            <div class="text-xs text-uppercase fw-bold text-green">Adoptadas</div>
                            <div class="h3 mb-0 fw-bold text-brown">@ViewBag.MascotasAdoptadas</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Filtros -->
        <div class="filter-card mb-4">
            <div class="filter-header bg-green text-white">
                <i class="fas fa-filter me-2"></i> Filtros de Búsqueda
            </div>
            <div class="filter-body">
                <form method="get" action="@Url.Action("Gestionar", "Mascotas")" class="row g-3 align-items-end">
                    <div class="col-md-4">
                        <label class="form-label text-brown fw-medium"><i class="fas fa-search text-green me-2"></i>Buscar</label>
                        <input type="text" name="buscar" class="form-control border-green" placeholder="Nombre o microchip..." value="@ViewBag.FiltroBuscar">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label text-brown fw-medium"><i class="fas fa-tag text-green me-2"></i>Estado</label>
                        <select name="estado" class="form-select border-green">
                            <option value="Todos" selected="@(string.IsNullOrEmpty(ViewBag.FiltroEstado) || ViewBag.FiltroEstado == "Todos")">Todos</option>
                            <option value="Rescatada" selected="@(ViewBag.FiltroEstado == "Rescatada")">Rescatada</option>
                            <option value="En revisión veterinaria" selected="@(ViewBag.FiltroEstado == "En revisión veterinaria")">En revisión</option>
                            <option value="En tratamiento" selected="@(ViewBag.FiltroEstado == "En tratamiento")">En tratamiento</option>
                            <option value="Disponible para adopción" selected="@(ViewBag.FiltroEstado == "Disponible para adopción")">Disponible</option>
                            <option value="Adoptada" selected="@(ViewBag.FiltroEstado == "Adoptada")">Adoptada</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label text-brown fw-medium"><i class="fas fa-paw text-green me-2"></i>Especie</label>
                        <select name="especie" class="form-select border-green">
                            <option value="Todos" selected="@(string.IsNullOrEmpty(ViewBag.FiltroEspecie) || ViewBag.FiltroEspecie == "Todos")">Todas</option>
                            <option value="Perro" selected="@(ViewBag.FiltroEspecie == "Perro")">Perro</option>
                            <option value="Gato" selected="@(ViewBag.FiltroEspecie == "Gato")">Gato</option>
                        </select>
                    </div>
                    <div class="col-md-2 d-flex gap-2">
                        <button type="submit" class="btn btn-green flex-grow-1">
                            <i class="fas fa-search me-2"></i>Buscar
                        </button>
                        <a href="@Url.Action("Gestionar", "Mascotas")" class="btn btn-outline-green" title="Limpiar filtros">
                            <i class="fas fa-times"></i>
                        </a>
                    </div>
                </form>
            </div>
        </div>

        <!-- Tabla -->
        <div class="table-card">
            <div class="table-card-header bg-green text-white">
                <i class="fas fa-list me-2"></i> Listado de Mascotas
            </div>
            <div class="table-card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Foto</th>
                                <th>Nombre / Raza</th>
                                <th>Especie</th>
                                <th>Sexo</th>
                                <th>Estado</th>
                                <th>F. Ingreso</th>
                                <th class="text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                foreach (var mascota in Model)
                                {
                                    string sexoTexto = mascota.Sexo == "M" ? "Macho" : "Hembra";
                                    string imagenUrl = "/Content/images/no-image.png";
                                    if (mascota.ImagenPrincipal != null && mascota.ImagenPrincipal.Length > 0)
                                    {
                                        imagenUrl = MVCMASCOTAS.Helpers.ImageHelper.GetImageDataUri(mascota.ImagenPrincipal);
                                    }

                                    <tr>
                                        <td><span class="badge bg-light-mint text-brown px-3 py-2">#@mascota.MascotaId</span></td>
                                        <td>
                                            <div class="avatar-placeholder">
                                                <img src="@imagenUrl" alt="@mascota.Nombre" onerror="this.src='/Content/images/no-image.png'">
                                            </div>
                                        </td>
                                        <td>
                                            <span class="fw-medium text-brown">@mascota.Nombre</span>
                                            @if (!string.IsNullOrEmpty(mascota.Raza))
                                            {
                                                <br><small class="text-secondary">@mascota.Raza</small>
                                            }
                                        </td>
                                        <td>
                                            <span class="badge @(mascota.Especie == "Perro" ? "bg-green text-white" : "bg-pink text-brown") px-3 py-2">
                                                @mascota.Especie
                                            </span>
                                        </td>
                                        <td class="text-center">
                                            @if (mascota.Sexo == "M")
                                            {
                                                <span class="badge bg-green text-white px-3 py-2" title="Macho">
                                                    <i class="fas fa-mars me-1"></i> ♂
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-pink text-brown px-3 py-2" title="Hembra">
                                                    <i class="fas fa-venus me-1"></i> ♀
                                                </span>
                                            }
                                        </td>
                                        <td>
                                            <span class="badge @(
                                                mascota.Estado == "Disponible para adopción" ? "bg-green text-white" :
                                                mascota.Estado == "Adoptada" ? "bg-info text-white" :
                                                mascota.Estado == "En tratamiento" ? "bg-yellow text-brown" :
                                                mascota.Estado == "Archivada" ? "bg-secondary text-white" : "bg-pink text-brown"
                                            ) px-3 py-2">
                                                @mascota.Estado
                                            </span>
                                        </td>
                                        <td class="text-secondary">@(mascota.FechaIngreso?.ToString("dd/MM/yyyy") ?? "N/A")</td>
                                        <td class="text-center">
                                            <div class="d-flex justify-content-center gap-2">
                                                <a href="@Url.Action("Detalle", "Mascotas", new { id = mascota.MascotaId })"
                                                   class="btn btn-sm btn-outline-green" title="Ver Detalles">
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                                <a href="@Url.Action("Editar", "Mascotas", new { id = mascota.MascotaId })"
                                                   class="btn btn-sm btn-yellow" title="Editar">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="8" class="text-center py-4">
                                        <div class="alert alert-beige border-green">
                                            <i class="fas fa-info-circle fa-2x text-green mb-2"></i>
                                            <h5 class="text-brown">No hay mascotas para mostrar</h5>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Paginación -->
        @if (ViewBag.TotalPages > 1)
        {
            <nav aria-label="Paginación" class="mt-4">
                <ul class="pagination justify-content-center">
                    @if (ViewBag.CurrentPage > 1)
                    {
                        <li class="page-item">
                            <a class="page-link" href="@Url.Action("Gestionar", new {
                                page = ViewBag.CurrentPage - 1,
                                estado = ViewBag.FiltroEstado,
                                especie = ViewBag.FiltroEspecie,
                                buscar = ViewBag.FiltroBuscar
                            })">
                                <i class="fas fa-chevron-left me-1"></i> Anterior
                            </a>
                        </li>
                    }

                    @for (int i = 1; i <= ViewBag.TotalPages; i++)
                    {
                        <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                            <a class="page-link" href="@Url.Action("Gestionar", new {
                                page = i,
                                estado = ViewBag.FiltroEstado,
                                especie = ViewBag.FiltroEspecie,
                                buscar = ViewBag.FiltroBuscar
                            })">@i</a>
                        </li>
                    }

                    @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                    {
                        <li class="page-item">
                            <a class="page-link" href="@Url.Action("Gestionar", new {
                                page = ViewBag.CurrentPage + 1,
                                estado = ViewBag.FiltroEstado,
                                especie = ViewBag.FiltroEspecie,
                                buscar = ViewBag.FiltroBuscar
                            })">
                                Siguiente <i class="fas fa-chevron-right ms-1"></i>
                            </a>
                        </li>
                    }
                </ul>
            </nav>
        }
    </div>
</section>

@section Styles {
    <style>
        :root {
            --green: #97C78B;
            --yellow: #F2C66D;
            --pink: #FBCDC0;
            --brown: #2F2F2F;
            --bg-light: #F2E9D8;
            --beige: #F5E6D3;
            --text-secondary: #555555;
            --info: #17a2b8;
        }

        body {
            background-color: var(--beige);
        }

        /* Hero */
        .gestionar-hero {
            background-color: var(--beige);
            border-radius: 0 0 30px 30px;
            margin-bottom: 1rem;
        }

        /* Tarjetas de estadísticas */
        .stat-card {
            background: white;
            border-radius: 24px;
            padding: 1.5rem;
            box-shadow: 0 8px 20px rgba(151,199,139,0.15);
            transition: transform 0.3s, box-shadow 0.3s;
            border: none;
        }

            .stat-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 15px 30px rgba(151,199,139,0.25);
            }

        /* Filtros */
        .filter-card {
            background: white;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 15px 35px rgba(151,199,139,0.15);
            border: none;
        }

        .filter-header {
            padding: 1rem 1.5rem;
            font-weight: 600;
            font-size: 1.1rem;
        }

        .filter-body {
            padding: 1.5rem;
        }

        /* Tabla */
        .table-card {
            background: white;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 15px 35px rgba(151,199,139,0.15);
            border: none;
        }

        .table-card-header {
            padding: 1rem 1.5rem;
            font-weight: 600;
            font-size: 1.1rem;
        }

        .table-card-body {
            padding: 0;
        }

        .table {
            margin-bottom: 0;
        }

            .table th {
                background-color: var(--bg-light);
                color: var(--brown);
                font-weight: 600;
                border-bottom: 2px solid var(--green);
                padding: 1rem 0.5rem;
            }

            .table td {
                padding: 1rem 0.5rem;
                border-bottom: 1px solid var(--bg-light);
            }

        .table-hover tbody tr:hover {
            background-color: rgba(151,199,139,0.05);
        }

        /* Avatar */
        .avatar-placeholder {
            width: 50px;
            height: 50px;
            border-radius: 12px;
            overflow: hidden;
            border: 2px solid var(--green);
            background-color: var(--bg-light);
        }

            .avatar-placeholder img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

        /* Badges */
        .badge.bg-green {
            background-color: var(--green) !important;
            color: white !important;
        }

        .badge.bg-yellow {
            background-color: var(--yellow) !important;
            color: var(--brown) !important;
        }

        .badge.bg-pink {
            background-color: var(--pink) !important;
            color: var(--brown) !important;
        }

        .badge.bg-light-mint {
            background-color: var(--bg-light) !important;
            color: var(--brown) !important;
            border: 1px solid var(--green);
        }

        .badge.bg-info {
            background-color: var(--info) !important;
            color: white !important;
        }

        .badge.bg-secondary {
            background-color: #6c757d !important;
            color: white !important;
        }

        /* Botones */
        .btn-green {
            background-color: var(--green);
            border: none;
            border-radius: 50px;
            padding: 0.6rem 1.8rem;
            font-weight: 500;
            transition: all 0.3s;
            color: white;
        }

            .btn-green:hover {
                background-color: #86b57a;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(151,199,139,0.4);
            }

        .btn-yellow {
            background-color: var(--yellow);
            border: none;
            border-radius: 50px;
            padding: 0.4rem 0.8rem;
            font-weight: 500;
            transition: all 0.3s;
            color: var(--brown);
        }

            .btn-yellow:hover {
                background-color: #e6b85c;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(242,198,109,0.4);
            }

        .btn-outline-green {
            border: 2px solid var(--green);
            background: transparent;
            color: var(--green);
            border-radius: 50px;
            padding: 0.4rem 0.8rem;
            font-weight: 500;
            transition: all 0.3s;
        }

            .btn-outline-green:hover {
                background-color: var(--green);
                color: white;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(151,199,139,0.3);
            }

        /* Alertas */
        .alert-beige {
            background-color: var(--bg-light);
            border: 1px solid var(--green);
            color: var(--brown);
            border-radius: 16px;
        }

        /* Formularios */
        .form-control, .form-select {
            border: 2px solid var(--green);
            border-radius: 16px;
            padding: 0.6rem 1rem;
            transition: border-color 0.2s, box-shadow 0.2s;
        }

            .form-control:focus, .form-select:focus {
                border-color: var(--green);
                box-shadow: 0 0 0 0.2rem rgba(151,199,139,0.25);
                outline: none;
            }

        /* Paginación */
        .pagination .page-link {
            color: var(--brown);
            border: 1px solid var(--green);
            border-radius: 30px;
            margin: 0 3px;
            transition: all 0.2s;
        }

            .pagination .page-link:hover {
                background-color: var(--green);
                color: white;
                border-color: var(--green);
            }

        .pagination .active .page-link {
            background-color: var(--green);
            border-color: var(--green);
            color: white;
        }

        /* Gap para acciones */
        .gap-2 {
            gap: 0.5rem;
        }

        /* Responsive */
        @@media (max-width: 768px) {
            .filter-body .row {
                flex-direction: column;
            }

            .table td .d-flex {
                flex-direction: column;
            }
        }
    </style>
}