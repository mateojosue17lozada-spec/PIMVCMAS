@model MVCMASCOTAS.Models.ViewModels.EditProfileViewModel

@{
    ViewBag.Title = "Editar Perfil";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Hero Section -->
<section class="py-4">
    <div class="container">
        <div class="text-center">
            <h1 class="display-5 fw-bold mb-2 text-brown">
                <i class="fa fa-user-edit text-green"></i> Editar Perfil
            </h1>
            <p class="lead mb-3 text-secondary">Actualiza tu información personal y de contacto</p>
        </div>
    </div>
</section>

<!-- Main Content -->
<section class="py-5 bg-light-mint">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <div class="card border-green shadow-hover">
                    <div class="card-header bg-green text-white">
                        <h4 class="mb-0">
                            <i class="fa fa-user-edit me-2"></i>@ViewBag.Title
                        </h4>
                    </div>

                    <div class="card-body">
                        @if (TempData["SuccessMessage"] != null)
                        {
                            <div class="alert alert-green border-green alert-dismissible fade show" role="alert">
                                <i class="fa fa-check-circle text-green me-2"></i>
                                <strong class="text-brown">@TempData["SuccessMessage"]</strong>
                                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                            </div>
                        }

                        @if (TempData["ErrorMessage"] != null)
                        {
                            <div class="alert alert-green border-green alert-dismissible fade show" role="alert">
                                <i class="fa fa-exclamation-triangle text-green me-2"></i>
                                <strong class="text-brown">@TempData["ErrorMessage"]</strong>
                                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                            </div>
                        }

                        @using (Html.BeginForm("EditProfile", "Account", FormMethod.Post,
                               new { enctype = "multipart/form-data", @class = "needs-validation", novalidate = "novalidate", id = "editProfileForm" }))
                        {
                            @Html.AntiForgeryToken()
                            @Html.ValidationSummary(true, "", new { @class = "alert alert-green border-green" })

                            <div class="row">
                                <!-- Columna izquierda - Imagen de perfil -->
                                <div class="col-md-4 mb-4">
                                    <div class="text-center">
                                        @if (!string.IsNullOrEmpty(Model.ImagenPerfilBase64))
                                        {
                                            <img id="profileImage" src="data:image/jpeg;base64,@Model.ImagenPerfilBase64"
                                                 class="img-fluid rounded-circle border border-3 border-green mb-3"
                                                 style="width: 200px; height: 200px; object-fit: cover;"
                                                 alt="Imagen de perfil actual" />
                                        }
                                        else
                                        {
                                            <div id="profileImage" class="rounded-circle border border-3 border-green mb-3 d-flex align-items-center justify-content-center mx-auto"
                                                 style="width: 200px; height: 200px; background-color: var(--bg-light);">
                                                <i class="fa fa-user fa-5x text-secondary"></i>
                                            </div>
                                        }

                                        <div class="mb-3">
                                            <label for="NuevaImagenPerfil" class="form-label text-brown fw-medium">
                                                <i class="fa fa-camera text-green me-1"></i>Cambiar imagen
                                            </label>
                                            <input type="file" class="form-control border-green" id="NuevaImagenPerfil"
                                                   name="NuevaImagenPerfil" accept="image/*"
                                                   onchange="previewImage(this)" />
                                            @Html.ValidationMessageFor(model => model.NuevaImagenPerfil, "", new { @class = "text-danger small" })
                                            <div class="form-text text-secondary">
                                                <i class="fa fa-info-circle text-green"></i> Formatos permitidos: JPG, PNG, GIF (máx. 5MB)
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Columna derecha - Formulario -->
                                <div class="col-md-8">
                                    <h5 class="mb-4 border-bottom pb-2 text-brown">
                                        <i class="fa fa-info-circle text-green me-2"></i>Información Personal
                                    </h5>

                                    <!-- Nombre Completo -->
                                    <div class="mb-4">
                                        @Html.LabelFor(model => model.NombreCompleto,
                                            new { @class = "form-label text-brown fw-medium" })
                                        @Html.TextBoxFor(model => model.NombreCompleto,
                                            new { @class = "form-control border-green", placeholder = "Ingrese su nombre completo" })
                                        @Html.ValidationMessageFor(model => model.NombreCompleto, "",
                                            new { @class = "text-danger small mt-1" })
                                    </div>

                                    <!-- Teléfono -->
                                    <div class="mb-4">
                                        @Html.LabelFor(model => model.Telefono,
                                            new { @class = "form-label text-brown fw-medium" })
                                        @Html.TextBoxFor(model => model.Telefono,
                                            new { @class = "form-control border-green", placeholder = "Ej: 0991234567" })
                                        @Html.ValidationMessageFor(model => model.Telefono, "",
                                            new { @class = "text-danger small mt-1" })
                                    </div>

                                    <!-- Dirección -->
                                    <div class="mb-4">
                                        @Html.LabelFor(model => model.Direccion,
                                            new { @class = "form-label text-brown fw-medium" })
                                        @Html.TextAreaFor(model => model.Direccion,
                                            new
                                                 {
                                                     @class = "form-control border-green",
                                                     rows = "2",
                                                  placeholder = "Ingrese su dirección completa"
                                                 })
                                        @Html.ValidationMessageFor(model => model.Direccion, "",
                                            new { @class = "text-danger small mt-1" })
                                    </div>

                                    <!-- Ciudad y Provincia -->
                                    <div class="row">
                                        <div class="col-md-6 mb-4">
                                            @Html.LabelFor(model => model.Ciudad,
                                                new { @class = "form-label text-brown fw-medium" })
                                            @Html.TextBoxFor(model => model.Ciudad,
                                                new { @class = "form-control border-green", placeholder = "Ciudad" })
                                            @Html.ValidationMessageFor(model => model.Ciudad, "",
                                                new { @class = "text-danger small mt-1" })
                                        </div>
                                        <div class="col-md-6 mb-4">
                                            @Html.LabelFor(model => model.Provincia,
                                                new { @class = "form-label text-brown fw-medium" })
                                            @Html.TextBoxFor(model => model.Provincia,
                                                new { @class = "form-control border-green", placeholder = "Provincia" })
                                            @Html.ValidationMessageFor(model => model.Provincia, "",
                                                new { @class = "text-danger small mt-1" })
                                        </div>
                                    </div>

                                    <!-- Información de solo lectura -->
                                    <h6 class="mt-4 mb-3 border-bottom pb-2 text-brown">
                                        <i class="fa fa-lock text-green me-2"></i>Información no editable
                                    </h6>

                                    <div class="row">
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label text-brown fw-medium">
                                                <i class="fa fa-envelope text-green me-1"></i>Email
                                            </label>
                                            @Html.TextBoxFor(model => model.Email,
                                                new { @class = "form-control-plaintext bg-light-mint p-2 rounded", @readonly = "readonly" })
                                        </div>
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label text-brown fw-medium">
                                                <i class="fa fa-id-card text-green me-1"></i>Cédula
                                            </label>
                                            @Html.TextBoxFor(model => model.Cedula,
                                                new
                                                     {
                                                         @class = "form-control-plaintext bg-light-mint p-2 rounded",
                                                         @readonly = "readonly",
                                                      value = Model.Cedula ?? "No disponible"
                                                     })
                                        </div>
                                    </div>

                                    <!-- Información adicional de solo lectura -->
                                    <div class="row">
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label text-brown fw-medium">
                                                <i class="fa fa-calendar-alt text-green me-1"></i>Fecha de Registro
                                            </label>
                                            @if (Model.FechaRegistro.HasValue)
                                            {
                                                <input type="text" class="form-control-plaintext bg-light-mint p-2 rounded"
                                                       value="@Model.FechaRegistro.Value.ToString("dd/MM/yyyy HH:mm")" readonly />
                                            }
                                            else
                                            {
                                                <input type="text" class="form-control-plaintext bg-light-mint p-2 rounded"
                                                       value="No disponible" readonly />
                                            }
                                        </div>
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label text-brown fw-medium">
                                                <i class="fa fa-check-circle text-green me-1"></i>Estado de Cuenta
                                            </label>
                                            <div class="d-flex flex-wrap gap-2">
                                                @if (Model.Activo == true)
                                                {
                                                    <span class="badge bg-green">Activo</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-pink">Inactivo</span>
                                                }

                                                @if (Model.EmailConfirmado == true)
                                                {
                                                    <span class="badge bg-green">Email Confirmado</span>
                                                }

                                                @if (Model.TelefonoConfirmado == true)
                                                {
                                                    <span class="badge bg-green">Teléfono Confirmado</span>
                                                }
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Botones -->
                                    <div class="d-flex justify-content-between mt-4 pt-3 border-top border-green">
                                        <a href="@Url.Action("MiPerfil", "Account")"
                                           class="btn btn-outline-green">
                                            <i class="fa fa-arrow-left me-1"></i>Volver al Perfil
                                        </a>
                                        <div>
                                            <button type="reset" class="btn btn-outline-green me-2" onclick="resetForm()">
                                                <i class="fa fa-redo me-1"></i>Cancelar Cambios
                                            </button>
                                            <button type="submit" class="btn btn-green text-white">
                                                <i class="fa fa-save me-1"></i>Guardar Cambios
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <!-- Enlace para cambiar contraseña -->
                <div class="card border-green shadow-hover mt-4">
                    <div class="card-body">
                        <h6 class="mb-3 text-brown">
                            <i class="fa fa-key text-green me-2"></i>Seguridad
                        </h6>
                        <a href="@Url.Action("ChangePassword", "Account")" class="btn btn-pink">
                            <i class="fa fa-lock me-1"></i>Cambiar Contraseña
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")

    <script>
        function previewImage(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();

                reader.onload = function (e) {
                    var imgElement = $('#profileImage');

                    if (imgElement.is('img')) {
                        imgElement
                            .attr('src', e.target.result)
                            .removeClass('border-green')
                            .addClass('border-green');
                    } else {
                        // Si es un div (icono de usuario), reemplazarlo por imagen
                        imgElement.replaceWith(
                            '<img id="profileImage" src="' + e.target.result +
                            '" class="img-fluid rounded-circle border border-3 border-green mb-3"' +
                            ' style="width: 200px; height: 200px; object-fit: cover;"' +
                            ' alt="Imagen de perfil nueva" />'
                        );
                    }
                }

                reader.readAsDataURL(input.files[0]);
            }
        }

        function resetForm() {
            // Restaurar imagen original
            var originalImage = '@(!string.IsNullOrEmpty(Model.ImagenPerfilBase64) ? Model.ImagenPerfilBase64 : "")';
            var imgElement = $('#profileImage');

            if (originalImage) {
                if (imgElement.is('img')) {
                    imgElement
                        .attr('src', 'data:image/jpeg;base64,' + originalImage)
                        .removeClass('border-success')
                        .addClass('border-green');
                } else {
                    // Si es un div (icono), reemplazar por imagen
                    imgElement.replaceWith(
                        '<img id="profileImage" src="data:image/jpeg;base64,' + originalImage +
                        '" class="img-fluid rounded-circle border border-3 border-green mb-3"' +
                        ' style="width: 200px; height: 200px; object-fit: cover;"' +
                        ' alt="Imagen de perfil actual" />'
                    );
                }
            } else {
                // Restaurar icono de usuario
                if (imgElement.is('img')) {
                    imgElement.replaceWith(
                        '<div id="profileImage" class="rounded-circle border border-3 border-green mb-3 d-flex align-items-center justify-content-center mx-auto"' +
                        ' style="width: 200px; height: 200px; background-color: var(--bg-light);">' +
                        '<i class="fa fa-user fa-5x text-secondary"></i>' +
                        '</div>'
                    );
                }
            }

            // Limpiar input de archivo
            $('#NuevaImagenPerfil').val('');

            // Mostrar mensaje
            showToast('Cambios descartados', 'Se restauraron los valores originales.', 'info');
        }

        function showToast(title, message, type) {
            var colorClass = 'bg-green';
            if (type === 'warning') {
                colorClass = 'bg-yellow text-brown';
            } else if (type === 'error') {
                colorClass = 'bg-pink text-brown';
            }

            var toastHtml = `
                <div class="toast align-items-center ${colorClass} border-0" role="alert" aria-live="assertive" aria-atomic="true">
                    <div class="d-flex">
                        <div class="toast-body">
                            <strong>${title}</strong><br>${message}
                        </div>
                        <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                    </div>
                </div>
            `;

            var toastContainer = $('#toastContainer');
            if (toastContainer.length === 0) {
                $('body').append('<div id="toastContainer" class="position-fixed bottom-0 end-0 p-3" style="z-index: 11"></div>');
                toastContainer = $('#toastContainer');
            }

            toastContainer.append(toastHtml);
            var toastElement = toastContainer.find('.toast').last();
            var toast = new bootstrap.Toast(toastElement, { delay: 3000 });
            toast.show();

            // Remover del DOM después de ocultarse
            toastElement.on('hidden.bs.toast', function () {
                $(this).remove();
            });
        }

        // Validación Bootstrap
        (function () {
            'use strict'
            var forms = document.querySelectorAll('.needs-validation')
            Array.prototype.slice.call(forms)
                .forEach(function (form) {
                    form.addEventListener('submit', function (event) {
                        if (!form.checkValidity()) {
                            event.preventDefault()
                            event.stopPropagation()
                        }
                        form.classList.add('was-validated')
                    }, false)
                })
        })()

        // Limitar tamaño de imagen en tiempo real
        document.getElementById('NuevaImagenPerfil').addEventListener('change', function(e) {
            var file = e.target.files[0];
            if (file) {
                var fileSize = file.size / 1024 / 1024; // en MB
                if (fileSize > 5) {
                    showToast('Archivo demasiado grande', 'La imagen no debe exceder 5 MB.', 'warning');
                    this.value = '';

                    // Restaurar imagen original
                    resetForm();
                }
            }
        });
    </script>
}

@section Styles {
    <style>
        /* Estilos específicos para Editar Perfil */
        .form-control:focus {
            border-color: var(--green) !important;
            box-shadow: 0 0 0 0.25rem rgba(151, 199, 139, 0.25) !important;
        }

        .form-control-plaintext.bg-light-mint {
            background-color: var(--bg-light) !important;
            cursor: not-allowed;
        }

        .border-success {
            border-color: var(--green) !important;
        }

        .badge {
            font-size: 0.75em;
            padding: 0.35em 0.65em;
        }

        /* Estilo para imagen de perfil */
        .rounded-circle {
            transition: all 0.3s ease;
        }

            .rounded-circle:hover {
                transform: scale(1.02);
                box-shadow: 0 5px 15px rgba(151, 199, 139, 0.3);
            }
    </style>
}