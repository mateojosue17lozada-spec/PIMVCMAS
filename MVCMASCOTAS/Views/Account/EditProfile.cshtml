@model MVCMASCOTAS.Models.ViewModels.EditProfileViewModel

@{
    ViewBag.Title = "Editar Perfil - ADOPTAMANÍA";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Hero Section -->
<section class="profile-hero py-4">
    <div class="container text-center">
        <i class="fas fa-user-edit fa-3x text-green mb-3"></i>
        <h1 class="display-5 fw-bold mb-2 text-brown">Editar Perfil</h1>
        <p class="lead mb-3 text-secondary">Actualiza tu información personal y de contacto</p>
    </div>
</section>

<!-- Main Content -->
<section class="py-5 bg-beige">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <div class="profile-card">
                    <div class="profile-card-header bg-green text-white">
                        <i class="fas fa-user-edit me-2"></i> @ViewBag.Title
                    </div>

                    <div class="profile-card-body">
                        @if (TempData["SuccessMessage"] != null)
                        {
                            <div class="alert alert-beige border-green alert-dismissible fade show" role="alert">
                                <i class="fas fa-check-circle text-green me-2"></i>
                                <strong class="text-brown">@TempData["SuccessMessage"]</strong>
                                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                            </div>
                        }

                        @if (TempData["ErrorMessage"] != null)
                        {
                            <div class="alert alert-beige border-green alert-dismissible fade show" role="alert">
                                <i class="fas fa-exclamation-triangle text-green me-2"></i>
                                <strong class="text-brown">@TempData["ErrorMessage"]</strong>
                                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                            </div>
                        }

                        @using (Html.BeginForm("EditProfile", "Account", FormMethod.Post,
                               new { enctype = "multipart/form-data", @class = "needs-validation", novalidate = "novalidate", id = "editProfileForm" }))
                        {
                            @Html.AntiForgeryToken()
                            @Html.ValidationSummary(true, "", new { @class = "alert alert-beige border-green mb-4" })

                            <div class="row g-4">
                                <!-- Columna izquierda - Imagen de perfil -->
                                <div class="col-md-4">
                                    <div class="profile-image-section text-center">
                                        @if (!string.IsNullOrEmpty(Model.ImagenPerfilBase64))
                                        {
                                            <img id="profileImage" src="data:image/jpeg;base64,@Model.ImagenPerfilBase64"
                                                 class="profile-avatar mb-3"
                                                 alt="Imagen de perfil actual" />
                                        }
                                        else
                                        {
                                            <div id="profileImage" class="profile-avatar-placeholder mx-auto mb-3">
                                                <i class="fas fa-user fa-5x text-secondary"></i>
                                            </div>
                                        }

                                        <div class="mb-3">
                                            <label for="NuevaImagenPerfil" class="btn btn-outline-green d-inline-flex align-items-center gap-2">
                                                <i class="fas fa-camera"></i> Cambiar imagen
                                            </label>
                                            <input type="file" class="d-none" id="NuevaImagenPerfil"
                                                   name="NuevaImagenPerfil" accept="image/*"
                                                   onchange="previewImage(this)" />
                                            <div class="form-text text-secondary small mt-2">
                                                <i class="fas fa-info-circle text-green"></i> JPG, PNG, GIF (máx. 5MB)
                                            </div>
                                            @Html.ValidationMessageFor(model => model.NuevaImagenPerfil, "", new { @class = "text-danger small" })
                                        </div>
                                    </div>
                                </div>

                                <!-- Columna derecha - Formulario -->
                                <div class="col-md-8">
                                    <h5 class="mb-4 border-bottom pb-2 text-brown">
                                        <i class="fas fa-info-circle text-green me-2"></i>Información Personal
                                    </h5>

                                    <!-- Nombre Completo -->
                                    <div class="mb-4">
                                        @Html.LabelFor(model => model.NombreCompleto,
                                            new { @class = "form-label text-brown fw-medium" })
                                        <div class="input-group">
                                            <span class="input-group-text bg-white border-green">
                                                <i class="fas fa-user text-green"></i>
                                            </span>
                                            @Html.TextBoxFor(model => model.NombreCompleto,
                                                new { @class = "form-control border-green", placeholder = "Ingrese su nombre completo" })
                                        </div>
                                        @Html.ValidationMessageFor(model => model.NombreCompleto, "",
                                            new { @class = "text-danger small mt-1" })
                                    </div>

                                    <!-- Teléfono -->
                                    <div class="mb-4">
                                        @Html.LabelFor(model => model.Telefono,
                                            new { @class = "form-label text-brown fw-medium" })
                                        <div class="input-group">
                                            <span class="input-group-text bg-white border-green">
                                                <i class="fas fa-phone-alt text-green"></i>
                                            </span>
                                            @Html.TextBoxFor(model => model.Telefono,
                                                new { @class = "form-control border-green", placeholder = "Ej: 0991234567" })
                                        </div>
                                        @Html.ValidationMessageFor(model => model.Telefono, "",
                                            new { @class = "text-danger small mt-1" })
                                    </div>

                                    <!-- Dirección -->
                                    <div class="mb-4">
                                        @Html.LabelFor(model => model.Direccion,
                                            new { @class = "form-label text-brown fw-medium" })
                                        <div class="input-group">
                                            <span class="input-group-text bg-white border-green">
                                                <i class="fas fa-map-marker-alt text-green"></i>
                                            </span>
                                            @Html.TextAreaFor(model => model.Direccion,
                                                new
                                                {
                                                    @class = "form-control border-green",
                                                    rows = "2",
                                                    placeholder = "Ingrese su dirección completa"
                                                })
                                        </div>
                                        @Html.ValidationMessageFor(model => model.Direccion, "",
                                            new { @class = "text-danger small mt-1" })
                                    </div>

                                    <!-- Ciudad y Provincia -->
                                    <div class="row">
                                        <div class="col-md-6 mb-4">
                                            @Html.LabelFor(model => model.Ciudad,
                                                new { @class = "form-label text-brown fw-medium" })
                                            <div class="input-group">
                                                <span class="input-group-text bg-white border-green">
                                                    <i class="fas fa-city text-green"></i>
                                                </span>
                                                @Html.TextBoxFor(model => model.Ciudad,
                                                    new { @class = "form-control border-green", placeholder = "Ciudad" })
                                            </div>
                                            @Html.ValidationMessageFor(model => model.Ciudad, "",
                                                new { @class = "text-danger small mt-1" })
                                        </div>
                                        <div class="col-md-6 mb-4">
                                            @Html.LabelFor(model => model.Provincia,
                                                new { @class = "form-label text-brown fw-medium" })
                                            <div class="input-group">
                                                <span class="input-group-text bg-white border-green">
                                                    <i class="fas fa-globe text-green"></i>
                                                </span>
                                                @Html.TextBoxFor(model => model.Provincia,
                                                    new { @class = "form-control border-green", placeholder = "Provincia" })
                                            </div>
                                            @Html.ValidationMessageFor(model => model.Provincia, "",
                                                new { @class = "text-danger small mt-1" })
                                        </div>
                                    </div>

                                    <!-- Información de solo lectura -->
                                    <h6 class="mt-4 mb-3 border-bottom pb-2 text-brown">
                                        <i class="fas fa-lock text-green me-2"></i>Información no editable
                                    </h6>

                                    <div class="row">
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label text-brown fw-medium">
                                                <i class="fas fa-envelope text-green me-1"></i>Email
                                            </label>
                                            <div class="readonly-field">
                                                <i class="fas fa-envelope-open-text text-green me-2"></i>
                                                @Html.DisplayFor(model => model.Email)
                                            </div>
                                        </div>
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label text-brown fw-medium">
                                                <i class="fas fa-id-card text-green me-1"></i>Cédula
                                            </label>
                                            <div class="readonly-field">
                                                <i class="fas fa-id-card text-green me-2"></i>
                                                @(Model.Cedula ?? "No disponible")
                                            </div>
                                        </div>
                                    </div>

                                    <div class="row">
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label text-brown fw-medium">
                                                <i class="fas fa-calendar-alt text-green me-1"></i>Fecha de Registro
                                            </label>
                                            <div class="readonly-field">
                                                <i class="fas fa-calendar-check text-green me-2"></i>
                                                @(Model.FechaRegistro?.ToString("dd/MM/yyyy HH:mm") ?? "No disponible")
                                            </div>
                                        </div>
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label text-brown fw-medium">
                                                <i class="fas fa-check-circle text-green me-1"></i>Estado de Cuenta
                                            </label>
                                            <div class="d-flex flex-wrap gap-2 mt-2">
                                                @if (Model.Activo == true)
                                                {
                                                    <span class="badge bg-green">Activo</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-pink">Inactivo</span>
                                                }

                                                @if (Model.EmailConfirmado == true)
                                                {
                                                    <span class="badge bg-green">Email Confirmado</span>
                                                }

                                                @if (Model.TelefonoConfirmado == true)
                                                {
                                                    <span class="badge bg-green">Teléfono Confirmado</span>
                                                }
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Botones -->
                                    <div class="d-flex justify-content-between mt-4 pt-3 border-top border-green">
                                        <a href="@Url.Action("MiPerfil", "Account")"
                                           class="btn btn-outline-green rounded-pill">
                                            <i class="fas fa-arrow-left me-2"></i>Volver al Perfil
                                        </a>
                                        <div>
                                            <button type="reset" class="btn btn-outline-green rounded-pill me-2" onclick="resetForm()">
                                                <i class="fas fa-undo me-2"></i>Cancelar
                                            </button>
                                            <button type="submit" class="btn btn-green rounded-pill">
                                                <i class="fas fa-save me-2"></i>Guardar Cambios
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <!-- Tarjeta para cambiar contraseña -->
                <div class="security-card mt-4">
                    <div class="security-card-body">
                        <h6 class="text-brown mb-3">
                            <i class="fas fa-key text-green me-2"></i>Seguridad
                        </h6>
                        <a href="@Url.Action("ChangePassword", "Account")" class="btn btn-pink rounded-pill">
                            <i class="fas fa-lock me-2"></i>Cambiar Contraseña
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")

    <script>
        function previewImage(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();

                reader.onload = function (e) {
                    var imgElement = $('#profileImage');

                    if (imgElement.is('img')) {
                        imgElement
                            .attr('src', e.target.result)
                            .removeClass('border-success')
                            .addClass('border-green');
                    } else {
                        // Si es un div (icono de usuario), reemplazarlo por imagen
                        imgElement.replaceWith(
                            '<img id="profileImage" src="' + e.target.result +
                            '" class="profile-avatar mb-3" alt="Imagen de perfil nueva" />'
                        );
                    }
                }

                reader.readAsDataURL(input.files[0]);
            }
        }

        function resetForm() {
            // Restaurar imagen original
            var originalImage = '@(!string.IsNullOrEmpty(Model.ImagenPerfilBase64) ? Model.ImagenPerfilBase64 : "")';
            var imgElement = $('#profileImage');

            if (originalImage) {
                if (imgElement.is('img')) {
                    imgElement
                        .attr('src', 'data:image/jpeg;base64,' + originalImage)
                        .removeClass('border-success')
                        .addClass('border-green');
                } else {
                    // Si es un div (icono), reemplazar por imagen
                    imgElement.replaceWith(
                        '<img id="profileImage" src="data:image/jpeg;base64,' + originalImage +
                        '" class="profile-avatar mb-3" alt="Imagen de perfil actual" />'
                    );
                }
            } else {
                // Restaurar icono de usuario
                if (imgElement.is('img')) {
                    imgElement.replaceWith(
                        '<div id="profileImage" class="profile-avatar-placeholder mx-auto mb-3">' +
                        '<i class="fas fa-user fa-5x text-secondary"></i>' +
                        '</div>'
                    );
                }
            }

            // Limpiar input de archivo
            $('#NuevaImagenPerfil').val('');

            // Mostrar mensaje
            showToast('Cambios descartados', 'Se restauraron los valores originales.', 'info');
        }

        function showToast(title, message, type) {
            var colorClass = 'bg-green';
            if (type === 'warning') {
                colorClass = 'bg-yellow text-brown';
            } else if (type === 'error') {
                colorClass = 'bg-pink text-brown';
            }

            var toastHtml = `
                <div class="toast align-items-center ${colorClass} border-0" role="alert" aria-live="assertive" aria-atomic="true">
                    <div class="d-flex">
                        <div class="toast-body">
                            <strong>${title}</strong><br>${message}
                        </div>
                        <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                    </div>
                </div>
            `;

            var toastContainer = $('#toastContainer');
            if (toastContainer.length === 0) {
                $('body').append('<div id="toastContainer" class="position-fixed bottom-0 end-0 p-3" style="z-index: 11"></div>');
                toastContainer = $('#toastContainer');
            }

            toastContainer.append(toastHtml);
            var toastElement = toastContainer.find('.toast').last();
            var toast = new bootstrap.Toast(toastElement, { delay: 3000 });
            toast.show();

            toastElement.on('hidden.bs.toast', function () {
                $(this).remove();
            });
        }

        // Validación Bootstrap
        (function () {
            'use strict'
            var forms = document.querySelectorAll('.needs-validation')
            Array.prototype.slice.call(forms)
                .forEach(function (form) {
                    form.addEventListener('submit', function (event) {
                        if (!form.checkValidity()) {
                            event.preventDefault()
                            event.stopPropagation()
                        }
                        form.classList.add('was-validated')
                    }, false)
                })
        })()

        // Limitar tamaño de imagen en tiempo real
        document.getElementById('NuevaImagenPerfil').addEventListener('change', function(e) {
            var file = e.target.files[0];
            if (file) {
                var fileSize = file.size / 1024 / 1024; // en MB
                if (fileSize > 5) {
                    showToast('Archivo demasiado grande', 'La imagen no debe exceder 5 MB.', 'warning');
                    this.value = '';
                    resetForm();
                }
            }
        });
    </script>
}

@section Styles {
    <style>
        /* Hero */
        .profile-hero {
            background-color: var(--fondo-beige);
            border-radius: 0 0 30px 30px;
            margin-bottom: 1rem;
        }

        /* Tarjeta principal */
        .profile-card {
            background: white;
            border-radius: 30px;
            overflow: hidden;
            box-shadow: 0 20px 40px rgba(151, 199, 139, 0.15);
            border: none;
        }

        .profile-card-header {
            padding: 1.5rem 2rem;
            font-size: 1.5rem;
            font-weight: 600;
            background-color: var(--verde-menta);
            color: white;
        }

        .profile-card-body {
            padding: 2.5rem;
        }

        /* Avatar */
        .profile-avatar {
            width: 200px;
            height: 200px;
            border-radius: 50%;
            object-fit: cover;
            border: 5px solid var(--verde-menta);
            box-shadow: 0 10px 25px rgba(151,199,139,0.3);
            transition: transform 0.3s;
        }

            .profile-avatar:hover {
                transform: scale(1.03);
            }

        .profile-avatar-placeholder {
            width: 200px;
            height: 200px;
            border-radius: 50%;
            background-color: var(--fondo-beige);
            border: 5px solid var(--verde-menta);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* Input groups */
        .input-group-text {
            border-radius: 12px 0 0 12px;
            border-right: none;
            background-color: white;
        }

        .form-control {
            border-radius: 0 12px 12px 0;
            border-left: none;
            padding: 0.75rem 1rem;
            font-size: 1rem;
            transition: border-color 0.2s, box-shadow 0.2s;
        }

            .form-control:focus {
                border-color: var(--verde-menta);
                box-shadow: 0 0 0 0.2rem rgba(151,199,139,0.25);
                outline: none;
            }

        .input-group:focus-within .input-group-text {
            border-color: var(--verde-menta);
            box-shadow: 0 0 0 0.2rem rgba(151,199,139,0.25);
        }

        /* Campos de solo lectura */
        .readonly-field {
            background-color: var(--fondo-beige);
            border: 2px solid var(--plomo-calido);
            border-radius: 12px;
            padding: 0.75rem 1rem;
            color: var(--texto-secundario);
            display: flex;
            align-items: center;
        }

            .readonly-field i {
                margin-right: 0.5rem;
            }

        /* Badges */
        .badge.bg-green {
            background-color: var(--verde-menta) !important;
            color: white;
            font-size: 0.85rem;
            padding: 0.5rem 1rem;
            border-radius: 30px;
        }

        .badge.bg-pink {
            background-color: var(--rosado-claro) !important;
            color: var(--texto-oscuro);
            font-size: 0.85rem;
            padding: 0.5rem 1rem;
            border-radius: 30px;
        }

        /* Botones */
        .btn-green {
            background-color: var(--verde-menta);
            border: none;
            border-radius: 50px;
            padding: 0.6rem 2rem;
            font-weight: 600;
            transition: all 0.3s;
            color: white;
        }

            .btn-green:hover {
                background-color: #86b57a;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(151,199,139,0.4);
                color: white;
            }

        .btn-pink {
            background-color: var(--rosado-claro);
            border: none;
            border-radius: 50px;
            padding: 0.6rem 2rem;
            font-weight: 600;
            transition: all 0.3s;
            color: var(--texto-oscuro);
        }

            .btn-pink:hover {
                background-color: #f9c2b0;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(249,194,176,0.4);
            }

        .btn-outline-green {
            border: 2px solid var(--verde-menta);
            background: transparent;
            color: var(--verde-menta);
            border-radius: 50px;
            padding: 0.6rem 2rem;
            font-weight: 600;
            transition: all 0.3s;
        }

            .btn-outline-green:hover {
                background-color: var(--verde-menta);
                color: white;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(151,199,139,0.3);
            }

        /* Tarjeta de seguridad */
        .security-card {
            background: white;
            border-radius: 24px;
            padding: 1.5rem;
            box-shadow: 0 10px 25px rgba(151,199,139,0.15);
            border: none;
        }

        .security-card-body {
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 1rem;
        }

        /* Alertas */
        .alert-beige {
            background-color: var(--fondo-beige);
            border: 1px solid var(--verde-menta);
            color: var(--texto-oscuro);
            border-radius: 16px;
        }

        /* Responsive */
        @@media (max-width: 768px) {
            .profile-card-body {
                padding: 1.5rem;
            }

            .profile-avatar, .profile-avatar-placeholder {
                width: 150px;
                height: 150px;
            }

            .security-card-body {
                flex-direction: column;
                align-items: flex-start;
            }
        }
    </style>
}