@{
    ViewBag.Title = "Confirmar Email - ADOPTAMANÍA";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Hero Section simple -->
<section class="email-hero py-4">
    <div class="container text-center">
        <i class="fas fa-envelope fa-3x text-green mb-3"></i>
        <h1 class="display-5 fw-bold mb-2 text-brown">Confirmar Email</h1>
    </div>
</section>

<!-- Main Content -->
<section class="py-5 bg-beige">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                @if (ViewBag.Success != null && ViewBag.Success)
                {
                    <!-- ✅ CONFIRMACIÓN EXITOSA -->
                    <div class="confirm-card">
                        <div class="confirm-card-header bg-green text-white text-center">
                            <div class="icon-circle bg-white text-green mx-auto mb-3">
                                <i class="fas fa-check fa-3x"></i>
                            </div>
                            <h2 class="mb-0">¡Email Confirmado!</h2>
                        </div>
                        <div class="confirm-card-body text-center py-5">
                            <i class="fas fa-envelope-open-text fa-5x text-green mb-4"></i>
                            <h4 class="text-green mb-3">Tu correo ha sido verificado exitosamente</h4>
                            <p class="lead mb-4 text-secondary">
                                Tu cuenta está ahora completamente activa. Ya puedes acceder a todas las funciones del sistema.
                            </p>

                            <div class="alert alert-beige border-green mb-4">
                                <i class="fas fa-info-circle text-green me-2"></i>
                                <strong class="text-brown">¡Bienvenido a ADOPTAMANÍA!</strong><br>
                                <span class="text-secondary">Ahora puedes iniciar sesión y comenzar a explorar todas nuestras funciones.</span>
                            </div>

                            <div class="d-flex flex-wrap justify-content-center gap-3">
                                <a href="@Url.Action("Login", "Account")" class="btn btn-green btn-lg">
                                    <i class="fas fa-sign-in-alt me-2"></i> Iniciar Sesión
                                </a>
                                <a href="@Url.Action("Index", "Home")" class="btn btn-outline-green btn-lg">
                                    <i class="fas fa-home me-2"></i> Ir al Inicio
                                </a>
                            </div>
                        </div>
                    </div>
                }
                else if (ViewBag.Error != null)
                {
                    <!-- ❌ ERROR EN LA CONFIRMACIÓN -->
                    <div class="confirm-card">
                        <div class="confirm-card-header bg-yellow text-brown text-center">
                            <div class="icon-circle bg-white text-yellow mx-auto mb-3">
                                <i class="fas fa-exclamation-triangle fa-3x"></i>
                            </div>
                            <h2 class="mb-0">Error al Confirmar Email</h2>
                        </div>
                        <div class="confirm-card-body text-center py-5">
                            <i class="fas fa-times-circle fa-5x text-brown mb-4"></i>
                            <h4 class="text-brown mb-3">No se pudo confirmar tu correo</h4>

                            <div class="alert alert-beige border-green mb-4">
                                <i class="fas fa-exclamation-circle text-green me-2"></i>
                                <strong class="text-brown">Detalles del Error:</strong><br>
                                <span class="text-secondary">@ViewBag.Error</span>
                            </div>

                            <div class="causes-card mb-4 p-4">
                                <h5 class="text-brown mb-3"><i class="fas fa-lightbulb text-yellow me-2"></i> Posibles causas:</h5>
                                <ul class="list-unstyled text-secondary">
                                    <li class="mb-2"><i class="fas fa-check-circle text-green me-2"></i> El enlace de confirmación ya fue usado anteriormente</li>
                                    <li class="mb-2"><i class="fas fa-clock text-green me-2"></i> El enlace ha expirado (válido por 24 horas)</li>
                                    <li class="mb-2"><i class="fas fa-link text-green me-2"></i> El enlace está incompleto o dañado</li>
                                    <li class="mb-2"><i class="fas fa-user-check text-green me-2"></i> La cuenta ya está confirmada</li>
                                    <li class="mb-2"><i class="fas fa-user-times text-green me-2"></i> El usuario no existe</li>
                                </ul>
                            </div>

                            <div class="alert alert-beige border-green mb-4">
                                <i class="fas fa-info-circle text-green me-2"></i>
                                <strong class="text-brown">Sugerencia:</strong>
                                <span class="text-secondary">Si tu cuenta ya está confirmada, intenta iniciar sesión directamente.</span>
                            </div>

                            <div class="d-flex flex-wrap justify-content-center gap-3">
                                <a href="@Url.Action("Login", "Account")" class="btn btn-green btn-lg">
                                    <i class="fas fa-sign-in-alt me-2"></i> Iniciar Sesión
                                </a>
                                <a href="@Url.Action("Register", "Account")" class="btn btn-pink btn-lg">
                                    <i class="fas fa-user-plus me-2"></i> Crear Cuenta
                                </a>
                                <a href="@Url.Action("Contact", "Home")" class="btn btn-outline-green btn-lg">
                                    <i class="fas fa-envelope me-2"></i> Soporte
                                </a>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <!-- ⏳ PROCESANDO -->
                    <div class="confirm-card">
                        <div class="confirm-card-header bg-green text-white text-center">
                            <div class="icon-circle bg-white text-green mx-auto mb-3">
                                <i class="fas fa-spinner fa-spin fa-3x"></i>
                            </div>
                            <h2 class="mb-0">Confirmando Email...</h2>
                        </div>
                        <div class="confirm-card-body text-center py-5">
                            <div class="spinner-border text-green mb-4" role="status" style="width: 3rem; height: 3rem;">
                                <span class="visually-hidden">Cargando...</span>
                            </div>
                            <h5 class="text-green mb-3">Estamos procesando tu solicitud...</h5>
                            <p class="text-secondary">Esto puede tomar unos segundos. Por favor, espera.</p>

                            <div class="alert alert-beige border-green mt-4">
                                <i class="fas fa-hourglass-half text-green me-2"></i>
                                <strong class="text-brown">Estado:</strong>
                                <span class="text-secondary">Verificando tu cuenta...</span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

@section Styles {
    <style>
        /* Hero */
        .email-hero {
            background-color: var(--fondo-beige);
            border-radius: 0 0 30px 30px;
            margin-bottom: 1rem;
        }

        /* Tarjeta principal */
        .confirm-card {
            background: white;
            border-radius: 30px;
            overflow: hidden;
            box-shadow: 0 20px 40px rgba(151, 199, 139, 0.15);
            border: none;
        }

        .confirm-card-header {
            padding: 2.5rem 1.5rem 1.5rem;
            position: relative;
        }

        .icon-circle {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            background: white;
            box-shadow: 0 10px 20px rgba(0,0,0,0.1);
        }

        .confirm-card-body {
            padding: 2rem;
        }

        .alert-beige {
            background-color: var(--fondo-beige);
            border: 1px solid var(--verde-menta);
            color: var(--texto-oscuro);
            border-radius: 16px;
            padding: 1rem 1.5rem;
            text-align: left;
        }

        .causes-card {
            background: #f9f9f9;
            border-radius: 16px;
            border-left: 5px solid var(--amarillo-pastel);
            text-align: left;
        }

            .causes-card ul {
                padding-left: 0;
            }

            .causes-card li {
                display: flex;
                align-items: center;
            }

        .btn-green {
            background-color: var(--verde-menta);
            border: none;
            border-radius: 50px;
            padding: 0.75rem 1.8rem;
            font-weight: 600;
            transition: all 0.3s;
            color: white;
        }

            .btn-green:hover {
                background-color: #86b57a;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(151,199,139,0.4);
                color: white;
            }

        .btn-pink {
            background-color: var(--rosado-claro);
            border: none;
            border-radius: 50px;
            padding: 0.75rem 1.8rem;
            font-weight: 600;
            transition: all 0.3s;
            color: var(--texto-oscuro);
        }

            .btn-pink:hover {
                background-color: #f9c2b0;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(249,194,176,0.4);
            }

        .btn-outline-green {
            border: 2px solid var(--verde-menta);
            background: transparent;
            color: var(--verde-menta);
            border-radius: 50px;
            padding: 0.75rem 1.8rem;
            font-weight: 600;
            transition: all 0.3s;
        }

            .btn-outline-green:hover {
                background-color: var(--verde-menta);
                color: white;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(151,199,139,0.3);
            }

        .spinner-border.text-green {
            color: var(--verde-menta) !important;
        }

        /* Responsive */
        @@media (max-width: 768px) {
            .confirm-card-header {
                padding: 1.5rem 1rem;
            }

            .icon-circle {
                width: 60px;
                height: 60px;
            }

                .icon-circle i {
                    font-size: 1.8rem;
                }

            .confirm-card-body {
                padding: 1.5rem;
            }

            .btn-lg {
                font-size: 1rem;
                padding: 0.6rem 1.2rem;
            }

            .fa-5x {
                font-size: 3.5em;
            }
        }
    </style>
}