@model MVCMASCOTAS.Models.ViewModels.EditProfileViewModel

@{
    ViewBag.Title = "Mi Perfil";
}

<div class="page-header mb-4">
    <h2><i class="fas fa-user-circle"></i> Mi Perfil</h2>
    <p class="text-muted">Gestiona tu información personal</p>
</div>

<div class="row">
    <!-- Información del perfil -->
    <div class="col-md-4">
        <div class="card shadow-custom mb-4">
            <div class="card-body text-center">
                <div class="mb-3">
                    @if (!string.IsNullOrEmpty(Model?.ImagenPerfilBase64))
                    {
                        <img src="data:image/jpeg;base64,@Model.ImagenPerfilBase64"
                             alt="Foto de perfil"
                             class="rounded-circle img-thumbnail"
                             style="width: 150px; height: 150px; object-fit: cover;" />
                        <p class="small text-muted mt-2">
                            <i class="fas fa-check-circle text-success"></i> Foto de perfil activa
                        </p>
                    }
                    else
                    {
                        <div class="rounded-circle bg-secondary d-inline-flex align-items-center justify-content-center mb-2"
                             style="width: 150px; height: 150px;">
                            <i class="fas fa-user fa-5x text-white"></i>
                        </div>
                        <p class="small text-muted">
                            <i class="fas fa-exclamation-circle"></i> Sin foto de perfil
                        </p>
                    }
                </div>
                <h4>@(Model?.NombreCompleto ?? User.Identity.Name)</h4>
                <p class="text-muted">
                    <i class="fas fa-envelope"></i> @(Model?.Email ?? "")
                </p>

                @if (Model?.EmailConfirmado == true)
                {
                    <span class="badge badge-success mb-2">
                        <i class="fas fa-check-circle"></i> Email verificado
                    </span>
                }
                else
                {
                    <span class="badge badge-warning mb-2">
                        <i class="fas fa-exclamation-triangle"></i> Email no verificado
                    </span>
                }

                <hr />

                <div class="text-left">
                    <p><i class="fas fa-id-card text-primary"></i> <strong>Cédula:</strong> @(Model?.Cedula ?? "No especificado")</p>
                    <p>
                        <i class="fas fa-phone text-success"></i> <strong>Teléfono:</strong>
                        @(Model?.Telefono ?? "No especificado")
                        @if (Model?.TelefonoConfirmado == true)
                        {
                            <span class="badge badge-success badge-sm ml-1">Verificado</span>
                        }
                    </p>
                    <p><i class="fas fa-map-marker-alt text-danger"></i> <strong>Dirección:</strong> @(Model?.Direccion ?? "No especificado")</p>
                    <p><i class="fas fa-map text-info"></i> <strong>Ubicación:</strong> @(Model?.Ciudad ?? "Quito"), @(Model?.Provincia ?? "Pichincha")</p>
                    <p><i class="fas fa-calendar text-info"></i> <strong>Fecha de Registro:</strong> @(Model?.FechaRegistro?.ToString("dd/MM/yyyy HH:mm") ?? "N/A")</p>

                    @if (Model?.Activo == true)
                    {
                        <p><i class="fas fa-check-circle text-success"></i> <strong>Estado:</strong> Activo</p>
                    }
                    else
                    {
                        <p><i class="fas fa-times-circle text-danger"></i> <strong>Estado:</strong> Inactivo</p>
                    }
                </div>
            </div>
        </div>

        <!-- Acciones rápidas -->
        <div class="card shadow-custom mb-4">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="fas fa-bolt"></i> Acciones Rápidas</h5>
            </div>
            <div class="list-group list-group-flush">
                <a href="@Url.Action("ChangePassword", "Account")" class="list-group-item list-group-item-action">
                    <i class="fas fa-key text-warning"></i> Cambiar Contraseña
                </a>
                <a href="@Url.Action("MisSolicitudes", "Adopcion")" class="list-group-item list-group-item-action">
                    <i class="fas fa-file-alt text-primary"></i> Mis Solicitudes de Adopción
                </a>
                <a href="@Url.Action("MisDonaciones", "Donaciones")" class="list-group-item list-group-item-action">
                    <i class="fas fa-hand-holding-heart text-success"></i> Mis Donaciones
                </a>
                <a href="@Url.Action("MisApadrinamientos", "Donaciones")" class="list-group-item list-group-item-action">
                    <i class="fas fa-heart text-danger"></i> Mis Apadrinamientos
                </a>
                <a href="@Url.Action("MisActividades", "Voluntariado")" class="list-group-item list-group-item-action">
                    <i class="fas fa-hands-helping text-info"></i> Mis Actividades de Voluntariado
                </a>
                <a href="@Url.Action("MisPedidos", "Tienda")" class="list-group-item list-group-item-action">
                    <i class="fas fa-shopping-bag text-purple"></i> Mis Pedidos
                </a>
                <a href="@Url.Action("MisReportes", "Rescate")" class="list-group-item list-group-item-action">
                    <i class="fas fa-ambulance text-orange"></i> Mis Reportes de Rescate
                </a>
            </div>
        </div>
    </div>

    <!-- Formulario de edición -->
    <div class="col-md-8">
        <div class="card shadow-custom mb-4">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="fas fa-edit"></i> Editar Información Personal</h5>
            </div>
            <div class="card-body">
                @using (Html.BeginForm("EditProfile", "Account", FormMethod.Post, new { enctype = "multipart/form-data", @class = "needs-validation", novalidate = "novalidate" }))
                {
                    @Html.AntiForgeryToken()
                    @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="NombreCompleto" class="font-weight-bold">
                                    <i class="fas fa-user"></i> Nombre Completo *
                                </label>
                                @Html.TextBoxFor(m => m.NombreCompleto, new
                                {
                                    @class = "form-control",
                                    placeholder = "Ej: Juan Pérez",
                                    required = "required",
                                    maxlength = "150"
                                })
                                @Html.ValidationMessageFor(m => m.NombreCompleto, "", new { @class = "text-danger small" })
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="Telefono" class="font-weight-bold">
                                    <i class="fas fa-phone"></i> Teléfono
                                </label>
                                @Html.TextBoxFor(m => m.Telefono, new
                                {
                                    @class = "form-control",
                                    placeholder = "Ej: 0987654321",
                                    maxlength = "20"
                                })
                                @Html.ValidationMessageFor(m => m.Telefono, "", new { @class = "text-danger small" })
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="Ciudad" class="font-weight-bold">
                                    <i class="fas fa-city"></i> Ciudad
                                </label>
                                @Html.TextBoxFor(m => m.Ciudad, new
                                {
                                    @class = "form-control",
                                    placeholder = "Ej: Quito",
                                    maxlength = "100"
                                })
                                @Html.ValidationMessageFor(m => m.Ciudad, "", new { @class = "text-danger small" })
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="Provincia" class="font-weight-bold">
                                    <i class="fas fa-map"></i> Provincia
                                </label>
                                @Html.TextBoxFor(m => m.Provincia, new
                                {
                                    @class = "form-control",
                                    placeholder = "Ej: Pichincha",
                                    maxlength = "100"
                                })
                                @Html.ValidationMessageFor(m => m.Provincia, "", new { @class = "text-danger small" })
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="Direccion" class="font-weight-bold">
                            <i class="fas fa-map-marker-alt"></i> Dirección
                        </label>
                        @Html.TextAreaFor(m => m.Direccion, new
                        {
                            @class = "form-control",
                            rows = "3",
                            placeholder = "Dirección completa incluyendo calles, sector, referencias...",
                            maxlength = "255"
                        })
                        @Html.ValidationMessageFor(m => m.Direccion, "", new { @class = "text-danger small" })
                    </div>

                    <!-- Campos de solo lectura (solo para mostrar) -->
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="font-weight-bold">
                                    <i class="fas fa-envelope"></i> Email (no editable)
                                </label>
                                <input type="email" class="form-control bg-light" value="@Model?.Email" readonly />
                                <small class="form-text text-muted">
                                    Contacta al administrador para cambiar tu email
                                </small>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="font-weight-bold">
                                    <i class="fas fa-id-card"></i> Cédula (no editable)
                                </label>
                                <input type="text" class="form-control bg-light" value="@Model?.Cedula" readonly />
                                <small class="form-text text-muted">
                                    La cédula no se puede modificar por seguridad
                                </small>
                            </div>
                        </div>
                    </div>

                    <!-- Imagen de perfil -->
                    <div class="form-group">
                        <label for="NuevaImagenPerfil" class="font-weight-bold">
                            <i class="fas fa-camera"></i> Cambiar Foto de Perfil
                        </label>
                        <div class="custom-file">
                            @Html.TextBoxFor(m => m.NuevaImagenPerfil, new
                            {
                                type = "file",
                                @class = "custom-file-input",
                                id = "NuevaImagenPerfil",
                                accept = "image/*",
                                lang = "es"
                            })
                            <label class="custom-file-label" for="NuevaImagenPerfil">
                                <i class="fas fa-cloud-upload-alt"></i> Seleccionar imagen...
                            </label>
                        </div>
                        <small class="form-text text-muted">
                            <i class="fas fa-info-circle"></i> Formatos aceptados: JPG, PNG, GIF. Tamaño máximo: 5MB
                        </small>
                        @Html.ValidationMessageFor(m => m.NuevaImagenPerfil, "", new { @class = "text-danger small" })
                    </div>

                    <!-- Vista previa de imagen -->
                    <div id="imagePreview" class="text-center mb-3" style="display: none;">
                        <p class="font-weight-bold mb-2">
                            <i class="fas fa-eye"></i> Vista Previa:
                        </p>
                        <img id="previewImage" class="img-thumbnail" style="max-width: 200px; max-height: 200px;" />
                    </div>

                    <hr class="my-4" />

                    <div class="form-group text-right">
                        <a href="@Url.Action("MiPerfil", "Account")" class="btn btn-outline-secondary btn-lg">
                            <i class="fas fa-times"></i> Cancelar
                        </a>
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="fas fa-save"></i> Guardar Cambios
                        </button>
                    </div>
                }
            </div>
        </div>

        <!-- Estadísticas del usuario -->
        @if (ViewBag.TotalSolicitudes != null || ViewBag.TotalDonaciones != null)
        {
            <div class="card shadow-custom">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0"><i class="fas fa-chart-bar"></i> Mi Actividad</h5>
                </div>
                <div class="card-body">
                    <div class="row text-center">
                        <div class="col-md-3 mb-3">
                            <div class="p-3 bg-light rounded shadow-sm">
                                <i class="fas fa-file-alt fa-2x text-primary mb-2"></i>
                                <h4 class="mb-0">@(ViewBag.TotalSolicitudes ?? 0)</h4>
                                <p class="text-muted mb-0">Solicitudes</p>
                            </div>
                        </div>
                        <div class="col-md-3 mb-3">
                            <div class="p-3 bg-light rounded shadow-sm">
                                <i class="fas fa-donate fa-2x text-success mb-2"></i>
                                <h4 class="mb-0">@(ViewBag.TotalDonaciones ?? 0)</h4>
                                <p class="text-muted mb-0">Donaciones</p>
                            </div>
                        </div>
                        <div class="col-md-3 mb-3">
                            <div class="p-3 bg-light rounded shadow-sm">
                                <i class="fas fa-heart fa-2x text-danger mb-2"></i>
                                <h4 class="mb-0">@(ViewBag.TotalApadrinamientos ?? 0)</h4>
                                <p class="text-muted mb-0">Apadrinamientos</p>
                            </div>
                        </div>
                        <div class="col-md-3 mb-3">
                            <div class="p-3 bg-light rounded shadow-sm">
                                <i class="fas fa-hands-helping fa-2x text-warning mb-2"></i>
                                <h4 class="mb-0">@(ViewBag.TotalVoluntariado ?? 0)</h4>
                                <p class="text-muted mb-0">Voluntariados</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Styles {
    <style>
        .shadow-custom {
            box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15);
            border: none;
            border-radius: 10px;
        }

        .text-purple {
            color: #6f42c1;
        }

        .text-orange {
            color: #fd7e14;
        }

        .badge-sm {
            font-size: 0.7em;
            padding: 2px 6px;
        }
    </style>
}

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
    <script>
        $(document).ready(function () {
            // Bootstrap file input preview
            $('.custom-file-input').on('change', function () {
                var fileName = $(this).val().split('\\').pop();
                $(this).next('.custom-file-label').html('<i class="fas fa-image"></i> ' + fileName);

                // Preview de imagen
                var input = this;
                if (input.files && input.files[0]) {
                    var reader = new FileReader();
                    reader.onload = function (e) {
                        $('#previewImage').attr('src', e.target.result);
                        $('#imagePreview').show();
                    };
                    reader.readAsDataURL(input.files[0]);
                }
            });

            // Validación de formulario
            (function () {
                'use strict';
                var forms = document.getElementsByClassName('needs-validation');
                var validation = Array.prototype.filter.call(forms, function (form) {
                    form.addEventListener('submit', function (event) {
                        if (form.checkValidity() === false) {
                            event.preventDefault();
                            event.stopPropagation();
                        }
                        form.classList.add('was-validated');
                    }, false);
                });
            })();

            // Máscara para teléfono
            $('#Telefono').inputmask('999-999-9999', {
                placeholder: '_',
                showMaskOnHover: false
            });
        });
    </script>
}