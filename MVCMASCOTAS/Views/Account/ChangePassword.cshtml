@model MVCMASCOTAS.Models.ViewModels.ChangePasswordViewModel

@{
    ViewBag.Title = "Cambiar Contraseña - ADOPTAMANÍA";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Hero Section simple con icono -->
<section class="password-hero py-4">
    <div class="container text-center">
        <i class="fas fa-key fa-3x text-green mb-3"></i>
        <h1 class="display-5 fw-bold mb-2 text-brown">Cambiar Contraseña</h1>
        <p class="lead mb-3 text-secondary">Actualiza tu contraseña para mantener tu cuenta segura.</p>
    </div>
</section>

<!-- Main Content -->
<section class="py-5 bg-beige">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                <div class="password-card">
                    <div class="password-card-header bg-green text-white text-center py-4">
                        <i class="fas fa-user-lock fa-3x mb-2"></i>
                        <h3 class="mb-0">Cambiar Contraseña</h3>
                    </div>
                    <div class="password-card-body p-4 p-md-5">
                        @using (Html.BeginForm("ChangePassword", "Account", FormMethod.Post, new { @class = "needs-validation", novalidate = "novalidate", id = "changePasswordForm" }))
                        {
                            @Html.AntiForgeryToken()
                            @Html.ValidationSummary(true, "", new { @class = "alert alert-beige mb-4" })

                            <!-- Campo Contraseña Actual -->
                            <div class="form-group mb-4">
                                <label for="CurrentPassword" class="form-label text-brown fw-medium">
                                    <i class="fas fa-lock text-green me-2"></i> Contraseña Actual *
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white border-green">
                                        <i class="fas fa-lock text-green"></i>
                                    </span>
                                    @Html.PasswordFor(m => m.CurrentPassword, new
                                    {
                                        @class = "form-control border-green",
                                        placeholder = "Ingresa tu contraseña actual",
                                        required = "required",
                                        id = "CurrentPassword",
                                        autocomplete = "current-password"
                                    })
                                </div>
                                @Html.ValidationMessageFor(m => m.CurrentPassword, "", new { @class = "text-danger small mt-1" })
                            </div>

                            <!-- Campo Nueva Contraseña -->
                            <div class="form-group mb-4">
                                <label for="NewPassword" class="form-label text-brown fw-medium">
                                    <i class="fas fa-key text-green me-2"></i> Nueva Contraseña *
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white border-green">
                                        <i class="fas fa-key text-green"></i>
                                    </span>
                                    @Html.PasswordFor(m => m.NewPassword, new
                                    {
                                        @class = "form-control border-green",
                                        placeholder = "Mínimo 8 caracteres",
                                        required = "required",
                                        minlength = "8",
                                        id = "NewPassword",
                                        autocomplete = "new-password"
                                    })
                                </div>
                                @Html.ValidationMessageFor(m => m.NewPassword, "", new { @class = "text-danger small mt-1" })
                                <small class="form-text text-secondary mt-2">
                                    <i class="fas fa-info-circle text-green me-1"></i> La contraseña debe tener al menos 8 caracteres, incluir letras y números.
                                </small>
                            </div>

                            <!-- Campo Confirmar Contraseña -->
                            <div class="form-group mb-4">
                                <label for="ConfirmPassword" class="form-label text-brown fw-medium">
                                    <i class="fas fa-check-circle text-green me-2"></i> Confirmar Nueva Contraseña *
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white border-green">
                                        <i class="fas fa-check-circle text-green"></i>
                                    </span>
                                    @Html.PasswordFor(m => m.ConfirmPassword, new
                                    {
                                        @class = "form-control border-green",
                                        placeholder = "Repite la nueva contraseña",
                                        required = "required",
                                        id = "ConfirmPassword",
                                        autocomplete = "new-password"
                                    })
                                </div>
                                @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "text-danger small mt-1" })
                                <!-- Mensajes de coincidencia -->
                                <div id="passwordMatch" class="mt-2 d-none">
                                    <small class="text-success">
                                        <i class="fas fa-check-circle me-1"></i> Las contraseñas coinciden
                                    </small>
                                </div>
                                <div id="passwordMismatch" class="mt-2 d-none">
                                    <small class="text-danger">
                                        <i class="fas fa-times-circle me-1"></i> Las contraseñas no coinciden
                                    </small>
                                </div>
                            </div>

                            <!-- Botón de envío -->
                            <div class="d-grid gap-3">
                                <button type="submit" class="btn btn-green btn-lg text-white">
                                    <i class="fas fa-save me-2"></i> Cambiar Contraseña
                                </button>
                            </div>
                        }

                        <!-- Botón de regreso -->
                        <div class="text-center mt-4 pt-3 border-top border-green">
                            <a href="@Url.Action("MiPerfil", "Account")" class="btn btn-outline-green">
                                <i class="fas fa-arrow-left me-2"></i> Volver a Mi Perfil
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Styles {
    <style>
        /* Estilos específicos para la página de cambio de contraseña */
        .password-hero {
            background-color: var(--fondo-beige);
            border-radius: 0 0 30px 30px;
            margin-bottom: 1rem;
        }

        .password-card {
            background: white;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 15px 35px rgba(151, 199, 139, 0.2);
            border: none;
        }

        .password-card-header {
            background: var(--verde-menta);
            padding: 2rem 1rem;
        }

            .password-card-header i {
                color: white;
            }

        .password-card-body {
            background: white;
        }

        .input-group-text {
            border-radius: 12px 0 0 12px;
            border-right: none;
            background-color: white;
        }

        .form-control {
            border-radius: 0 12px 12px 0;
            border-left: none;
            padding: 0.75rem 1rem;
            font-size: 1rem;
            transition: border-color 0.2s, box-shadow 0.2s;
        }

            .form-control:focus {
                border-color: var(--verde-menta);
                box-shadow: 0 0 0 0.2rem rgba(151, 199, 139, 0.25);
                outline: none;
            }

        .input-group:focus-within .input-group-text {
            border-color: var(--verde-menta);
            box-shadow: 0 0 0 0.2rem rgba(151, 199, 139, 0.25);
        }

        .alert-beige {
            background-color: var(--fondo-beige);
            border: 1px solid var(--verde-menta);
            color: var(--texto-oscuro);
            border-radius: 16px;
        }

        .btn-green {
            background-color: var(--verde-menta);
            border: none;
            border-radius: 50px;
            padding: 0.8rem 2rem;
            font-weight: 600;
            transition: all 0.3s;
        }

            .btn-green:hover {
                background-color: #86b57a;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(151, 199, 139, 0.4);
            }

        .btn-outline-green {
            border: 2px solid var(--verde-menta);
            color: var(--verde-menta);
            border-radius: 50px;
            padding: 0.6rem 2rem;
            font-weight: 500;
            transition: all 0.3s;
        }

            .btn-outline-green:hover {
                background-color: var(--verde-menta);
                color: white;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(151, 199, 139, 0.3);
            }

        /* Estados de validación visuales */
        .is-valid {
            border-color: var(--verde-menta) !important;
        }

        .is-invalid {
            border-color: #dc3545 !important;
        }

        /* Responsive */
        @@media (max-width: 768px) {
            .password-card-body {
                padding: 1.5rem !important;
            }
        }
    </style>
}

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")

    <script>
        $(document).ready(function () {
            console.log('ChangePassword page loaded');

            // Validar que las contraseñas coincidan
            $('#ConfirmPassword').on('input', function () {
                var newPass = $('#NewPassword').val();
                var confirmPass = $(this).val();

                if (newPass === confirmPass && confirmPass !== '') {
                    $(this).removeClass('is-invalid').addClass('is-valid');
                    $('#passwordMatch').removeClass('d-none');
                    $('#passwordMismatch').addClass('d-none');
                } else if (confirmPass !== '') {
                    $(this).removeClass('is-valid').addClass('is-invalid');
                    $('#passwordMatch').addClass('d-none');
                    $('#passwordMismatch').removeClass('d-none');
                } else {
                    $(this).removeClass('is-valid is-invalid');
                    $('#passwordMatch').addClass('d-none');
                    $('#passwordMismatch').addClass('d-none');
                }
            });

            // Validación del formulario
            $('#changePasswordForm').submit(function (e) {
                var newPass = $('#NewPassword').val();
                var confirmPass = $('#ConfirmPassword').val();

                // Validar longitud mínima
                if (newPass.length < 8) {
                    e.preventDefault();
                    Swal.fire({
                        icon: 'error',
                        title: 'Contraseña muy corta',
                        text: 'La contraseña debe tener al menos 8 caracteres.',
                        confirmButtonColor: '#97C78B'
                    });
                    return false;
                }

                // Validar que coincidan
                if (newPass !== confirmPass) {
                    e.preventDefault();
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: 'Las contraseñas no coinciden. Por favor, verifica.',
                        confirmButtonColor: '#97C78B'
                    });
                    return false;
                }

                return true;
            });
        });
    </script>
}