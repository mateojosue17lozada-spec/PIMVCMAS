@model MVCMASCOTAS.Models.ViewModels.ForgotPasswordViewModel

@{
    ViewBag.Title = "Recuperar Contraseña";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="py-5 bg-light-mint">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                <div class="card border-green shadow-hover mb-4">
                    <div class="card-header bg-yellow text-brown text-center">
                        <h3 class="mb-0">
                            <i class="fa fa-key"></i> Recuperar Contraseña
                        </h3>
                    </div>
                    <div class="card-body p-4">
                        <div class="alert alert-green border-green">
                            <i class="fa fa-info-circle text-green"></i>
                            <strong class="text-brown">Ingresa tu correo electrónico</strong>
                            <p class="text-secondary mb-0 mt-1">Te enviaremos instrucciones para restablecer tu contraseña.</p>
                        </div>

                        @using (Html.BeginForm("ForgotPassword", "Account", FormMethod.Post, new { @class = "needs-validation", novalidate = "novalidate" }))
                        {
                            @Html.AntiForgeryToken()
                            @Html.ValidationSummary(true, "", new { @class = "alert alert-green border-green" })

                            <div class="form-group mb-3">
                                <label for="Email" class="text-brown fw-medium">
                                    <i class="fa fa-envelope text-green"></i> Correo Electrónico *
                                </label>
                                @Html.TextBoxFor(m => m.Email, new
                                {
                                    @class = "form-control border-green",
                                    type = "email",
                                    placeholder = "correo@ejemplo.com",
                                    required = "required"
                                })
                                @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger small mt-1" })
                                <small class="form-text text-secondary mt-2">
                                    <i class="fa fa-info-circle text-green"></i> Ingresa el correo electrónico asociado a tu cuenta
                                </small>
                            </div>

                            <button type="submit" class="btn btn-green btn-block btn-lg text-white">
                                <i class="fa fa-paper-plane"></i> Enviar Instrucciones
                            </button>
                        }

                        <hr class="border-green" />

                        <div class="text-center">
                            <p class="text-brown">¿Recordaste tu contraseña?</p>
                            <div class="d-flex flex-wrap justify-content-center gap-2">
                                <a href="@Url.Action("Login", "Account")" class="btn btn-outline-green">
                                    <i class="fa fa-sign-in-alt"></i> Iniciar Sesión
                                </a>
                                <a href="@Url.Action("Register", "Account")" class="btn btn-pink">
                                    <i class="fa fa-user-plus"></i> Crear Cuenta Nueva
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Información adicional -->
                <div class="card border-green shadow-hover">
                    <div class="card-body p-4">
                        <h5 class="text-brown mb-3">
                            <i class="fa fa-question-circle text-green"></i> ¿Necesitas ayuda?
                        </h5>
                        <p class="text-secondary mb-3">Si tienes problemas para recuperar tu contraseña:</p>
                        <ul class="text-secondary mb-3">
                            <li><i class="fa fa-check-circle text-green me-2"></i> Verifica que el correo electrónico sea el correcto</li>
                            <li><i class="fa fa-check-circle text-green me-2"></i> Revisa tu carpeta de spam o correo no deseado</li>
                            <li><i class="fa fa-check-circle text-green me-2"></i> El enlace de recuperación es válido por 24 horas</li>
                            <li><i class="fa fa-check-circle text-green me-2"></i> Contáctanos si necesitas asistencia adicional</li>
                        </ul>
                        <div class="d-grid">
                            <a href="@Url.Action("Contact", "Home")" class="btn btn-outline-green">
                                <i class="fa fa-envelope"></i> Contactar Soporte
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}