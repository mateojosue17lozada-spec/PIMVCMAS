@model MVCMASCOTAS.Models.ViewModels.ForgotPasswordViewModel

@{
    ViewBag.Title = "Recuperar Contraseña - ADOPTAMANÍA";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Hero Section simple -->
<section class="password-hero py-4">
    <div class="container text-center">
        <i class="fas fa-key fa-3x text-green mb-3"></i>
        <h1 class="display-5 fw-bold mb-2 text-brown">Recuperar Contraseña</h1>
        <p class="lead mb-3 text-secondary">Te ayudaremos a restablecer tu acceso</p>
    </div>
</section>

<!-- Main Content -->
<section class="py-5 bg-beige">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                <!-- Tarjeta principal -->
                <div class="forgot-card mb-4">
                    <div class="forgot-card-header bg-yellow text-brown text-center">
                        <i class="fas fa-unlock-alt fa-3x mb-3"></i>
                        <h3 class="mb-0">Recuperar Contraseña</h3>
                    </div>
                    <div class="forgot-card-body p-4">
                        <!-- Alerta informativa -->
                        <div class="alert alert-beige border-green d-flex align-items-start mb-4">
                            <i class="fas fa-info-circle fa-2x text-green me-3"></i>
                            <div>
                                <strong class="text-brown">Ingresa tu correo electrónico</strong>
                                <p class="text-secondary mb-0 mt-1">Te enviaremos instrucciones para restablecer tu contraseña.</p>
                            </div>
                        </div>

                        @using (Html.BeginForm("ForgotPassword", "Account", FormMethod.Post, new { @class = "needs-validation", novalidate = "novalidate" }))
                        {
                            @Html.AntiForgeryToken()
                            @Html.ValidationSummary(true, "", new { @class = "alert alert-beige border-green" })

                            <!-- Campo Email -->
                            <div class="form-group mb-4">
                                <label for="Email" class="form-label text-brown fw-medium">
                                    <i class="fas fa-envelope text-green me-2"></i>Correo Electrónico *
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white border-green">
                                        <i class="fas fa-envelope text-green"></i>
                                    </span>
                                    @Html.TextBoxFor(m => m.Email, new
                                    {
                                        @class = "form-control border-green",
                                        type = "email",
                                        placeholder = "correo@ejemplo.com",
                                        required = "required"
                                    })
                                </div>
                                @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger small mt-1" })
                                <small class="form-text text-secondary mt-2">
                                    <i class="fas fa-info-circle text-green me-1"></i> Ingresa el correo electrónico asociado a tu cuenta
                                </small>
                            </div>

                            <!-- Botón de envío -->
                            <button type="submit" class="btn btn-green btn-lg w-100 text-white">
                                <i class="fas fa-paper-plane me-2"></i> Enviar Instrucciones
                            </button>
                        }

                        <hr class="border-green my-4" />

                        <!-- Enlaces a Login y Registro -->
                        <div class="text-center">
                            <p class="text-brown mb-3">¿Recordaste tu contraseña?</p>
                            <div class="d-flex flex-wrap justify-content-center gap-2">
                                <a href="@Url.Action("Login", "Account")" class="btn btn-outline-green">
                                    <i class="fas fa-sign-in-alt me-2"></i> Iniciar Sesión
                                </a>
                                <a href="@Url.Action("Register", "Account")" class="btn btn-pink">
                                    <i class="fas fa-user-plus me-2"></i> Crear Cuenta
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Tarjeta de ayuda adicional -->
                <div class="forgot-card">
                    <div class="forgot-card-body p-4">
                        <h5 class="text-brown mb-3">
                            <i class="fas fa-question-circle text-green me-2"></i> ¿Necesitas ayuda?
                        </h5>
                        <p class="text-secondary mb-3">Si tienes problemas para recuperar tu contraseña:</p>
                        <ul class="help-list list-unstyled">
                            <li class="mb-2"><i class="fas fa-check-circle text-green me-2"></i> Verifica que el correo electrónico sea el correcto</li>
                            <li class="mb-2"><i class="fas fa-check-circle text-green me-2"></i> Revisa tu carpeta de spam o correo no deseado</li>
                            <li class="mb-2"><i class="fas fa-check-circle text-green me-2"></i> El enlace de recuperación es válido por 24 horas</li>
                            <li class="mb-2"><i class="fas fa-check-circle text-green me-2"></i> Contáctanos si necesitas asistencia adicional</li>
                        </ul>
                        <a href="@Url.Action("Contact", "Home")" class="btn btn-outline-green w-100">
                            <i class="fas fa-envelope me-2"></i> Contactar Soporte
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Styles {
    <style>
        /* Hero */
        .password-hero {
            background-color: var(--fondo-beige);
            border-radius: 0 0 30px 30px;
            margin-bottom: 1rem;
        }

        /* Tarjetas */
        .forgot-card {
            background: white;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 15px 35px rgba(151, 199, 139, 0.2);
            border: none;
        }

        .forgot-card-header {
            padding: 2rem 1.5rem 1.5rem;
        }

        .forgot-card-body {
            padding: 2rem;
        }

        /* Alertas personalizadas */
        .alert-beige {
            background-color: var(--fondo-beige);
            border: 1px solid var(--verde-menta);
            color: var(--texto-oscuro);
            border-radius: 16px;
            padding: 1rem 1.5rem;
        }

        /* Input group */
        .input-group-text {
            border-radius: 12px 0 0 12px;
            border-right: none;
            background-color: white;
        }

        .form-control {
            border-radius: 0 12px 12px 0;
            border-left: none;
            padding: 0.75rem 1rem;
            font-size: 1rem;
            transition: border-color 0.2s, box-shadow 0.2s;
        }

            .form-control:focus {
                border-color: var(--verde-menta);
                box-shadow: 0 0 0 0.2rem rgba(151, 199, 139, 0.25);
                outline: none;
            }

        .input-group:focus-within .input-group-text {
            border-color: var(--verde-menta);
            box-shadow: 0 0 0 0.2rem rgba(151, 199, 139, 0.25);
        }

        /* Botones */
        .btn-green {
            background-color: var(--verde-menta);
            border: none;
            border-radius: 50px;
            padding: 0.8rem 2rem;
            font-weight: 600;
            transition: all 0.3s;
        }

            .btn-green:hover {
                background-color: #86b57a;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(151, 199, 139, 0.4);
            }

        .btn-pink {
            background-color: var(--rosado-claro);
            border: none;
            border-radius: 50px;
            padding: 0.6rem 1.5rem;
            font-weight: 600;
            transition: all 0.3s;
            color: var(--texto-oscuro);
        }

            .btn-pink:hover {
                background-color: #f9c2b0;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(249, 194, 176, 0.4);
            }

        .btn-outline-green {
            border: 2px solid var(--verde-menta);
            background: transparent;
            color: var(--verde-menta);
            border-radius: 50px;
            padding: 0.6rem 1.5rem;
            font-weight: 600;
            transition: all 0.3s;
        }

            .btn-outline-green:hover {
                background-color: var(--verde-menta);
                color: white;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(151, 199, 139, 0.3);
            }

        /* Lista de ayuda */
        .help-list li {
            display: flex;
            align-items: center;
        }

        /* Responsive */
        @@media (max-width: 768px) {
            .forgot-card-header {
                padding: 1.5rem 1rem;
            }

            .forgot-card-body {
                padding: 1.5rem;
            }
        }
    </style>
}

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")

    <script>
        $(document).ready(function () {
            // Opcional: agregar foco al campo de email al cargar la página
            $('#Email').focus();
        });
    </script>
}