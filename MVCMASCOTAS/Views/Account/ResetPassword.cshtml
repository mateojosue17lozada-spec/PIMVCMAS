@model MVCMASCOTAS.Models.ViewModels.ResetPasswordViewModel

@{
    ViewBag.Title = "Restablecer Contraseña - ADOPTAMANÍA";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Hero Section -->
<section class="password-hero py-4">
    <div class="container text-center">
        <i class="fas fa-key fa-3x text-green mb-3"></i>
        <h1 class="display-5 fw-bold mb-2 text-brown">Restablecer Contraseña</h1>
        <p class="lead mb-3 text-secondary">Crea una nueva contraseña para tu cuenta</p>
    </div>
</section>

<!-- Main Content -->
<section class="py-5 bg-beige">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8 col-md-10">
                <div class="reset-card">
                    <div class="reset-card-header bg-green text-white text-center">
                        <i class="fas fa-key fa-3x mb-3"></i>
                        <h3 class="mb-0">Restablecer Contraseña</h3>
                    </div>
                    <div class="reset-card-body p-4 p-md-5">
                        <!-- ✅ CASO 1: ÉXITO -->
                        @if (ViewBag.Success != null && ViewBag.Success)
                        {
                            <div class="text-center py-4">
                                <i class="fas fa-check-circle fa-5x text-green mb-4"></i>
                                <h4 class="text-green mb-3">¡Contraseña Restablecida!</h4>
                                <p class="lead mb-4 text-secondary">Tu contraseña ha sido actualizada exitosamente.</p>

                                <div class="alert alert-beige border-green mb-4">
                                    <i class="fas fa-info-circle text-green me-2"></i>
                                    <strong class="text-brown">Ya puedes iniciar sesión con tu nueva contraseña.</strong>
                                </div>

                                <div class="d-grid">
                                    <a href="@Url.Action("Login", "Account")" class="btn btn-green btn-lg">
                                        <i class="fas fa-sign-in-alt me-2"></i> Iniciar Sesión
                                    </a>
                                </div>
                            </div>
                        }
                        else if (ViewBag.Error != null)
                        {
                            <!-- ❌ CASO 2: ERROR -->
                            <div class="alert alert-beige border-green mb-4">
                                <i class="fas fa-exclamation-triangle text-yellow me-2"></i>
                                <strong class="text-brown">Error:</strong> <span class="text-secondary">@ViewBag.Error</span>
                            </div>

                            <div class="causes-card p-4 mb-4">
                                <h6 class="text-brown mb-3"><i class="fas fa-lightbulb text-yellow me-2"></i> Posibles causas:</h6>
                                <ul class="list-unstyled text-secondary mb-0">
                                    <li class="mb-2"><i class="fas fa-clock text-green me-2"></i> El enlace de restablecimiento ha expirado</li>
                                    <li class="mb-2"><i class="fas fa-link text-green me-2"></i> El enlace ya fue usado</li>
                                    <li class="mb-2"><i class="fas fa-exclamation-circle text-green me-2"></i> El enlace está incompleto o dañado</li>
                                </ul>
                            </div>

                            <div class="d-grid gap-3">
                                <a href="@Url.Action("ForgotPassword", "Account")" class="btn btn-green btn-lg">
                                    <i class="fas fa-redo-alt me-2"></i> Solicitar Nuevo Enlace
                                </a>
                                <a href="@Url.Action("Login", "Account")" class="btn btn-outline-green btn-lg">
                                    <i class="fas fa-arrow-left me-2"></i> Volver al Login
                                </a>
                            </div>
                        }
                        else
                        {
                            <!-- 📝 CASO 3: FORMULARIO -->
                            using (Html.BeginForm("ResetPassword", "Account", FormMethod.Post, new { @class = "needs-validation", novalidate = "novalidate", id = "resetPasswordForm" }))
                            {
                                @Html.AntiForgeryToken()
                                @Html.ValidationSummary(true, "", new { @class = "alert alert-beige border-green" })

                                <!-- Campos ocultos -->
                                if (Model != null)
                                {
                                    @Html.HiddenFor(m => m.Token)
                                    @Html.HiddenFor(m => m.UserId)
                                }
                                else
                                {
                                    <input type="hidden" name="Token" value="@Request.QueryString["token"]" />
                                    <input type="hidden" name="UserId" value="@Request.QueryString["userId"]" />
                                }

                                <div class="alert alert-beige border-green mb-4">
                                    <i class="fas fa-info-circle text-green me-2"></i>
                                    <strong class="text-brown">Ingresa tu nueva contraseña para restablecer el acceso a tu cuenta.</strong>
                                </div>

                                <!-- Campo Nueva Contraseña -->
                                <div class="form-group mb-4">
                                    <label for="NewPassword" class="form-label text-brown fw-medium">
                                        <i class="fas fa-lock text-green me-2"></i> Nueva Contraseña *
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-white border-green">
                                            <i class="fas fa-lock text-green"></i>
                                        </span>
                                        @Html.PasswordFor(m => m.NewPassword, new
                                        {
                                            @class = "form-control border-green",
                                            placeholder = "Mínimo 8 caracteres con letras y números",
                                            required = "required",
                                            minlength = "8",
                                            id = "NewPassword"
                                        })
                                        <button type="button" class="btn btn-outline-green toggle-password" data-target="#NewPassword">
                                            <i class="fas fa-eye"></i>
                                        </button>
                                    </div>
                                    @Html.ValidationMessageFor(m => m.NewPassword, "", new { @class = "text-danger small mt-1" })
                                </div>

                                <!-- Campo Confirmar Contraseña -->
                                <div class="form-group mb-4">
                                    <label for="ConfirmPassword" class="form-label text-brown fw-medium">
                                        <i class="fas fa-check-circle text-green me-2"></i> Confirmar Contraseña *
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-white border-green">
                                            <i class="fas fa-check-circle text-green"></i>
                                        </span>
                                        @Html.PasswordFor(m => m.ConfirmPassword, new
                                        {
                                            @class = "form-control border-green",
                                            placeholder = "Repite tu contraseña",
                                            required = "required",
                                            id = "ConfirmPassword"
                                        })
                                        <button type="button" class="btn btn-outline-green toggle-password" data-target="#ConfirmPassword">
                                            <i class="fas fa-eye"></i>
                                        </button>
                                    </div>
                                    @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "text-danger small mt-1" })
                                </div>

                                <!-- Requisitos de contraseña (dinámicos) -->
                                <div class="requirements-card p-4 mb-4">
                                    <h6 class="text-brown mb-3">
                                        <i class="fas fa-shield-alt text-green me-2"></i> Requisitos de Contraseña:
                                    </h6>
                                    <ul class="list-unstyled mb-0" id="passwordRequirements">
                                        <li id="req-length" class="text-muted mb-2">
                                            <i class="fas fa-circle me-2"></i> Al menos 8 caracteres
                                        </li>
                                        <li id="req-letter" class="text-muted mb-2">
                                            <i class="fas fa-circle me-2"></i> Al menos una letra
                                        </li>
                                        <li id="req-number" class="text-muted mb-2">
                                            <i class="fas fa-circle me-2"></i> Al menos un número
                                        </li>
                                        <li id="req-match" class="text-muted mb-2">
                                            <i class="fas fa-circle me-2"></i> Las contraseñas coinciden
                                        </li>
                                    </ul>
                                </div>

                                <!-- Botones -->
                                <div class="d-grid gap-3">
                                    <button type="submit" class="btn btn-green btn-lg" id="btnSubmit">
                                        <i class="fas fa-check me-2"></i> Restablecer Contraseña
                                    </button>
                                    <a href="@Url.Action("Login", "Account")" class="btn btn-outline-green btn-lg">
                                        <i class="fas fa-arrow-left me-2"></i> Volver al Login
                                    </a>
                                </div>
                            }
                        }
                    </div>
                    <div class="reset-card-footer text-center text-secondary border-top border-green p-3">
                        <small>
                            <i class="fas fa-lock text-green me-1"></i> Conexión segura SSL/TLS
                        </small>
                    </div>
                </div>

                <div class="text-center mt-3">
                    <small class="text-secondary">
                        ¿Problemas para restablecer?
                        <a href="@Url.Action("Contact", "Home")" class="text-green">Contáctanos</a>
                    </small>
                </div>
            </div>
        </div>
    </div>
</section>

@section Styles {
    <style>
        /* Hero */
        .password-hero {
            background-color: var(--fondo-beige);
            border-radius: 0 0 30px 30px;
            margin-bottom: 1rem;
        }

        /* Tarjeta principal */
        .reset-card {
            background: white;
            border-radius: 30px;
            overflow: hidden;
            box-shadow: 0 20px 40px rgba(151, 199, 139, 0.15);
            border: none;
        }

        .reset-card-header {
            padding: 2rem 1.5rem 1.5rem;
        }

        .reset-card-body {
            padding: 2rem;
        }

        .reset-card-footer {
            background: white;
        }

        /* Alertas personalizadas */
        .alert-beige {
            background-color: var(--fondo-beige);
            border: 1px solid var(--verde-menta);
            color: var(--texto-oscuro);
            border-radius: 16px;
        }

        /* Tarjeta de causas de error */
        .causes-card {
            background: #f9f9f9;
            border-radius: 16px;
            border-left: 5px solid var(--amarillo-pastel);
        }

        /* Tarjeta de requisitos */
        .requirements-card {
            background: #f9f9f9;
            border-radius: 16px;
            border-left: 5px solid var(--verde-menta);
        }

        /* Lista de requisitos dinámica */
        #passwordRequirements li {
            transition: all 0.3s ease;
        }

        .text-green i {
            color: var(--verde-menta);
        }

        .text-muted i {
            color: var(--texto-secundario);
        }

        /* Input group */
        .input-group-text {
            border-radius: 12px 0 0 12px;
            border-right: none;
            background-color: white;
        }

        .form-control {
            border-radius: 0 12px 12px 0;
            border-left: none;
            padding: 0.75rem 1rem;
            font-size: 1rem;
            transition: border-color 0.2s, box-shadow 0.2s;
        }

            .form-control:focus {
                border-color: var(--verde-menta);
                box-shadow: 0 0 0 0.2rem rgba(151, 199, 139, 0.25);
                outline: none;
            }

        .input-group:focus-within .input-group-text {
            border-color: var(--verde-menta);
            box-shadow: 0 0 0 0.2rem rgba(151, 199, 139, 0.25);
        }

        /* Botón toggle contraseña */
        .btn-outline-green {
            border: 2px solid var(--verde-menta);
            background: transparent;
            color: var(--verde-menta);
            border-radius: 0 12px 12px 0;
            border-left: none;
            transition: all 0.2s;
        }

            .btn-outline-green:hover {
                background-color: var(--verde-menta);
                color: white;
            }

        /* Botones principales */
        .btn-green {
            background-color: var(--verde-menta);
            border: none;
            border-radius: 50px;
            padding: 0.8rem 2rem;
            font-weight: 600;
            transition: all 0.3s;
        }

            .btn-green:hover {
                background-color: #86b57a;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(151, 199, 139, 0.4);
            }

            .btn-green:disabled {
                background-color: #b8d9b0;
                transform: none;
                box-shadow: none;
            }

        .btn-outline-green:not(.toggle-password) {
            border-radius: 50px;
            border-left: 2px solid var(--verde-menta);
        }

        /* Estados de validación */
        .is-valid {
            border-color: var(--verde-menta) !important;
        }

        .is-invalid {
            border-color: #dc3545 !important;
        }

        /* Responsive */
        @@media (max-width: 768px) {
            .reset-card-header {
                padding: 1.5rem 1rem;
            }

            .reset-card-body {
                padding: 1.5rem;
            }

            .fa-5x {
                font-size: 3.5em;
            }
        }
    </style>
}

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
    <script>
        $(document).ready(function () {
            console.log('ResetPassword page loaded');

            // Toggle password visibility
            $('.toggle-password').click(function () {
                var target = $(this).data('target');
                var input = $(target);
                var icon = $(this).find('i');

                if (input.attr('type') === 'password') {
                    input.attr('type', 'text');
                    icon.removeClass('fa-eye').addClass('fa-eye-slash');
                } else {
                    input.attr('type', 'password');
                    icon.removeClass('fa-eye-slash').addClass('fa-eye');
                }
            });

            // Validación en tiempo real con indicadores visuales
            function validatePassword() {
                var password = $('#NewPassword').val();
                var confirm = $('#ConfirmPassword').val();
                var allValid = true;

                // Validar longitud (8+ caracteres)
                if (password.length >= 8) {
                    $('#req-length').removeClass('text-muted text-brown').addClass('text-green');
                    $('#req-length i').removeClass('fa-circle fa-times').addClass('fa-check-circle');
                } else {
                    $('#req-length').removeClass('text-green text-muted').addClass('text-brown');
                    $('#req-length i').removeClass('fa-check-circle fa-circle').addClass('fa-circle');
                    allValid = false;
                }

                // Validar letra
                if (/[a-zA-Z]/.test(password)) {
                    $('#req-letter').removeClass('text-muted text-brown').addClass('text-green');
                    $('#req-letter i').removeClass('fa-circle fa-times').addClass('fa-check-circle');
                } else {
                    $('#req-letter').removeClass('text-green text-muted').addClass('text-brown');
                    $('#req-letter i').removeClass('fa-check-circle fa-circle').addClass('fa-circle');
                    allValid = false;
                }

                // Validar número
                if (/[0-9]/.test(password)) {
                    $('#req-number').removeClass('text-muted text-brown').addClass('text-green');
                    $('#req-number i').removeClass('fa-circle fa-times').addClass('fa-check-circle');
                } else {
                    $('#req-number').removeClass('text-green text-muted').addClass('text-brown');
                    $('#req-number i').removeClass('fa-check-circle fa-circle').addClass('fa-circle');
                    allValid = false;
                }

                // Validar coincidencia
                if (confirm.length > 0) {
                    if (password === confirm && password.length > 0) {
                        $('#req-match').removeClass('text-muted text-brown').addClass('text-green');
                        $('#req-match i').removeClass('fa-circle fa-times').addClass('fa-check-circle');
                        $('#ConfirmPassword').removeClass('is-invalid').addClass('is-valid');
                    } else {
                        $('#req-match').removeClass('text-green text-muted').addClass('text-brown');
                        $('#req-match i').removeClass('fa-check-circle fa-circle').addClass('fa-circle');
                        $('#ConfirmPassword').removeClass('is-valid').addClass('is-invalid');
                        allValid = false;
                    }
                } else {
                    $('#req-match').removeClass('text-green text-brown').addClass('text-muted');
                    $('#req-match i').removeClass('fa-check-circle fa-circle').addClass('fa-circle');
                    $('#ConfirmPassword').removeClass('is-valid is-invalid');
                }

                // Actualizar campo de contraseña
                if (password.length > 0) {
                    if (password.length >= 8 && /[a-zA-Z]/.test(password) && /[0-9]/.test(password)) {
                        $('#NewPassword').removeClass('is-invalid').addClass('is-valid');
                    } else {
                        $('#NewPassword').removeClass('is-valid').addClass('is-invalid');
                    }
                } else {
                    $('#NewPassword').removeClass('is-valid is-invalid');
                }

                // Habilitar/deshabilitar botón
                $('#btnSubmit').prop('disabled', !allValid);
            }

            $('#NewPassword, #ConfirmPassword').on('keyup', validatePassword);

            // Deshabilitar botón inicialmente
            validatePassword();

            // Validación del formulario
            $('#resetPasswordForm').submit(function (e) {
                var password = $('#NewPassword').val();
                var confirm = $('#ConfirmPassword').val();

                // Validar requisitos básicos
                if (password.length < 8) {
                    e.preventDefault();
                    Swal.fire({
                        icon: 'error',
                        title: 'Contraseña muy corta',
                        text: 'La contraseña debe tener al menos 8 caracteres.',
                        confirmButtonColor: '#97C78B'
                    });
                    return false;
                }

                if (!/[a-zA-Z]/.test(password) || !/[0-9]/.test(password)) {
                    e.preventDefault();
                    Swal.fire({
                        icon: 'error',
                        title: 'Contraseña inválida',
                        text: 'La contraseña debe incluir letras y números.',
                        confirmButtonColor: '#97C78B'
                    });
                    return false;
                }

                if (password !== confirm) {
                    e.preventDefault();
                    Swal.fire({
                        icon: 'error',
                        title: 'Contraseñas no coinciden',
                        text: 'Las contraseñas deben ser idénticas.',
                        confirmButtonColor: '#97C78B'
                    });
                    return false;
                }

                // Deshabilitar botón y mostrar spinner
                $('#btnSubmit').prop('disabled', true).html('<i class="fas fa-spinner fa-spin me-2"></i> Procesando...');
                return true;
            });
        });
    </script>
}