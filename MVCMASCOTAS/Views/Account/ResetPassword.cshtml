@model MVCMASCOTAS.Models.ViewModels.ResetPasswordViewModel

@{
    ViewBag.Title = "Restablecer Contraseña";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Hero Section -->
<section class="py-4">
    <div class="container">
        <div class="text-center">
            <h1 class="display-5 fw-bold mb-2 text-brown">
                <i class="fa fa-key text-green"></i> Restablecer Contraseña
            </h1>
            <p class="lead mb-3 text-secondary">Crea una nueva contraseña para tu cuenta</p>
        </div>
    </div>
</section>

<!-- Main Content -->
<section class="py-5 bg-light-mint">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8 col-md-10">
                <div class="card border-green shadow-hover">
                    <div class="card-header bg-green text-white">
                        <h3 class="text-center mb-0">
                            <i class="fa fa-key"></i> Restablecer Contraseña
                        </h3>
                    </div>
                    <div class="card-body p-4 p-md-5">
                        <!-- ✅ CASO 1: ÉXITO -->
                        @if (ViewBag.Success != null && ViewBag.Success)
                        {
                            <div class="text-center py-4">
                                <i class="fa fa-check-circle fa-5x text-green mb-4"></i>
                                <h4 class="text-green mb-3">¡Contraseña Restablecida!</h4>
                                <p class="lead mb-4 text-secondary">Tu contraseña ha sido actualizada exitosamente.</p>

                                <div class="alert alert-green border-green">
                                    <i class="fa fa-info-circle text-green"></i>
                                    <strong class="text-brown">Ya puedes iniciar sesión con tu nueva contraseña.</strong>
                                </div>

                                <div class="d-grid">
                                    <a href="@Url.Action("Login", "Account")" class="btn btn-green btn-lg text-white">
                                        <i class="fa fa-sign-in-alt"></i> Iniciar Sesión
                                    </a>
                                </div>
                            </div>
                        }
                        else if (ViewBag.Error != null)
                        {
                            <!-- ❌ CASO 2: ERROR -->
                            <div class="alert alert-green border-green">
                                <i class="fa fa-exclamation-triangle text-green"></i>
                                <strong class="text-brown">Error:</strong> <span class="text-secondary">@ViewBag.Error</span>
                            </div>

                            <div class="card mb-4 border-green">
                                <div class="card-header bg-light-mint">
                                    <h6 class="mb-0 text-brown"><i class="fa fa-lightbulb text-green"></i> Posibles causas:</h6>
                                </div>
                                <div class="card-body">
                                    <ul class="small mb-0 text-secondary">
                                        <li><i class="fa fa-clock text-green me-2"></i> El enlace de restablecimiento ha expirado</li>
                                        <li><i class="fa fa-link text-green me-2"></i> El enlace ya fue usado</li>
                                        <li><i class="fa fa-exclamation-circle text-green me-2"></i> El enlace está incompleto o dañado</li>
                                    </ul>
                                </div>
                            </div>

                            <div class="d-grid gap-3">
                                <a href="@Url.Action("ForgotPassword", "Account")" class="btn btn-green btn-lg text-white">
                                    <i class="fa fa-redo"></i> Solicitar Nuevo Enlace
                                </a>
                                <a href="@Url.Action("Login", "Account")" class="btn btn-outline-green btn-lg">
                                    <i class="fa fa-arrow-left"></i> Volver al Login
                                </a>
                            </div>
                        }
                        else
                        {
                            <!-- 📝 CASO 3: FORMULARIO -->
                            using (Html.BeginForm("ResetPassword", "Account", FormMethod.Post, new { @class = "needs-validation", novalidate = "novalidate", id = "resetPasswordForm" }))
                            {
                                @Html.AntiForgeryToken()
                                @Html.ValidationSummary(true, "", new { @class = "alert alert-green border-green" })

                                <!-- Campos ocultos -->
                                if (Model != null)
                                {
                                    @Html.HiddenFor(m => m.Token)
                                    @Html.HiddenFor(m => m.UserId)
                                }
                                else
                                {
                                    <input type="hidden" name="Token" value="@Request.QueryString["token"]" />
                                    <input type="hidden" name="UserId" value="@Request.QueryString["userId"]" />
                                }

                                <div class="alert alert-green border-green mb-4">
                                    <i class="fa fa-info-circle text-green"></i>
                                    <strong class="text-brown">Ingresa tu nueva contraseña para restablecer el acceso a tu cuenta.</strong>
                                </div>

                                <div class="form-group mb-4">
                                    <label for="NewPassword" class="form-label text-brown fw-medium">
                                        <i class="fa fa-lock text-green"></i> Nueva Contraseña *
                                    </label>
                                    <div class="input-group">
                                        @Html.PasswordFor(m => m.NewPassword, new
                                        {
                                            @class = "form-control border-green",
                                            placeholder = "Mínimo 8 caracteres con letras y números",
                                            required = "required",
                                            minlength = "8",
                                            id = "NewPassword"
                                        })
                                        <button type="button" class="btn btn-outline-green toggle-password" data-target="#NewPassword">
                                            <i class="fa fa-eye"></i>
                                        </button>
                                    </div>
                                    @Html.ValidationMessageFor(m => m.NewPassword, "", new { @class = "text-danger small mt-1" })
                                </div>

                                <div class="form-group mb-4">
                                    <label for="ConfirmPassword" class="form-label text-brown fw-medium">
                                        <i class="fa fa-lock text-green"></i> Confirmar Contraseña *
                                    </label>
                                    <div class="input-group">
                                        @Html.PasswordFor(m => m.ConfirmPassword, new
                                        {
                                            @class = "form-control border-green",
                                            placeholder = "Repite tu contraseña",
                                            required = "required",
                                            id = "ConfirmPassword"
                                        })
                                        <button type="button" class="btn btn-outline-green toggle-password" data-target="#ConfirmPassword">
                                            <i class="fa fa-eye"></i>
                                        </button>
                                    </div>
                                    @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "text-danger small mt-1" })
                                </div>

                                <div class="card mb-4 border-green">
                                    <div class="card-header bg-light-mint">
                                        <h6 class="mb-0 text-brown">
                                            <i class="fa fa-shield-alt text-green"></i> Requisitos de Contraseña:
                                        </h6>
                                    </div>
                                    <div class="card-body">
                                        <ul class="mb-0 text-secondary">
                                            <li id="req-length" class="text-muted">
                                                <i class="fa fa-circle me-2"></i> Al menos 8 caracteres
                                            </li>
                                            <li id="req-letter" class="text-muted">
                                                <i class="fa fa-circle me-2"></i> Al menos una letra
                                            </li>
                                            <li id="req-number" class="text-muted">
                                                <i class="fa fa-circle me-2"></i> Al menos un número
                                            </li>
                                            <li id="req-match" class="text-muted">
                                                <i class="fa fa-circle me-2"></i> Las contraseñas coinciden
                                            </li>
                                        </ul>
                                    </div>
                                </div>

                                <div class="d-grid gap-3">
                                    <button type="submit" class="btn btn-green btn-lg text-white" id="btnSubmit">
                                        <i class="fa fa-check"></i> Restablecer Contraseña
                                    </button>
                                    <a href="@Url.Action("Login", "Account")" class="btn btn-outline-green btn-lg">
                                        <i class="fa fa-arrow-left"></i> Volver al Login
                                    </a>
                                </div>
                            }
                        }
                    </div>
                    <div class="card-footer text-center text-secondary border-top border-green">
                        <small>
                            <i class="fa fa-lock text-green"></i> Conexión segura SSL/TLS
                        </small>
                    </div>
                </div>

                <div class="text-center mt-3">
                    <small class="text-secondary">
                        ¿Problemas para restablecer?
                        <a href="@Url.Action("Contact", "Home")" class="text-green">Contáctanos</a>
                    </small>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
    <script>
        $(document).ready(function () {
            console.log('ResetPassword page loaded');

            // Toggle password visibility
            $('.toggle-password').click(function () {
                var target = $(this).data('target');
                var input = $(target);
                var icon = $(this).find('i');

                if (input.attr('type') === 'password') {
                    input.attr('type', 'text');
                    icon.removeClass('fa-eye').addClass('fa-eye-slash');
                } else {
                    input.attr('type', 'password');
                    icon.removeClass('fa-eye-slash').addClass('fa-eye');
                }
            });

            // Validación en tiempo real con indicadores visuales
            function validatePassword() {
                var password = $('#NewPassword').val();
                var confirm = $('#ConfirmPassword').val();
                var allValid = true;

                // Validar longitud (8+ caracteres)
                if (password.length >= 8) {
                    $('#req-length').removeClass('text-muted text-danger').addClass('text-green');
                    $('#req-length i').removeClass('fa-circle fa-times').addClass('fa-check-circle');
                } else {
                    $('#req-length').removeClass('text-muted text-green').addClass('text-brown');
                    $('#req-length i').removeClass('fa-circle fa-check-circle').addClass('fa-circle');
                    allValid = false;
                }

                // Validar letra
                if (/[a-zA-Z]/.test(password)) {
                    $('#req-letter').removeClass('text-muted text-danger').addClass('text-green');
                    $('#req-letter i').removeClass('fa-circle fa-times').addClass('fa-check-circle');
                } else {
                    $('#req-letter').removeClass('text-muted text-green').addClass('text-brown');
                    $('#req-letter i').removeClass('fa-circle fa-check-circle').addClass('fa-circle');
                    allValid = false;
                }

                // Validar número
                if (/[0-9]/.test(password)) {
                    $('#req-number').removeClass('text-muted text-danger').addClass('text-green');
                    $('#req-number i').removeClass('fa-circle fa-times').addClass('fa-check-circle');
                } else {
                    $('#req-number').removeClass('text-muted text-green').addClass('text-brown');
                    $('#req-number i').removeClass('fa-circle fa-check-circle').addClass('fa-circle');
                    allValid = false;
                }

                // Validar coincidencia
                if (confirm.length > 0) {
                    if (password === confirm && password.length > 0) {
                        $('#req-match').removeClass('text-muted text-danger').addClass('text-green');
                        $('#req-match i').removeClass('fa-circle fa-times').addClass('fa-check-circle');
                        $('#ConfirmPassword').removeClass('is-invalid').addClass('is-valid');
                    } else {
                        $('#req-match').removeClass('text-muted text-green').addClass('text-brown');
                        $('#req-match i').removeClass('fa-circle fa-check-circle').addClass('fa-circle');
                        $('#ConfirmPassword').removeClass('is-valid').addClass('is-invalid');
                        allValid = false;
                    }
                } else {
                    $('#req-match').removeClass('text-green text-brown').addClass('text-muted');
                    $('#req-match i').removeClass('fa-check-circle fa-times').addClass('fa-circle');
                    $('#ConfirmPassword').removeClass('is-valid is-invalid');
                }

                // Actualizar campo de contraseña
                if (password.length > 0) {
                    if (password.length >= 8 && /[a-zA-Z]/.test(password) && /[0-9]/.test(password)) {
                        $('#NewPassword').removeClass('is-invalid').addClass('is-valid');
                    } else {
                        $('#NewPassword').removeClass('is-valid').addClass('is-invalid');
                    }
                } else {
                    $('#NewPassword').removeClass('is-valid is-invalid');
                }

                // Habilitar/deshabilitar botón
                $('#btnSubmit').prop('disabled', !allValid);
            }

            $('#NewPassword, #ConfirmPassword').on('keyup', validatePassword);

            // Deshabilitar botón inicialmente
            validatePassword();

            // Validación del formulario
            $('#resetPasswordForm').submit(function (e) {
                var password = $('#NewPassword').val();
                var confirm = $('#ConfirmPassword').val();

                // Validar requisitos básicos
                if (password.length < 8) {
                    e.preventDefault();
                    Swal.fire({
                        icon: 'error',
                        title: 'Contraseña muy corta',
                        text: 'La contraseña debe tener al menos 8 caracteres.',
                        confirmButtonColor: '#97C78B'
                    });
                    return false;
                }

                if (!/[a-zA-Z]/.test(password) || !/[0-9]/.test(password)) {
                    e.preventDefault();
                    Swal.fire({
                        icon: 'error',
                        title: 'Contraseña inválida',
                        text: 'La contraseña debe incluir letras y números.',
                        confirmButtonColor: '#97C78B'
                    });
                    return false;
                }

                if (password !== confirm) {
                    e.preventDefault();
                    Swal.fire({
                        icon: 'error',
                        title: 'Contraseñas no coinciden',
                        text: 'Las contraseñas deben ser idénticas.',
                        confirmButtonColor: '#97C78B'
                    });
                    return false;
                }

                // Deshabilitar botón y mostrar spinner
                $('#btnSubmit').prop('disabled', true).html('<i class="fa fa-spinner fa-spin"></i> Procesando...');
                return true;
            });
        });
    </script>
}

@section Styles {
    <style>
        /* Estilos específicos para Restablecer Contraseña */
        .form-control:focus {
            border-color: var(--green) !important;
            box-shadow: 0 0 0 0.25rem rgba(151, 199, 139, 0.25) !important;
        }

        .is-valid {
            border-color: var(--green) !important;
        }

        .is-invalid {
            border-color: #dc3545 !important;
        }

        .text-green i {
            color: var(--green);
        }

        .text-brown i {
            color: var(--brown);
        }

        .text-muted i {
            color: var(--text-secondary);
        }

        ul {
            padding-left: 0;
            list-style-type: none;
        }

        li {
            margin-bottom: 8px;
            transition: all 0.3s ease;
        }

        .fa-5x {
            font-size: 5em;
        }

        .input-group .btn-outline-green {
            border-left: none;
        }

        @@media (max-width: 768px) {
            .fa-5x {
                font-size: 3.5em;
            }

            .btn-lg {
                font-size: 1rem;
                padding: 0.6rem 1.2rem;
            }
        }
    </style>
}