@model MVCMASCOTAS.Models.ViewModels.LoginViewModel

@{
    ViewBag.Title = "Iniciar Sesión";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="py-4">
    <div class="container">
        <div class="text-center">
            <h1 class="display-5 fw-bold mb-2 text-brown">
                <i class="fa fa-sign-in-alt text-green"></i> Iniciar Sesión
            </h1>
            <p class="lead mb-3 text-secondary">Accede a tu cuenta del Refugio de Mascotas</p>
        </div>
    </div>
</section>

<section class="py-5 bg-light-mint">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                <div class="card border-green shadow-hover">
                    <div class="card-header bg-green text-white">
                        <h3 class="text-center mb-0">
                            <i class="fa fa-sign-in-alt"></i> Iniciar Sesión
                        </h3>
                    </div>
                    <div class="card-body p-4 p-md-5">
                        <p class="text-center text-secondary mb-4">Ingresa tus credenciales para continuar</p>

                        @if (TempData["ErrorMessage"] != null)
                        {
                            <div class="alert alert-danger border-danger alert-dismissible fade show" role="alert">
                                <i class="fa fa-exclamation-circle"></i>
                                <strong>@TempData["ErrorMessage"]</strong>
                                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                            </div>
                        }

                        @if (TempData["WarningMessage"] != null)
                        {
                            <div class="alert alert-warning border-warning alert-dismissible fade show" role="alert">
                                <i class="fa fa-exclamation-triangle"></i>
                                <strong>@TempData["WarningMessage"]</strong>
                                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                            </div>
                        }

                        @if (TempData["SuccessMessage"] != null)
                        {
                            <div class="alert alert-success border-success alert-dismissible fade show" role="alert">
                                <i class="fa fa-check-circle"></i>
                                <strong>@TempData["SuccessMessage"]</strong>
                                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                            </div>
                        }

                        @if (ViewBag.ErrorLogin != null)
                        {
                            <div class="alert alert-green border-green text-center">
                                <i class="fa fa-exclamation-triangle text-green"></i>
                                <strong class="text-brown">@ViewBag.ErrorLogin</strong>
                            </div>
                        }

                        @using (Html.BeginForm("Login", "Account", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "needs-validation", novalidate = "novalidate", id = "loginForm" }))
                        {
                            @Html.AntiForgeryToken()

                            <!-- Validation Summary -->
                            if (!ViewData.ModelState.IsValid)
                            {
                                <div class="alert alert-danger border-danger">
                                    @Html.ValidationSummary(true, "")
                                </div>
                            }

                            <!-- Si hay usuario con email no confirmado -->
                            if (ViewBag.EmailNoConfirmado != null && (bool)ViewBag.EmailNoConfirmado)
                            {
                                <div class="alert alert-warning border-warning mb-4">
                                    <i class="fa fa-envelope text-warning"></i>
                                    <strong>Email no confirmado</strong>
                                    <p class="mb-1">Tu email no ha sido confirmado. Por favor, revisa tu correo.</p>
                                    @if (ViewBag.UsuarioId != null)
                                    {
                                        <div class="mt-2">
                                            <!-- NO usar otro <form> aquí, usar un link o AJAX -->
                                            @Html.ActionLink("Reenviar enlace de confirmación", "ResendConfirmationEmail", "Account",
                                                new { email = Model.Email },
                                                new { @class = "btn btn-warning btn-sm" })
                                        </div>
                                    }
                                </div>
                            }

                            <div class="form-group mb-4">
                                <label for="Email" class="form-label text-brown fw-medium">
                                    <i class="fa fa-envelope text-green"></i> Correo Electrónico *
                                </label>
                                @Html.TextBoxFor(m => m.Email, new
                                {
                                    @class = "form-control border-green",
                                    placeholder = "correo@ejemplo.com",
                                    type = "email",
                                    required = "required",
                                    autocomplete = "email"
                                })
                                <span class="text-danger small mt-1">@Html.ValidationMessageFor(m => m.Email)</span>
                            </div>

                            <div class="form-group mb-4">
                                <label for="Password" class="form-label text-brown fw-medium">
                                    <i class="fa fa-lock text-green"></i> Contraseña *
                                </label>
                                <div class="input-group">
                                    @Html.PasswordFor(m => m.Password, new
                                    {
                                        @class = "form-control border-green",
                                        placeholder = "Ingresa tu contraseña",
                                        required = "required",
                                        id = "Password",
                                        autocomplete = "current-password"
                                    })
                                    <button type="button" class="btn btn-outline-green toggle-password" data-target="#Password">
                                        <i class="fa fa-eye"></i>
                                    </button>
                                </div>
                                <span class="text-danger small mt-1">@Html.ValidationMessageFor(m => m.Password)</span>
                                <div class="text-end mt-2">
                                    <a href="@Url.Action("ForgotPassword", "Account")" class="small text-green">
                                        <i class="fa fa-question-circle"></i> ¿Olvidaste tu contraseña?
                                    </a>
                                </div>
                            </div>

                            <div class="form-group form-check mb-4">
                                @Html.CheckBoxFor(m => m.RememberMe, new { @class = "form-check-input", id = "RememberMe" })
                                <label class="form-check-label text-brown" for="RememberMe">
                                    <i class="fa fa-clock text-green me-1"></i> Recordarme en este dispositivo
                                </label>
                            </div>

                            <div class="d-grid mb-4">
                                <button type="submit" class="btn btn-green btn-lg text-white" id="btnLogin">
                                    <i class="fa fa-sign-in-alt"></i> Iniciar Sesión
                                </button>
                            </div>
                        }

                        <div class="text-center mt-4 pt-3 border-top border-green">
                            <div class="mb-3">
                                <p class="text-brown mb-2">¿No tienes cuenta?</p>
                                <a href="@Url.Action("Register", "Account")" class="btn btn-pink">
                                    <i class="fa fa-user-plus"></i> Regístrate aquí
                                </a>
                            </div>
                            <div>
                                <a href="@Url.Action("Index", "Home")" class="btn btn-outline-green">
                                    <i class="fa fa-arrow-left"></i> Volver al Inicio
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card border-green shadow-hover mt-4">
                    <div class="card-body text-center">
                        <h5 class="text-brown mb-3">
                            <i class="fa fa-heart text-green"></i> Bienvenido al Refugio
                        </h5>
                        <p class="text-secondary mb-0">
                            Accede para reportar mascotas perdidas, ver adopciones, hacer donaciones y más.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")

    <script type="text/javascript">
        $(document).ready(function () {
            console.log('Login page loaded');

            // Toggle password visibility
            $('.toggle-password').click(function () {
                var target = $(this).data('target');
                var input = $(target);
                var icon = $(this).find('i');

                if (input.attr('type') === 'password') {
                    input.attr('type', 'text');
                    icon.removeClass('fa-eye').addClass('fa-eye-slash');
                } else {
                    input.attr('type', 'password');
                    icon.removeClass('fa-eye-slash').addClass('fa-eye');
                }
            });

            // Auto-focus en el campo de email
            $('#Email').focus();

            // Validación básica
            $('#loginForm').submit(function (e) {
                var email = $('#Email').val();
                var password = $('#Password').val();

                if (!email || !password) {
                    e.preventDefault();
                    alert('Por favor, completa todos los campos requeridos.');
                    return false;
                }

                // Validar formato de email - CORREGIDO
                var atPos = email.indexOf('@@');  // Doble @@ para escapar en Razor
                var dotPos = email.lastIndexOf('.');

                if (atPos < 1 || dotPos < atPos + 2 || dotPos + 2 >= email.length) {
                    e.preventDefault();
                    alert('Por favor, ingresa un email válido.');
                    $('#Email').focus();
                    return false;
                }

                // Deshabilitar botón y mostrar spinner
                $('#btnLogin').prop('disabled', true).html('<i class="fa fa-spinner fa-spin"></i> Iniciando sesión...');
                return true;
            });
        });
    </script>
}

@section Styles {
    <style>
        .form-check-input:checked {
            background-color: var(--green);
            border-color: var(--green);
        }

        .form-check-input:focus {
            border-color: var(--green);
            box-shadow: 0 0 0 0.25rem rgba(151, 199, 139, 0.25);
        }

        .input-group .btn-outline-green {
            border-left: none;
        }

        .form-control:focus {
            border-color: var(--green) !important;
            box-shadow: 0 0 0 0.25rem rgba(151, 199, 139, 0.25) !important;
        }

        .btn-link.text-green {
            text-decoration: none;
        }

            .btn-link.text-green:hover {
                text-decoration: underline;
            }
    </style>
}