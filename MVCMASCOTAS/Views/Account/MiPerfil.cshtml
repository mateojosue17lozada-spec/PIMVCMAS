@model MVCMASCOTAS.Models.Usuarios
@{
    ViewBag.Title = "Mi Perfil";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Hero Section -->
<section class="hero-section py-4">
    <div class="container">
        <div class="text-center">
            <h1 class="display-5 fw-bold mb-2 text-brown">
                <i class="fa fa-user-circle text-green"></i> Mi Perfil
            </h1>
            <p class="lead mb-3 text-secondary">Bienvenido de vuelta, @Model.NombreCompleto</p>
        </div>
    </div>
</section>

<!-- Encabezado del perfil -->
<section class="py-5 bg-light-mint">
    <div class="container">
        <div class="row mb-4">
            <div class="col-md-4 text-center mb-4 mb-md-0">
                @if (Model.ImagenPerfil != null && Model.ImagenPerfil.Length > 0)
                {
                    <img src="data:image/jpeg;base64,@Convert.ToBase64String(Model.ImagenPerfil)"
                         class="img-fluid rounded-circle border border-3 border-green shadow-hover mb-3"
                         style="width: 180px; height: 180px; object-fit: cover;"
                         alt="Foto de perfil">
                }
                else
                {
                    <div class="rounded-circle border border-3 border-green d-flex align-items-center justify-content-center mx-auto mb-3"
                         style="width: 180px; height: 180px; background-color: var(--bg-light);">
                        <i class="fa fa-user fa-5x text-secondary"></i>
                    </div>
                }
                <h4 class="mb-2 text-brown">@Model.NombreCompleto</h4>
                <div class="mb-3">
                    <p class="mb-1">
                        <i class="fa fa-envelope text-green me-1"></i> @Model.Email
                        @if (Model.EmailConfirmado == true)
                        {
                            <span class="badge bg-green text-white ms-2">Verificado</span>
                        }
                        else
                        {
                            <span class="badge bg-yellow text-brown ms-2">No verificado</span>
                        }
                    </p>
                    <p class="mb-0">
                        <i class="fa fa-phone text-green me-1"></i> @(Model.Telefono ?? "No registrado")
                        @if (Model.TelefonoConfirmado == true)
                        {
                            <span class="badge bg-green text-white ms-2">Verificado</span>
                        }
                        else if (!string.IsNullOrEmpty(Model.Telefono))
                        {
                            <span class="badge bg-yellow text-brown ms-2">No verificado</span>
                        }
                    </p>
                </div>
                <a href="@Url.Action("EditProfile", "Account")" class="btn btn-pink">
                    <i class="fa fa-edit"></i> Editar Perfil
                </a>
            </div>

            <div class="col-md-8">
                <div class="row">
                    <div class="col-md-6 col-6 mb-3">
                        <div class="stat-box border-green text-center">
                            <div class="text-green mb-2">
                                <i class="fa fa-home fa-2x"></i>
                            </div>
                            <div class="h4 text-brown mb-1">
                                @(Model.Ciudad ?? "Quito")
                            </div>
                            <div class="text-secondary">
                                Ciudad
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6 col-6 mb-3">
                        <div class="stat-box border-green text-center">
                            <div class="text-green mb-2">
                                <i class="fa fa-map-marker-alt fa-2x"></i>
                            </div>
                            <div class="h4 text-brown mb-1">
                                @(Model.Provincia ?? "Pichincha")
                            </div>
                            <div class="text-secondary">
                                Provincia
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6 col-6 mb-3">
                        <div class="stat-box border-green text-center">
                            <div class="text-green mb-2">
                                <i class="fa fa-calendar-check fa-2x"></i>
                            </div>
                            <div class="h4 text-brown mb-1">
                                @Model.FechaRegistro?.ToString("dd MMM yyyy")
                            </div>
                            <div class="text-secondary">
                                Miembro desde
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6 col-6 mb-3">
                        <div class="stat-box border-green text-center">
                            <div class="mb-2">
                                <i class="fa fa-user-check fa-2x @(Model.Activo == true ? "text-green" : "text-brown")"></i>
                            </div>
                            <div class="h4 mb-1">
                                @if (Model.Activo == true)
                                {
                                    <span class="text-green">Activo</span>
                                }
                                else
                                {
                                    <span class="text-brown">Inactivo</span>
                                }
                            </div>
                            <div class="text-secondary">
                                Estado de cuenta
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Estadísticas del usuario -->
        <div class="row mb-4">
            <div class="col-md-3 col-6 mb-3">
                <div class="stat-box border-green bg-pink">
                    <div class="text-center mb-2">
                        <i class="fa fa-paw fa-2x"></i>
                    </div>
                    <div class="h3 text-center text-brown counter">
                        @ViewBag.TotalSolicitudes
                    </div>
                    <div class="text-center text-brown">
                        Solicitudes de Adopción
                    </div>
                </div>
            </div>

            <div class="col-md-3 col-6 mb-3">
                <div class="stat-box border-green bg-yellow">
                    <div class="text-center mb-2">
                        <i class="fa fa-donate fa-2x"></i>
                    </div>
                    <div class="h3 text-center text-brown counter">
                        @ViewBag.TotalDonaciones
                    </div>
                    <div class="text-center text-brown">
                        Donaciones
                    </div>
                </div>
            </div>

            <div class="col-md-3 col-6 mb-3">
                <div class="stat-box border-green bg-green text-white">
                    <div class="text-center mb-2">
                        <i class="fa fa-heart fa-2x"></i>
                    </div>
                    <div class="h3 text-center counter">
                        @ViewBag.TotalApadrinamientos
                    </div>
                    <div class="text-center">
                        Mascotas Apadrinadas
                    </div>
                </div>
            </div>

            <div class="col-md-3 col-6 mb-3">
                <div class="stat-box border-green bg-light-mint">
                    <div class="text-center mb-2">
                        <i class="fa fa-hands-helping fa-2x text-green"></i>
                    </div>
                    <div class="h3 text-center text-brown counter">
                        @ViewBag.TotalVoluntariado
                    </div>
                    <div class="text-center text-brown">
                        Actividades de Voluntariado
                    </div>
                </div>
            </div>
        </div>

        <!-- Pestañas de actividades -->
        <div class="card border-green shadow-hover mb-4">
            <ul class="nav nav-tabs nav-fill" id="profileTab" role="tablist">
                <li class="nav-item">
                    <a class="nav-link active text-brown" id="solicitudes-tab" data-toggle="tab" href="#solicitudes" role="tab">
                        <i class="fa fa-file-alt"></i> Solicitudes (@ViewBag.TotalSolicitudes)
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-brown" id="donaciones-tab" data-toggle="tab" href="#donaciones" role="tab">
                        <i class="fa fa-donate"></i> Donaciones (@ViewBag.TotalDonaciones)
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-brown" id="apadrinamientos-tab" data-toggle="tab" href="#apadrinamientos" role="tab">
                        <i class="fa fa-heart"></i> Apadrinamientos (@ViewBag.TotalApadrinamientos)
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-brown" id="voluntariado-tab" data-toggle="tab" href="#voluntariado" role="tab">
                        <i class="fa fa-hands-helping"></i> Voluntariado (@ViewBag.TotalVoluntariado)
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-brown" id="pedidos-tab" data-toggle="tab" href="#pedidos" role="tab">
                        <i class="fa fa-shopping-bag"></i> Pedidos (@ViewBag.TotalPedidos)
                    </a>
                </li>
            </ul>

            <div class="tab-content p-4" id="profileTabContent">
                <!-- Pestaña 1: Solicitudes de Adopción -->
                <div class="tab-pane fade show active" id="solicitudes" role="tabpanel">
                    @{
                        var solicitudes = ViewBag.MisSolicitudes as IEnumerable<dynamic>;
                    }

                    @if (solicitudes != null && solicitudes.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th class="text-brown">Mascota</th>
                                        <th class="text-brown">Fecha</th>
                                        <th class="text-brown">Estado</th>
                                        <th class="text-brown">Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var solicitud in solicitudes)
                                    {
                                        <tr>
                                            <td>
                                                <strong class="text-brown">@solicitud.NombreMascota</strong>
                                                <br>
                                                <small class="text-secondary">@solicitud.Especie</small>
                                            </td>
                                            <td class="text-secondary">@solicitud.FechaSolicitud</td>
                                            <td>
                                                @switch (solicitud.Estado)
                                                {
                                                    case "Aprobada":
                                                        <span class="badge bg-green text-white">@solicitud.Estado</span>
                                                        break;
                                                    case "Rechazada":
                                                        <span class="badge bg-pink text-brown">@solicitud.Estado</span>
                                                        break;
                                                    default:
                                                        <span class="badge bg-yellow text-brown">@solicitud.Estado</span>
                                                        break;
                                                }
                                            </td>
                                            <td>
                                                <a href="@Url.Action("DetallesSolicitud", "Adopcion", new { id = solicitud.SolicitudId })"
                                                   class="btn btn-sm btn-outline-green">
                                                    <i class="fa fa-eye"></i> Ver
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        <div class="text-center mt-3">
                            <a href="@Url.Action("MisSolicitudes", "Adopcion")" class="btn btn-green text-white">
                                <i class="fa fa-list"></i> Ver todas las solicitudes
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-4">
                            <i class="fa fa-file-alt fa-3x text-secondary mb-3"></i>
                            <h5 class="text-brown">No tienes solicitudes de adopción</h5>
                            <p class="text-secondary mb-3">Comienza adoptando una mascota</p>
                            <a href="@Url.Action("Index", "Mascotas")" class="btn btn-green text-white">
                                <i class="fa fa-paw"></i> Ver mascotas disponibles
                            </a>
                        </div>
                    }
                </div>

                <!-- Pestaña 2: Donaciones -->
                <div class="tab-pane fade" id="donaciones" role="tabpanel">
                    @{
                        var donaciones = ViewBag.MisDonaciones as IEnumerable<dynamic>;
                    }

                    @if (donaciones != null && donaciones.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th class="text-brown">Tipo</th>
                                        <th class="text-brown">Monto</th>
                                        <th class="text-brown">Fecha</th>
                                        <th class="text-brown">Estado</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var donacion in donaciones)
                                    {
                                        <tr>
                                            <td>
                                                <i class="fa fa-gift text-green"></i>
                                                <span class="text-brown ms-1">@donacion.TipoDonacion</span>
                                            </td>
                                            <td>
                                                <strong class="text-green">$@donacion.Monto</strong>
                                            </td>
                                            <td class="text-secondary">@donacion.FechaDonacion</td>
                                            <td>
                                                <span class="badge @(donacion.Estado == "Completada" ? "bg-green text-white" : "bg-yellow text-brown")">
                                                    @donacion.Estado
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        <div class="text-center mt-3">
                            <a href="@Url.Action("MisDonaciones", "Donaciones")" class="btn btn-green text-white">
                                <i class="fa fa-history"></i> Ver historial completo
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-4">
                            <i class="fa fa-donate fa-3x text-secondary mb-3"></i>
                            <h5 class="text-brown">No tienes donaciones registradas</h5>
                            <p class="text-secondary mb-3">Tu apoyo es importante para las mascotas</p>
                            <a href="@Url.Action("Create", "Donaciones")" class="btn btn-green text-white">
                                <i class="fa fa-hand-holding-heart"></i> Hacer una donación
                            </a>
                        </div>
                    }
                </div>

                <!-- Pestaña 3: Apadrinamientos -->
                <div class="tab-pane fade" id="apadrinamientos" role="tabpanel">
                    @{
                        var apadrinamientos = ViewBag.MisApadrinamientos as IEnumerable<dynamic>;
                    }

                    @if (apadrinamientos != null && apadrinamientos.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th class="text-brown">Mascota</th>
                                        <th class="text-brown">Monto Mensual</th>
                                        <th class="text-brown">Inicio</th>
                                        <th class="text-brown">Estado</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var apadrinamiento in apadrinamientos)
                                    {
                                        <tr>
                                            <td>
                                                <strong class="text-brown">@apadrinamiento.NombreMascota</strong>
                                                <br>
                                                <small class="text-secondary">@apadrinamiento.Especie</small>
                                            </td>
                                            <td>
                                                <strong class="text-green">$@apadrinamiento.MontoMensual</strong>
                                            </td>
                                            <td class="text-secondary">@apadrinamiento.FechaInicio</td>
                                            <td>
                                                <span class="badge @(apadrinamiento.Estado == "Activo" ? "bg-green text-white" : "bg-light-mint text-brown")">
                                                    @apadrinamiento.Estado
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        <div class="text-center mt-3">
                            <a href="@Url.Action("MisApadrinamientos", "Donaciones")" class="btn btn-green text-white">
                                <i class="fa fa-heart"></i> Ver mis apadrinamientos
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-4">
                            <i class="fa fa-heart fa-3x text-secondary mb-3"></i>
                            <h5 class="text-brown">No tienes mascotas apadrinadas</h5>
                            <p class="text-secondary mb-3">Apoya mensualmente a una mascota</p>
                            <a href="@Url.Action("Index", "Mascotas")" class="btn btn-green text-white">
                                <i class="fa fa-heart"></i> Apadrinar una mascota
                            </a>
                        </div>
                    }
                </div>

                <!-- Pestaña 4: Voluntariado -->
                <div class="tab-pane fade" id="voluntariado" role="tabpanel">
                    @{
                        var actividades = ViewBag.MisActividades as IEnumerable<dynamic>;
                    }

                    @if (actividades != null && actividades.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th class="text-brown">Actividad</th>
                                        <th class="text-brown">Fecha</th>
                                        <th class="text-brown">Estado</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var actividad in actividades)
                                    {
                                        <tr>
                                            <td>
                                                <strong class="text-brown">@actividad.NombreActividad</strong>
                                                <br>
                                                <small class="text-secondary">@actividad.TipoActividad</small>
                                            </td>
                                            <td class="text-secondary">@actividad.FechaActividad</td>
                                            <td>
                                                <span class="badge @(actividad.Estado == "Confirmada" ? "bg-green text-white" : "bg-yellow text-brown")">
                                                    @actividad.Estado
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        <div class="text-center mt-3">
                            <a href="@Url.Action("MisActividades", "Voluntariado")" class="btn btn-green text-white">
                                <i class="fa fa-calendar-check"></i> Ver mis actividades
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-4">
                            <i class="fa fa-hands-helping fa-3x text-secondary mb-3"></i>
                            <h5 class="text-brown">No estás inscrito en actividades</h5>
                            <p class="text-secondary mb-3">Únete a nuestras actividades de voluntariado</p>
                            <a href="@Url.Action("Index", "Actividades")" class="btn btn-green text-white">
                                <i class="fa fa-user-plus"></i> Ver actividades disponibles
                            </a>
                        </div>
                    }
                </div>

                <!-- Pestaña 5: Pedidos -->
                <div class="tab-pane fade" id="pedidos" role="tabpanel">
                    @{
                        var pedidos = ViewBag.MisPedidos as IEnumerable<dynamic>;
                    }

                    @if (pedidos != null && pedidos.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th class="text-brown">N° Pedido</th>
                                        <th class="text-brown">Fecha</th>
                                        <th class="text-brown">Total</th>
                                        <th class="text-brown">Estado</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var pedido in pedidos)
                                    {
                                        <tr>
                                            <td>
                                                <strong class="text-brown">@pedido.NumeroPedido</strong>
                                            </td>
                                            <td class="text-secondary">@pedido.FechaPedido</td>
                                            <td>
                                                <strong class="text-green">$@pedido.Total</strong>
                                            </td>
                                            <td>
                                                <span class="badge @(pedido.Estado == "Entregado" ? "bg-green text-white" : "bg-yellow text-brown")">
                                                    @pedido.Estado
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        <div class="text-center mt-3">
                            <a href="@Url.Action("MisPedidos", "Tienda")" class="btn btn-green text-white">
                                <i class="fa fa-shopping-bag"></i> Ver todos mis pedidos
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-4">
                            <i class="fa fa-shopping-bag fa-3x text-secondary mb-3"></i>
                            <h5 class="text-brown">No tienes pedidos registrados</h5>
                            <p class="text-secondary mb-3">Visita nuestra tienda solidaria</p>
                            <a href="@Url.Action("Index", "Tienda")" class="btn btn-green text-white">
                                <i class="fa fa-store"></i> Ir a la tienda
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Sección de acciones importantes -->
        <div class="row mt-4">
            <div class="col-md-6 mb-4">
                <div class="card border-green shadow-hover h-100">
                    <div class="card-header bg-green text-white">
                        <h5 class="mb-0"><i class="fa fa-shield-alt"></i> Seguridad de la Cuenta</h5>
                    </div>
                    <div class="card-body">
                        <div class="list-group list-group-flush">
                            <a href="@Url.Action("ChangePassword", "Account")" class="list-group-item list-group-item-action border-green">
                                <i class="fa fa-key text-green me-2"></i> Cambiar Contraseña
                                <i class="fa fa-chevron-right text-secondary float-end"></i>
                            </a>
                            <div class="list-group-item border-green">
                                <i class="fa fa-envelope @(Model.EmailConfirmado == true ? "text-green" : "text-brown") me-2"></i>
                                Email Confirmado
                                @if (Model.EmailConfirmado == true)
                                {
                                    <span class="badge bg-green text-white float-end">Verificado</span>
                                }
                                else
                                {
                                    <span class="badge bg-yellow text-brown float-end">Pendiente</span>
                                }
                            </div>
                            <div class="list-group-item border-green">
                                <i class="fa fa-phone @(Model.TelefonoConfirmado == true ? "text-green" :
                                                        string.IsNullOrEmpty(Model.Telefono) ? "text-secondary" : "text-brown") me-2"></i>
                                Teléfono Confirmado
                                @if (Model.TelefonoConfirmado == true)
                                {
                                    <span class="badge bg-green text-white float-end">Verificado</span>
                                }
                                else if (!string.IsNullOrEmpty(Model.Telefono))
                                {
                                    <span class="badge bg-yellow text-brown float-end">Pendiente</span>
                                }
                                else
                                {
                                    <span class="badge bg-light-mint text-brown float-end">No registrado</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 mb-4">
                <div class="card border-green shadow-hover h-100">
                    <div class="card-header bg-green text-white">
                        <h5 class="mb-0"><i class="fa fa-bullhorn"></i> Mis Reportes (@ViewBag.TotalReportes)</h5>
                    </div>
                    <div class="card-body">
                        @{
                            var reportes = ViewBag.MisReportes as IEnumerable<dynamic>;
                        }

                        @if (reportes != null && reportes.Any())
                        {
                            <div class="list-group">
                                @foreach (var reporte in reportes)
                                {
                                    <div class="list-group-item border-green">
                                        <div class="d-flex w-100 justify-content-between">
                                            <h6 class="mb-1 text-brown">
                                                <i class="fa fa-paw text-green"></i>
                                                @reporte.TipoAnimal
                                            </h6>
                                            <small class="text-secondary">@reporte.FechaReporte</small>
                                        </div>
                                        <p class="mb-1 text-secondary">@reporte.UbicacionReporte</p>
                                        <small>
                                            <span class="badge @(reporte.Estado == "Pendiente" ? "bg-yellow text-brown" :
                                                                reporte.Estado == "Rescatado" ? "bg-green text-white" : "bg-light-mint text-brown")">
                                                @reporte.Estado
                                            </span>
                                        </small>
                                    </div>
                                }
                            </div>
                            <div class="text-center mt-3">
                                <a href="@Url.Action("MisReportes", "Rescate")" class="btn btn-sm btn-outline-green">
                                    <i class="fa fa-list"></i> Ver todos los reportes
                                </a>
                            </div>
                        }
                        else
                        {
                            <div class="text-center py-3">
                                <i class="fa fa-exclamation-triangle fa-2x text-secondary mb-2"></i>
                                <p class="text-brown">No has realizado reportes de rescate</p>
                                <a href="@Url.Action("ReportarRescate", "Rescate")" class="btn btn-sm btn-green text-white">
                                    <i class="fa fa-plus"></i> Reportar un rescate
                                </a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Styles {
    <style>
        /* Estilos específicos para Mi Perfil */
        .stat-box {
            padding: 20px;
            border-radius: 10px;
            height: 100%;
            transition: all 0.3s ease;
        }

            .stat-box:hover {
                transform: translateY(-3px);
                box-shadow: 0 5px 15px rgba(151, 199, 139, 0.2);
            }

        .nav-tabs {
            border-bottom: 2px solid var(--green);
        }

            .nav-tabs .nav-link {
                border: none;
                color: var(--brown);
                font-weight: 500;
                border-radius: 8px 8px 0 0;
                background-color: var(--bg-light);
                margin: 0 2px;
            }

                .nav-tabs .nav-link:hover {
                    background-color: var(--pink);
                    color: var(--brown);
                }

                .nav-tabs .nav-link.active {
                    background: var(--green);
                    color: white;
                    border: none;
                }

        .tab-content {
            background: white;
            border: 2px solid var(--green);
            border-top: none;
            border-radius: 0 0 10px 10px;
        }

        .table th {
            color: var(--brown);
            border-top: none;
            border-bottom: 2px solid var(--green);
        }

        .table-hover tbody tr:hover {
            background-color: rgba(151, 199, 139, 0.1);
        }

        .list-group-item {
            border-color: var(--green);
        }

        .list-group-item-action:hover {
            background: var(--bg-light);
            color: var(--brown);
        }

        .badge {
            font-size: 0.75em;
            padding: 4px 8px;
            border-radius: 12px;
        }

        @@media (max-width: 768px) {
            .nav-tabs .nav-link {
                margin-bottom: 5px;
                font-size: 0.9em;
            }

            .stat-box {
                padding: 15px;
            }
        }
    </style>
}

@section Scripts {
    <script>
        $(document).ready(function () {
            console.log('Mi Perfil page loaded');

            // Activar pestañas
            $('#profileTab a').on('click', function (e) {
                e.preventDefault();
                $(this).tab('show');
            });

            // Contador animado
            $('.counter').each(function () {
                var $this = $(this);
                var currentValue = parseInt($this.text());

                if (!isNaN(currentValue) && currentValue > 0) {
                    $({ countNum: 0 }).animate({
                        countNum: currentValue
                    }, {
                        duration: 1500,
                        easing: 'swing',
                        step: function () {
                            $this.text(Math.floor(this.countNum));
                        },
                        complete: function () {
                            $this.text(this.countNum);
                        }
                    });
                }
            });

            // Efecto hover para stat boxes
            $('.stat-box').hover(
                function() {
                    $(this).css('transform', 'translateY(-5px)');
                },
                function() {
                    $(this).css('transform', 'translateY(0)');
                }
            );

            // Inicializar tooltips
            $('[data-toggle="tooltip"]').tooltip();

            // Mostrar mensajes con SweetAlert2
            @if (TempData["SuccessMessage"] != null)
            {
                <text>
                Swal.fire({
                    icon: 'success',
                    title: '¡Éxito!',
                    text: '@TempData["SuccessMessage"]',
                    confirmButtonColor: '#97C78B'
                });
                </text>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <text>
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: '@TempData["ErrorMessage"]',
                    confirmButtonColor: '#97C78B'
                });
                </text>
            }
        });
    </script>
}